# Markdown Cloud Vault — example configuration
# Copy to .env and adjust values. Environment variables override .env values.

# --- Server ---
APP_ADDR=:8080

# --- Database ---
DB_PATH=./data/app.db

# --- Storage ---
# Use "local" for development (no external deps required).
# Use "qiniu" for Qiniu Kodo production storage.
STORAGE_PROVIDER=local

# --- Local storage (used when STORAGE_PROVIDER=local) ---
LOCAL_ROOT=./data/objects

# --- Qiniu Kodo (used when STORAGE_PROVIDER=qiniu) ---
# QINIU_ACCESS_KEY=your-access-key
# QINIU_SECRET_KEY=your-secret-key
# QINIU_BUCKET=markdown-vault
# QINIU_DOMAIN=https://example.com
# QINIU_REGION=z0        # z0=华东  z1=华北  z2=华南  na0=北美  as0=新加坡
# QINIU_USE_HTTPS=true

# --- Application ---
APP_MAX_UPLOAD_SIZE_MB=10
APP_VERSION_POLICY=always

# --- TLS (optional) ---
# APP_TLS_ENABLED=false
# APP_TLS_CERT_FILE=cert.pem
# APP_TLS_KEY_FILE=key.pem

# --- Full-text search (V0.3) ---
# SEARCH_ENABLED=true
# SEARCH_INDEX_ON_SAVE=true
# SEARCH_INDEX_ON_IMPORT=background   # inline | background | disabled
# SEARCH_INDEX_BATCH_SIZE=100
# SEARCH_INDEX_INTERVAL_SECONDS=5
# SEARCH_MAX_CONTENT_SIZE_MB=5
# SEARCH_SNIPPET_TOKENS=20
# SEARCH_HISTORY_LIMIT=100
