# Cloud Vault Environment Variables
# Copy this file to .env and adjust values as needed
# Environment variables override config.toml values

# =============================================================================
# Server Configuration
# =============================================================================
# HTTP listen address
# Format: ":port" or "host:port"
# SERVER_ADDR=:8080

# TLS configuration (optional)
# SERVER_TLS_ENABLED=false
# SERVER_TLS_CERT_FILE=
# SERVER_TLS_KEY_FILE=

# =============================================================================
# Database Configuration
# =============================================================================
# SQLite database file path
# DATABASE_PATH=./data/app.db

# =============================================================================
# Storage Configuration
# =============================================================================
# Storage provider: "local" or "qiniu"
# STORAGE_PROVIDER=local

# Local storage root directory
# STORAGE_LOCAL_ROOT=./data/objects

# Qiniu configuration (when STORAGE_PROVIDER=qiniu)
# QINIU_ACCESS_KEY=
# QINIU_SECRET_KEY=
# QINIU_BUCKET=
# QINIU_DOMAIN=
# QINIU_REGION=z0
# QINIU_USE_HTTPS=true

# =============================================================================
# Application Configuration
# =============================================================================
# Maximum upload size in MB
# APP_MAX_UPLOAD_SIZE_MB=10
# Version retention policy: "bounded", "full", or "overwrite"
# APP_VERSION_POLICY=bounded
# Recent non-pinned snapshots to keep when APP_VERSION_POLICY=bounded
# APP_VERSION_KEEP_LATEST=5

# =============================================================================
# Authentication Configuration (V0.7+)
# =============================================================================
# Enable authentication
# AUTH_ENABLED=true
# Session cookie name
# AUTH_COOKIE_NAME=cloud_vault_session
# Session time-to-live in hours
# AUTH_SESSION_TTL_HOURS=168
# Minimum password length
# AUTH_PASSWORD_MIN_LENGTH=10
# Maximum failed login attempts
# AUTH_MAX_LOGIN_FAILURES=5
# Account lockout duration in minutes
# AUTH_LOCKOUT_MINUTES=30
# Use secure cookies (recommended: true for production)
# AUTH_SECURE_COOKIE=false

# Bootstrap admin configuration (optional)
# AUTH_BOOTSTRAP_ADMIN_ENABLED=false
# AUTH_BOOTSTRAP_ADMIN_USERNAME=
# AUTH_BOOTSTRAP_ADMIN_EMAIL=
# AUTH_BOOTSTRAP_ADMIN_PASSWORD=

# =============================================================================
# Search Configuration (V0.3+)
# =============================================================================
# Enable full-text search
# SEARCH_ENABLED=true
# Index documents on save
# SEARCH_INDEX_ON_SAVE=true
# Index documents during import: "inline", "background", or "disabled"
# SEARCH_INDEX_ON_IMPORT=background
# Batch size for background indexing
# SEARCH_INDEX_BATCH_SIZE=100
# Interval between indexing batches (seconds)
# SEARCH_INDEX_INTERVAL_SECONDS=5
# Maximum document size to index (MB)
# SEARCH_MAX_CONTENT_SIZE_MB=10
# Context tokens in search snippets
# SEARCH_SNIPPET_TOKENS=20
# Search history retention limit
# SEARCH_HISTORY_LIMIT=100

# =============================================================================
# Organization Configuration (V0.4+)
# =============================================================================
# Enable duplicate detection
# ORGANIZE_DUPLICATE_DETECTION=true
# Enable similarity detection
# ORGANIZE_SIMILARITY_DETECTION=true
# Enable tag suggestions
# ORGANIZE_TAG_SUGGESTION=true
# Enable topic building
# ORGANIZE_TOPIC_BUILD=true
# Near-duplicate threshold (0.0-1.0)
# ORGANIZE_NEAR_DUP_THRESHOLD=0.95
# Related document threshold (0.0-1.0)
# ORGANIZE_RELATED_THRESHOLD=0.7
# Maximum comparisons per bucket
# ORGANIZE_MAX_COMPARE_PER_BUCKET=1000
# Similarity batch size
# ORGANIZE_SIMILARITY_BATCH_SIZE=100
# Auto-archive duplicates
# ORGANIZE_AUTO_ARCHIVE_DUPLICATES=false
# Auto-apply tag suggestions
# ORGANIZE_AUTO_APPLY_TAG_SUGGESTIONS=false
# Enable prompt candidate detection
# ORGANIZE_PROMPT_CANDIDATE_DETECTION=true

# =============================================================================
# AI Configuration (V0.5+)
# =============================================================================
# Enable AI features
# AI_ENABLED=false
# AI provider: "local_mock" or "openai_compatible"
# AI_PROVIDER=local_mock
# OpenAI-compatible API base URL
# AI_BASE_URL=
# OpenAI-compatible API key
# AI_API_KEY=
# AI model name
# AI_MODEL=
# Maximum context tokens
# AI_MAX_CONTEXT_TOKENS=4000
# Maximum retry attempts
# AI_MAX_RETRIES=3
# Number of AI task workers
# AI_TASK_WORKERS=2
# Enable AI summaries
# AI_SUMMARY_ENABLED=true
# Enable AI Q&A
# AI_QA_ENABLED=true
# Enable AI prompt extraction
# AI_PROMPT_EXTRACT_ENABLED=true

# =============================================================================
# Update Check Configuration (V1.0+)
# =============================================================================
# UPDATE_ENABLED=false
# UPDATE_CHECK_ON_STARTUP=false
# UPDATE_URL=
# UPDATE_CHECK_INTERVAL_MIN=1440
# UPDATE_CHANNEL=stable
