# guardus — environment variables
# Copy to .env (or export directly) and adjust per environment. Empty/unset
# variables fall back to the defaults shown.

# --- Deployment ---
GUARDUS_METRICS=true
GUARDUS_CONCURRENCY=3

GUARDUS_WEB_ADDRESS=0.0.0.0
GUARDUS_WEB_PORT=8080
# GUARDUS_WEB_READ_BUFFER_SIZE=8192
# GUARDUS_WEB_TLS_CERT_FILE=
# GUARDUS_WEB_TLS_KEY_FILE=

# --- Storage ---
GUARDUS_STORAGE_TYPE=sqlite
GUARDUS_STORAGE_PATH=./guardus.db
GUARDUS_STORAGE_CACHING=true
GUARDUS_STORAGE_MAX_RESULTS=100
GUARDUS_STORAGE_MAX_EVENTS=50

# Optional: import endpoints into the DB on startup (upsert by key).
# GUARDUS_BOOTSTRAP_FILE=./endpoints.json

# --- Security (basic auth) ---
# Either bcrypt-base64 (gatus-compatible) or pbkdf2 (plumego/security/password).
# GUARDUS_SECURITY_BASIC_USERNAME=admin
# GUARDUS_SECURITY_BASIC_PASSWORD_BCRYPT_BASE64=
# GUARDUS_SECURITY_BASIC_PASSWORD_PBKDF2=

# --- UI customization ---
# GUARDUS_UI_TITLE=Health Dashboard | Gatus
# GUARDUS_UI_DESCRIPTION=
# GUARDUS_UI_HEADER=Gatus
# GUARDUS_UI_DASHBOARD_HEADING=Health Dashboard
# GUARDUS_UI_DASHBOARD_SUBHEADING=Monitor the health of your endpoints in real-time
# GUARDUS_UI_LOGO=
# GUARDUS_UI_LINK=
# GUARDUS_UI_DARK_MODE=true
# GUARDUS_UI_DEFAULT_SORT_BY=name           # name|group|health
# GUARDUS_UI_DEFAULT_FILTER_BY=none         # none|failing|unstable
# GUARDUS_UI_LOGIN_SUBTITLE=System Monitoring Dashboard
# GUARDUS_UI_FAVICON=/favicon.ico
# GUARDUS_UI_FAVICON_16=/favicon-16x16.png
# GUARDUS_UI_FAVICON_32=/favicon-32x32.png

# --- Alerting providers (each is one JSON document) ---
# Keys mirror the previous YAML configuration shape (kebab-case in JSON).
# GUARDUS_ALERTING_SLACK={"default-config":{"webhook-url":"https://hooks.slack.com/...","title":"alerts"}}
# GUARDUS_ALERTING_DISCORD={"default-config":{"webhook-url":"https://discord.com/api/webhooks/..."}}
# GUARDUS_ALERTING_TELEGRAM={"default-config":{"token":"...","id":"...","api-url":"https://api.telegram.org"}}
# GUARDUS_ALERTING_EMAIL={"default-config":{"from":"alerts@example.com","host":"smtp.example.com","port":587,"username":"...","password":"...","to":"oncall@example.com"}}
# GUARDUS_ALERTING_CUSTOM={"default-config":{"url":"https://hooks.example.com/incoming","method":"POST","body":"{\"text\":\"[ENDPOINT_NAME] [ALERT_TRIGGERED_OR_RESOLVED]\"}"}}

# --- Connectivity checker (TCP DNS probe; target must end with :53) ---
# GUARDUS_CONNECTIVITY_TARGET=1.1.1.1:53
# GUARDUS_CONNECTIVITY_INTERVAL=60s

# --- Maintenance window (single global) ---
# GUARDUS_MAINTENANCE_ENABLED=true
# GUARDUS_MAINTENANCE_START=23:00
# GUARDUS_MAINTENANCE_DURATION=1h
# GUARDUS_MAINTENANCE_TIMEZONE=UTC
# GUARDUS_MAINTENANCE_EVERY=Saturday,Sunday
