# mini-saas-api — environment reference
# Copy to .env for local development; never commit .env to version control.

# ── Server ──────────────────────────────────────────────────────────────────
APP_ADDR=:8090
APP_SERVICE_NAME=mini-saas-api
APP_ENV_FILE=.env

# ── Body limit ───────────────────────────────────────────────────────────────
# Maximum request body size in bytes. 0 disables the limit.
APP_MAX_BODY_BYTES=1048576

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Empty allows all origins (*).
# Always set this in production.
# APP_CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# ── TLS ──────────────────────────────────────────────────────────────────────
APP_TLS_ENABLED=false
# APP_TLS_CERT_FILE=/etc/ssl/certs/server.crt
# APP_TLS_KEY_FILE=/etc/ssl/private/server.key

# ── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED in production. Must be at least 32 characters.
# Generate: openssl rand -hex 32
APP_JWT_SECRET=dev-secret-do-not-use-in-production-change-me!!
APP_JWT_ACCESS_TTL=15m
APP_JWT_REFRESH_TTL=168h

# ── Tenant traffic limits ────────────────────────────────────────────────────
# Per-tenant token-bucket rate limit and fixed-window request quota applied to
# the authenticated API surface by the x/tenant middleware chain.
APP_TENANT_RPS=50
APP_TENANT_BURST=100
APP_TENANT_QUOTA_PER_MINUTE=600

# ── Storage ──────────────────────────────────────────────────────────────────
# Directory for the embedded store/kv state file (JWT signing keys and
# refresh-token records). Created if missing.
APP_DATA_DIR=.data

# ── Metrics ───────────────────────────────────────────────────────────────────
# Optional bearer token to guard GET /metrics. Empty disables the guard.
# Set this in any environment where /metrics is publicly reachable.
# APP_METRICS_TOKEN=change-me-metrics-token
