# Listen address (default: 127.0.0.1:8080 — loopback only)
APP_ADDR=127.0.0.1:8080

# Data directory for KV stores (sessions, connections, history)
DBADMIN_DATA_DIR=./data

# Web UI login credentials
DBADMIN_USER=admin
DBADMIN_PASSWORD=changeme
DBADMIN_ROLE=admin

# Demo-only escape hatch. Keep false for real deployments.
DBADMIN_ALLOW_DEFAULT_PASSWORD=false

# Optional: 32-byte (64 hex chars) AES-GCM key for encrypting stored passwords.
# Required before saving connection passwords, API keys, or Mongo URIs with embedded credentials.
# Generate with: openssl rand -hex 32
DBADMIN_ENCRYPTION_KEY=

# Query timeout configuration (seconds)
# Maximum execution time for SQL queries before automatic cancellation
# Set to 0 or omit to disable timeout (not recommended for production)
DBADMIN_QUERY_TIMEOUT_SECONDS=30

# Enable SQL query/non-SQL operation cancellation endpoints and UI controls
DBADMIN_QUERY_CANCEL_ENABLED=true

# Maximum execution time for non-SQL operations before request cancellation
DBADMIN_REDIS_COMMAND_TIMEOUT_SECONDS=30
DBADMIN_MONGO_QUERY_TIMEOUT_SECONDS=30
DBADMIN_ES_QUERY_TIMEOUT_SECONDS=30
DBADMIN_RESOURCE_LIST_TIMEOUT_SECONDS=30

# Optional TLS
# APP_TLS_ENABLED=true
# APP_TLS_CERT_FILE=/path/to/cert.pem
# APP_TLS_KEY_FILE=/path/to/key.pem
