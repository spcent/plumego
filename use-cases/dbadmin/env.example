# Listen address (default: 127.0.0.1:8080 — loopback only)
APP_ADDR=127.0.0.1:8080

# Data directory for KV stores (sessions, connections, history)
DBADMIN_DATA_DIR=./data

# Web UI login credentials
DBADMIN_USER=admin
DBADMIN_PASSWORD=changeme

# Optional: 32-byte (64 hex chars) AES-GCM key for encrypting stored passwords.
# Generate with: openssl rand -hex 32
# DBADMIN_ENCRYPTION_KEY=

# Optional TLS
# APP_TLS_ENABLED=true
# APP_TLS_CERT_FILE=/path/to/cert.pem
# APP_TLS_KEY_FILE=/path/to/key.pem
