# Application server
# Timeouts are in milliseconds unless noted.
APP_ADDR=:8080
APP_ENV_FILE=.env
APP_DEBUG=false
APP_SHUTDOWN_TIMEOUT_MS=5000
APP_READ_TIMEOUT_MS=30000
APP_READ_HEADER_TIMEOUT_MS=5000
APP_WRITE_TIMEOUT_MS=30000
APP_IDLE_TIMEOUT_MS=60000
APP_MAX_HEADER_BYTES=1048576
APP_ENABLE_HTTP2=true
APP_DRAIN_INTERVAL_MS=500
APP_MAX_BODY_BYTES=10485760
APP_MAX_CONCURRENCY=256
APP_QUEUE_DEPTH=512
APP_QUEUE_TIMEOUT_MS=250

# Ops / admin protection
# When set, x/ops protected endpoints require this token via Bearer auth.
AUTH_TOKEN=

# Workerfleet reference app
# Required when WORKERFLEET_PROFILE=prod. When set, worker register and heartbeat endpoints require Bearer auth.
WORKERFLEET_WORKER_AUTH_TOKEN=
WORKERFLEET_HTTP_ADDR=:8080
WORKERFLEET_SHUTDOWN_TIMEOUT=10s
WORKERFLEET_STORE_BACKEND=memory
WORKERFLEET_MONGO_URI=
WORKERFLEET_MONGO_DATABASE=
WORKERFLEET_MONGO_CONNECT_TIMEOUT=10s
WORKERFLEET_MONGO_OPERATION_TIMEOUT=10s
WORKERFLEET_MONGO_MAX_POOL_SIZE=
WORKERFLEET_RETENTION_DAYS=7
WORKERFLEET_PROFILE=dev
WORKERFLEET_STATUS_STALE_AFTER=45s
WORKERFLEET_STATUS_OFFLINE_AFTER=90s
WORKERFLEET_STATUS_STAGE_STUCK_AFTER=10m
WORKERFLEET_STATUS_RESTART_BURST_THRESHOLD=3
WORKERFLEET_ALERT_STAGE_STUCK_AFTER=10m
WORKERFLEET_ALERT_RESTART_BURST_THRESHOLD=3
WORKERFLEET_EXPERIMENTAL_METRICS_ENABLED=true
WORKERFLEET_KUBE_SYNC_ENABLED=false
WORKERFLEET_STATUS_SWEEP_ENABLED=false
WORKERFLEET_ALERT_EVALUATION_ENABLED=false
WORKERFLEET_NOTIFICATION_ENABLED=false
WORKERFLEET_KUBE_SYNC_INTERVAL=30s
WORKERFLEET_STATUS_SWEEP_INTERVAL=30s
WORKERFLEET_ALERT_EVALUATION_INTERVAL=30s
WORKERFLEET_NOTIFIER_DELIVERY_TIMEOUT=5s
WORKERFLEET_KUBE_API_HOST=
WORKERFLEET_KUBE_BEARER_TOKEN=
WORKERFLEET_KUBE_NAMESPACE=
WORKERFLEET_KUBE_LABEL_SELECTOR=
WORKERFLEET_KUBE_WORKER_CONTAINER=worker
WORKERFLEET_FEISHU_WEBHOOK_URL=
WORKERFLEET_WEBHOOK_URL=
WORKERFLEET_WEBHOOK_HEADERS=

# TLS
TLS_ENABLED=false
TLS_CERT_FILE=
TLS_KEY_FILE=

# WebSocket
# Secret must be at least 32 bytes.
WS_SECRET=change-me-change-me-change-me-change-me
WS_ROUTE_PATH=/ws
WS_BROADCAST_PATH=/_admin/broadcast

# Pub/Sub debug endpoint
PUBSUB_DEBUG_ENABLED=false
PUBSUB_DEBUG_PATH=/_debug/pubsub

# Webhooks
WEBHOOK_TRIGGER_TOKEN=change-me
GITHUB_WEBHOOK_SECRET=change-me
STRIPE_WEBHOOK_SECRET=whsec_change-me
WEBHOOK_QUEUE_SIZE=2048
WEBHOOK_WORKERS=8
WEBHOOK_DROP_POLICY=block_timeout
WEBHOOK_BLOCK_WAIT_MS=50
WEBHOOK_DEFAULT_TIMEOUT_MS=5000
WEBHOOK_DEFAULT_MAX_RETRIES=6
WEBHOOK_BACKOFF_BASE_MS=500
WEBHOOK_BACKOFF_MAX_MS=30000
WEBHOOK_RETRY_ON_429=true
WEBHOOK_ALLOW_PRIVATE_NET=false
WEBHOOK_INCLUDE_STATS=false
WEBHOOK_DEFAULT_PAGE_LIMIT=50
