# with-tenant-admin environment variables
# Copy this file to .env for local development.
# Process environment variables override .env; command-line flags override both.

# Listen address (default: :8086)
# APP_ADDR=:8086

# Static admin authentication token.
# REQUIRED — must be non-empty. All /admin/* routes reject requests that do not
# carry this value in the Authorization: Bearer <token> header.
# Use a strong random value in production (e.g. openssl rand -base64 32).
# The default shown here is safe for local development only; never use it in production.
# ADMIN_TOKEN=local-admin-token

# Log level: debug, info, warn, error (default: info)
# APP_LOG_LEVEL=info
