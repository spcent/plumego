# with-gateway environment variables
# Copy this file to .env for local development.
# Process environment variables override .env; command-line flags override both.

# Listen address (default: :8083)
# APP_ADDR=:8083

# Backend URL that the gateway proxies all matched requests to.
# Must be non-empty. In production use your internal service URL.
# Example: GATEWAY_BACKEND=https://api.internal.example.com
GATEWAY_BACKEND=http://localhost:9090

# Enable verbose request/response logging for gateway routes (default: false)
# Set to true during local development to trace proxied requests.
# APP_DEBUG=false

# Path to the .env file loaded at startup (default: .env in the working directory).
# APP_ENV_FILE=.env
