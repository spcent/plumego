# reference/standard-service environment variables
# Copy this file to .env for local development.
# Process environment variables override .env; command-line flags override both.

# Listen address (default: :8080)
# APP_ADDR=:8080

# Service identity used in /healthz, /readyz, and /api/* responses (default: plumego-reference)
# APP_SERVICE_NAME=plumego-reference

# Maximum request body size in bytes; 0 disables the limit (default: 1048576 = 1 MiB)
# APP_MAX_BODY_BYTES=1048576

# Write-operation guard key.
# When set, POST /api/v1/items, PUT /api/v1/items/:id, PATCH /api/v1/items/:id,
# and DELETE /api/v1/items/:id require the matching value in the X-Write-Key header.
# Leave unset (the default) to allow unauthenticated writes during local development.
# Always set a non-empty value in production.
#
# To disable a key that was set in this .env file, set APP_WRITE_KEY= in the
# process environment — an empty process-env value explicitly clears the key.
# APP_WRITE_KEY=

# Path to the .env file loaded at startup (default: .env in the working directory).
# Override with the --env-file flag or this variable before startup.
# APP_ENV_FILE=.env

# TLS configuration.
# When APP_TLS_ENABLED=true, APP_TLS_CERT_FILE and APP_TLS_KEY_FILE are required.
# In most deployments TLS is terminated by a proxy and these fields are left unset.
# APP_TLS_ENABLED=false
# APP_TLS_CERT_FILE=
# APP_TLS_KEY_FILE=
