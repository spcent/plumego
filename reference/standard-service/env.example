# reference/standard-service environment variables
# Copy this file to .env for local development.
# Process environment variables override .env; command-line flags override both.

# Listen address (default: :8080)
# APP_ADDR=:8080

# Service identity used in /healthz and /readyz responses (default: plumego-reference)
# APP_SERVICE_NAME=plumego-reference

# Maximum request body size in bytes; 0 disables the limit (default: 1048576 = 1 MiB)
# APP_MAX_BODY_BYTES=1048576

# Write-operation guard key.
# When set, POST /api/v1/items, PUT /api/v1/items/:id, and DELETE /api/v1/items/:id
# require the matching value in the X-Write-Key request header.
# Leave unset (the default) to allow unauthenticated writes during local development.
# Always set a non-empty value in production.
# APP_WRITE_KEY=

# Path to the .env file loaded at startup (default: .env in the working directory).
# Override with the --env-file flag or this variable before startup.
# APP_ENV_FILE=.env
