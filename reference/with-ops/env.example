# with-ops environment variables
# Copy this file to .env for local development.
# Process environment variables override .env; command-line flags override both.

# Listen address (default: :8087)
# APP_ADDR=:8087

# Authentication token required on all /ops/* requests.
# When set, the Authorization: Bearer <token> header must match this value.
# Leave unset (the default) to allow unauthenticated ops access during local development.
# Always set a non-empty value in production to protect health aggregates and metrics.
# OPS_TOKEN=local-admin-token

# Base path for ops endpoints; all health and metrics routes are mounted under this prefix.
# (default: /ops)
# OPS_BASE_PATH=/ops
