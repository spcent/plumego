# Workerfleet reference app
# Required when WORKERFLEET_PROFILE=prod. When set, worker register and
# heartbeat endpoints require Bearer auth.
WORKERFLEET_WORKER_AUTH_TOKEN=

# HTTP entrypoint
WORKERFLEET_HTTP_ADDR=:8080
WORKERFLEET_SHUTDOWN_TIMEOUT=10s

# Storage
WORKERFLEET_STORE_BACKEND=memory
WORKERFLEET_MONGO_URI=
WORKERFLEET_MONGO_DATABASE=
WORKERFLEET_MONGO_CONNECT_TIMEOUT=10s
WORKERFLEET_MONGO_OPERATION_TIMEOUT=10s
WORKERFLEET_MONGO_MAX_POOL_SIZE=
WORKERFLEET_RETENTION_DAYS=7

# Runtime profile and policy
WORKERFLEET_PROFILE=dev
WORKERFLEET_STATUS_STALE_AFTER=45s
WORKERFLEET_STATUS_OFFLINE_AFTER=90s
WORKERFLEET_STATUS_STAGE_STUCK_AFTER=10m
WORKERFLEET_STATUS_RESTART_BURST_THRESHOLD=3
WORKERFLEET_ALERT_STAGE_STUCK_AFTER=10m
WORKERFLEET_ALERT_RESTART_BURST_THRESHOLD=3
WORKERFLEET_EXPERIMENTAL_METRICS_ENABLED=true

# Runtime loops
WORKERFLEET_KUBE_SYNC_ENABLED=false
WORKERFLEET_STATUS_SWEEP_ENABLED=false
WORKERFLEET_ALERT_EVALUATION_ENABLED=false
WORKERFLEET_NOTIFICATION_ENABLED=false
WORKERFLEET_KUBE_SYNC_INTERVAL=30s
WORKERFLEET_STATUS_SWEEP_INTERVAL=30s
WORKERFLEET_ALERT_EVALUATION_INTERVAL=30s
WORKERFLEET_NOTIFIER_DELIVERY_TIMEOUT=5s

# Kubernetes inventory sync
WORKERFLEET_KUBE_API_HOST=
WORKERFLEET_KUBE_BEARER_TOKEN=
WORKERFLEET_KUBE_NAMESPACE=
WORKERFLEET_KUBE_LABEL_SELECTOR=
WORKERFLEET_KUBE_WORKER_CONTAINER=worker

# Notification sinks. At least one URL is required when
# WORKERFLEET_NOTIFICATION_ENABLED=true.
WORKERFLEET_FEISHU_WEBHOOK_URL=
WORKERFLEET_WEBHOOK_URL=
WORKERFLEET_WEBHOOK_HEADERS=
