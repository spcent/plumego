# with-frontend environment variables
# Copy this file to .env for local development.
# Process environment variables override .env; command-line flags override both.

# Listen address (default: :8088)
# APP_ADDR=:8088

# URL prefix under which JSON API endpoints are mounted (default: /api)
# API_PREFIX=/api

# URL prefix under which the embedded UI assets are served (default: /)
# UI_PREFIX=/

# Filesystem directory containing the static assets to embed and serve.
# Relative paths resolve from the working directory at startup. (default: ./assets)
# ASSETS_DIR=./assets
