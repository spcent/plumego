# with-events environment variables
# Copy this file to .env for local development.
# Process environment variables override .env; command-line flags override both.

# Listen address (default: :8083)
# APP_ADDR=:8083

# Log level: debug, info, warn, error (default: info)
# APP_LOG_LEVEL=info

# Optional webhook delivery target.
# When set, domain events are POSTed as JSON to this URL in addition to being
# published to the in-process event bus. Leave unset to disable outbound delivery.
# Example: WEBHOOK_TARGET_URL=https://your-receiver.example.com/events
# WEBHOOK_TARGET_URL=
