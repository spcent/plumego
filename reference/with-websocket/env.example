# with-websocket environment variables
# Copy this file to .env for local development.
# Process environment variables override .env; command-line flags override both.

# Listen address (default: :8084)
# APP_ADDR=:8084

# JWT signing secret for WebSocket authentication tokens.
# REQUIRED — must be at least 32 bytes. The service refuses to start when this
# value is absent or shorter than 32 bytes.
# Generate a secure value: openssl rand -base64 32
# WS_SECRET=

# Enable verbose request/response logging (default: false)
# APP_DEBUG=false

# Path to the .env file loaded at startup (default: .env in the working directory).
# APP_ENV_FILE=.env
