# with-rest environment variables
# Copy this file to .env for local development.
# Process environment variables override .env; command-line flags override both.

# Listen address (default: :8084)
# APP_ADDR=:8084

# CORS allowed origins — comma-separated list of origins permitted to make cross-origin requests.
# Leave unset (the default) to allow all origins ("*") during local development.
# Always restrict to known domains in production; wildcard origins are not allowed for
# authenticated APIs. Example: "https://app.example.com,https://admin.example.com"
# APP_CORS_ALLOWED_ORIGINS=
