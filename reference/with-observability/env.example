# with-observability environment variables
# Copy this file to .env for local development.
# Process environment variables override .env; command-line flags override both.

# Listen address (default: :8080)
# APP_ADDR=:8080

# Service identity used in /healthz, /readyz, and /api/* responses (default: plumego-observability)
# APP_SERVICE_NAME=plumego-observability

# Maximum request body size in bytes; 0 disables the limit (default: 1048576 = 1 MiB)
# APP_MAX_BODY_BYTES=1048576

# Prometheus metrics — namespace prefix for all metric names (default: plumego)
# APP_METRICS_NAMESPACE=plumego

# Prometheus metrics — maximum number of distinct label-value combinations tracked.
# Protects against cardinality explosions from unbounded path or header values. (default: 10000)
# APP_METRICS_MAX_SERIES=10000

# CORS allowed origins — comma-separated list of origins permitted to make cross-origin requests.
# Leave unset (the default) to allow all origins ("*") during local development.
# Always restrict to known domains in production; wildcard origins are not allowed for
# authenticated APIs. Example: "https://app.example.com,https://admin.example.com"
# APP_CORS_ALLOWED_ORIGINS=

# Path to the .env file loaded at startup (default: .env in the working directory).
# APP_ENV_FILE=.env

# TLS configuration.
# When APP_TLS_ENABLED=true, APP_TLS_CERT_FILE and APP_TLS_KEY_FILE are required.
# In most deployments TLS is terminated by a proxy and these fields are left unset.
# APP_TLS_ENABLED=false
# APP_TLS_CERT_FILE=
# APP_TLS_KEY_FILE=
