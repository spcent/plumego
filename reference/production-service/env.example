# production-service environment variables
# Copy to .env or inject via your platform's secret management.
# Flags override environment variables; environment variables override defaults.

# Listen address (default: :8080)
# APP_ADDR=:8080

# Deployment environment label — operator metadata only, not a security switch (default: local)
# APP_ENV=production

# Service identity used in status and health responses (default: plumego-production-reference)
# APP_SERVICE_NAME=my-service

# Bearer token for protected API routes (/api/profile).
# REQUIRED in production. If unset, the auth middleware accepts all bearer tokens.
# APP_API_TOKEN=

# Bearer token for the ops surface (/ops/metrics).
# REQUIRED in production. If unset, the auth middleware accepts all bearer tokens.
# OPS_TOKEN=

# Path to the JSON profile store file.
# When set and the file does not exist, the service creates it with seeded profiles (mode 0600).
# When unset, profiles are held in memory only (lost on restart).
# APP_PROFILE_STORE_PATH=

# Maximum request body size in bytes (default: 1048576 = 1 MiB)
# APP_BODY_LIMIT_BYTES=1048576

# Per-request timeout as a Go duration string (default: 5s)
# APP_REQUEST_TIMEOUT=5s

# Token-bucket rate limit: sustained requests per second per client IP (default: 20)
# APP_RATE_LIMIT=20

# Token-bucket burst capacity per client IP (default: 40)
# APP_RATE_BURST=40
