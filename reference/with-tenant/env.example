# with-tenant environment variables
# Copy this file to .env for local development.
# Process environment variables override .env; command-line flags override both.

# Listen address (default: :8085)
# APP_ADDR=:8085

# NOTE: tenant configuration (rate limits, quotas, allowed plans) is seeded
# in-memory at startup for demo purposes. In a real service these values would
# be loaded from a database or external config store.
