#!/usr/bin/env bash
# check-spec — validate milestone pipeline artifacts before execution or review.
#
# Usage:
#   scripts/check-spec tasks/milestones/active/M-001.md
#   scripts/check-spec tasks/milestones/M-001.plan.md
#   scripts/check-spec tasks/milestones/M-001.verify.md
#   scripts/check-spec tasks/cards/active/C-001-my-card.md
#
# Exits 0 if the artifact is structurally valid, 1 if it has structural problems.
# Does NOT check content quality — that is still the author's responsibility.

set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BOLD='\033[1m'; RESET='\033[0m'

usage() {
  echo "Usage: $0 <artifact-file>"
  echo "  Examples:"
  echo "    $0 tasks/milestones/active/M-001.md"
  echo "    $0 tasks/milestones/M-001.plan.md"
  echo "    $0 tasks/milestones/M-001.verify.md"
  echo "    $0 tasks/cards/active/C-001-slice-router-work.md"
  exit 1
}

[ $# -lt 1 ] && usage

TARGET="$1"

if [ ! -f "$TARGET" ]; then
  echo -e "${RED}Error:${RESET} File not found: $TARGET"
  exit 1
fi

FAILED=0
WARNINGS=0
KIND=""

kind_label() {
  case "$1" in
    milestone) printf 'Milestone' ;;
    plan)      printf 'Plan' ;;
    verify)    printf 'Verify' ;;
    card)      printf 'Card' ;;
    *)         printf 'Artifact' ;;
  esac
}

check() {
  local label="$1"; local pattern="$2"
  if grep -Eq "$pattern" "$TARGET" 2>/dev/null; then
    echo -e "  ${GREEN}OK${RESET}    $label"
  else
    echo -e "  ${RED}MISS${RESET}  $label"
    FAILED=1
  fi
}

warn() {
  local label="$1"; local pattern="$2"; local msg="$3"
  if grep -Eq "$pattern" "$TARGET" 2>/dev/null; then
    echo -e "  ${YELLOW}WARN${RESET}  $label — $msg"
    WARNINGS=1
  fi
}

warn_message() {
  local msg="$1"
  echo -e "  ${YELLOW}WARN${RESET}  $msg"
  WARNINGS=1
}

ok_message() {
  local msg="$1"
  echo -e "  ${GREEN}OK${RESET}    $msg"
}

extract_milestone_id() {
  local id
  id="$(sed -nE 's/^# (M-[0-9][0-9][0-9]): .*/\1/p' "$TARGET" | head -n1)"
  if [ -n "$id" ]; then
    printf '%s' "$id"
    return
  fi

  id="$(sed -nE 's/^Milestone:[[:space:]]*`?(M-[0-9][0-9][0-9])`?.*/\1/p' "$TARGET" | head -n1)"
  if [ -n "$id" ]; then
    printf '%s' "$id"
  fi
}

find_milestone_spec() {
  local milestone_id="$1"
  local candidate
  for candidate in \
    "tasks/milestones/active/${milestone_id}.md" \
    "tasks/milestones/done/${milestone_id}.md"
  do
    if [ -f "$candidate" ]; then
      printf '%s' "$candidate"
      return
    fi
  done
}

detect_kind() {
  case "$TARGET" in
    */tasks/milestones/*.plan.md|tasks/milestones/*.plan.md)
      printf 'plan'
      ;;
    */tasks/milestones/*.verify.md|tasks/milestones/*.verify.md)
      printf 'verify'
      ;;
    */tasks/milestones/*.md|tasks/milestones/*.md)
      printf 'milestone'
      ;;
    */tasks/cards/*.md|tasks/cards/*.md)
      printf 'card'
      ;;
    *)
      printf 'unknown'
      ;;
  esac
}

validate_milestone() {
  local milestone_id plan_path verify_path

  echo "Required sections:"
  check "Title (# M-)"                    "^# M-"
  check "Branch declaration"              "^\- \*\*Branch:\*\*"
  check "Goal section"                    "^## Goal"
  check "Architecture Decisions section"  "^## Architecture Decisions"
  check "Context section"                 "^## Context"
  check "Affected Modules section"        "^## Affected Modules"
  check "Tasks section"                   "^## Tasks"
  check "Acceptance Criteria section"     "^## Acceptance Criteria"
  check "Out of Scope section"            "^## Out of Scope"
  check "Open Questions section"          "^## Open Questions"
  check "Done Definition section"         "^## Done Definition"

  echo ""
  echo "Required gate commands in Acceptance Criteria:"
  check "dependency-rules check"    "dependency-rules"
  check "agent-workflow check"      "agent-workflow"
  check "module-manifests check"    "module-manifests"
  check "reference-layout check"    "reference-layout"
  check "go test race"              "go test -race"
  check "go test standard"          "go test -timeout"
  check "go vet"                    "go vet"
  check "gofmt"                     "gofmt"

  echo ""
  echo "Module declarations:"
  check "Primary module set"        "\*\*Primary:\*\*"

  echo ""
  echo "Companion artifact check:"
  milestone_id="$(extract_milestone_id)"
  if [ -n "$milestone_id" ]; then
    plan_path="tasks/milestones/${milestone_id}.plan.md"
    verify_path="tasks/milestones/${milestone_id}.verify.md"
    if [ -f "$plan_path" ]; then
      ok_message "Companion plan exists: $plan_path"
    else
      warn_message "Companion plan missing — scaffold with: make new-plan M=active/${milestone_id}"
    fi
    if [ -f "$verify_path" ]; then
      ok_message "Companion verify exists: $verify_path"
    else
      warn_message "Companion verify missing — scaffold with: make new-verify M=active/${milestone_id}"
    fi
  else
    warn_message "Milestone ID not resolved from title; companion artifact lookup skipped"
  fi

  echo ""
  echo "Template placeholder check:"
  warn "M-XXX placeholder still present"  "M-XXX"            "replace with real milestone ID"
  warn "primary-module placeholder"       "primary-module"   "replace with real module path"
  warn "slug placeholder"                 "M-XXX-<slug>"     "replace with real slug"
  warn "Title placeholder"                "^# M-.*<Title>"   "replace with real title"

  echo ""
  if [[ "$TARGET" == */active/* ]]; then
    ok_message "Spec is in active/ directory"
  else
    warn_message "Spec is not in active/ — confirm it is ready for execution"
  fi
}

validate_plan() {
  local milestone_id milestone_spec

  echo "Required fields:"
  check "Title (# Plan for M-)"       "^# Plan for M-"
  check "Milestone field"             "^Milestone:"
  check "Objective field"             "^Objective:"
  check "Constraints field"           "^Constraints:"
  check "Affected Modules field"      "^Affected Modules:"

  echo ""
  echo "Required sections:"
  check "Phase Map section"           "^## Phase Map"
  check "Card Inventory section"      "^## Card Inventory"
  check "Dependency Edges section"    "^## Dependency Edges"
  check "Parallel Groups section"     "^## Parallel Groups"
  check "Risk Register section"       "^## Risk Register"
  check "Verification Strategy"       "^## Verification Strategy"
  check "Exit Condition section"      "^## Exit Condition"

  echo ""
  echo "Plan structure:"
  check "Card inventory header"       "^\| Card \| Goal \| Primary Module \| Owned Files \| Depends On \| Quick Gates \|$"
  check "Dependency edge example"     '^- `C-[0-9][0-9][0-9].*`$|^- `C-001 -> C-002`$'

  echo ""
  echo "Milestone linkage:"
  milestone_id="$(extract_milestone_id)"
  if [ -n "$milestone_id" ]; then
    milestone_spec="$(find_milestone_spec "$milestone_id" || true)"
    if [ -n "$milestone_spec" ]; then
      ok_message "Companion milestone exists: $milestone_spec"
    else
      echo -e "  ${RED}MISS${RESET}  Companion milestone spec exists"
      FAILED=1
    fi
  else
    echo -e "  ${RED}MISS${RESET}  Milestone ID resolvable from plan"
    FAILED=1
  fi

  echo ""
  echo "Template placeholder check:"
  warn "M-XXX placeholder still present"  "M-XXX"          "replace with real milestone ID"
  warn "Title placeholder"                "<Title>"        "replace with real title"
  warn "C-001 example still present"      "^| C-001 "      "replace with real card inventory"
}

validate_verify() {
  local milestone_id milestone_spec plan_path

  echo "Required fields:"
  check "Title (# Verify M-)"          "^# Verify M-"
  check "Milestone field"              "^Milestone:"
  check "Branch field"                 "^Branch:"
  check "Verified Cards field"         "^Verified Cards:"

  echo ""
  echo "Required sections:"
  check "Scope Check section"          "^## Scope Check"
  check "Ownership Check section"      "^## Ownership Check"
  check "Symbol Completeness section"  "^## Symbol Completeness Check"
  check "Module Test Summary section"  "^## Module Test Summary"
  check "Boundary Check section"       "^## Boundary Check Summary"
  check "Repo Gate Summary section"    "^## Repo Gate Summary"
  check "Open Issues section"          "^## Open Issues"
  check "Final Verdict section"        "^## Final Verdict"

  echo ""
  echo "Required repo gates:"
  check "go test race"                 "go test -race -timeout 60s"
  check "go test standard"             "go test -timeout 20s"
  check "go vet"                       "go vet ./"
  check "gofmt"                        "gofmt -l ."

  echo ""
  echo "Milestone linkage:"
  milestone_id="$(extract_milestone_id)"
  if [ -n "$milestone_id" ]; then
    milestone_spec="$(find_milestone_spec "$milestone_id" || true)"
    if [ -n "$milestone_spec" ]; then
      ok_message "Companion milestone exists: $milestone_spec"
    else
      echo -e "  ${RED}MISS${RESET}  Companion milestone spec exists"
      FAILED=1
    fi
    plan_path="tasks/milestones/${milestone_id}.plan.md"
    if [ -f "$plan_path" ]; then
      ok_message "Companion plan exists: $plan_path"
    else
      warn_message "Companion plan missing — verify cannot reference planner output"
    fi
  else
    echo -e "  ${RED}MISS${RESET}  Milestone ID resolvable from verify report"
    FAILED=1
  fi

  echo ""
  echo "Template placeholder check:"
  warn "M-XXX placeholder still present"  "M-XXX"      "replace with real milestone ID"
  warn "Title placeholder"                "<Title>"    "replace with real title"
  warn "Verdict placeholder still present" '`PASS` or `FAIL`' "replace with a real verdict"
}

validate_card() {
  local milestone_id milestone_spec

  echo "Required card fields:"
  check "Title (# Card)"               "^# Card "
  check "Goal field"                   "^Goal:"
  check "Files field"                  "^Files:"
  check "Tests field"                  "^Tests:"
  check "Done Definition field"        "^Done Definition:"

  echo ""
  echo "Workflow metadata:"
  if grep -Eq "^Milestone:" "$TARGET" 2>/dev/null; then
    check "Milestone field"            "^Milestone:"
    check "Priority field"             "^Priority:"
    check "State field"                "^State:"
    check "Primary Module field"       "^Primary Module:"
    check "Owned Files field"          "^Owned Files:"
    check "Depends On field"           "^Depends On:"
    check "Scope field"                "^Scope:"
    check "Non-goals field"            "^Non-goals:"
    check "Docs Sync field"            "^Docs Sync:"
    check "Outcome field"              "^Outcome:"

    milestone_id="$(extract_milestone_id)"
    if [ -n "$milestone_id" ]; then
      milestone_spec="$(find_milestone_spec "$milestone_id" || true)"
      if [ -n "$milestone_spec" ]; then
        ok_message "Companion milestone exists: $milestone_spec"
      else
        warn_message "Milestone reference has no matching spec in active/ or done/"
      fi
    fi
  else
    warn_message "Legacy card shape detected — milestone linkage and ownership fields are not declared"
  fi

  echo ""
  echo "Template placeholder check:"
  warn "C-XXX placeholder still present"  "C-XXX"      "replace with real card ID"
  warn "M-XXX placeholder still present"  "M-XXX"      "replace with real milestone ID"
}

KIND="$(detect_kind)"

if [ "$KIND" = "unknown" ]; then
  echo -e "${RED}Error:${RESET} Unsupported artifact path: $TARGET"
  usage
fi

echo -e "\n${BOLD}Artifact: $TARGET${RESET}"
echo -e "${BOLD}Kind: $KIND${RESET}\n"

case "$KIND" in
  milestone) validate_milestone ;;
  plan)      validate_plan ;;
  verify)    validate_verify ;;
  card)      validate_card ;;
esac

echo ""
KIND_LABEL="$(kind_label "$KIND")"

if [ $FAILED -ne 0 ]; then
  echo -e "${RED}${BOLD}${KIND_LABEL} is INVALID — missing required fields or sections.${RESET}"
  echo -e "Fix the issues above, then re-run ${BOLD}scripts/check-spec $TARGET${RESET}."
  exit 1
fi

if [ $WARNINGS -ne 0 ]; then
  echo -e "${YELLOW}${BOLD}${KIND_LABEL} has warnings — confirm placeholders or legacy fields are intentional.${RESET}"
  exit 0
fi

echo -e "${GREEN}${BOLD}${KIND_LABEL} is valid.${RESET}"
