#!/usr/bin/env bash
# pre-push — plumego local quality gates
#
# Runs automatically before every `git push`. On milestone/* branches, runs
# the full quality gate suite and blocks the push if any gate fails.
# On other branches, runs a lighter quick-check (vet + fmt + fast tests).
#
# Install once: make setup-hooks
# Skip once:    git push --no-verify  (use sparingly; CI will still catch failures)

set -euo pipefail

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")
ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

# ── colour helpers ────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BOLD='\033[1m'; RESET='\033[0m'

pass() { echo -e "  ${GREEN}PASS${RESET}  $1"; }
fail() { echo -e "  ${RED}FAIL${RESET}  $1"; }
info() { echo -e "${YELLOW}▶${RESET} $1"; }

# ── gate runner ───────────────────────────────────────────────────────────────
FAILED=0

run_gate() {
  local label="$1"; shift
  if "$@" >/tmp/plumego-gate-out 2>&1; then
    pass "$label"
  else
    fail "$label"
    cat /tmp/plumego-gate-out | sed 's/^/    /'
    FAILED=1
  fi
}

run_fmt() {
  local out
  out=$(gofmt -l . 2>/dev/null)
  if [ -z "$out" ]; then
    pass "gofmt"
  else
    fail "gofmt (unformatted files)"
    echo "$out" | sed 's/^/    /'
    FAILED=1
  fi
}

# ── milestone branch: full gate suite ────────────────────────────────────────
if [[ "$BRANCH" == milestone/* ]]; then
  echo -e "\n${BOLD}plumego — milestone quality gates (${BRANCH})${RESET}\n"

  run_gate "dependency-rules"  go run ./internal/checks/dependency-rules
  run_gate "agent-workflow"    go run ./internal/checks/agent-workflow
  run_gate "module-manifests"  go run ./internal/checks/module-manifests
  run_gate "reference-layout"  go run ./internal/checks/reference-layout
  run_gate "go vet"            go vet ./...
  run_fmt
  run_gate "tests"             go test -timeout 20s ./...
  run_gate "tests (race)"      go test -race -timeout 60s ./...

  echo ""
  if [ $FAILED -ne 0 ]; then
    echo -e "${RED}${BOLD}Push blocked: one or more quality gates failed.${RESET}"
    echo -e "Fix the failures above, then push again."
    echo -e "To skip (e.g. push a WIP): ${YELLOW}git push --no-verify${RESET}"
    exit 1
  fi
  echo -e "${GREEN}${BOLD}All gates passed. Pushing.${RESET}\n"
  exit 0
fi

# ── non-milestone branch: quick check ────────────────────────────────────────
if [[ "$BRANCH" == main ]] || [[ "$BRANCH" == claude/* ]] || [[ "$BRANCH" == feature/* ]]; then
  echo -e "\n${BOLD}plumego — quick check (${BRANCH})${RESET}\n"

  run_gate "go vet"  go vet ./...
  run_fmt
  run_gate "tests"   go test -timeout 20s ./...

  echo ""
  if [ $FAILED -ne 0 ]; then
    echo -e "${RED}${BOLD}Push blocked: quick-check failed.${RESET}"
    echo -e "To skip: ${YELLOW}git push --no-verify${RESET}"
    exit 1
  fi
  echo -e "${GREEN}All checks passed.${RESET}\n"
fi

exit 0
