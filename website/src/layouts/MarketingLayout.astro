---
import '../styles/starlight-bridge.css';
import '../styles/global.css';
import '../styles/prose.css';
import '../styles/home.css';
import SiteHeader from '../components/shared/SiteHeader.astro';
import { FOOTER_GROUPS, SITE, SITE_COPY, type Locale } from '../data/site';
import { RELEASE_FACTS } from '../generated/releases';
import { toLocalePath } from '../lib/i18n';
import { LOCALES } from '../lib/locales';
import { buildMarketingSeo } from '../lib/seo';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  currentPath: string;
  imagePath?: string;
  noindex?: boolean;
  type?: 'website' | 'article';
  keywords?: string[];
  includeAlternates?: boolean;
}

const { locale, title, description, currentPath, imagePath, noindex, type, keywords, includeAlternates } = Astro.props;
const layoutCopy = {
  en: {
    preBadgeLabel: `pv1.0.0 · stable roots GA · x/* families carry explicit maturity labels`,
    preBadgeCta: 'View release posture →',
  },
  zh: {
    preBadgeLabel: `v1.0.0 · 稳定根 GA · 扩展模块按成熟度标注`,
    preBadgeCta: '查看发布策略 →',
  },
} satisfies Record<Locale, { preBadgeLabel: string; preBadgeCta: string }>;
const releasesHref = toLocalePath('/releases', locale);
const preBadgeLabel = layoutCopy[locale].preBadgeLabel;
const preBadgeCta = layoutCopy[locale].preBadgeCta;
const pageTitle = `${title} · ${SITE.name}`;
const footerGroups = FOOTER_GROUPS[locale];
const seo = buildMarketingSeo({
  title: pageTitle,
  description,
  currentPath,
  locale,
  imagePath,
  noindex,
  type,
  keywords,
  includeAlternates,
});
const lang = LOCALES[locale].htmlLang;

const footerTagline = SITE_COPY[locale].footerTagline;
---

<!doctype html>
<html lang={lang} data-theme="">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {seo.keywords && <meta name="keywords" content={seo.keywords} />}
    <meta name="robots" content={seo.robots} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f3f6fb" data-theme-color-meta />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={seo.canonicalUrl} />
    {seo.includeAlternates && <link rel="alternate" href="https://plumego.birdor.com/" hreflang="x-default" />}
    {seo.includeAlternates && seo.alternates.map((alternate) => (
      <link rel="alternate" href={`${seo.siteOrigin}${alternate.path}`} hreflang={alternate.hreflang} />
    ))}
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:type" content={seo.type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={seo.canonicalUrl} />
    <meta property="og:image" content={seo.imageUrl} />
    <meta property="og:image:alt" content={description} />
    <meta property="og:locale" content={seo.ogLocale} />
    {seo.includeAlternates && seo.alternateLocales.map((alternateLocale) => (
      <meta property="og:locale:alternate" content={alternateLocale} />
    ))}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={seo.imageUrl} />
    <script is:inline>
      (() => {
        const storageKey = 'starlight-theme';
        const stored = window.localStorage.getItem(storageKey);
        const theme =
          stored === 'light' || stored === 'dark'
            ? stored
            : window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        document.documentElement.dataset.theme = theme;
        document.documentElement.style.colorScheme = theme;
        document
          .querySelectorAll('meta[name="theme-color"][data-theme-color-meta]')
          .forEach((node) => (node.content = theme === 'dark' ? '#080c14' : '#f3f6fb'));
      })();
    </script>
  </head>
  <body class="marketing-shell">
    <div class="release-banner" role="note">
      <span class="release-banner__version">{RELEASE_FACTS.currentVersion}</span>
      <span class="release-banner__sep" aria-hidden="true">·</span>
      <span class="release-banner__text">{preBadgeLabel}</span>
      <a class="release-banner__link" href={releasesHref}>{preBadgeCta}</a>
    </div>
    <SiteHeader locale={locale} currentPath={currentPath} />
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="site-footer__meta">
        <p class="site-footer__brand">{SITE.name}</p>
        <p class="site-footer__tagline">{footerTagline}</p>
        <div class="site-footer__meta-links">
          <a href={SITE.githubUrl} class="site-footer__meta-link" target="_blank" rel="noreferrer">GitHub</a>
          <span class="site-footer__sep">·</span>
          <span class="site-footer__badge">{SITE.currentVersion}</span>
          <span class="site-footer__badge">MIT</span>
        </div>
        <p class="site-footer__copy">&copy; {new Date().getFullYear()} Plumego contributors</p>
      </div>
      <div class="site-footer__grid">
        {footerGroups.map((group) => (
          <div class="site-footer__group">
            <p class="site-footer__group-title">{group.title}</p>
            <div class="site-footer__links">
              {group.links.map((link) => (
                <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined} rel={link.href.startsWith('http') ? 'noreferrer' : undefined}>
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </footer>
    <script is:inline>
      (() => {
        const initSpotlight = () => {
          document.querySelectorAll('.signal-list__item, .page-panel, .fit-check-board__item').forEach((card) => {
            card.addEventListener('mousemove', (e) => {
              const r = card.getBoundingClientRect();
              card.style.setProperty('--spotlight-x', ((e.clientX - r.left) / r.width * 100).toFixed(1) + '%');
              card.style.setProperty('--spotlight-y', ((e.clientY - r.top) / r.height * 100).toFixed(1) + '%');
              card.style.setProperty('--spotlight-op', '1');
            });
            card.addEventListener('mouseleave', () => card.style.setProperty('--spotlight-op', '0'));
          });
        };
        document.addEventListener('astro:page-load', initSpotlight);
        initSpotlight();
      })();
    </script>
  </body>
</html>
