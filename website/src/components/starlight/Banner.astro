---
/**
 * Banner.astro — Starlight Banner override
 *
 * Extends the default Starlight banner with automatic stale-translation
 * detection. For any zh docs page whose translationKey appears in
 * STALE_TRANSLATIONS (generated at build time by scripts/check-translation-lag.mjs),
 * a stale-translation notice is prepended before any page-level banner content.
 */
import { STALE_TRANSLATIONS } from '../../generated/translation-lag';
import { localeFromPath } from '../../lib/i18n';
import { TRANSLATION_LAG_LOCALE } from '../../lib/locales';

const { entry } = Astro.locals.starlightRoute;

const locale = localeFromPath(Astro.url.pathname);
const translationKey: string | undefined = (entry.data as Record<string, unknown>).translationKey as string | undefined;
const isStale: boolean | undefined = translationKey
  ? (STALE_TRANSLATIONS as Record<string, boolean>)[translationKey]
  : undefined;

const showLagNotice = locale === TRANSLATION_LAG_LOCALE && isStale === true;
---

{showLagNotice && (
  <aside class="translation-notice" role="note" aria-label="Translation notice">
    <span class="translation-notice__icon">⚠</span>
    <span class="translation-notice__text">
      此页面的中文翻译可能已过时（英文源内容已更新）。
      如需获取最新内容，请查阅
      {translationKey && (
        <a href={`/docs/${translationKey.replace(/-/g, '/')}`}>英文原版</a>
      )}。
    </span>
  </aside>
)}

{entry.data.banner && (
  <p class="sl-banner" set:html={entry.data.banner.content} />
)}

<style>
  .translation-notice {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    margin-bottom: 1.25rem;
    border: 1px solid var(--sl-color-orange-high, #c77b1a);
    border-radius: 0.375rem;
    background: color-mix(in srgb, var(--sl-color-orange-low, #fff8ee) 80%, transparent);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .translation-notice__icon {
    flex-shrink: 0;
    color: var(--sl-color-orange-high, #c77b1a);
    font-style: normal;
  }

  .translation-notice__text a {
    color: var(--sl-color-text-accent, var(--accent));
    text-decoration: underline;
  }
</style>
