---
const { copy } = Astro.props;
---

<section class="section">
  <div class="section__intro section__intro--center">
    <h2>{copy.valueTitle}</h2>
    <p>{copy.valueLead}</p>
  </div>
  <div class="feature-grid">
    {copy.values.map((item: { kicker: string; title: string; body: string }) => (
      <article class="feature-card">
        <p class="feature-card__kicker">{item.kicker}</p>
        <h3>{item.title}</h3>
        <p>{item.body}</p>
      </article>
    ))}
  </div>
</section>
