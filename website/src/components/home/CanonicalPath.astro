---
const { copy } = Astro.props;
---

<section class="section section--split">
  <div class="section__intro">
    <h2>{copy.canonicalTitle}</h2>
    <p>{copy.canonicalBody}</p>
    <a class="text-link" href={copy.canonicalCta.href}>{copy.canonicalCta.label}</a>
    <div class="step-list">
      {copy.canonicalSteps.map((step: { label: string; title: string; body: string }) => (
        <article class="step-list__item">
          <p class="signal-list__kicker">{step.label}</p>
          <h3>{step.title}</h3>
          <p>{step.body}</p>
        </article>
      ))}
    </div>
  </div>
  <pre class="code-panel"><code>reference/standard-service/
  main.go
  internal/app/app.go
  internal/app/routes.go
  internal/handler/health.go</code></pre>
</section>
