---
interface Props {
  stableRoots: readonly string[];
  extensions: readonly string[];
}

const { stableRoots, extensions } = Astro.props as Props;

const stableNodes: string[] = [...stableRoots].slice(0, 5);
const extensionNodes: string[] = [...extensions].slice(0, 5);
---

<svg class="topology-diagram" viewBox="0 0 720 500" aria-hidden="true">
  <defs>
    <linearGradient id="plumegoPulse" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.7" />
      <stop offset="100%" stop-color="var(--accent-strong)" stop-opacity="0.2" />
    </linearGradient>
  </defs>

  <g class="topology-diagram__links">
    {stableNodes.map((_, index) => (
      <line x1="294" y1="198" x2="148" y2={96 + index * 62} />
    ))}
    {extensionNodes.map((_, index) => (
      <line x1="426" y1="198" x2="572" y2={96 + index * 62} />
    ))}
    <line x1="360" y1="258" x2="360" y2="358" />
  </g>

  <g class="topology-diagram__kernel">
    <circle cx="360" cy="198" r="70" />
    <text x="360" y="185">stdlib first</text>
    <text x="360" y="215">net/http</text>
  </g>

  <g class="topology-diagram__lane">
    <rect x="246" y="362" width="228" height="80" rx="18" />
    <text x="360" y="390">canonical path</text>
    <text x="360" y="414">docs → app → flow</text>
  </g>

  <g class="topology-diagram__labels topology-diagram__labels--stable">
    {stableNodes.map((node, index) => (
      <>
        <rect x="36" y={78 + index * 62} width="160" height="34" rx="17" />
        <text x="116" y={99 + index * 62}>{node}</text>
      </>
    ))}
  </g>

  <g class="topology-diagram__labels topology-diagram__labels--extension">
    {extensionNodes.map((node, index) => (
      <>
        <rect x="524" y={78 + index * 62} width="160" height="34" rx="17" />
        <text x="604" y={99 + index * 62}>{node}</text>
      </>
    ))}
  </g>
</svg>
