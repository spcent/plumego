---
import type { Locale } from '../../lib/locales';

const { locale = 'en' } = Astro.props as { locale?: Locale };

const copy = {
  en: {
    kicker: 'Agent-ready',
    title: 'Built for the way modern teams work.',
    disclaimer: 'This section is about AI coding assistants — Copilot, Claude, Cursor — tools that write or review code. It is not about building AI agent services; for that, see x/ai.',
    lead: 'As AI coding assistants take on more execution work, the question shifts: does your repository give them a clear operating model — or do they guess? Plumego\'s control plane gives agents the same routing signals a senior reviewer uses.',
    files: [
      {
        path: 'specs/task-routing.yaml',
        label: 'task routing',
        desc: 'Maps work types to owning modules. An agent reads this before writing a single line.',
      },
      {
        path: 'specs/dependency-rules.yaml',
        label: 'boundary enforcement',
        desc: 'Import violations are caught by a machine, not by reviewer memory.',
      },
      {
        path: '<module>/module.yaml',
        label: 'per-module scope',
        desc: 'Each module declares its own checks. Agents run only what is relevant.',
      },
    ],
    tableCaption: 'Try a scenario — see where it routes',
    scenarios: [
      {
        chip: 'Rate limiting',
        task: 'Add rate limiting to an HTTP endpoint',
        rule: 'middleware',
        owner: 'middleware/',
        reason: 'Transport-only cross-cutting concern — no x/* import needed. Stable roots handle this entirely.',
      },
      {
        chip: 'Per-tenant JWT',
        task: 'Add per-tenant JWT validation and quota enforcement',
        rule: 'tenant_policy_change',
        owner: 'x/tenant/',
        reason: 'Tenant identity and policy always route to x/tenant. Stable roots never see tenant logic.',
      },
      {
        chip: 'AI streaming SSE',
        task: 'Build an AI streaming SSE endpoint with tool routing',
        rule: 'extension_work → x/ai',
        owner: 'x/ai/',
        reason: 'AI capability work stays in the extension layer. The stable HTTP kernel is not modified.',
      },
      {
        chip: 'Boundary rules',
        task: 'Update allowed import directions in specs',
        rule: 'repo_rules',
        owner: 'specs/',
        reason: 'Import policy and dependency rules live in the control plane — not in any Go package.',
      },
    ],
    resultLabels: { rule: 'routing rule', owner: 'owner', reason: 'why' },
    cta: 'Full interactive routing demo →',
    ctaHref: '/docs/concepts/agent-first-workflow',
    whyHref: '/why-plumego',
    whyLabel: 'Adoption fit check',
  },
  zh: {
    kicker: 'Agent-ready',
    title: '为现代团队的工作方式而生。',
    lead: '当 AI 编程助手承担越来越多的执行工作时，关键问题变成了：你的仓库是否给了它们清晰的操作模型——还是让它们猜测？Plumego 的控制平面给 Agent 提供了资深评审者同样的路由信号。',
    files: [
      {
        path: 'specs/task-routing.yaml',
        label: '任务路由',
        desc: '将工作类型映射到归属模块。Agent 在写任何代码前先读这份文件。',
      },
      {
        path: 'specs/dependency-rules.yaml',
        label: '边界执行',
        desc: 'import 违规由机器捕获，不依赖评审者的记忆。',
      },
      {
        path: '<module>/module.yaml',
        label: '模块级 scope',
        desc: '每个模块自声明检查命令。Agent 只运行相关的验证。',
      },
    ],
    disclaimer: '本节讨论的是 AI 编码助手——Copilot、Claude、Cursor——帮助写代码或评审代码的工具。这不是关于构建 AI agent 服务的内容；那是 x/ai 模块的范围。',
    tableCaption: '选择一个场景，看看它会路由到哪里',
    scenarios: [
      {
        chip: '限流中间件',
        task: '为 HTTP 端点添加限流',
        rule: 'middleware',
        owner: 'middleware/',
        reason: '传输层横切关注点，不需要引入 x/* 模块。稳定根完全可以处理。',
      },
      {
        chip: '每租户 JWT',
        task: '添加每租户 JWT 验证和配额执行',
        rule: 'tenant_policy_change',
        owner: 'x/tenant/',
        reason: '租户身份和策略始终路由到 x/tenant。稳定根从不接触租户逻辑。',
      },
      {
        chip: 'AI 流式 SSE',
        task: '构建带工具路由的 AI 流式 SSE 端点',
        rule: 'extension_work → x/ai',
        owner: 'x/ai/',
        reason: 'AI 能力工作留在扩展层。稳定的 HTTP 内核不会被修改。',
      },
      {
        chip: '边界规则',
        task: '更新 specs 中允许的 import 方向',
        rule: 'repo_rules',
        owner: 'specs/',
        reason: 'import 策略和依赖规则存储在控制平面，不在任何 Go 包里。',
      },
    ],
    resultLabels: { rule: '路由规则', owner: '归属模块', reason: '原因' },
    cta: '查看完整交互式路由 demo →',
    ctaHref: '/zh/docs/concepts/agent-first-workflow',
    whyHref: '/zh/why-plumego',
    whyLabel: '查看完整适用性评估',
  },
} as const;

const t = copy[locale];
---

<section class="section agent-showcase-section">
  <div class="agent-showcase-header">
    <div class="agent-showcase-header__left">
      <p class="agent-showcase-kicker">{t.kicker}</p>
      <h2>{t.title}</h2>
      <p class="agent-showcase-disclaimer">{t.disclaimer}</p>
      <p class="agent-showcase-lead">{t.lead}</p>
    </div>
    <div class="agent-showcase-files">
      {t.files.map((file) => (
        <div class="agent-file">
          <div class="agent-file__top">
            <code class="agent-file__path">{file.path}</code>
            <span class="agent-file__label">{file.label}</span>
          </div>
          <p class="agent-file__desc">{file.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="agent-routing-block">
    <p class="agent-routing-caption">{t.tableCaption}</p>

    <div class="agent-scenario-picker" data-scenarios={JSON.stringify(t.scenarios)} data-labels={JSON.stringify(t.resultLabels)}>
      <div class="agent-scenario-chips" role="tablist" aria-label={t.tableCaption}>
        {t.scenarios.map((s, i) => (
          <button
            class={`agent-chip${i === 0 ? ' agent-chip--active' : ''}`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            data-idx={i}
          >{s.chip}</button>
        ))}
      </div>
      <div class="agent-scenario-result" role="tabpanel">
        <div class="agent-scenario-result__task" id="agentResultTask">{t.scenarios[0].task}</div>
        <div class="agent-scenario-result__row">
          <span class="agent-scenario-result__label">{t.resultLabels.rule}</span>
          <code class="agent-scenario-result__val" id="agentResultRule">{t.scenarios[0].rule}</code>
        </div>
        <div class="agent-scenario-result__row">
          <span class="agent-scenario-result__label">{t.resultLabels.owner}</span>
          <code class="agent-scenario-result__val" id="agentResultOwner">{t.scenarios[0].owner}</code>
        </div>
        <div class="agent-scenario-result__row agent-scenario-result__row--reason">
          <span class="agent-scenario-result__label">{t.resultLabels.reason}</span>
          <span class="agent-scenario-result__reason" id="agentResultReason">{t.scenarios[0].reason}</span>
        </div>
      </div>
    </div>

    <div class="agent-showcase-links">
      <a class="text-link" href={t.ctaHref}>{t.cta}</a>
      <a class="text-link" href={t.whyHref}>{t.whyLabel} →</a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.agent-scenario-picker').forEach((picker) => {
    const scenarios: Array<{ chip: string; task: string; rule: string; owner: string; reason: string }> =
      JSON.parse(picker.dataset.scenarios || '[]');

    const taskEl = picker.querySelector<HTMLElement>('#agentResultTask');
    const ruleEl = picker.querySelector<HTMLElement>('#agentResultRule');
    const ownerEl = picker.querySelector<HTMLElement>('#agentResultOwner');
    const reasonEl = picker.querySelector<HTMLElement>('#agentResultReason');

    picker.querySelectorAll<HTMLButtonElement>('.agent-chip').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = parseInt(btn.dataset.idx || '0', 10);
        const s = scenarios[idx];
        if (!s || !taskEl || !ruleEl || !ownerEl || !reasonEl) return;

        picker.querySelectorAll('.agent-chip').forEach((b) => {
          b.classList.remove('agent-chip--active');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('agent-chip--active');
        btn.setAttribute('aria-selected', 'true');

        taskEl.textContent = s.task;
        ruleEl.textContent = s.rule;
        ownerEl.textContent = s.owner;
        reasonEl.textContent = s.reason;
      });
    });
  });
</script>

<style>
  .agent-showcase-section {
    padding-block: 4rem;
  }

  .agent-showcase-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    max-width: 64rem;
    margin-inline: auto;
    margin-bottom: 2rem;
  }

  @media (min-width: 860px) {
    .agent-showcase-header {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .agent-showcase-kicker {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.5rem;
  }

  .agent-showcase-header__left h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.85rem;
    letter-spacing: -0.025em;
    line-height: 1.25;
    color: var(--fg);
  }

  .agent-showcase-disclaimer {
    font-size: 0.78rem;
    color: var(--fg-soft);
    font-style: italic;
    line-height: 1.55;
    margin: 0 0 0.5rem;
    max-width: 36rem;
    border-left: 2px solid var(--line);
    padding-left: 0.75rem;
  }

  .agent-showcase-lead {
    font-size: 0.92rem;
    color: var(--fg-soft);
    line-height: 1.7;
    margin: 0;
    max-width: 36rem;
  }

  .agent-showcase-files {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .agent-file {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 0.6rem;
    padding: 0.9rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .agent-file__top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .agent-file__path {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.1rem 0.45rem;
    border-radius: 0.25rem;
    white-space: nowrap;
  }

  .agent-file__label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-soft);
  }

  .agent-file__desc {
    font-size: 0.83rem;
    color: var(--fg-soft);
    margin: 0;
    line-height: 1.5;
  }

  .agent-routing-block {
    max-width: 64rem;
    margin-inline: auto;
  }

  .agent-routing-caption {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--fg-soft);
    margin: 0 0 0.75rem;
  }

  /* ── Interactive scenario picker ──────────────────────── */
  .agent-scenario-picker {
    border: 1px solid var(--line);
    border-radius: 0.75rem;
    overflow: hidden;
    background: var(--bg-elevated);
    margin-bottom: 1.25rem;
  }

  .agent-scenario-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    padding: 0.6rem 0.8rem;
    background: var(--bg-strong);
    border-bottom: 1px solid var(--line);
  }

  .agent-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.28rem 0.75rem;
    border-radius: 1rem;
    border: 1px solid transparent;
    background: transparent;
    color: var(--fg-soft);
    cursor: pointer;
    transition: background 0.15s, color 0.15s, border-color 0.15s;
    font-family: inherit;
    letter-spacing: 0.01em;
  }

  .agent-chip:hover {
    background: var(--bg-elevated);
    color: var(--fg);
    border-color: var(--line);
  }

  .agent-chip--active {
    background: var(--accent-soft);
    color: var(--accent-strong);
    border-color: color-mix(in srgb, var(--accent) 30%, transparent);
  }

  :root[data-theme="dark"] .agent-chip--active {
    color: var(--accent);
  }

  .agent-scenario-result {
    padding: 1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    min-height: 7rem;
  }

  .agent-scenario-result__task {
    font-size: 0.84rem;
    color: var(--fg);
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: 0.1rem;
  }

  .agent-scenario-result__row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .agent-scenario-result__row--reason {
    align-items: flex-start;
  }

  .agent-scenario-result__label {
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-soft);
    width: 4.5rem;
    flex-shrink: 0;
    padding-top: 0.05rem;
  }

  .agent-scenario-result__val {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
    white-space: nowrap;
  }

  .agent-scenario-result__reason {
    font-size: 0.83rem;
    color: var(--fg-soft);
    line-height: 1.5;
  }

  /* ─────────────────────────────────────────────────────── */

  .agent-showcase-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
</style>
