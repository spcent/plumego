---
const { locale = 'en' } = Astro.props as { locale?: 'en' | 'zh' };

const copy = {
  en: {
    kicker: 'Agent-ready',
    title: 'Built for the way modern teams work.',
    lead: 'As AI coding assistants take on more of the execution, the question shifts: does your repository give them a clear operating model — or do they guess? Plumego\'s control plane gives agents the same routing signals a senior reviewer uses.',
    files: [
      {
        path: 'specs/task-routing.yaml',
        label: 'task routing',
        desc: 'Maps work types to owning modules. An agent reads this before writing a single line.',
      },
      {
        path: 'specs/dependency-rules.yaml',
        label: 'boundary enforcement',
        desc: 'Import violations are caught by a machine, not by reviewer memory.',
      },
      {
        path: '<module>/module.yaml',
        label: 'per-module scope',
        desc: 'Each module declares its own checks. Agents run only what is relevant.',
      },
    ],
    tableCaption: 'How task routing works in practice',
    tableHead: ['Task description', 'Routing rule', 'Owner'],
    tableRows: [
      ['Add rate limiting to HTTP endpoint', 'middleware', 'middleware/'],
      ['Add per-tenant JWT validation', 'tenant_policy_change', 'x/tenant/'],
      ['Build AI streaming SSE endpoint', 'extension_work → x/ai', 'x/ai/'],
      ['Update import boundary rules', 'repo_rules', 'specs/'],
    ],
    cta: 'How agents use the control plane →',
    ctaHref: '/docs/concepts/agent-first-workflow',
    whyHref: '/why-plumego',
    whyLabel: 'Adoption fit check',
  },
  zh: {
    kicker: 'Agent-ready',
    title: '为现代团队的工作方式而生。',
    lead: '当 AI 编程助手承担越来越多的执行工作时，关键问题变成了：你的仓库是否给了它们清晰的操作模型——还是让它们猜测？Plumego 的控制平面给 Agent 提供了资深评审者同样的路由信号。',
    files: [
      {
        path: 'specs/task-routing.yaml',
        label: '任务路由',
        desc: '将工作类型映射到归属模块。Agent 在写任何代码前先读这份文件。',
      },
      {
        path: 'specs/dependency-rules.yaml',
        label: '边界执行',
        desc: 'import 违规由机器捕获，不依赖评审者的记忆。',
      },
      {
        path: '<module>/module.yaml',
        label: '模块级 scope',
        desc: '每个模块自声明检查命令。Agent 只运行相关的验证。',
      },
    ],
    tableCaption: '任务路由实际运作方式',
    tableHead: ['任务描述', '路由规则', '归属模块'],
    tableRows: [
      ['为 HTTP 端点添加限流', 'middleware', 'middleware/'],
      ['添加每租户 JWT 验证', 'tenant_policy_change', 'x/tenant/'],
      ['构建 AI 流式 SSE 端点', 'extension_work → x/ai', 'x/ai/'],
      ['更新 import 边界规则', 'repo_rules', 'specs/'],
    ],
    cta: '了解 Agent 如何使用控制平面 →',
    ctaHref: '/zh/docs/concepts/agent-first-workflow',
    whyHref: '/zh/why-plumego',
    whyLabel: '查看完整适用性评估',
  },
} as const;

const t = copy[locale];
---

<section class="section agent-showcase-section">
  <div class="agent-showcase-header">
    <div class="agent-showcase-header__left">
      <p class="agent-showcase-kicker">{t.kicker}</p>
      <h2>{t.title}</h2>
      <p class="agent-showcase-lead">{t.lead}</p>
    </div>
    <div class="agent-showcase-files">
      {t.files.map((file) => (
        <div class="agent-file">
          <div class="agent-file__top">
            <code class="agent-file__path">{file.path}</code>
            <span class="agent-file__label">{file.label}</span>
          </div>
          <p class="agent-file__desc">{file.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="agent-routing-block">
    <p class="agent-routing-caption">{t.tableCaption}</p>
    <div class="agent-routing-table" role="table" aria-label={t.tableCaption}>
      <div class="agent-routing-table__head" role="row">
        {t.tableHead.map((h) => <span role="columnheader">{h}</span>)}
      </div>
      {t.tableRows.map(([task, rule, owner]) => (
        <div class="agent-routing-table__row" role="row">
          <span role="cell">{task}</span>
          <span role="cell"><code>{rule}</code></span>
          <span role="cell"><code>{owner}</code></span>
        </div>
      ))}
    </div>
    <div class="agent-showcase-links">
      <a class="text-link" href={t.ctaHref}>{t.cta}</a>
      <a class="text-link" href={t.whyHref}>{t.whyLabel} →</a>
    </div>
  </div>
</section>

<style>
  .agent-showcase-section {
    padding-block: 4rem;
  }

  .agent-showcase-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    max-width: 64rem;
    margin-inline: auto;
    margin-bottom: 2rem;
  }

  @media (min-width: 860px) {
    .agent-showcase-header {
      grid-template-columns: 1fr 1fr;
      align-items: start;
    }
  }

  .agent-showcase-kicker {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.5rem;
  }

  .agent-showcase-header__left h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.85rem;
    letter-spacing: -0.025em;
    line-height: 1.25;
    color: var(--fg);
  }

  .agent-showcase-lead {
    font-size: 0.92rem;
    color: var(--fg-soft);
    line-height: 1.7;
    margin: 0;
    max-width: 36rem;
  }

  .agent-showcase-files {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .agent-file {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 0.6rem;
    padding: 0.9rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .agent-file__top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .agent-file__path {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.1rem 0.45rem;
    border-radius: 0.25rem;
    white-space: nowrap;
  }

  .agent-file__label {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--fg-soft);
  }

  .agent-file__desc {
    font-size: 0.83rem;
    color: var(--fg-soft);
    margin: 0;
    line-height: 1.5;
  }

  .agent-routing-block {
    max-width: 64rem;
    margin-inline: auto;
  }

  .agent-routing-caption {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--fg-soft);
    margin: 0 0 0.6rem;
  }

  .agent-routing-table {
    border: 1px solid var(--line);
    border-radius: 0.625rem;
    overflow: hidden;
    background: var(--bg-elevated);
    margin-bottom: 1.25rem;
  }

  .agent-routing-table__head {
    display: grid;
    grid-template-columns: 2fr 1.2fr 1fr;
    padding: 0.5rem 1.1rem;
    background: var(--bg-strong);
    border-bottom: 1px solid var(--line);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--fg-soft);
    gap: 0.5rem;
  }

  .agent-routing-table__row {
    display: grid;
    grid-template-columns: 2fr 1.2fr 1fr;
    padding: 0.65rem 1.1rem;
    border-bottom: 1px solid var(--line);
    font-size: 0.84rem;
    gap: 0.5rem;
    align-items: center;
    color: var(--fg-soft);
  }

  .agent-routing-table__row:last-child {
    border-bottom: none;
  }

  .agent-routing-table__row code {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.1rem 0.35rem;
    border-radius: 0.22rem;
    white-space: nowrap;
  }

  .agent-showcase-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .agent-routing-table__head,
    .agent-routing-table__row {
      grid-template-columns: 1fr;
    }
    .agent-routing-table__head span:not(:first-child) {
      display: none;
    }
  }
</style>
