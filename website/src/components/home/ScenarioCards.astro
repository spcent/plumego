---
type ScenarioCard = {
  kicker: string;
  title: string;
  code: string;
  body: string;
  href: string;
  label: string;
  maturity: string | null;
};

interface Props {
  cards: ScenarioCard[];
  sectionTitle?: string;
}

const { cards, sectionTitle } = Astro.props;

const maturityColors: Record<string, string> = {
  beta: 'badge--beta',
  experimental: 'badge--experimental',
};
---

<section class="section scenario-section">
  {sectionTitle && (
    <div class="section__intro section__intro--center">
      <h2>{sectionTitle}</h2>
    </div>
  )}
  <div class="scenario-grid">
    {cards.map((card) => (
      <article class="scenario-card">
        <header class="scenario-card__header">
          <p class="scenario-card__kicker">{card.kicker}</p>
          {card.maturity && (
            <span class={`scenario-card__maturity-badge ${maturityColors[card.maturity] ?? ''}`}>
              {card.maturity}
            </span>
          )}
        </header>
        <h3 class="scenario-card__title">{card.title}</h3>
        <div class="scenario-card__code-wrap">
          <pre class="scenario-card__pre"><code>{card.code}</code></pre>
        </div>
        <p class="scenario-card__body">{card.body}</p>
        <a class="scenario-card__link" href={card.href}>{card.label} →</a>
      </article>
    ))}
  </div>
</section>

<style>
  .scenario-section {
    padding-block: 3rem 1.5rem;
  }

  .scenario-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 64rem;
    margin-inline: auto;
  }

  @media (min-width: 780px) {
    .scenario-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .scenario-card {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 0.875rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    box-shadow: var(--shadow);
    transition: border-color 0.18s, box-shadow 0.18s;
  }

  .scenario-card:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, var(--line));
    box-shadow: var(--shadow), 0 0 0 3px var(--accent-soft);
  }

  .scenario-card__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .scenario-card__kicker {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
  }

  .scenario-card__maturity-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 0.15rem 0.45rem;
    border-radius: 0.25rem;
    white-space: nowrap;
  }

  .badge--beta {
    background: color-mix(in srgb, #4f46e5 10%, var(--bg-elevated));
    border: 1px solid color-mix(in srgb, #4f46e5 20%, var(--line));
    color: #4f46e5;
  }

  :root[data-theme="dark"] .badge--beta {
    background: color-mix(in srgb, #818cf8 10%, var(--bg-elevated));
    border-color: color-mix(in srgb, #818cf8 20%, var(--line));
    color: #818cf8;
  }

  .badge--experimental {
    background: color-mix(in srgb, #d97706 10%, var(--bg-elevated));
    border: 1px solid color-mix(in srgb, #d97706 18%, var(--line));
    color: #b45309;
  }

  :root[data-theme="dark"] .badge--experimental {
    background: color-mix(in srgb, #fbbf24 8%, var(--bg-elevated));
    border-color: color-mix(in srgb, #fbbf24 16%, var(--line));
    color: #fbbf24;
  }

  .scenario-card__title {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--fg);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .scenario-card__code-wrap {
    background: var(--code-bg);
    border: 1px solid var(--code-border);
    border-radius: 0.5rem;
    overflow: hidden;
  }

  .scenario-card__pre {
    margin: 0;
    padding: 0.85rem 1rem;
    overflow-x: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,0.12) transparent;
  }

  .scenario-card__pre code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.65;
    color: var(--code-text);
    white-space: pre;
    display: block;
  }

  .scenario-card__body {
    font-size: 0.86rem;
    color: var(--fg-soft);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .scenario-card__link {
    font-size: 0.84rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    margin-top: auto;
    transition: color 0.15s;
  }

  .scenario-card__link:hover {
    color: var(--accent-strong);
    text-decoration: underline;
  }
</style>
