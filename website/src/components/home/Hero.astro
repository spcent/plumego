---
const { copy } = Astro.props;
---

<section class="hero">
  <div class="hero__copy">
    <p class="hero__eyebrow">{copy.eyebrow}</p>
    <h1>{copy.headline}</h1>
    <p class="hero__summary" set:html={copy.summary} />
    <div class="hero__actions">
      <a class="button button--primary" href={copy.primaryCta.href}>{copy.primaryCta.label}</a>
      <a class="button button--ghost" href={copy.secondaryCta.href}>{copy.secondaryCta.label}</a>
    </div>
    <div class="hero__install">
      <code class="hero__install-cmd">go run ./reference/standard-service</code>
      <span class="hero__install-sep">or</span>
      <code class="hero__install-cmd">go get github.com/spcent/plumego@latest</code>
    </div>
  </div>

  <div class="hero__panel">
    <div class="hero-code">
      <div class="hero-code__bar">
        <span class="hero-code__dots">
          <span></span><span></span><span></span>
        </span>
        <span class="hero-code__filename">internal/app/routes.go</span>
      </div>
      <pre class="hero-code__pre"><code><span class="hc-kw">func</span> (a *App) <span class="hc-fn">Routes</span>() http.Handler &#123;
    r := router.<span class="hc-fn">New</span>()

    <span class="hc-cm">// middleware order is explicit, not hidden</span>
    r.<span class="hc-fn">Use</span>(middleware.RequestID)
    r.<span class="hc-fn">Use</span>(middleware.<span class="hc-fn">Logger</span>(a.log))

    <span class="hc-cm">// route ownership visible in one file</span>
    api := r.<span class="hc-fn">Group</span>(<span class="hc-str">"/api/v1"</span>,
        middleware.<span class="hc-fn">Auth</span>(a.cfg.JWTSecret))
    api.<span class="hc-fn">Get</span>(<span class="hc-str">"/users/:id"</span>, a.users.<span class="hc-fn">Get</span>)
    api.<span class="hc-fn">Post</span>(<span class="hc-str">"/users"</span>,    a.users.<span class="hc-fn">Create</span>)
    api.<span class="hc-fn">Get</span>(<span class="hc-str">"/items"</span>,     a.items.<span class="hc-fn">List</span>)

    <span class="hc-kw">return</span> r
&#125;</code></pre>
    </div>
  </div>
</section>
