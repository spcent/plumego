---
import { SITE } from '../../data/site';
const { copy } = Astro.props;
---

<section class="hero">
  <div class="hero__copy">
    <p class="hero__eyebrow">{copy.eyebrow}</p>
    <h1>{copy.headline}</h1>
    <p class="hero__summary">{copy.summary}</p>
    <div class="hero__actions">
      <a class="button button--primary" href={copy.primaryCta.href}>{copy.primaryCta.label}</a>
      <a class="button button--ghost" href={copy.secondaryCta.href}>{copy.secondaryCta.label}</a>
    </div>
    {copy.notes && copy.notes.length > 0 && (
      <div class="hero__notes">
        {copy.notes.map((note: string) => (
          <span class="hero__note">{note}</span>
        ))}
      </div>
    )}
    <div class="hero__install">
      <code class="hero__install-cmd">go get github.com/spcent/plumego@main</code>
    </div>
  </div>

  <div class="hero__panel">
    <div class="hero-code">
      <div class="hero-code__bar">
        <span class="hero-code__dots">
          <span></span><span></span><span></span>
        </span>
        <span class="hero-code__filename">internal/handler/api.go</span>
      </div>
      <pre class="hero-code__pre"><code><span class="hc-kw">package</span> handler

<span class="hc-kw">import</span> (
    <span class="hc-str">"net/http"</span>

    <span class="hc-str">"github.com/spcent/plumego/contract"</span>
)

<span class="hc-kw">func</span> (h *ItemsAPI) <span class="hc-fn">List</span>(w http.ResponseWriter, r *http.Request) &#123;
    items, err := h.store.<span class="hc-fn">All</span>(r.<span class="hc-fn">Context</span>())
    <span class="hc-kw">if</span> err != <span class="hc-kw">nil</span> &#123;
        _ = contract.<span class="hc-fn">WriteError</span>(w, r,
            contract.<span class="hc-fn">NewErrorBuilder</span>().
                <span class="hc-fn">Type</span>(contract.TypeInternal).
                <span class="hc-fn">Message</span>(<span class="hc-str">"could not list items"</span>).
                <span class="hc-fn">Build</span>())
        <span class="hc-kw">return</span>
    &#125;
    _ = contract.<span class="hc-fn">WriteResponse</span>(w, r,
        http.StatusOK, items, <span class="hc-kw">nil</span>)
&#125;</code></pre>
    </div>
  </div>
</section>
