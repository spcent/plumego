---
const { copy } = Astro.props;
---

<section class="section section--cta">
  <div class="section__intro">
    <h2>{copy.exploreTitle}</h2>
    <p>{copy.exploreBody}</p>
  </div>
  <div class="signal-list">
    {copy.exploreCards.map((item: { kicker: string; title: string; body: string; href: string; label: string }) => (
      <article class="signal-list__item">
        <p class="signal-list__kicker">{item.kicker}</p>
        <h3>{item.title}</h3>
        <p>{item.body}</p>
        <a class="text-link" href={item.href}>{item.label}</a>
      </article>
    ))}
  </div>
  <div class="section__intro">
    <h2>{copy.controlTitle}</h2>
    <p>{copy.controlBody}</p>
    <div class="control-grid">
      {copy.controlItems.map((item: { title: string; body: string }) => (
        <article class="control-grid__item">
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </div>
  <div class="section__intro">
    <h2>{copy.finalTitle}</h2>
    <p>{copy.finalBody}</p>
    <div class="hero__actions">
      <a class="button button--primary" href={copy.finalPrimary.href}>{copy.finalPrimary.label}</a>
      <a class="button button--ghost" href={copy.finalSecondary.href}>{copy.finalSecondary.label}</a>
    </div>
  </div>
</section>
