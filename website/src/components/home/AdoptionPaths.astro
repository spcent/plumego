---
const { copy } = Astro.props;
---

<section class="section section--adoption">
  <div class="section__intro">
    <h2>{copy.adoptionTitle}</h2>
    <p>{copy.adoptionBody}</p>
  </div>
  <div class="adoption-grid">
    {copy.adoptionCards.map((item: { kicker: string; title: string; body: string; href: string; label: string }) => (
      <a class="adoption-card" href={item.href}>
        <p class="signal-list__kicker">{item.kicker}</p>
        <h3>{item.title}</h3>
        <p>{item.body}</p>
        <span class="adoption-card__link">{item.label}</span>
      </a>
    ))}
  </div>
</section>
