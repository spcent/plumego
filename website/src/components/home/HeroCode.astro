---
const snippet1 = [
  '<span class="t-cm">// New wires deps explicitly — no hidden registration.</span>',
  '<span class="t-kw">func</span> New(cfg config.Config) (*App, <span class="t-kw">error</span>) {',
  '\tapp := core.New(cfg.Core, core.AppDependencies{',
  '\t\tLogger: plumelog.NewLogger(),',
  '\t})',
  '',
  '\tapp.Use(',
  '\t\trequestid.Middleware(),',
  '\t\trecovery.Recovery(app.Logger()),',
  '\t\taccesslog.Middleware(app.Logger()),',
  '\t)',
  '',
  '\t<span class="t-kw">return</span> &amp;App{Core: app, Cfg: cfg}, <span class="t-kw">nil</span>',
  '}',
].join('\n');

const snippet2 = [
  '<span class="t-cm">// RegisterRoutes: every route is explicit — nothing registered elsewhere.</span>',
  '<span class="t-kw">func</span> (a *App) RegisterRoutes() <span class="t-kw">error</span> {',
  '\ta.Core.Get(<span class="t-str">"/healthz"</span>,      http.HandlerFunc(health.Live))',
  '\ta.Core.Get(<span class="t-str">"/readyz"</span>,       http.HandlerFunc(health.Ready))',
  '\ta.Core.Get(<span class="t-str">"/api/v1/greet"</span>, http.HandlerFunc(api.Greet))',
  '\t<span class="t-kw">return nil</span>',
  '}',
].join('\n');
---

<div class="hero__code">
  <div class="hero__code-bar">
    <div class="hero__code-dots">
      <span></span><span></span><span></span>
    </div>
    <span class="hero__code-label">internal/app/app.go</span>
  </div>
  <pre class="hero__code-pre"><code set:html={snippet1}></code></pre>
  <div class="hero__code-divider"></div>
  <pre class="hero__code-pre"><code set:html={snippet2}></code></pre>
</div>
