---
const { locale = 'en' } = Astro.props as { locale?: 'en' | 'zh' };

const copy = {
  en: {
    heading: 'Running in under two minutes.',
    lead: 'Install, write one handler, run. Continue to',
    referenceLink: '/docs/reference-app',
    referenceLinkLabel: 'reference/standard-service',
    leadSuffix: 'for the full canonical service shape.',
    verifyHeading: 'Verify',
    verifyLabel: 'expected response',
  },
  zh: {
    heading: '两分钟内跑起来。',
    lead: '安装，写一个 handler，运行。完整的 canonical 服务结构见',
    referenceLink: '/zh/docs/reference-app',
    referenceLinkLabel: 'reference/standard-service',
    leadSuffix: '。',
    verifyHeading: '验证',
    verifyLabel: '预期响应',
  },
} as const;

const t = copy[locale];
---

<section class="section minimal-example-section">
  <div class="section__intro">
    <h2>{t.heading}</h2>
    <p>
      {t.lead} <a href={t.referenceLink}>{t.referenceLinkLabel}</a> {t.leadSuffix}
    </p>
  </div>

  <div class="minimal-example-grid">
    <div class="hero-code minimal-example-code">
      <div class="hero-code__bar">
        <span class="hero-code__dots">
          <span></span><span></span><span></span>
        </span>
        <span class="hero-code__filename">main.go</span>
      </div>
      <pre class="hero-code__pre"><code><span class="hc-kw">package</span> main

<span class="hc-kw">import</span> (
    <span class="hc-str">"log"</span>
    <span class="hc-str">"net/http"</span>

    <span class="hc-str">"github.com/spcent/plumego/contract"</span>
    <span class="hc-str">"github.com/spcent/plumego/core"</span>
    plog <span class="hc-str">"github.com/spcent/plumego/log"</span>
)

<span class="hc-kw">func</span> <span class="hc-fn">main</span>() &#123;
    app := core.<span class="hc-fn">New</span>(core.<span class="hc-fn">DefaultConfig</span>(),
        core.AppDependencies&#123;Logger: plog.<span class="hc-fn">NewLogger</span>()&#125;)

    _ = app.<span class="hc-fn">Get</span>(<span class="hc-str">"/ping"</span>, http.<span class="hc-fn">HandlerFunc</span>(
        <span class="hc-kw">func</span>(w http.ResponseWriter, r *http.Request) &#123;
            _ = contract.<span class="hc-fn">WriteResponse</span>(w, r,
                http.StatusOK,
                map[string]string&#123;<span class="hc-str">"status"</span>: <span class="hc-str">"ok"</span>&#125;, <span class="hc-kw">nil</span>)
        &#125;))

    <span class="hc-kw">if</span> err := app.<span class="hc-fn">Prepare</span>(); err != <span class="hc-kw">nil</span> &#123;
        log.<span class="hc-fn">Fatal</span>(err)
    &#125;
    srv, _ := app.<span class="hc-fn">Server</span>()
    log.<span class="hc-fn">Println</span>(<span class="hc-str">"listening on :8080"</span>)
    srv.<span class="hc-fn">ListenAndServe</span>()
&#125;</code></pre>
    </div>

    <div class="minimal-example-verify">
      <div class="hero-code hero-code--canonical">
        <div class="hero-code__bar">
          <span class="hero-code__dots">
            <span></span><span></span><span></span>
          </span>
          <span class="hero-code__filename">{t.verifyHeading}</span>
        </div>
        <pre class="hero-code__pre"><code><span class="hc-cm">$ go get github.com/spcent/plumego@latest</span>
<span class="hc-cm">$ go run .</span>

<span class="hc-cm">$ curl localhost:8080/ping</span>
&#123;<span class="hc-str">"data"</span>: &#123;<span class="hc-str">"status"</span>: <span class="hc-str">"ok"</span>&#125;&#125;</code></pre>
      </div>
      <p class="minimal-example-note">{t.verifyLabel}</p>
    </div>
  </div>
</section>

<style>
  .minimal-example-section {
    padding-block: 3.5rem;
  }

  .minimal-example-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 56rem;
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .minimal-example-grid {
      grid-template-columns: 3fr 2fr;
      align-items: start;
    }
  }

  .minimal-example-verify {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .minimal-example-note {
    font-size: 0.78rem;
    color: var(--fg-soft);
    margin: 0;
    padding-inline-start: 0.25rem;
  }
</style>
