---
interface Props {
  locale?: 'en' | 'zh';
}

const { locale = 'en' } = Astro.props as Props;

const groups =
  locale === 'zh'
    ? [
        {
          title: '先判断，再进入实现',
          body: '如果你还没有完全确认适配度，就先回到 Why Plumego；如果判断已经清楚，就从文档首页继续实现路径。',
          links: [
            { label: '为什么选择 Plumego', href: '/zh/why-plumego' },
            { label: '开始使用', href: '/zh/docs/getting-started' },
          ],
        },
        {
          title: 'Concepts',
          body: '先建立请求流程与仓库边界的心智模型。',
          links: [
            { label: '请求流程', href: '/zh/docs/concepts/request-flow' },
            { label: '仓库边界', href: '/zh/docs/concepts/repo-control-plane' },
            { label: '常见问题', href: '/zh/docs/faq' },
          ],
        },
        {
          title: 'Boundaries',
          body: '当你需要判断改动归属时，再进入模块与发布姿态。',
          links: [
            { label: '模块总览', href: '/zh/docs/modules/overview' },
            { label: '稳定根', href: '/zh/docs/stable-roots' },
            { label: 'x/* 家族', href: '/zh/docs/x-family' },
            { label: '发布姿态', href: '/zh/docs/release-posture' },
          ],
        },
      ]
    : [
        {
          title: 'Evaluate, then implement',
          body: 'If fit is still unclear, go back to Why Plumego. If the decision is already made, continue from docs home into the implementation path.',
          links: [
            { label: 'Why Plumego', href: '/why-plumego' },
            { label: 'Getting Started', href: '/docs/getting-started' },
          ],
        },
        {
          title: 'Concepts',
          body: 'Build the request-flow and repository-boundary model before you open packages at random.',
          links: [
            { label: 'Request Flow', href: '/docs/concepts/request-flow' },
            { label: 'Repository Boundaries', href: '/docs/concepts/repo-control-plane' },
            { label: 'FAQ', href: '/docs/faq' },
          ],
        },
        {
          title: 'Boundaries',
          body: 'Move into modules and release posture when you need to decide where work belongs.',
          links: [
            { label: 'Modules Overview', href: '/docs/modules/overview' },
            { label: 'Stable Roots', href: '/docs/stable-roots' },
            { label: 'x/* Family', href: '/docs/x-family' },
            { label: 'Release Posture', href: '/docs/release-posture' },
          ],
        },
      ];
---

<div class="docs-topic-groups">
  {groups.map((group) => (
    <article class="topic-group">
      <h3>{group.title}</h3>
      <p>{group.body}</p>
      <ul>
        {group.links.map((item) => (
          <li><a class="text-link" href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </article>
  ))}
</div>
