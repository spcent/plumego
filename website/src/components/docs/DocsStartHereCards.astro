---
interface Props {
  locale?: 'en' | 'zh';
}

const { locale = 'en' } = Astro.props as Props;

const cards =
  locale === 'zh'
    ? [
        {
          eyebrow: 'canonical path',
          title: '开始使用',
          body: '先跑通最小参考路径，确认 Plumego 的默认起步方式和 HTTP 形态。',
          href: '/zh/docs/getting-started',
          label: '进入开始使用',
        },
        {
          eyebrow: 'reference',
          title: '参考应用',
          body: '从 bootstrap、app wiring 和 route 注册理解 canonical 应用布局。',
          href: '/zh/docs/reference-app',
          label: '查看参考应用',
        },
        {
          eyebrow: 'boundaries',
          title: '模块总览',
          body: '先看稳定根和扩展家族的分层，再决定改动应该落在哪一层。',
          href: '/zh/docs/modules/overview',
          label: '查看模块总览',
        },
        {
          eyebrow: 'stable surface',
          title: '稳定根',
          body: '理解哪些包属于默认学习路径，以及哪些职责不应继续长进稳定层。',
          href: '/zh/docs/stable-roots',
          label: '查看稳定根',
        },
        {
          eyebrow: 'extensions',
          title: 'x/* 家族',
          body: '把能力型工作从稳定根分离出去，先从主扩展家族入口开始读起。',
          href: '/zh/docs/x-family',
          label: '查看 x/* 家族',
        },
        {
          eyebrow: 'compatibility',
          title: '发布姿态',
          body: '在假设长期兼容性之前，先看支持矩阵和当前发布姿态。',
          href: '/zh/docs/release-posture',
          label: '查看发布姿态',
        },
        {
          eyebrow: 'direction',
          title: '路线图',
          body: '看清仓库当前在补什么、下一步做什么，以及哪些事情明确不做。',
          href: '/zh/roadmap',
          label: '查看路线图',
        },
        {
          eyebrow: 'releases',
          title: '发布',
          body: '查看当前版本、支持分组和 README 同步过来的支持矩阵。',
          href: '/zh/releases',
          label: '查看发布页',
        },
      ]
    : [
        {
          eyebrow: 'canonical path',
          title: 'Getting Started',
          body: 'Run the smallest reference path first and confirm the default Plumego entry flow.',
          href: '/docs/getting-started',
          label: 'Open getting started',
        },
        {
          eyebrow: 'reference',
          title: 'Reference App',
          body: 'Read the canonical app layout from bootstrap to wiring to route registration.',
          href: '/docs/reference-app',
          label: 'Open reference app',
        },
        {
          eyebrow: 'boundaries',
          title: 'Modules Overview',
          body: 'See the stable-root versus extension split before deciding where work belongs.',
          href: '/docs/modules/overview',
          label: 'Open modules overview',
        },
        {
          eyebrow: 'stable surface',
          title: 'Stable Roots',
          body: 'Understand which packages define the default learning path and what should stay out of them.',
          href: '/docs/stable-roots',
          label: 'Open stable roots',
        },
        {
          eyebrow: 'extensions',
          title: 'x/* Family',
          body: 'Start capability work from the primary extension families instead of pushing it into stable roots.',
          href: '/docs/x-family',
          label: 'Open x/* family',
        },
        {
          eyebrow: 'compatibility',
          title: 'Release Posture',
          body: 'Read the support matrix before assuming a package already carries long-term compatibility.',
          href: '/docs/release-posture',
          label: 'Open release posture',
        },
        {
          eyebrow: 'direction',
          title: 'Roadmap',
          body: 'Check what the repository is hardening now, what comes next, and what stays out of scope.',
          href: '/roadmap',
          label: 'Open roadmap',
        },
        {
          eyebrow: 'releases',
          title: 'Releases',
          body: 'Inspect the current version, support groups, and README-synced release matrix.',
          href: '/releases',
          label: 'Open releases',
        },
      ];
---

<div class="portal-grid portal-grid--dense">
  {cards.map((card) => (
    <article class="fact-card">
      <p class="signal-list__kicker">{card.eyebrow}</p>
      <h3>{card.title}</h3>
      <p>{card.body}</p>
      <a class="text-link" href={card.href}>{card.label}</a>
    </article>
  ))}
</div>
