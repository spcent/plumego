---
import { MODULE_FACTS } from '../../generated/modules';

interface Props {
  locale?: 'en' | 'zh';
}

const { locale = 'en' } = Astro.props as Props;

const copy =
  locale === 'zh'
    ? {
        stableTitle: '稳定根',
        stableCaption: '从 `specs/repo.yaml` 同步',
        extensionTitle: '主扩展家族',
        extensionCaption: '从 `specs/task-routing.yaml` 同步',
        footnote: '这些列表由构建前同步脚本生成，而不是手工重复维护。',
      }
    : {
        stableTitle: 'Stable roots',
        stableCaption: 'Synced from `specs/repo.yaml`',
        extensionTitle: 'Primary extension families',
        extensionCaption: 'Synced from `specs/task-routing.yaml`',
        footnote: 'These lists are generated by the prebuild sync scripts instead of being hand-maintained twice.',
      };
---

<div class="fact-grid">
  <article class="fact-card">
    <p class="fact-card__eyebrow">{copy.stableCaption}</p>
    <h3>{copy.stableTitle}</h3>
    <p class="fact-card__count">{MODULE_FACTS.stableRoots.length}</p>
    <ul>
      {MODULE_FACTS.stableRoots.map((item) => <li><code>{item}</code></li>)}
    </ul>
  </article>

  <article class="fact-card">
    <p class="fact-card__eyebrow">{copy.extensionCaption}</p>
    <h3>{copy.extensionTitle}</h3>
    <p class="fact-card__count">{MODULE_FACTS.primaryExtensionFamilies.length}</p>
    <ul>
      {MODULE_FACTS.primaryExtensionFamilies.map((item) => <li><code>{item}</code></li>)}
    </ul>
  </article>
</div>

<p class="fact-footnote">{copy.footnote}</p>
