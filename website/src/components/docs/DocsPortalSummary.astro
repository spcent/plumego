---
import { MODULE_FACTS } from '../../generated/modules';
import { RELEASE_FACTS } from '../../generated/releases';
import { ROADMAP_FACTS } from '../../generated/roadmap';

interface Props {
  locale?: 'en' | 'zh';
}

const { locale = 'en' } = Astro.props as Props;

const copy =
  locale === 'zh'
    ? {
        moduleEyebrow: '模块事实',
        moduleTitle: '模块与边界',
        moduleBody: '默认学习路径从稳定根开始，能力工作从主扩展家族开始。',
        modulePrimary: '稳定根',
        moduleSecondary: '主扩展家族',
        moduleLink: '/zh/docs/modules/overview',
        moduleLinkLabel: '查看模块总览',
        releaseEyebrow: '发布事实',
        releaseTitle: '发布姿态',
        releaseBody: '在假设长期兼容性之前，先看 README 同步过来的支持矩阵。',
        releasePrimary: '当前版本',
        releaseSecondary: '支持分组',
        releaseLink: '/zh/docs/release-posture',
        releaseLinkLabel: '查看发布姿态',
        roadmapEyebrow: '路线图事实',
        roadmapTitle: '当前方向',
        roadmapBody: '路线图摘要会在构建前从 docs/ROADMAP.md 自动同步。',
        roadmapPrimary: '进行中',
        roadmapSecondary: '计划中',
        roadmapLink: '/zh/roadmap',
        roadmapLinkLabel: '查看路线图',
        source: '这些摘要全部来自构建前同步的仓库事实，而不是站点专属副本。',
      }
    : {
        moduleEyebrow: 'module facts',
        moduleTitle: 'Modules and boundaries',
        moduleBody: 'The default learning path starts with stable roots. Capability work starts from the primary extension families.',
        modulePrimary: 'Stable roots',
        moduleSecondary: 'Primary extension families',
        moduleLink: '/docs/modules/overview',
        moduleLinkLabel: 'Open modules overview',
        releaseEyebrow: 'release facts',
        releaseTitle: 'Release posture',
        releaseBody: 'Read the support matrix synced from README before assuming long-term compatibility.',
        releasePrimary: 'Current version',
        releaseSecondary: 'Support groups',
        releaseLink: '/docs/release-posture',
        releaseLinkLabel: 'Open release posture',
        roadmapEyebrow: 'roadmap facts',
        roadmapTitle: 'Current direction',
        roadmapBody: 'The roadmap summary is synced from docs/ROADMAP.md before each build.',
        roadmapPrimary: 'In progress',
        roadmapSecondary: 'Planned',
        roadmapLink: '/roadmap',
        roadmapLinkLabel: 'Open roadmap',
        source: 'These summaries all come from prebuild-synced repository facts instead of a website-only copy.',
      };
---

<div class="portal-grid">
  <article class="fact-card">
    <p class="signal-list__kicker">{copy.moduleEyebrow}</p>
    <h3>{copy.moduleTitle}</h3>
    <p>{copy.moduleBody}</p>
    <div class="portal-stats">
      <div>
        <p class="fact-card__eyebrow">{copy.modulePrimary}</p>
        <p class="fact-card__count">{MODULE_FACTS.stableRoots.length}</p>
      </div>
      <div>
        <p class="fact-card__eyebrow">{copy.moduleSecondary}</p>
        <p class="fact-card__count">{MODULE_FACTS.primaryExtensionFamilies.length}</p>
      </div>
    </div>
    <a class="text-link" href={copy.moduleLink}>{copy.moduleLinkLabel}</a>
  </article>

  <article class="fact-card">
    <p class="signal-list__kicker">{copy.releaseEyebrow}</p>
    <h3>{copy.releaseTitle}</h3>
    <p>{copy.releaseBody}</p>
    <div class="portal-stats">
      <div>
        <p class="fact-card__eyebrow">{copy.releasePrimary}</p>
        <p class="fact-card__count">{RELEASE_FACTS.currentVersion}</p>
      </div>
      <div>
        <p class="fact-card__eyebrow">{copy.releaseSecondary}</p>
        <p class="fact-card__count">{RELEASE_FACTS.supportMatrix.length}</p>
      </div>
    </div>
    <a class="text-link" href={copy.releaseLink}>{copy.releaseLinkLabel}</a>
  </article>

  <article class="fact-card">
    <p class="signal-list__kicker">{copy.roadmapEyebrow}</p>
    <h3>{copy.roadmapTitle}</h3>
    <p>{copy.roadmapBody}</p>
    <div class="portal-stats">
      <div>
        <p class="fact-card__eyebrow">{copy.roadmapPrimary}</p>
        <p class="fact-card__count">{ROADMAP_FACTS.inProgress.length}</p>
      </div>
      <div>
        <p class="fact-card__eyebrow">{copy.roadmapSecondary}</p>
        <p class="fact-card__count">{ROADMAP_FACTS.planned.length}</p>
      </div>
    </div>
    <a class="text-link" href={copy.roadmapLink}>{copy.roadmapLinkLabel}</a>
  </article>
</div>

<p class="fact-footnote">{copy.source}</p>
