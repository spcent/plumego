---
interface Props {
  locale?: 'en' | 'zh';
}

const { locale = 'en' } = Astro.props as Props;

const steps =
  locale === 'zh'
    ? [
        {
          eyebrow: '第 1 步',
          title: '确认适配后，从文档首页进入',
          body: '如果你刚从“为什么选择 Plumego”过来，就先把文档首页当作实现交接页，再从“开始使用”和“参考应用”开始落地。',
          href: '/zh/docs',
          label: '打开文档首页',
        },
        {
          eyebrow: '第 2 步',
          title: '再跑通开始使用',
          body: '先确认最小参考路径可运行，再进入更细的模块边界和扩展家族。',
          href: '/zh/docs/getting-started',
          label: '打开开始使用',
        },
        {
          eyebrow: '第 3 步',
          title: '先建立请求流程心智模型',
          body: '先搞清楚一个 HTTP 请求如何从显式路由注册流到 handler，再继续读应用结构。',
          href: '/zh/docs/concepts/request-flow',
          label: '打开请求流程',
        },
        {
          eyebrow: '第 4 步',
          title: '顺着参考应用往下读',
          body: '从 bootstrap、app wiring 和 route 注册开始理解 canonical 应用路径。',
          href: '/zh/docs/reference-app',
          label: '打开参考应用',
        },
        {
          eyebrow: '第 5 步',
          title: '再理解仓库边界',
          body: '读清楚 docs、specs 和 tasks 分别承担什么角色，再去判断边界和工作入口。',
          href: '/zh/docs/concepts/repo-control-plane',
          label: '打开仓库边界',
        },
        {
          eyebrow: '第 6 步',
          title: '最后再判断模块与发布姿态',
          body: '在决定改动归属和兼容性假设前，再看模块总览与发布姿态。',
          href: '/zh/docs/modules/overview',
          label: '打开模块总览',
        },
      ]
    : [
        {
          eyebrow: 'step 1',
          title: 'If fit is clear, begin at docs home',
          body: 'Treat docs home as the implementation handoff if you just came from Why Plumego, then continue into Getting Started and the Reference App.',
          href: '/docs',
          label: 'Open docs home',
        },
        {
          eyebrow: 'step 2',
          title: 'Start with Getting Started',
          body: 'Confirm the smallest reference path works before moving deeper into boundaries and extension families.',
          href: '/docs/getting-started',
          label: 'Open getting started',
        },
        {
          eyebrow: 'step 3',
          title: 'Build the request-flow model',
          body: 'Understand how an HTTP request moves from explicit route registration into a handler before reading deeper app structure.',
          href: '/docs/concepts/request-flow',
          label: 'Open request flow',
        },
        {
          eyebrow: 'step 4',
          title: 'Follow the Reference App',
          body: 'Read the canonical application path from bootstrap to app wiring to route registration.',
          href: '/docs/reference-app',
          label: 'Open reference app',
        },
        {
          eyebrow: 'step 5',
          title: 'Then read repository boundaries',
          body: 'Learn how docs, specs, and tasks work together before you classify work across boundaries.',
          href: '/docs/concepts/repo-control-plane',
          label: 'Open repository boundaries',
        },
        {
          eyebrow: 'step 6',
          title: 'Finish with boundaries and release posture',
          body: 'Use modules overview and release posture before assuming work belongs in a specific package or carries long-term compatibility.',
          href: '/docs/modules/overview',
          label: 'Open modules overview',
        },
      ];
---

<div class="portal-grid">
  {steps.map((step) => (
    <article class="fact-card">
      <p class="signal-list__kicker">{step.eyebrow}</p>
      <h3>{step.title}</h3>
      <p>{step.body}</p>
      <a class="text-link" href={step.href}>{step.label}</a>
    </article>
  ))}
</div>
