---
import { localeFromPath } from '../../lib/i18n';

const locale = localeFromPath(Astro.url.pathname);

const copy = {
  en: {
    label: 'Theme',
    light: 'Light',
    dark: 'Dark',
  },
  zh: {
    label: '主题',
    light: '浅色',
    dark: '深色',
  },
}[locale];
---

<div class="theme-switch" role="group" aria-label={copy.label}>
  <button class="theme-switch__option" type="button" data-theme-choice="light" aria-pressed="false">
    {copy.light}
  </button>
  <button class="theme-switch__option" type="button" data-theme-choice="dark" aria-pressed="false">
    {copy.dark}
  </button>
</div>

<script>
  type Theme = 'dark' | 'light';

  const storageKey = 'starlight-theme';

  const resolveTheme = (): Theme => {
    const stored = localStorage.getItem(storageKey);
    if (stored === 'light' || stored === 'dark') return stored;
    return matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
  };

  const syncButtons = () => {
    const theme = resolveTheme();
    document.documentElement.dataset.theme = theme;

    document.querySelectorAll('[data-theme-choice]').forEach((button) => {
      if (!(button instanceof HTMLButtonElement)) return;
      const active = button.dataset.themeChoice === theme;
      button.setAttribute('aria-pressed', String(active));
      button.dataset.active = active ? 'true' : 'false';
    });
  };

  const bindButtons = () => {
    document.querySelectorAll('[data-theme-choice]').forEach((button) => {
      if (!(button instanceof HTMLButtonElement) || button.dataset.bound === 'true') return;
      button.dataset.bound = 'true';
      button.addEventListener('click', () => {
        const next = button.dataset.themeChoice === 'dark' ? 'dark' : 'light';
        localStorage.setItem(storageKey, next);
        syncButtons();
      });
    });
  };

  matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
    if (!localStorage.getItem(storageKey)) syncButtons();
  });

  document.addEventListener('astro:page-load', () => {
    bindButtons();
    syncButtons();
  });

  bindButtons();
  syncButtons();
</script>
