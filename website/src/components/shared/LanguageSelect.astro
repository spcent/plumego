---
import { localeFromPath, toLocalePath } from '../../lib/i18n';

const currentPath = Astro.url.pathname;
const currentLocale = localeFromPath(currentPath);

const locales = [
  { code: 'en', label: 'English', shortLabel: 'EN', href: toLocalePath(currentPath, 'en') },
  { code: 'zh', label: '简体中文', shortLabel: '中文', href: toLocalePath(currentPath, 'zh') },
] as const;

const current = locales.find((item) => item.code === currentLocale) ?? locales[0];
const accessibleLabel = currentLocale === 'zh' ? '选择语言' : 'Select language';
---

<details class="language-menu" data-language-menu>
  <summary class="language-menu__trigger" aria-label={accessibleLabel}>
    <span class="language-menu__label">
      <svg class="language-menu__globe" viewBox="0 0 20 20" aria-hidden="true">
        <path d="M10 2.5a7.5 7.5 0 1 0 0 15 7.5 7.5 0 0 0 0-15Zm0 0c1.9 2 3 4.7 3 7.5s-1.1 5.5-3 7.5m0-15c-1.9 2-3 4.7-3 7.5s1.1 5.5 3 7.5m-7.2-5h14.4M2.8 7.2h14.4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.5" />
      </svg>
      <span>{current.shortLabel}</span>
    </span>
    <svg class="language-menu__caret" viewBox="0 0 20 20" aria-hidden="true">
      <path d="m5 7.5 5 5 5-5" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
    </svg>
  </summary>
  <div class="language-menu__panel" role="menu">
    {locales.map((item) => (
      <a
        href={item.href}
        class:list={['language-menu__item', item.code === currentLocale && 'is-active']}
        aria-current={item.code === currentLocale ? 'true' : undefined}
        lang={item.code === 'zh' ? 'zh-CN' : 'en'}
        role="menuitem"
      >
        <span>{item.label}</span>
        {item.code === currentLocale && (
          <svg class="language-menu__check" viewBox="0 0 20 20" aria-hidden="true">
            <path d="m4.5 10.5 3.2 3.2 7.8-7.8" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.9" />
          </svg>
        )}
      </a>
    ))}
  </div>
</details>

<script>
  const bindLanguageMenus = () => {
    document.querySelectorAll('[data-language-menu]').forEach((node) => {
      if (!(node instanceof HTMLDetailsElement) || node.dataset.bound === 'true') return;
      node.dataset.bound = 'true';

      document.addEventListener('click', (event) => {
        if (!node.open) return;
        if (node.contains(event.target as Node)) return;
        node.open = false;
      });

      node.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          node.open = false;
          node.querySelector('summary')?.focus();
        }
      });
    });
  };

  document.addEventListener('astro:page-load', bindLanguageMenus);
  bindLanguageMenus();
</script>
