---
import type { Locale } from '../../lib/locales';

interface LinkItem {
  label: string;
  href: string;
}

type HeroVisual = 'decision' | 'architecture' | 'examples' | 'releases' | 'roadmap' | 'fit' | 'migration' | 'extensions';

interface Props {
  eyebrow: string;
  title: string;
  description: string;
  links?: LinkItem[];
  locale?: Locale;
  visual?: HeroVisual;
}

const { eyebrow, title, description, links = [], locale = 'en', visual } = Astro.props as Props;

const visualCopy = {
  en: {
    decision: {
      label: 'fit model',
      title: 'Adopt when structure should stay visible',
      primary: 'reviewable wiring',
      secondary: 'shared baseline',
      tertiary: 'maturity signal',
      footer: 'Use fit first, then open architecture, examples, or releases.',
    },
    architecture: {
      label: 'repo map',
      title: 'One kernel, one path, outward capability families',
      primary: 'stable roots',
      secondary: 'canonical path',
      tertiary: 'x/* families',
      footer: 'Keep transport and lifecycle narrow before expanding capability work.',
    },
    examples: {
      label: 'reading path',
      title: 'Start from the reference service, then use recipes',
      primary: 'reference/standard-service',
      secondary: 'request flow',
      tertiary: 'module fit',
      footer: 'Examples answer concrete adoption questions, not parallel demos.',
    },
    releases: {
      label: 'release posture',
      title: 'Read maturity before widening adoption',
      primary: 'stable-root candidates',
      secondary: 'supported reference',
      tertiary: 'experimental families',
      footer: 'Compatibility promises should be explicit before production use.',
    },
    roadmap: {
      label: 'direction map',
      title: 'Baseline first. In progress. Planned scope.',
      primary: 'current baseline',
      secondary: 'in progress',
      tertiary: 'planned & non-goals',
      footer: 'Roadmap shows sequencing priority, not compatibility promises.',
    },
    fit: {
      label: 'adoption fit',
      title: 'Match service shape before committing to tech.',
      primary: 'reviewable wiring',
      secondary: 'canonical shape',
      tertiary: 'maturity evidence',
      footer: 'Fit precedes architecture. Evaluate shape, not features.',
    },
    migration: {
      label: 'migration path',
      title: 'Converge on one stdlib handler shape, keep cost visible.',
      primary: 'gin.Context',
      secondary: 'echo.Context',
      tertiary: 'chi -> func(w, r)',
      footer: 'Choose the source framework first, then measure rewrite cost against the stable path.',
    },
    extensions: {
      label: 'capability map',
      title: 'Keep the kernel narrow. Add capability in explicit families.',
      primary: 'stable roots',
      secondary: 'beta families',
      tertiary: 'experimental families',
      footer: 'Adopt from the outside in: stable kernel first, then the x/* family that matches the product need.',
    },
  },
  zh: {
    decision: {
      label: '适配模型',
      title: '当服务结构需要持续可见时再采用',
      primary: '可评审的 wiring',
      secondary: '共享服务基线',
      tertiary: '成熟度信号',
      footer: '先判断适配，再进入架构、示例或发布页。',
    },
    architecture: {
      label: '仓库地图',
      title: '一个内核、一条默认路径、向外分层的能力家族',
      primary: '稳定根',
      secondary: 'canonical path',
      tertiary: 'x/* 家族',
      footer: '先保护 transport 与 lifecycle，再让能力向外扩展。',
    },
    examples: {
      label: '阅读路径',
      title: '先看参考服务，再进入聚焦 recipe',
      primary: 'reference/standard-service',
      secondary: '请求路径',
      tertiary: '模块归属',
      footer: '示例回答具体采用问题，而不是堆并行 demo。',
    },
    releases: {
      label: '发布姿态',
      title: '扩大采用范围前先读成熟度',
      primary: '稳定根候选',
      secondary: '受支持参考路径',
      tertiary: '实验性家族',
      footer: '进入生产前，兼容性承诺必须是显式的。',
    },
    roadmap: {
      label: '方向地图',
      title: '先补强基线，再推进计划方向。',
      primary: '当前基线',
      secondary: '进行中',
      tertiary: '计划 & 非目标',
      footer: '路线图表达优先顺序，不是兼容性承诺。',
    },
    fit: {
      label: '适配判断',
      title: '先判断服务形态，再深入技术细节。',
      primary: '可评审的 wiring',
      secondary: 'canonical 形态',
      tertiary: '成熟度证据',
      footer: '先判断适配，再看架构。从形态开始，不是功能。',
    },
    migration: {
      label: '迁移路径',
      title: '收束到同一套 stdlib handler 形态，同时看清迁移成本。',
      primary: 'gin.Context',
      secondary: 'echo.Context',
      tertiary: 'chi -> func(w, r)',
      footer: '先确认来源框架，再对照稳定路径评估改写成本。',
    },
    extensions: {
      label: '能力地图',
      title: '保持内核收敛，把能力放进显式的家族边界里。',
      primary: '稳定根',
      secondary: 'beta 家族',
      tertiary: '实验性家族',
      footer: '采用顺序从内到外：先稳定内核，再接入匹配产品需求的 x/* 家族。',
    },
  },
} as const;

const selectedVisual = visual ? visualCopy[locale][visual] : undefined;
const useSvgVisual = visual === 'roadmap' || visual === 'fit' || visual === 'migration' || visual === 'extensions';
---

<section class={`page-hero ${selectedVisual ? 'page-hero--with-visual' : ''}`}>
  <div class="page-hero__copy">
    <p class="hero__eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p>{description}</p>
    {links.length > 0 && (
      <div class="page-hero__links">
        {links.map((item) => (
          <a class="text-link" href={item.href}>{item.label}</a>
        ))}
      </div>
    )}
  </div>

  {selectedVisual && (
    <div class={`page-hero-visual page-hero-visual--${visual}`} aria-hidden="true">
      <div class="page-hero-visual__header">
        <span>{selectedVisual.label}</span>
        <i></i>
      </div>
      <h2>{selectedVisual.title}</h2>

      {useSvgVisual ? (
        <div class="page-hero-visual__illustration">
          {visual === 'roadmap' && (
            <svg class="phv-svg" viewBox="0 0 260 88" fill="none" xmlns="http://www.w3.org/2000/svg">
              {/* timeline track */}
              <line x1="44" y1="30" x2="216" y2="30" stroke="currentColor" stroke-width="1" opacity="0.2"/>
              {/* baseline — solid filled (done) */}
              <circle cx="44" cy="30" r="11" fill="currentColor" opacity="0.1"/>
              <circle cx="44" cy="30" r="6" fill="currentColor" opacity="0.75"/>
              {/* in progress — ring with center dot (active) */}
              <circle cx="130" cy="30" r="11" stroke="currentColor" stroke-width="1.5" fill="currentColor" fill-opacity="0.07"/>
              <circle cx="130" cy="30" r="4" fill="currentColor" opacity="0.8"/>
              {/* planned — dashed ring (future) */}
              <circle cx="216" cy="30" r="11" stroke="currentColor" stroke-width="1.25" stroke-dasharray="3.5 2.5" opacity="0.32"/>
              {/* phase labels */}
              <text x="44" y="53" text-anchor="middle" font-size="9" font-family="monospace" opacity="0.55">baseline</text>
              <text x="130" y="53" text-anchor="middle" font-size="9" font-family="monospace" opacity="0.9">in progress</text>
              <text x="216" y="53" text-anchor="middle" font-size="9" font-family="monospace" opacity="0.38">planned</text>
              {/* non-goals boundary */}
              <line x1="14" y1="70" x2="246" y2="70" stroke="currentColor" stroke-width="0.75" stroke-dasharray="6 4" opacity="0.18"/>
              <text x="130" y="82" text-anchor="middle" font-size="7.5" font-family="monospace" opacity="0.28">— non-goals boundary —</text>
            </svg>
          )}
          {visual === 'fit' && (
            <svg class="phv-svg" viewBox="0 0 260 88" fill="none" xmlns="http://www.w3.org/2000/svg">
              {/* row 1 — checked */}
              <rect x="12" y="10" width="14" height="14" rx="2.5" fill="currentColor" opacity="0.82"/>
              <path d="M15 17l3 3 5.5-5.5" stroke="var(--bg-elevated)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
              <line x1="34" y1="17" x2="160" y2="17" stroke="currentColor" stroke-width="0.75" opacity="0.22"/>
              <text x="166" y="21" font-size="9" font-family="monospace" opacity="0.72">reviewable wiring</text>
              {/* row 2 — checked */}
              <rect x="12" y="34" width="14" height="14" rx="2.5" fill="currentColor" opacity="0.82"/>
              <path d="M15 41l3 3 5.5-5.5" stroke="var(--bg-elevated)" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
              <line x1="34" y1="41" x2="148" y2="41" stroke="currentColor" stroke-width="0.75" opacity="0.22"/>
              <text x="154" y="45" font-size="9" font-family="monospace" opacity="0.72">canonical shape</text>
              {/* row 3 — open (to evaluate) */}
              <rect x="12" y="58" width="14" height="14" rx="2.5" stroke="currentColor" stroke-width="1.25" opacity="0.38"/>
              <line x1="34" y1="65" x2="143" y2="65" stroke="currentColor" stroke-width="0.75" opacity="0.15"/>
              <text x="149" y="69" font-size="9" font-family="monospace" opacity="0.35">maturity evidence</text>
              {/* decision trail */}
              <line x1="12" y1="82" x2="108" y2="82" stroke="currentColor" stroke-width="0.75" opacity="0.3"/>
              <polygon points="108,78.5 115,82 108,85.5" fill="currentColor" opacity="0.3"/>
              <text x="119" y="85.5" font-size="8" font-family="monospace" opacity="0.45">evaluate fit</text>
            </svg>
          )}
          {visual === 'migration' && (
            <svg class="phv-svg" viewBox="0 0 260 88" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="10" y="12" width="58" height="18" rx="9" fill="currentColor" opacity="0.1"/>
              <text x="39" y="23.5" text-anchor="middle" font-size="8.5" font-family="monospace" opacity="0.82">gin.Context</text>
              <rect x="10" y="36" width="58" height="18" rx="9" fill="currentColor" opacity="0.08"/>
              <text x="39" y="47.5" text-anchor="middle" font-size="8.5" font-family="monospace" opacity="0.78">echo.Context</text>
              <rect x="10" y="60" width="58" height="18" rx="9" stroke="currentColor" stroke-width="1.1" stroke-dasharray="3 2" opacity="0.28"/>
              <text x="39" y="71.5" text-anchor="middle" font-size="8.5" font-family="monospace" opacity="0.42">chi</text>

              <path d="M68 21h22c10 0 15 8 22 16s12 16 22 16h22" stroke="currentColor" stroke-width="1.2" opacity="0.28" stroke-linecap="round"/>
              <path d="M68 45h22c10 0 15 0 22 0s12 0 22 0h22" stroke="currentColor" stroke-width="1.2" opacity="0.22" stroke-linecap="round"/>
              <path d="M68 69h22c10 0 15-8 22-16s12-16 22-16h22" stroke="currentColor" stroke-width="1.2" opacity="0.2" stroke-linecap="round"/>

              <rect x="178" y="27" width="70" height="36" rx="12" fill="currentColor" opacity="0.08" stroke="currentColor" stroke-width="1.1" stroke-opacity="0.22"/>
              <text x="213" y="42" text-anchor="middle" font-size="9" font-family="monospace" opacity="0.56">stable path</text>
              <text x="213" y="55" text-anchor="middle" font-size="9" font-family="monospace" opacity="0.88">func(w, r)</text>

              <circle cx="162" cy="45" r="4.5" fill="currentColor" opacity="0.72"/>
              <circle cx="162" cy="45" r="11" stroke="currentColor" stroke-width="1.1" opacity="0.16"/>
              <path d="M166.5 45h8" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" opacity="0.48"/>
            </svg>
          )}
          {visual === 'extensions' && (
            <svg class="phv-svg" viewBox="0 0 260 88" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="16" y="30" width="56" height="28" rx="10" fill="currentColor" opacity="0.1" stroke="currentColor" stroke-width="1.1" stroke-opacity="0.22"/>
              <text x="44" y="41.5" text-anchor="middle" font-size="7.5" font-family="monospace" opacity="0.55">kernel</text>
              <text x="44" y="51.5" text-anchor="middle" font-size="9" font-family="monospace" opacity="0.88">stable roots</text>

              <path d="M72 44h26c10 0 14-10 22-16s11-10 20-10h20" stroke="currentColor" stroke-width="1.2" opacity="0.28" stroke-linecap="round"/>
              <path d="M72 44h32c10 0 14 0 22 0s11 0 20 0h14" stroke="currentColor" stroke-width="1.2" opacity="0.22" stroke-linecap="round"/>
              <path d="M72 44h26c10 0 14 10 22 16s11 10 20 10h20" stroke="currentColor" stroke-width="1.2" opacity="0.18" stroke-linecap="round"/>

              <rect x="180" y="10" width="58" height="18" rx="9" fill="currentColor" opacity="0.1"/>
              <text x="209" y="21.5" text-anchor="middle" font-size="8.5" font-family="monospace" opacity="0.82">x/rest</text>
              <rect x="180" y="35" width="58" height="18" rx="9" fill="currentColor" opacity="0.08"/>
              <text x="209" y="46.5" text-anchor="middle" font-size="8.5" font-family="monospace" opacity="0.74">x/tenant</text>
              <rect x="180" y="60" width="58" height="18" rx="9" stroke="currentColor" stroke-width="1.1" stroke-dasharray="3 2" opacity="0.28"/>
              <text x="209" y="71.5" text-anchor="middle" font-size="8.5" font-family="monospace" opacity="0.42">x/ai</text>

              <circle cx="165" cy="19" r="2.8" fill="currentColor" opacity="0.72"/>
              <circle cx="165" cy="44" r="2.8" fill="currentColor" opacity="0.54"/>
              <circle cx="165" cy="69" r="2.8" fill="currentColor" opacity="0.28"/>
            </svg>
          )}
        </div>
      ) : (
        <div class="page-hero-visual__map">
          <span class="page-hero-visual__node page-hero-visual__node--primary">{selectedVisual.primary}</span>
          <span class="page-hero-visual__line"></span>
          <span class="page-hero-visual__node">{selectedVisual.secondary}</span>
          <span class="page-hero-visual__line"></span>
          <span class="page-hero-visual__node page-hero-visual__node--muted">{selectedVisual.tertiary}</span>
        </div>
      )}

      <p>{selectedVisual.footer}</p>
      <div class="page-hero-visual__scan">
        <span></span>
        <span></span>
        <span></span>
      </div>
    </div>
  )}
</section>
