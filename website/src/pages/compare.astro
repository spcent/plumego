---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import PageHero from '../components/marketing/PageHero.astro';
import JourneyBar from '../components/marketing/JourneyBar.astro';
import CheckIcon from '../components/shared/CheckIcon.astro';
import CautionIcon from '../components/shared/CautionIcon.astro';

// ── Framework data ──────────────────────────────────────────────────────────

interface Framework {
  id: string;
  name: string;
  url: string;
  tagline: string;
  handlerSig: string;
  stdlibHandler: boolean;
  zeroDeps: boolean;
  responseContract: boolean;
  canonicalShape: boolean;
  middlewareStdlib: boolean;
  agentReady: boolean;
  stabilityModel: boolean;
  stars: string;
  verdict: string;
  whenToChoose: string[];
  whenNotToChoose: string[];
  migrationCost: 'low' | 'medium' | 'high' | 'n/a';
  migrationNote: string;
  color: string;
  isPlumego?: boolean;
  warning?: string;
}

const frameworks: Framework[] = [
  {
    id: 'gin',
    name: 'Gin',
    url: 'https://github.com/gin-gonic/gin',
    tagline: 'Martini-like web framework, radix tree router',
    handlerSig: 'func(c *gin.Context)',
    stdlibHandler: false,
    zeroDeps: false,
    responseContract: false,
    canonicalShape: false,
    middlewareStdlib: false,
    agentReady: false,
    stabilityModel: false,
    stars: '~80k',
    verdict: 'Best-in-class speed for teams happy with a custom context type. Large ecosystem. The go-to default for many Go teams.',
    whenToChoose: [
      'Your team wants the fastest possible time-to-working-API',
      'You need a large plugin ecosystem for auth, rate limiting, etc.',
      'The team is comfortable with gin.Context and its trade-offs',
      'Existing Gin code makes the switching cost too high',
    ],
    whenNotToChoose: [
      'You need plain func(w, r) handlers so existing stdlib middleware works without adapters',
      'You want route ownership and middleware order visible in code review without reading framework internals',
      'You want a structured, consistent error and response envelope across all handlers',
    ],
    migrationCost: 'medium',
    migrationNote: 'All handlers must be rewritten from gin.Context to func(w, r). Middleware must be adapted or replaced. Route syntax maps cleanly (/foo/:id stays the same). Expect 1–3 days per service depending on handler count.',
    color: '#00b4d8',
  },
  {
    id: 'echo',
    name: 'Echo',
    url: 'https://github.com/labstack/echo',
    tagline: 'High performance, minimalist web framework',
    handlerSig: 'func(c echo.Context) error',
    stdlibHandler: false,
    zeroDeps: false,
    responseContract: false,
    canonicalShape: false,
    middlewareStdlib: false,
    agentReady: false,
    stabilityModel: false,
    stars: '~30k',
    verdict: 'Clean API, good middleware ecosystem, error return in handler is ergonomic. Solid choice when the custom context trade-off is acceptable.',
    whenToChoose: [
      'You prefer returning errors from handlers rather than writing to w directly',
      'You want a clean, well-documented framework with good middleware support',
      'The team appreciates the grouped routing and binder/validator conveniences',
    ],
    whenNotToChoose: [
      'You need plain net/http compatibility — echo.Context breaks middleware reuse',
      'You need a consistent JSON envelope; Echo leaves response formatting to you',
      'You want one canonical service shape across multiple teams',
    ],
    migrationCost: 'medium',
    migrationNote: 'Handler rewrite from echo.Context + error return to func(w, r). Grouped routing concepts map cleanly. Middleware adapters needed. Expect similar effort to Gin migration — roughly 1–3 days per service.',
    color: '#6c63ff',
  },
  {
    id: 'fiber',
    name: 'Fiber',
    url: 'https://github.com/gofiber/fiber',
    tagline: 'Express-inspired, Fasthttp-based web framework',
    handlerSig: 'func(c *fiber.Ctx) error',
    stdlibHandler: false,
    zeroDeps: false,
    responseContract: false,
    canonicalShape: false,
    middlewareStdlib: false,
    agentReady: false,
    stabilityModel: false,
    stars: '~34k',
    verdict: 'Highest raw throughput by benchmark. The tradeoff is total incompatibility with net/http — no stdlib middleware, no net/http handler, no standard library ecosystem.',
    whenToChoose: [
      'Raw HTTP throughput is the primary constraint and you have benchmarks proving it matters',
      'You are building a greenfield service with no existing net/http middleware to integrate',
      'The team has Fasthttp experience and understands the net/http incompatibility trade-off',
    ],
    whenNotToChoose: [
      'You have any net/http middleware, handlers, or tooling — none of it will work',
      'You use net/http-based observability, tracing, or auth libraries',
      'Your team is Go-stdlib-first and expects standard library compatibility',
    ],
    migrationCost: 'high',
    migrationNote: 'Full rewrite required. Fasthttp and net/http are fundamentally incompatible — no handler reuse, no middleware reuse, no testing infrastructure reuse. Observability, auth, and tracing libraries all need replacing. Expect weeks, not days.',
    color: '#00d4aa',
    warning: 'Fiber uses Fasthttp, not net/http. It is incompatible with the Go standard library HTTP ecosystem.',
  },
  {
    id: 'chi',
    name: 'Chi',
    url: 'https://github.com/go-chi/chi',
    tagline: 'Lightweight, idiomatic router for Go HTTP services',
    handlerSig: 'func(w http.ResponseWriter, r *http.Request)',
    stdlibHandler: true,
    zeroDeps: true,
    responseContract: false,
    canonicalShape: false,
    middlewareStdlib: true,
    agentReady: false,
    stabilityModel: false,
    stars: '~18k',
    verdict: "The minimalist's choice. Pure stdlib, zero opinions on response format, service shape, or module stability. If you want to build everything yourself, Chi is the right starting point.",
    whenToChoose: [
      'You only need routing — you are happy assembling your own response envelope, middleware, and security layer',
      'You want pure stdlib compatibility with no framework opinions on service structure',
      'The team prefers maximum flexibility and is willing to build and maintain the surrounding layer',
    ],
    whenNotToChoose: [
      'You want a consistent response envelope across handlers without implementing it yourself',
      'You need a canonical service shape to onboard new team members quickly',
      'You want explicit maturity signals per module rather than all-or-nothing routing',
    ],
    migrationCost: 'low',
    migrationNote: 'Handler signature is identical (stdlib func(w, r)). Route syntax differs slightly: Chi uses /foo/{id} while Plumego uses /foo/:id. Middleware is fully compatible. Most services migrate in hours, not days.',
    color: '#f59e0b',
  },
  {
    id: 'plumego',
    name: 'Plumego',
    url: 'https://github.com/spcent/plumego',
    tagline: 'Explicit HTTP toolkit — stdlib-only, machine-readable specs, v1.0.0',
    handlerSig: 'func(w http.ResponseWriter, r *http.Request)',
    stdlibHandler: true,
    zeroDeps: true,
    responseContract: true,
    canonicalShape: true,
    middlewareStdlib: true,
    agentReady: true,
    stabilityModel: true,
    stars: 'v1.0.0',
    verdict: 'For teams where route ownership, review clarity, and a shared service shape matter more than framework convenience. The only choice if your team uses AI coding tools and wants machine-readable ownership signals.',
    whenToChoose: [
      'Route registration, middleware order, and dependency wiring must be visible in code review',
      'Multiple services should start from one canonical shape rather than each team\'s custom bootstrap',
      'You use AI coding assistants and want machine-readable ownership rules: task-routing.yaml, change-recipes/, and module.yaml give agents a deterministic operating model',
      'You need clear separation between stable modules and experimental capability work',
    ],
    whenNotToChoose: [
      'You want a framework to hide structure decisions — Plumego keeps them explicit by design',
      'Your team already has a large Gin/Echo codebase and the migration cost outweighs the benefit',
      'You need a mature v1+ release with a proven multi-year track record',
      'Your service is a small script or short-lived tool where structure overhead isn\'t worth it',
    ],
    migrationCost: 'n/a',
    migrationNote: 'This is the destination, not the source.',
    isPlumego: true,
    color: 'var(--accent)',
  },
];

// ── Feature matrix rows ─────────────────────────────────────────────────────

const matrixRows = [
  {
    feature: 'stdlib handler signature',
    note: 'func(w http.ResponseWriter, r *http.Request)',
    values: { gin: false, echo: false, fiber: false, chi: true, plumego: true },
  },
  {
    feature: 'net/http middleware reuse',
    note: 'No adapter needed for existing stdlib middleware',
    values: { gin: false, echo: false, fiber: false, chi: true, plumego: true },
  },
  {
    feature: 'Zero external dependencies',
    note: 'Stable core uses only Go standard library',
    values: { gin: false, echo: false, fiber: false, chi: true, plumego: true },
  },
  {
    feature: 'Built-in response contract',
    note: 'Typed JSON envelope for success and error responses',
    values: { gin: false, echo: false, fiber: false, chi: false, plumego: true },
  },
  {
    feature: 'Canonical service shape',
    note: 'Reference app for bootstrap, routing, and handler layout',
    values: { gin: false, echo: false, fiber: false, chi: false, plumego: true },
  },
  {
    feature: 'Explicit module stability tiers',
    note: 'stable / beta / experimental labels with adoption guidance',
    values: { gin: false, echo: false, fiber: false, chi: false, plumego: true },
  },
  {
    feature: 'AI / agent-ready control plane',
    note: 'specs/task-routing.yaml classifies work before code is opened; specs/change-recipes/ defines ordered steps for 15 change types; module.yaml scopes each package; internal/checks/ enforces boundaries in CI',
    values: { gin: false, echo: false, fiber: false, chi: false, plumego: true },
  },
] as const;

type FwId = 'gin' | 'echo' | 'fiber' | 'chi' | 'plumego';
const fwIds: FwId[] = ['gin', 'echo', 'fiber', 'chi', 'plumego'];

// ── Benchmark data ──────────────────────────────────────────────────────────
// go test -bench -benchmem -count=3 · GET /users/:id · linux/amd64 · Intel Xeon @ 2.10 GHz
const routerRows = [
  { name: 'Plumego', nsOp: 4291, allocsOp: 16, bytesOp: 5715, relative: '1.0×', isPlumego: true },
  { name: 'Chi',     nsOp: 4547, allocsOp: 17, bytesOp: 6036, relative: '1.06×' },
  { name: 'Gin',     nsOp: 3773, allocsOp: 13, bytesOp: 5331, relative: '0.88×', isFaster: true },
  { name: 'Echo',    nsOp: 3743, allocsOp: 13, bytesOp: 5331, relative: '0.87×', isFaster: true },
];
const parallelRows = [
  { name: 'Plumego', nsOp: 663,  allocsOp: 7, bytesOp: 592, relative: '1.0×',  isPlumego: true },
  { name: 'Chi',     nsOp: 1013, allocsOp: 8, bytesOp: 912, relative: '1.53×' },
  { name: 'Gin',     nsOp: 285,  allocsOp: 4, bytesOp: 208, relative: '0.43×', isFaster: true },
  { name: 'Echo',    nsOp: 231,  allocsOp: 4, bytesOp: 208, relative: '0.35×', isFaster: true },
];

// ── stdlib baseline comparison ───────────────────────────────────────────────
// Measured against Go 1.22+ http.ServeMux with PathValue() parameter extraction.
// Overhead covers per-request context injection (480 B, 5 allocs), param map, middleware chain.
const stdlibRows = [
  { scenario: 'Static route',           stdlibNs: 110, plumegoNs: 367,   ratio: '3.3×' },
  { scenario: 'Single :param + read',   stdlibNs: 186, plumegoNs: 807,   ratio: '4.3×' },
  { scenario: 'Four :param deep path',  stdlibNs: 722, plumegoNs: 1036,  ratio: '1.4×' },
  { scenario: '70-route mixed table',   stdlibNs: 247, plumegoNs: 660,   ratio: '2.7×' },
];

const journeySteps = [
  { label: 'Why Plumego', href: '/why-plumego' },
  { label: 'Extensions', href: '/extensions' },
  { label: 'Examples', href: '/examples' },
  { label: 'Releases', href: '/releases' },
];
---

<MarketingLayout
  locale="en"
  title="Go HTTP Toolkits Compared: Gin, Echo, Fiber, Chi, Plumego"
  description="An honest technical comparison of the five most-used Go HTTP toolkits. Handler signatures, response contracts, stdlib compatibility, and when NOT to choose each one."
  currentPath="/compare"
  keywords={['go web framework comparison', 'gin vs echo', 'fiber vs chi', 'plumego vs gin', 'go http toolkit']}
>
  <PageHero
    eyebrow="Framework Comparison"
    title="Go HTTP Toolkits"
    description="Gin, Echo, Fiber, Chi, and Plumego — what each one trades away and what it gets in return. This page is a decision aid, not a benchmark race."
    visual="decision"
    links={[
      { label: 'Why Plumego', href: '/why-plumego' },
      { label: 'Status', href: '/status' },
      { label: 'Getting Started', href: '/docs/getting-started' },
    ]}
  />

  <JourneyBar steps={journeySteps} current="/compare" />

  <!-- 30-second verdict cards -->
  <section class="section">
    <div class="section__intro">
      <h2>The 30-second verdict.</h2>
      <p>
        All five toolkits are built for Go HTTP services. The differences are philosophy and scope, not
        raw performance at typical request volumes. Read the verdict row first, then follow the deep-dive
        that matches your team's actual constraint.
      </p>
    </div>

    <p class="matrix-note" style="margin-bottom:1.25rem">
      Star counts are approximate GitHub figures captured in May 2026 and will grow over time.
      They are a rough ecosystem-size signal, not a quality ranking.
    </p>
    <div class="verdict-grid">
      {frameworks.map((fw) => (
        <article class={`verdict-card ${fw.isPlumego ? 'verdict-card--highlight' : ''}`}>
          {fw.warning && (
            <div class="verdict-warning">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 2L14.5 13H1.5L8 2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                <path d="M8 6v4M8 11.5v.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
              {fw.warning}
            </div>
          )}
          <div class="verdict-card__header">
            <h3 class="verdict-card__name">{fw.name}</h3>
            <span class="verdict-card__stars">{fw.stars} ★</span>
          </div>
          <p class="verdict-card__tagline">{fw.tagline}</p>
          <p class="verdict-card__verdict">{fw.verdict}</p>
          <code class="verdict-card__sig">{fw.handlerSig}</code>
        </article>
      ))}
    </div>
  </section>

  <!-- Feature matrix -->
  <section class="section section--tinted">
    <div class="section__intro">
      <h2>Feature matrix.</h2>
      <p>
        Read across a row to compare one property across all five toolkits. The matrix does not capture
        ecosystem size, community, or raw performance — those depend on your benchmark. It captures
        structural trade-offs that don't change with load.
      </p>
    </div>

    <div class="matrix-wrap">
      <table class="matrix-table" role="table">
        <thead>
          <tr>
            <th class="matrix-table__feature-col">Property</th>
            {frameworks.map((fw) => (
              <th class={fw.isPlumego ? 'matrix-table__fw-col matrix-table__fw-col--highlight' : 'matrix-table__fw-col'}>
                {fw.name}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {matrixRows.map((row) => (
            <tr>
              <td class="matrix-table__feature">
                <strong>{row.feature}</strong>
                <span class="matrix-table__note">{row.note}</span>
              </td>
              {fwIds.map((id) => {
                const val = row.values[id];
                const isPlumego = id === 'plumego';
                return (
                  <td class={`matrix-table__cell ${isPlumego ? 'matrix-table__cell--highlight' : ''}`}>
                    {val ? (
                      <svg class="matrix-icon matrix-icon--yes" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-label="yes">
                        <circle cx="8" cy="8" r="7" fill="color-mix(in srgb, currentColor 12%, transparent)" stroke="currentColor" stroke-width="1.4"/>
                        <path d="M4.5 8l2.5 2.5L11.5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    ) : (
                      <svg class="matrix-icon matrix-icon--no" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-label="no">
                        <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.4" stroke-dasharray="3 2"/>
                        <path d="M10.5 5.5l-5 5M5.5 5.5l5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                      </svg>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="matrix-note">
      Fiber's net/http incompatibility is not a missing feature — it's a deliberate architectural choice that
      enables higher throughput. See the Fiber deep-dive for when this trade is worth making.
    </p>
  </section>

  <!-- Handler signature comparison — the most visible trade-off -->
  <section class="section">
    <div class="section__intro">
      <h2>The handler signature is the most consequential choice.</h2>
      <p>
        Custom context types (Gin, Echo, Fiber) break compatibility with the existing net/http middleware
        ecosystem. If you adopt one of these frameworks, every stdlib middleware needs an adapter. With
        Chi and Plumego, the entire net/http world works out of the box.
      </p>
    </div>

    <div class="code-compare-grid">
      <!-- Gin -->
      <div class="code-compare-item">
        <div class="code-compare-item__header">
          <span class="code-compare-item__fw">Gin</span>
          <span class="compat-badge compat-badge--no">custom context</span>
        </div>
        <div class="hero-code">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">handler.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// gin.Context — net/http middleware needs adapter</span>
r.<span class="hc-fn">GET</span>(<span class="hc-str">"/users/:id"</span>, <span class="hc-kw">func</span>(c *gin.Context) &#123;
    id := c.<span class="hc-fn">Param</span>(<span class="hc-str">"id"</span>)
    c.<span class="hc-fn">JSON</span>(http.StatusOK, gin.H&#123;<span class="hc-str">"id"</span>: id&#125;)
&#125;)

<span class="hc-cm">// to reuse net/http middleware:</span>
r.<span class="hc-fn">Use</span>(gin.<span class="hc-fn">WrapH</span>(myStdlibMiddleware))</code></pre>
        </div>
      </div>

      <!-- Echo -->
      <div class="code-compare-item">
        <div class="code-compare-item__header">
          <span class="code-compare-item__fw">Echo</span>
          <span class="compat-badge compat-badge--no">custom context</span>
        </div>
        <div class="hero-code">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">handler.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// echo.Context + error return</span>
e.<span class="hc-fn">GET</span>(<span class="hc-str">"/users/:id"</span>, <span class="hc-kw">func</span>(c echo.Context) error &#123;
    id := c.<span class="hc-fn">Param</span>(<span class="hc-str">"id"</span>)
    <span class="hc-kw">return</span> c.<span class="hc-fn">JSON</span>(http.StatusOK,
        map[string]any&#123;<span class="hc-str">"id"</span>: id&#125;)
&#125;)</code></pre>
        </div>
      </div>

      <!-- Fiber -->
      <div class="code-compare-item">
        <div class="code-compare-item__header">
          <span class="code-compare-item__fw">Fiber</span>
          <span class="compat-badge compat-badge--warn">fasthttp — not net/http</span>
        </div>
        <div class="hero-code">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">handler.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// fasthttp — incompatible with net/http entirely</span>
<span class="hc-cm">// zero net/http middleware can be reused</span>
app.<span class="hc-fn">Get</span>(<span class="hc-str">"/users/:id"</span>, <span class="hc-kw">func</span>(c *fiber.Ctx) error &#123;
    id := c.<span class="hc-fn">Params</span>(<span class="hc-str">"id"</span>)
    <span class="hc-kw">return</span> c.<span class="hc-fn">JSON</span>(fiber.Map&#123;<span class="hc-str">"id"</span>: id&#125;)
&#125;)</code></pre>
        </div>
      </div>

      <!-- Chi -->
      <div class="code-compare-item">
        <div class="code-compare-item__header">
          <span class="code-compare-item__fw">Chi</span>
          <span class="compat-badge compat-badge--yes">stdlib handler</span>
        </div>
        <div class="hero-code">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">handler.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// pure stdlib — but no response contract</span>
r.<span class="hc-fn">Get</span>(<span class="hc-str">"/users/&#123;id&#125;"</span>, <span class="hc-kw">func</span>(w http.ResponseWriter, r *http.Request) &#123;
    id := chi.<span class="hc-fn">URLParam</span>(r, <span class="hc-str">"id"</span>)
    <span class="hc-cm">// build your own JSON response every time</span>
    json.<span class="hc-fn">NewEncoder</span>(w).<span class="hc-fn">Encode</span>(map[string]any&#123;<span class="hc-str">"id"</span>: id&#125;)
&#125;)</code></pre>
        </div>
      </div>

      <!-- Plumego -->
      <div class="code-compare-item code-compare-item--highlight">
        <div class="code-compare-item__header">
          <span class="code-compare-item__fw">Plumego</span>
          <span class="compat-badge compat-badge--yes">stdlib handler + contract</span>
        </div>
        <div class="hero-code hero-code--canonical">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">internal/handler/users.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// stdlib signature + typed response contract</span>
r.<span class="hc-fn">Get</span>(<span class="hc-str">"/users/:id"</span>, <span class="hc-kw">func</span>(w http.ResponseWriter, r *http.Request) &#123;
    id := router.<span class="hc-fn">Param</span>(r, <span class="hc-str">"id"</span>)
    contract.<span class="hc-fn">WriteResponse</span>(w, r, http.StatusOK, user, <span class="hc-kw">nil</span>)
    <span class="hc-cm">// → &#123;"data": &#123;...&#125;, "meta": null&#125;</span>
&#125;)

<span class="hc-cm">// all net/http middleware works without adapters</span>
r.<span class="hc-fn">Use</span>(middleware.RequestID)
r.<span class="hc-fn">Use</span>(myOtelMiddleware)  <span class="hc-cm">// any net/http middleware</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- Response contract comparison -->
  <section class="section section--tinted">
    <div class="section__intro">
      <h2>Response contracts: consistent envelope vs. build your own.</h2>
      <p>
        Gin, Echo, Fiber, and Chi all leave the JSON response format to you. This means each team,
        each handler, or each project may produce subtly different shapes. Plumego's
        <code>contract</code> module enforces one envelope for both success and error responses.
      </p>
    </div>

    <div class="contract-compare">
      <div class="contract-panel contract-panel--before">
        <p class="contract-panel__label">Gin / Echo / Fiber / Chi — roll your own</p>
        <div class="hero-code">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">handler.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// success — each team decides the shape</span>
c.<span class="hc-fn">JSON</span>(200, gin.H&#123;
    <span class="hc-str">"data"</span>:    user,
    <span class="hc-str">"success"</span>: <span class="hc-kw">true</span>,   <span class="hc-cm">// some teams add this</span>
    <span class="hc-str">"code"</span>:    0,          <span class="hc-cm">// some teams add this</span>
&#125;)

<span class="hc-cm">// error — even more inconsistent</span>
c.<span class="hc-fn">JSON</span>(400, gin.H&#123;
    <span class="hc-str">"error"</span>:   <span class="hc-str">"name required"</span>,
    <span class="hc-str">"message"</span>: <span class="hc-str">"..."</span>,       <span class="hc-cm">// duplicate? missing?</span>
    <span class="hc-str">"code"</span>:    1001,
&#125;)</code></pre>
        </div>
      </div>

      <div class="contract-panel contract-panel--after">
        <p class="contract-panel__label">Plumego — one contract, all handlers</p>
        <div class="hero-code hero-code--canonical">
