        <span class="hero-code__dots"><span></span><span></span><span></span></span>
        <span class="hero-code__filename">environment</span>
      </div>
      <pre class="hero-code__pre"><code><span class="hc-cm"># Go 1.26.0 · linux/amd64 · Intel Xeon @ 2.10 GHz</span>
<span class="hc-cm"># 5 runs · 3 s each · medians reported</span>
go test -bench=BenchmarkCmp -benchmem -count=5 -benchtime=3s ./router/</code></pre>
    </div>
  </section>

