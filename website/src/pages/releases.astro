---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import PageHero from '../components/marketing/PageHero.astro';
import { RELEASE_COPY, SITE } from '../data/site';
import { RELEASE_FACTS } from '../generated/releases';

const copy = RELEASE_COPY.en;
const stableGroups = RELEASE_FACTS.supportMatrix.filter((entry) => entry.status.includes('GA')).length;
const experimentalGroups = RELEASE_FACTS.supportMatrix.filter((entry) =>
  entry.status.toLowerCase().includes('experimental'),
).length;
---

<MarketingLayout locale="en" title={copy.title} description={copy.description} currentPath="/releases">
  <PageHero
    eyebrow={copy.eyebrow}
    title={copy.title}
    description={copy.description}
    links={[
      { label: 'Roadmap', href: '/roadmap' },
      { label: 'Docs', href: '/docs' },
    ]}
  />

  <section class="release-banner">
    <p>Current version</p>
    <strong>{SITE.currentVersion}</strong>
    <a class="text-link" href={SITE.githubUrl + '/releases'} target="_blank" rel="noreferrer">GitHub Releases</a>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.introTitle}</h2>
      <p>{copy.introBody}</p>
    </div>
    <div class="signal-list">
      {copy.guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="release-stats">
    <article class="page-panel">
      <p class="signal-list__kicker">source</p>
      <h2>README.md</h2>
      <p>The release page consumes the synced v1 support matrix instead of a hand-copied website-only list.</p>
    </article>
    <article class="page-panel">
      <p class="signal-list__kicker">stable groups</p>
      <h2>{stableGroups}</h2>
      <p>Groups currently carrying a GA-level compatibility promise.</p>
    </article>
    <article class="page-panel">
      <p class="signal-list__kicker">experimental groups</p>
      <h2>{experimentalGroups}</h2>
      <p>Groups still included in release scope but not yet frozen for compatibility.</p>
    </article>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.principlesTitle}</h2>
      <p>{copy.principlesBody}</p>
    </div>
    <div class="control-grid">
      {copy.principles.map((item) => (
        <article class="control-grid__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.matrixTitle}</h2>
      <p>{copy.matrixBody}</p>
    </div>
  </section>

  <section class="page-grid">
    {RELEASE_FACTS.supportMatrix.map((entry) => (
      <article class="page-panel">
        <p class="status-pill">{entry.status}</p>
        <h2>{entry.area}</h2>
        <p>{entry.promise}</p>
        <p><strong>Modules:</strong> {entry.modules}</p>
      </article>
    ))}
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>Continue with the canonical path</h2>
      <p>Use release posture as a boundary map, then return to the default app path for actual adoption work.</p>
    </div>
    <div class="page-links">
      <a class="text-link" href="/docs/getting-started">Open getting started</a>
      <a class="text-link" href="/docs/reference-app">Read the reference app</a>
      <a class="text-link" href="/roadmap">Open roadmap</a>
    </div>
  </section>
</MarketingLayout>
