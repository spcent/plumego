---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { EXAMPLES_COPY } from '../data/site';

const copy = EXAMPLES_COPY.en;
---

<MarketingLayout
  locale="en"
  title={copy.title}
  description={copy.description}
  currentPath="/examples"
  keywords={['plumego examples', 'go http example', 'reference standard service', 'plumego reference app']}
>
  <section class="page-hero">
    <p class="hero__eyebrow">{copy.eyebrow}</p>
    <h1>{copy.title}</h1>
    <p>{copy.description}</p>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.introTitle}</h2>
      <p>{copy.introBody}</p>
    </div>
    <div class="signal-list">
      {copy.guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.runnableTitle}</h2>
      <p>{copy.runnableBody}</p>
    </div>
    <div class="page-grid">
      {copy.runnableExamples.map((item) => (
        <article class="page-panel">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
          <ul>
            {item.details.map((detail) => (
              <li>{detail}</li>
            ))}
          </ul>
          <a class="text-link" href={item.href}>{item.label}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.guidedTitle}</h2>
      <p>{copy.guidedBody}</p>
    </div>
    <div class="control-grid">
      {copy.guidedExamples.map((item) => (
        <article class="control-grid__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
          <a class="text-link" href={item.href}>{item.label}</a>
        </article>
      ))}
    </div>
  </section>
</MarketingLayout>
