---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import PageHero from '../components/marketing/PageHero.astro';
import { EXAMPLES_COPY } from '../data/site';

const copy = EXAMPLES_COPY.en;
---

<MarketingLayout
  locale="en"
  title={copy.title}
  description={copy.description}
  currentPath="/examples"
  keywords={['plumego examples', 'go http example', 'reference standard service', 'plumego reference app']}
>
  <PageHero
    eyebrow={copy.eyebrow}
    title={copy.title}
    description={copy.description}
    links={[
      { label: 'Use Cases', href: '/use-cases' },
      { label: 'Docs', href: '/docs' },
    ]}
  />

  <section class="section">
    <div class="section__intro">
      <h2>{copy.introTitle}</h2>
      <p>{copy.introBody}</p>
    </div>
    <div class="signal-list">
      {copy.guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.runnableTitle}</h2>
      <p>{copy.runnableBody}</p>
    </div>
    <div class="page-grid">
      {copy.runnableExamples.map((item) => (
        <article class="page-panel">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
          <ul>
            {item.details.map((detail) => (
              <li>{detail}</li>
            ))}
          </ul>
          <a class="text-link" href={item.href}>{item.label}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.guidedTitle}</h2>
      <p>{copy.guidedBody}</p>
    </div>
    <div class="control-grid">
      {copy.guidedExamples.map((item) => (
        <article class="control-grid__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
          <a class="text-link" href={item.href}>{item.label}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>Continue with documentation</h2>
      <p>Examples are meant to push you toward the reference path, not replace it.</p>
    </div>
    <div class="page-links">
      <a class="text-link" href="/docs/getting-started">Open getting started</a>
      <a class="text-link" href="/docs/reference-app">Read the reference app</a>
      <a class="text-link" href="/docs/modules/overview">Open modules overview</a>
    </div>
  </section>
</MarketingLayout>
