---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import PageHero from '../components/marketing/PageHero.astro';
import JourneyBar from '../components/marketing/JourneyBar.astro';
import { MODULE_FACTS } from '../generated/modules';

const journeySteps = [
  { label: 'Docs', href: '/docs' },
  { label: 'Extensions', href: '/extensions' },
  { label: 'Stability', href: '/stability' },
];

interface ExtCard {
  name: string;
  status: 'beta' | 'experimental';
  description: string;
  entrypoint: string;
  docHref: string;
  tags: string[];
}

const extensionCards: ExtCard[] = [
  // Beta families
  { name: 'x/rest', status: 'beta', description: 'CRUD resource conventions, typed handlers, and REST response contracts over the stable HTTP kernel.', entrypoint: 'x/rest', docHref: '/docs/modules/x-rest', tags: ['api', 'rest', 'crud'] },
  { name: 'x/gateway', status: 'beta', description: 'Reverse proxy, upstream health, load balancing, and route composition at the service edge.', entrypoint: 'x/gateway', docHref: '/docs/modules/x-gateway', tags: ['proxy', 'edge', 'lb'] },
  { name: 'x/websocket', status: 'beta', description: 'Full-duplex WebSocket connections managed by a hub, coexisting with standard HTTP routes.', entrypoint: 'x/websocket', docHref: '/docs/modules/x-websocket', tags: ['realtime', 'ws'] },
  { name: 'x/observability', status: 'beta', description: 'Prometheus metrics, OpenTelemetry traces, and structured log exporters wired at the service boundary.', entrypoint: 'x/observability', docHref: '/docs/modules/x-observability', tags: ['metrics', 'traces', 'otel'] },
  { name: 'x/tenant', status: 'beta', description: 'Per-tenant JWT identity, quota enforcement, and policy evaluation at the transport layer.', entrypoint: 'x/tenant', docHref: '/docs/modules/x-tenant', tags: ['saas', 'multi-tenant', 'jwt'] },
  { name: 'x/frontend', status: 'beta', description: 'Static asset serving, SPA fallback routing, and embedded filesystem support for frontend integration.', entrypoint: 'x/frontend', docHref: '/docs/modules/x-frontend', tags: ['static', 'spa', 'assets'] },
  { name: 'x/messaging', status: 'beta', description: 'Event publishing, webhook dispatch, and messaging service-level API over pluggable transports.', entrypoint: 'x/messaging', docHref: '/docs/modules/x-messaging', tags: ['events', 'pubsub', 'webhooks'] },
  // Experimental families
  { name: 'x/ai', status: 'experimental', description: 'Multi-provider AI abstraction, session lifecycle, streaming SSE responses, and tool-call routing.', entrypoint: 'x/ai/provider', docHref: '/docs/modules/x-ai', tags: ['ai', 'llm', 'streaming'] },
  { name: 'x/data', status: 'experimental', description: 'File storage, idempotency keys, and data access primitives above the stable store interface.', entrypoint: 'x/data', docHref: '/docs/modules/x-data', tags: ['storage', 'data', 'files'] },
  { name: 'x/resilience', status: 'experimental', description: 'Circuit breakers, retry policies, and timeout wrappers for outbound HTTP and service calls.', entrypoint: 'x/resilience', docHref: '/docs/modules/x-resilience', tags: ['resilience', 'circuit-breaker', 'retry'] },
  { name: 'x/rpc', status: 'experimental', description: 'gRPC + HTTP dual-protocol service wiring that shares the same stable middleware chain.', entrypoint: 'x/rpc', docHref: '/docs/modules/x-rpc', tags: ['grpc', 'rpc', 'protocol'] },
  { name: 'x/openapi', status: 'experimental', description: 'OpenAPI 3 spec generation from route definitions, with schema inference and doc server.', entrypoint: 'x/openapi', docHref: '/docs/modules/x-openapi', tags: ['openapi', 'swagger', 'docs'] },
  { name: 'x/validate', status: 'experimental', description: 'Request body validation middleware with struct tag rules and structured error responses.', entrypoint: 'x/validate', docHref: '/docs/modules/x-validate', tags: ['validation', 'input'] },
  { name: 'x/fileapi', status: 'experimental', description: 'Multipart upload handlers, chunk resumption, and file metadata management over the stable HTTP kernel.', entrypoint: 'x/fileapi', docHref: '/docs/modules/x-fileapi', tags: ['upload', 'files', 'multipart'] },
];

const betaCount = extensionCards.filter(c => c.status === 'beta').length;
const expCount = extensionCards.filter(c => c.status === 'experimental').length;
---

<MarketingLayout
  locale="en"
  title="x/* Extension Families — Plumego"
  description="Browse all Plumego x/* capability families by maturity tier. 7 beta families with frozen APIs, plus experimental families for product-specific capability work."
  currentPath="/extensions"
>
  <PageHero
    eyebrow="extension families"
    title="The x/* ecosystem. Capability outside the kernel."
    body={`${betaCount} beta families with APIs frozen between release refs. ${expCount} experimental families for product capability work. All separated cleanly from the zero-dependency stable core.`}
  />

  <JourneyBar steps={journeySteps} current="/extensions" />

  <section class="section extensions-section">
    <div class="extensions-meta">
      <div class="meta-pill meta-pill--stable">
        <span class="meta-dot meta-dot--stable"></span>
        9 stable roots — zero external deps
      </div>
      <div class="meta-pill meta-pill--beta">
        <span class="meta-dot meta-dot--beta"></span>
        {betaCount} beta families — API frozen between refs
      </div>
      <div class="meta-pill meta-pill--exp">
        <span class="meta-dot meta-dot--exp"></span>
        {expCount} experimental families — evaluate before adopting
      </div>
    </div>

    <h2 class="extensions-group-title">Beta</h2>
    <p class="extensions-group-desc">API frozen between release references. Safe to adopt with awareness of beta stability semantics.</p>
    <div class="ext-grid">
      {extensionCards.filter(c => c.status === 'beta').map((card) => (
        <a class="ext-card ext-card--beta" href={card.docHref}>
          <div class="ext-card__header">
            <code class="ext-card__name">{card.name}</code>
            <span class="ext-badge ext-badge--beta">beta</span>
          </div>
          <p class="ext-card__desc">{card.description}</p>
          <div class="ext-card__tags">
            {card.tags.map(t => <span class="ext-tag">{t}</span>)}
          </div>
          <span class="ext-card__link">Read primer →</span>
        </a>
      ))}
    </div>

    <h2 class="extensions-group-title">Experimental</h2>
    <p class="extensions-group-desc">APIs may change between releases. Evaluate maturity evidence in the primer before adopting in production.</p>
    <div class="ext-grid">
      {extensionCards.filter(c => c.status === 'experimental').map((card) => (
        <a class="ext-card ext-card--exp" href={card.docHref}>
          <div class="ext-card__header">
            <code class="ext-card__name">{card.name}</code>
            <span class="ext-badge ext-badge--exp">experimental</span>
          </div>
          <p class="ext-card__desc">{card.description}</p>
          <div class="ext-card__tags">
            {card.tags.map(t => <span class="ext-tag">{t}</span>)}
          </div>
          <span class="ext-card__link">Read primer →</span>
        </a>
      ))}
    </div>

    <div class="extensions-footer-cta">
      <a class="button button--primary" href="/docs/x-family">X-Family Overview →</a>
      <a class="button button--ghost" href="/stability">Stability & Maturity Policy →</a>
      <a class="button button--ghost" href="/architecture#extensions">Architecture Diagram →</a>
    </div>
  </section>
</MarketingLayout>

<style>
  .extensions-section {
    padding-block: 3rem 5rem;
    max-width: 72rem;
    margin-inline: auto;
  }

  .extensions-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 3rem;
  }

  .meta-pill {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--fg-soft);
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 2rem;
    padding: 0.35rem 0.9rem;
  }

  .meta-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .meta-dot--stable { background: var(--status-stable, #22c55e); }
  .meta-dot--beta   { background: var(--status-beta, #3b82f6); }
  .meta-dot--exp    { background: var(--status-exp, #f59e0b); }

  .extensions-group-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--fg);
    margin: 2.5rem 0 0.4rem;
    letter-spacing: -0.02em;
  }

  .extensions-group-desc {
    font-size: 0.88rem;
    color: var(--fg-soft);
    margin: 0 0 1.25rem;
    line-height: 1.6;
  }

  .ext-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  @media (min-width: 560px) { .ext-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 900px) { .ext-grid { grid-template-columns: repeat(3, 1fr); } }

  .ext-card {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 0.75rem;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    text-decoration: none;
    transition: border-color 0.18s, box-shadow 0.18s;
  }

  .ext-card--beta:hover {
    border-color: color-mix(in srgb, #3b82f6 35%, var(--line));
    box-shadow: 0 0 0 3px color-mix(in srgb, #3b82f6 10%, transparent);
  }

  .ext-card--exp:hover {
    border-color: color-mix(in srgb, #f59e0b 35%, var(--line));
    box-shadow: 0 0 0 3px color-mix(in srgb, #f59e0b 10%, transparent);
  }

  .ext-card__header {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .ext-card__name {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.15rem 0.5rem;
    border-radius: 0.3rem;
  }

  .ext-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.1rem 0.4rem;
    border-radius: 0.25rem;
  }

  .ext-badge--beta {
    background: color-mix(in srgb, #3b82f6 15%, transparent);
    color: #3b82f6;
    border: 1px solid color-mix(in srgb, #3b82f6 30%, transparent);
  }

  .ext-badge--exp {
    background: color-mix(in srgb, #f59e0b 15%, transparent);
    color: #b45309;
    border: 1px solid color-mix(in srgb, #f59e0b 30%, transparent);
  }

  :root[data-theme="dark"] .ext-badge--exp { color: #fbbf24; }

  .ext-card__desc {
    font-size: 0.85rem;
    color: var(--fg-soft);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .ext-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .ext-tag {
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--fg-muted, var(--fg-soft));
    background: var(--bg-strong);
    border: 1px solid var(--line);
    border-radius: 0.25rem;
    padding: 0.1rem 0.4rem;
    letter-spacing: 0.04em;
  }

  .ext-card__link {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--accent);
    margin-top: 0.15rem;
    transition: color 0.15s;
  }

  .ext-card:hover .ext-card__link { color: var(--accent-strong); text-decoration: underline; }

  .extensions-footer-cta {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }
</style>
