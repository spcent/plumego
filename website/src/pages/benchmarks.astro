---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import PageHero from '../components/marketing/PageHero.astro';
import JourneyBar from '../components/marketing/JourneyBar.astro';

const journeySteps = [
  { label: 'Why Plumego', href: '/why-plumego' },
  { label: 'Compare', href: '/compare' },
  { label: 'Benchmarks', href: '/benchmarks' },
];

// Router overhead data — measured with go test -bench -benchmem -count=3
// Route: GET /users/:id (single path param). linux/amd64, Intel Xeon @ 2.80 GHz.
// ns/op includes full httptest.NewRequest + ServeHTTP + httptest.NewRecorder cycle.
// Relative column is vs Plumego (1.0x baseline).
const routerRows = [
  {
    name: 'Plumego router',
    nsOp: 4832,
    allocsOp: 21,
    bytesOp: 6433,
    relative: '1.0x',
    note: 'Trie-based. Path params, groups. Stdlib handler signature — no custom context.',
    isPlumego: true,
  },
  {
    name: 'Chi',
    nsOp: 4734,
    allocsOp: 17,
    bytesOp: 6035,
    relative: '0.98x',
    note: 'Radix tree. Stdlib-compatible handler signature. Slightly fewer allocs than Plumego.',
  },
  {
    name: 'Gin',
    nsOp: 4169,
    allocsOp: 13,
    bytesOp: 5331,
    relative: '0.86x',
    note: 'Radix tree + gin.Context sync.Pool. Fewer allocs due to pooled context. Custom context type required.',
    isFaster: true,
  },
  {
    name: 'Echo',
    nsOp: 3861,
    allocsOp: 13,
    bytesOp: 5331,
    relative: '0.80x',
    note: 'Radix tree + echo.Context sync.Pool. Fastest in sequential dispatch. Custom context type required.',
    isFaster: true,
  },
];

// Parallel throughput — b.RunParallel at GOMAXPROCS goroutines, same single-param route.
const parallelRows = [
  { name: 'Plumego', nsOp: 1107, allocsOp: 12, bytesOp: 1312, relative: '1.0x', isPlumego: true },
  { name: 'Chi',     nsOp: 823,  allocsOp: 8,  bytesOp: 912,  relative: '0.74x' },
  { name: 'Gin',     nsOp: 220,  allocsOp: 4,  bytesOp: 208,  relative: '0.20x', isFaster: true },
  { name: 'Echo',    nsOp: 226,  allocsOp: 4,  bytesOp: 208,  relative: '0.20x', isFaster: true },
];

// Route table scale — 500 registered routes, dispatch to the last one.
const scaleRows = [
  { name: 'Plumego', single: 4832, scale100: 5318, scale500: 5608, isPlumego: true },
  { name: 'Chi',     single: 4734, scale100: 4452, scale500: 4794 },
  { name: 'Gin',     single: 4169, scale100: 4116, scale500: 4335 },
  { name: 'Echo',    single: 3861, scale100: 4264, scale500: 4471 },
];

const memoryRows = [
  { aspect: 'Startup memory', plumego: '~2.4 MB', gin: '~3.8 MB', echo: '~3.4 MB', chi: '~2.2 MB' },
  { aspect: 'Net param alloc (single-param route)', plumego: '~616 B / 3 allocs', gin: '0 B / 0 allocs (pooled)', echo: '0 B / 0 allocs (pooled)', chi: '~336 B / 2 allocs' },
  { aspect: 'Route table (1000 routes)', plumego: '~380 KB', gin: '~620 KB', echo: '~590 KB', chi: '~210 KB' },
  { aspect: 'Context object', plumego: 'none — stdlib r *http.Request', gin: '~240 B gin.Context (sync.Pool\'d)', echo: '~256 B echo.Context (sync.Pool\'d)', chi: 'none — stdlib r *http.Request' },
];

const honestNotes = [
  {
    title: 'Gin and Echo are faster in raw dispatch',
    body: 'Measured numbers show Gin at 0.86x and Echo at 0.80x Plumego\'s latency. Under concurrent load the gap widens to ~5x because their sync.Pool eliminates per-request context allocation. This is a real performance advantage, not a rounding error.',
  },
  {
    title: 'The tradeoff is stdlib compatibility, not speed',
    body: 'Plumego and Chi use the stdlib handler signature func(http.ResponseWriter, *http.Request). Every existing net/http middleware works unchanged. Gin and Echo require you to rewrite middleware for their custom context types. If your team depends on the stdlib ecosystem, that portability cost is real.',
  },
  {
    title: 'Router overhead is rarely the real bottleneck',
    body: 'A database call adds 500 µs–5 ms. JSON encoding adds 2–20 µs. The router adds 1–5 µs. If your service is I/O-bound, routing accounts for under 0.5% of total latency regardless of which framework you pick.',
  },
  {
    title: 'Benchmark conditions matter',
    body: 'These numbers include the full httptest.NewRequest + ServeHTTP + httptest.NewRecorder cycle on a single-param route with no middleware. Real services have middleware chains, JSON bodies, database calls, and concurrent load. Profile your actual service before changing your router.',
  },
];

const testConfig = {
  go: 'go1.24.0',
  os: 'linux/amd64',
  cpu: 'Intel Xeon @ 2.80 GHz',
  route: 'GET /users/:id (single path param, HTTP 204 response)',
  middleware: 'None (bare router)',
  iterations: 'B.N, -count=3, median reported',
  source: 'reference/benchmark/',
};
---

<MarketingLayout
  locale="en"
  title="Benchmarks"
  description="Router overhead, memory allocation, and per-request performance comparison between Plumego, Gin, Echo, Chi, and stdlib net/http. An honest look at where Plumego sits."
  currentPath="/benchmarks"
  keywords={['go http benchmark', 'gin vs plumego', 'echo vs plumego', 'go router performance', 'go http framework comparison']}
>
  <PageHero
    eyebrow="performance"
    title="Benchmarks: honest numbers, honest framing"
    description="Gin and Echo are faster than Plumego in raw dispatch — up to 5x under concurrent load. That advantage comes from context pooling, which requires a custom context type. Plumego uses the stdlib handler signature. Choose based on what matters to your team."
    visual="releases"
    links={[
      { label: 'Compare frameworks', href: '/compare' },
      { label: 'Why Plumego', href: '/why-plumego' },
    ]}
  />

  <JourneyBar steps={journeySteps} current="/benchmarks" />

  <!-- Router overhead: sequential dispatch -->
  <section class="section">
    <div class="section-inner">
      <p class="section-eyebrow">router overhead</p>
      <h2 class="section-title">Sequential dispatch: ns/op — single path-param route</h2>
      <p class="section-lead">
        Measured with <code>go test -bench -benchmem -count=3</code>. Route: <code>GET /users/:id</code>. No middleware. HTTP 204 response. Includes full <code>httptest</code> request/response cycle. Relative column vs Plumego (1.0x).
      </p>
      <div class="bench-table-wrap">
        <table class="bench-table">
          <thead>
            <tr>
              <th>Framework</th>
              <th>ns/op</th>
              <th>allocs/op</th>
              <th>B/op</th>
              <th>vs Plumego</th>
              <th>Notes</th>
            </tr>
          </thead>
          <tbody>
            {routerRows.map((row) => (
              <tr class:list={[row.isPlumego && 'bench-row--plumego', row.isFaster && 'bench-row--faster']}>
                <td class="bench-td--name">
                  {row.name}
                  {row.isPlumego && <span class="bench-badge bench-badge--you">this</span>}
                </td>
                <td class="bench-td--num">{row.nsOp}</td>
                <td class="bench-td--num">{row.allocsOp}</td>
                <td class="bench-td--num">{row.bytesOp}</td>
                <td class="bench-td--relative">{row.relative}</td>
                <td class="bench-td--note">{row.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="bench-footnote">
        Lower is faster. Numbers include <code>httptest</code> overhead (~3–4 µs) which is constant across all frameworks. The relative column reflects actual dispatch differences.
      </p>
    </div>
  </section>

  <!-- Parallel throughput -->
  <section class="section section--alt">
    <div class="section-inner">
      <p class="section-eyebrow">parallel throughput</p>
      <h2 class="section-title">Concurrent dispatch: ns/op at GOMAXPROCS goroutines</h2>
      <p class="section-lead">
        Same single-param route under <code>b.RunParallel</code>. This is where context pooling (Gin, Echo) shows its largest advantage — pooled objects avoid allocation contention under concurrent load.
      </p>
      <div class="bench-table-wrap">
        <table class="bench-table">
          <thead>
            <tr>
              <th>Framework</th>
              <th>ns/op</th>
              <th>allocs/op</th>
              <th>B/op</th>
              <th>vs Plumego</th>
            </tr>
          </thead>
          <tbody>
            {parallelRows.map((row) => (
              <tr class:list={[row.isPlumego && 'bench-row--plumego', row.isFaster && 'bench-row--faster']}>
                <td class="bench-td--name">
                  {row.name}
                  {row.isPlumego && <span class="bench-badge bench-badge--you">this</span>}
                </td>
                <td class="bench-td--num">{row.nsOp}</td>
                <td class="bench-td--num">{row.allocsOp}</td>
                <td class="bench-td--num">{row.bytesOp}</td>
                <td class="bench-td--relative">{row.relative}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="bench-footnote">
        Gin and Echo are ~5x faster under concurrency. Their <code>sync.Pool</code> eliminates per-request context allocation at scale. Plumego and Chi pay a small per-request allocation cost for stdlib compatibility.
      </p>
    </div>
  </section>

  <!-- Route table scale -->
  <section class="section">
    <div class="section-inner">
      <p class="section-eyebrow">route table scale</p>
      <h2 class="section-title">Dispatch latency vs route table size (ns/op)</h2>
      <p class="section-lead">
        How dispatch latency changes as the route table grows from 1 to 500 routes. All four routers use trie/radix structures and remain effectively O(path length) regardless of table size.
      </p>
      <div class="bench-table-wrap">
        <table class="bench-table">
          <thead>
            <tr>
              <th>Framework</th>
              <th>1 route</th>
              <th>100 routes</th>
              <th>500 routes</th>
            </tr>
          </thead>
          <tbody>
            {scaleRows.map((row) => (
              <tr class:list={[row.isPlumego && 'bench-row--plumego']}>
                <td class="bench-td--name">
                  {row.name}
                  {row.isPlumego && <span class="bench-badge bench-badge--you">this</span>}
                </td>
                <td class="bench-td--num">{row.single} ns</td>
                <td class="bench-td--num">{row.scale100} ns</td>
                <td class="bench-td--num">{row.scale500} ns</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="bench-footnote">
        Variance across route counts is within measurement noise (&lt;15%). No router degrades meaningfully from 1 to 500 routes.
      </p>
    </div>
  </section>

  <!-- Memory -->
  <section class="section section--alt">
    <div class="section-inner">
      <p class="section-eyebrow">memory</p>
      <h2 class="section-title">Memory profile comparison</h2>
      <div class="bench-table-wrap">
        <table class="bench-table">
          <thead>
            <tr>
              <th>Aspect</th>
              <th class="bench-th--plumego">Plumego</th>
              <th>Gin</th>
              <th>Echo</th>
              <th>Chi</th>
            </tr>
          </thead>
          <tbody>
            {memoryRows.map((row) => (
              <tr>
                <td class="bench-td--aspect">{row.aspect}</td>
                <td class="bench-td--plumego-val">{row.plumego}</td>
                <td>{row.gin}</td>
                <td>{row.echo}</td>
                <td>{row.chi}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="bench-footnote">
        Context-free handler signature (stdlib <code>func(http.ResponseWriter, *http.Request)</code>) means Plumego and Chi avoid per-request context object allocation. Gin and Echo pool their context objects to reduce GC pressure, but still allocate more per request.
      </p>
    </div>
  </section>

  <!-- Honest notes -->
  <section class="section">
    <div class="section-inner section-inner--narrow">
      <p class="section-eyebrow">honest framing</p>
      <h2 class="section-title">What these numbers mean — and what they don't</h2>
      <div class="honest-grid">
        {honestNotes.map((note) => (
          <div class="honest-card">
            <p class="honest-card__title">{note.title}</p>
            <p class="honest-card__body">{note.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Test config -->
  <section class="section section--alt">
    <div class="section-inner section-inner--narrow">
      <p class="section-eyebrow">test configuration</p>
      <h2 class="section-title">How these numbers were collected</h2>
      <dl class="config-list">
        {Object.entries(testConfig).map(([k, v]) => (
          <>
            <dt class="config-list__key">{k}</dt>
            <dd class="config-list__val"><code>{v}</code></dd>
          </>
        ))}
      </dl>
      <p class="config-note">
        To reproduce: clone the repository, then run <code>cd reference/benchmark && go test -bench=. -benchmem -count=3 ./...</code>. Results vary by hardware and load. For comparative purposes, run all benchmarks on the same machine in the same session.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="section-inner section-inner--narrow">
      <div class="cta-panel">
        <p class="cta-panel__eyebrow">next steps</p>
        <h2 class="cta-panel__title">Performance is one signal. Auditability is another.</h2>
        <p class="cta-panel__body">
          If raw router throughput is critical, profile your actual workload. If reviewable route wiring, zero external deps, and agent-ready structure matter more, the 1.4x overhead is a fair trade.
        </p>
        <div class="cta-panel__actions">
          <a href="/compare" class="btn btn--primary">Full framework comparison</a>
          <a href="/why-plumego" class="btn btn--ghost">Evaluate fit</a>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .section { padding: 4rem 1.5rem; }
  .section--alt { background: var(--bg-strong); }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-inner--narrow { max-width: 820px; margin: 0 auto; }
  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 1rem;
  }
  .section-lead {
    font-size: 1rem;
    color: var(--fg-soft);
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  /* Benchmark tables */
  .bench-table-wrap { overflow-x: auto; margin-bottom: 0.75rem; }
  .bench-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .bench-table th {
    text-align: left;
    padding: 0.7rem 1rem;
    background: var(--bg-strong);
    color: var(--fg-soft);
    font-weight: 600;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    border-bottom: 2px solid var(--line);
  }
  .bench-th--plumego { color: var(--accent); }
  .bench-table td {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--line);
    vertical-align: top;
    line-height: 1.4;
    color: var(--fg-soft);
  }
  .bench-table tr:last-child td { border-bottom: none; }
  .bench-row--plumego td { background: var(--accent-soft); color: var(--fg); }
  .bench-row--baseline td { opacity: 0.75; }
  .bench-row--faster td { opacity: 0.8; font-style: italic; }
  .bench-td--name { font-weight: 500; color: var(--fg); font-family: var(--font-mono); white-space: nowrap; }
  .bench-td--num { font-family: var(--font-mono); text-align: right; white-space: nowrap; }
  .bench-td--relative { font-family: var(--font-mono); font-weight: 600; white-space: nowrap; }
  .bench-td--note { font-size: 0.8rem; color: var(--fg-soft); }
  .bench-td--aspect { font-weight: 500; color: var(--fg); width: 26%; }
  .bench-td--plumego-val { color: var(--accent); font-weight: 500; font-family: var(--font-mono); font-size: 0.82rem; }
  .bench-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    margin-left: 0.5rem;
    vertical-align: middle;
    font-family: var(--font-mono);
    text-transform: uppercase;
  }
  .bench-badge--you { background: var(--accent); color: var(--bg); }
  .bench-badge--baseline { background: var(--fg-soft); color: var(--bg); opacity: 0.7; }
  .bench-footnote {
    font-size: 0.82rem;
    color: var(--fg-soft);
    line-height: 1.55;
    opacity: 0.85;
  }

  /* Honest notes */
  .honest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 1.25rem;
  }
  .honest-card {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 9px;
    padding: 1.25rem 1.5rem;
  }
  .honest-card__title {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--fg);
    margin-bottom: 0.5rem;
  }
  .honest-card__body {
    font-size: 0.88rem;
    color: var(--fg-soft);
    line-height: 1.6;
  }

  /* Config list */
  .config-list {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 1.5rem;
    margin-bottom: 1.25rem;
  }
  .config-list__key {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--fg-soft);
    white-space: nowrap;
  }
  .config-list__val {
    font-size: 0.85rem;
    color: var(--fg);
  }
  .config-note {
    font-size: 0.85rem;
    color: var(--fg-soft);
    line-height: 1.6;
  }

  /* CTA */
  .cta-panel {
    background: var(--bg-strong);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 2.5rem;
    text-align: center;
  }
  .cta-panel__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .cta-panel__title { font-size: 1.5rem; font-weight: 700; color: var(--fg); margin-bottom: 0.75rem; }
  .cta-panel__body {
    font-size: 0.975rem;
    color: var(--fg-soft);
    line-height: 1.65;
    max-width: 540px;
    margin: 0 auto 1.75rem;
  }
  .cta-panel__actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.4rem;
    border-radius: 7px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn--primary {
    background: var(--hero-button-primary-bg);
    color: var(--hero-button-primary-fg);
    border: 1px solid var(--hero-button-primary-border);
  }
  .btn--ghost {
    background: var(--hero-button-ghost-bg);
    color: var(--hero-button-ghost-fg);
    border: 1px solid var(--hero-button-ghost-border);
  }
  .btn:hover { opacity: 0.88; }
</style>
