---
import PageHero from '../components/marketing/PageHero.astro';
import JourneyBar from '../components/marketing/JourneyBar.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import WiringContrast from '../components/home/WiringContrast.astro';
import CheckIcon from '../components/shared/CheckIcon.astro';
import CautionIcon from '../components/shared/CautionIcon.astro';

const journeySteps = [
  { label: 'Why Plumego', href: '/why-plumego' },
  { label: 'Examples', href: '/examples' },
  { label: 'Status', href: '/status' },
];

const wiringCopy = {
  contrastTitle: 'What explicit wiring looks like in review.',
  contrastLead:
    'The core question before adopting: should route ownership, middleware order, and dependency wiring be visible in code — or managed by the framework?  Plumego keeps registration in <code>internal/app/routes.go</code>, where it appears in every code review.',
  contrastBeforeLabel: 'hidden behind registration calls',
  contrastAfterLabel: 'plumego: visible in routes.go',
};

const guideCards = [
  {
    kicker: 'explicit wiring',
    title: 'Plumego is for teams where service structure should stay readable as the codebase grows',
    body: 'The value shows up when the team stops being small: route registration, middleware order, and dependency wiring are visible in code — so reviewing a change means reading the code, not tracing framework conventions.',
  },
  {
    kicker: 'shared baseline',
    title: 'It gets stronger when multiple services should start from one default shape',
    body: 'If new services should begin from one readable reference rather than each team writing its own setup, Plumego gives you a baseline that is easy to hand off and extend without diverging into service-specific patterns.',
  },
  {
    kicker: 'clear maturity signals',
    title: 'It is most useful when you need to separate stable from experimental before adopting',
    body: 'Stable modules and experimental capabilities are kept separate on purpose, so adoption decisions can be based on release posture instead of assuming every package has the same maturity.',
  },
] as const;

const fitChecks = [
  {
    label: '01',
    title: 'reviewable wiring',
    evidence: 'route registration, middleware order, and dependencies stay visible in code review',
  },
  {
    label: '02',
    title: 'shared baseline',
    evidence: 'new services start from one reference shape instead of custom bootstraps',
  },
  {
    label: '03',
    title: 'maturity signal',
    evidence: 'stable roots and experimental families are separated before adoption',
  },
  {
    label: '04',
    title: 'agent-ready',
    evidence: 'machine-readable specs, per-module manifests, and standardized check commands give code agents a clear operating model',
  },
  {
    label: '05',
    title: 'stdlib-first',
    evidence: 'handler signature is func(w http.ResponseWriter, r *http.Request) — no custom context, all net/http middleware works without adapters',
  },
  {
    label: '06',
    title: 'zero deps',
    evidence: 'the stable core imports only the Go standard library — no transitive dependency risk in the kernel layer',
  },
] as const;

const fitProfiles = [
  {
    kicker: 'best fit',
    title: 'Internal APIs where reviewers need to trace request flow in code',
    body: 'Choose Plumego when a pull request should let you see which routes are registered, which middleware runs in order, and who owns each dependency — without reading framework source.',
    points: [
      'route registration must be visible in code review',
      'handler ownership and middleware order must be explicit',
      'the team already works comfortably with net/http',
    ],
  },
  {
    kicker: 'best fit',
    title: 'Platform services where multiple teams share one service skeleton',
    body: 'The framework is strongest when several teams need to start new services from the same reference shape and you want structural drift between repositories to stay low.',
    points: [
      'new services should inherit the same structure as existing ones',
      'reviewers want a small set of accepted patterns across the codebase',
      'a shared skeleton reduces onboarding cost as teams rotate',
    ],
  },
  {
    kicker: 'best fit',
    title: 'Repositories where you need clear signals about module readiness',
    body: 'Plumego is a strong fit when adoption decisions need to be based on explicit maturity evidence — stable, supported, or experimental — rather than inferred from package presence alone.',
    points: [
      'stable and experimental surfaces must be easy to distinguish',
      'teams need to know what can be depended on versus what may still change',
      'adoption scope should follow published evidence, not just availability',
    ],
  },
  {
    kicker: 'best fit',
    title: 'Repositories maintained by both human engineers and AI coding agents',
    body: 'Plumego is designed for codebases where AI agents share execution and review responsibilities. Machine-readable specs, per-module manifests, standardized check commands, and explicit task cards give agents a clear operating model — the same structure that makes human review easier also makes agent contributions safe to verify.',
    points: [
      'specs/ provides task routing, dependency rules, and change scope in YAML',
      'module.yaml scopes changes and checks to the owning module before editing starts',
      'make gates provides a consistent, agent-executable validation loop',
    ],
  },
] as const;

const cautionProfiles = [
  {
    kicker: 'not a fit',
    title: 'Your team is invested in the Gin or Echo plugin ecosystem',
    body: 'Gin and Echo have large middleware catalogs, authentication plugins, and community tooling built around their custom context types. If your team depends on gin.Context or echo.Context — and the ecosystem around it — switching handler signatures imposes real migration cost with no clear upside.',
  },
  {
    kicker: 'not a fit',
    title: 'You need framework-level ORM, DI container, or auto-wiring',
    body: 'Plumego does not carry database access, dependency injection, or auto-registration. If your team expects the framework to provide or wire these concerns, the explicit DI pattern will feel like unnecessary overhead. Reach for a full application framework instead.',
  },
  {
    kicker: 'not a fit',
    title: 'The x/* families\' maturity risk is a blocker for your organization',
    body: 'The 9 stable roots carry the v1 compatibility promise. The x/* extension families are experimental or beta — their APIs may still change until their own evidence is complete. If your organization requires a fully stable, versioned API across every capability you use, restrict adoption to stable roots and promoted beta surfaces only.',
  },
  {
    kicker: 'slow down',
    title: 'You want framework conventions to handle structure automatically',
    body: 'If the team mainly wants routing and dependency setup handled invisibly by the framework, Plumego may feel more deliberate than productive.',
  },
  {
    kicker: 'slow down',
    title: 'Every service is intentionally built with its own custom structure',
    body: 'The more each service must define its own startup, routing, and dependency patterns, the less a shared reference baseline can offer.',
  },
] as const;

const teamRows = [
  {
    signal: 'Team posture',
    fit: 'You want a shared service structure before the codebase becomes too wide for one person to hold in mind.',
    caution: 'You prefer each team to optimize its own service shape without a common reference model.',
  },
  {
    signal: 'Code review expectation',
    fit: 'Reviewers should be able to inspect routes, middleware, and dependency wiring directly in code.',
    caution: 'Review focuses on business logic and is comfortable letting the framework own structural decisions.',
  },
  {
    signal: 'Repository structure',
    fit: 'You want docs, examples, releases, and roadmap to reinforce one visible adoption model.',
    caution: 'You are comfortable letting package presence imply maturity without a published module boundary map.',
  },
] as const;


const frameworkDecision = [
  {
    name: 'Gin / Echo',
    whenToChoose: 'Your team wants fast setup, a large plugin ecosystem, and is comfortable with custom context types (<code>gin.Context</code> / <code>echo.Context</code>). Existing <code>net/http</code> middleware needs adapters, but the convention-first model is a worthwhile trade.',
    whenNotToChoose: 'You need handlers to stay as plain <code>func(w, r)</code> and want all existing stdlib middleware to work without wrappers.',
    isPlumego: false,
  },
  {
    name: 'Chi',
    whenToChoose: 'You only need routing and want to assemble everything else yourself. Chi is the right choice when you prefer minimal opinions and are happy building your own response envelope, middleware catalog, and security layer.',
    whenNotToChoose: 'You want a structured response contract, built-in middleware ordering, security helpers, and a canonical service shape out of the box.',
    isPlumego: false,
  },
  {
    name: 'Plumego',
    whenToChoose: 'Visible route ownership and review clarity matter more than framework convenience. You want <code>stdlib</code> handler signature (<code>func(w http.ResponseWriter, r *http.Request)</code>), a structured <code>contract</code> layer, and an explicit canonical service shape — without hidden registration.',
    whenNotToChoose: 'You want the framework to handle structure invisibly, or your team is already comfortable with Gin/Echo and happy with the trade-offs.',
    isPlumego: true,
  },
] as const;
---

<MarketingLayout
  locale="en"
  title="Adoption Decision"
  description="Use this page when you need to decide whether Plumego fits the service, team posture, and repository shape in front of you."
  currentPath="/why-plumego"
  keywords={['why plumego', 'plumego adoption fit', 'go service toolkit', 'explicit http services']}
>
  <PageHero
    eyebrow="Adoption Decision"
    title="Why Plumego"
    description="Use this page when the question is whether Plumego fits your team and review expectations — before committing time to the technical details."
    visual="decision"
    links={[
      { label: 'Architecture', href: '/architecture' },
      { label: 'Releases', href: '/releases' },
      { label: 'Examples', href: '/examples' },
    ]}
  />

  <JourneyBar steps={journeySteps} current="/why-plumego" />

  <!-- Agent-first callout — surfaced near the top as a unique differentiator -->
  <section class="section agent-first-callout">
    <div class="agent-first-callout__inner">
      <div class="agent-first-callout__badge">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
          <rect x="9" y="2" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
          <rect x="2" y="9" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
          <rect x="9" y="9" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Agent-ready
      </div>
      <h2 class="agent-first-callout__title">Built for teams using AI coding tools.</h2>
      <p class="agent-first-callout__body">
        <em>This is about AI coding assistants (Claude, Copilot, Cursor) — tools that write or review code.
        It is not about building AI agent services; for that, see <code>x/ai</code>.</em>
      </p>
      <p class="agent-first-callout__body">
        Plumego is the first Go HTTP toolkit designed so those coding assistants know exactly where a change
        belongs — before writing any code. Machine-readable specs, per-module manifests, and explicit
        boundary rules give agents the same routing signals a senior reviewer uses.
      </p>
      <div class="agent-first-callout__points">
        <div class="agent-first-callout__point">
          <code>specs/task-routing.yaml</code>
          <span>maps work types to owning modules</span>
        </div>
        <div class="agent-first-callout__point">
          <code>specs/dependency-rules.yaml</code>
          <span>prevents agents from crossing stable-root boundaries</span>
        </div>
        <div class="agent-first-callout__point">
          <code>AGENTS.md</code>
          <span>defines the shared protocol for human + AI collaboration</span>
        </div>
      </div>
      <a class="text-link" href="/docs/concepts/agent-first-workflow">See the interactive routing demo →</a>
    </div>
  </section>

  <!-- Terminology: Plumego-specific terms defined on first use (CONTENT_RULES Rule 4) -->
  <section class="section section--tinted">
    <div class="section__intro reveal">
      <h2>Four terms Plumego uses specifically.</h2>
      <p>These words have precise meanings in this repository — they are not general Go jargon.</p>
    </div>
    <div class="comparison-table reveal" role="table" aria-label="Plumego-specific terminology">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">Term</span>
        <span role="columnheader">One-line definition</span>
      </div>
      <div class="comparison-table__row" role="row">
        <strong role="cell">stable root</strong>
        <span role="cell">A module with a long-term API compatibility promise, part of the v1 stable-root surface: <code>core</code>, <code>router</code>, <code>contract</code>, <code>middleware</code>, <code>security</code>, <code>store</code>, <code>health</code>, <code>log</code>, <code>metrics</code>.</span>
      </div>
      <div class="comparison-table__row" role="row">
        <strong role="cell">x/* family</strong>
        <span role="cell">An optional capability module under the <code>x/</code> directory — experimental unless labeled otherwise. Start from the owning family, not a subordinate primitive.</span>
      </div>
      <div class="comparison-table__row" role="row">
        <strong role="cell">control plane</strong>
        <span role="cell">The <code>docs/</code>, <code>specs/</code>, and <code>tasks/</code> directories that hold human-readable rules and machine-readable constraints for both humans and AI coding assistants.</span>
      </div>
      <div class="comparison-table__row" role="row">
        <strong role="cell">canonical path</strong>
        <span role="cell">The default service layout defined by <code>reference/standard-service</code> — the one starting point every new service should compare against.</span>
      </div>
    </div>
  </section>

  <!-- Before/after code contrast: what explicit wiring looks like -->
  <WiringContrast copy={wiringCopy} />

  <section class="section section--tinted">
    <div class="section__intro reveal">
      <h2>Fit check before architecture detail.</h2>
      <p>
        Plumego is a good match when the adoption question can be answered with visible engineering evidence, not framework enthusiasm.
      </p>
    </div>
    <div class="fit-check-board reveal">
      <div class="fit-check-board__track">
        {fitChecks.map((item) => (
          <article class="fit-check-board__item">
            <span>{item.label}</span>
            <h3>{item.title}</h3>
            <p>{item.evidence}</p>
          </article>
        ))}
      </div>
      <div class="code-block">
        <div class="code-block__bar">
          <div class="code-block__dots"><span></span><span></span><span></span></div>
          <span class="code-block__filename">adoption-review.md</span>
        </div>
        <pre class="code-block__pre"><code>- route registration stays visible
- middleware order is reviewable
- reference app is the canonical service shape
- release posture limits adoption assumptions
- stdlib handler signature — no adapters needed
- zero external deps in the stable core</code></pre>
      </div>
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro reveal">
      <h2>Where Plumego is strongest.</h2>
      <p>
        Plumego becomes a stronger fit when review clarity, explicit ownership, and one default service shape matter more than framework-managed convenience.
      </p>
    </div>
    <div class="page-grid reveal-stagger">
      {fitProfiles.map((item) => (
        <article class="page-panel page-panel--fit">
          <p class="signal-list__kicker">
            <CheckIcon class="comparison-cell-icon comparison-cell-icon--fit" size={13} />
            {item.kicker}
          </p>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
          <ul>
            {item.points.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro reveal">
      <h2>AI coding tools work more reliably with a machine-readable repository.</h2>
      <p>
        <em>This section is about AI <strong>coding assistants</strong> (Copilot, Claude, Cursor) — tools that write
        or review code. It is not about building AI agent services; that is the scope of <code>x/ai</code>.</em>
      </p>
      <p>
        Most teams using these tools today face the same problem: the assistant has to guess where a change belongs.
        Plumego's control plane gives those tools the same routing signals a senior reviewer uses.
      </p>
    </div>
    <div class="signal-list reveal-stagger">
      <article class="signal-list__item">
        <p class="signal-list__kicker">work routing</p>
        <h3>The agent knows which module owns the change before writing any code</h3>
        <p>
          <code>specs/task-routing.yaml</code> maps work types to owning modules. An agent reads the routing table
          when evaluating a change instead of inferring ownership by guessing directory structure.
        </p>
      </article>
      <article class="signal-list__item">
        <p class="signal-list__kicker">boundary enforcement</p>
        <h3>Import violations are caught by a machine, not by reviewer memory</h3>
        <p>
          <code>specs/dependency-rules.yaml</code> and <code>internal/checks/dependency-rules</code> reject
          PRs that cross stable-root boundaries — whether the change came from a human or an AI tool.
        </p>
      </article>
      <article class="signal-list__item">
        <p class="signal-list__kicker">change recipes</p>
        <h3>Common change types have a defined path, not an open prompt</h3>
        <p>
          <code>specs/change-recipes/</code> gives agents an explicit execution sequence for known change
          types: new stable module, bug fix, extension promotion, deprecation. Recipes reduce hallucination
          surface and make agent output reviewable with the same rules as human PRs.
        </p>
      </article>
    </div>
    <div class="routing-teaser">
      <p class="routing-teaser__label">How task routing works in practice</p>
      <div class="comparison-table routing-teaser__table" role="table" aria-label="Task routing examples">
        <div class="comparison-table__head" role="row">
          <strong role="columnheader">Task description</strong>
          <strong role="columnheader">Routing rule</strong>
          <strong role="columnheader">Owner</strong>
        </div>
        <div class="comparison-table__row" role="row">
          <span role="cell">Add rate limiting to inbound HTTP endpoint</span>
          <span role="cell"><code>middleware</code></span>
          <span role="cell"><code>middleware/</code></span>
        </div>
        <div class="comparison-table__row" role="row">
          <span role="cell">Add per-tenant JWT validation</span>
          <span role="cell"><code>tenant_policy_change</code></span>
          <span role="cell"><code>x/tenant/</code></span>
        </div>
        <div class="comparison-table__row" role="row">
          <span role="cell">Build AI streaming SSE endpoint</span>
          <span role="cell"><code>extension_work → x/ai</code></span>
          <span role="cell"><code>x/ai/</code></span>
        </div>
        <div class="comparison-table__row" role="row">
          <span role="cell">Update allowed import directions in specs</span>
          <span role="cell"><code>repo_rules</code></span>
          <span role="cell"><code>specs/</code></span>
        </div>
      </div>
      <p class="routing-teaser__note">The full routing table covers 10 task types. The interactive demo on the docs page lets you step through each classification.</p>
    </div>
    <div class="page-links" style="margin-top: 1.5rem;">
      <a class="text-link" href="/docs/concepts/agent-first-workflow">Try the interactive routing demo →</a>
    </div>
  </section>

  <section class="section">
    <div class="section__intro reveal">
      <h2>Good fit versus caution signals.</h2>
      <p>
        This comparison should help you decide, not merely admire the architecture. Use it when you need to know whether Plumego's explicit model actually improves the
        service in front of you.
      </p>
    </div>
    <div class="comparison-table reveal" role="table" aria-label="Good fit versus caution signals for Plumego adoption">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">Signal</span>
        <span role="columnheader">
          <CheckIcon class="comparison-cell-icon comparison-cell-icon--fit" size={13} />
          Good fit
        </span>
        <span role="columnheader">
          <CautionIcon class="comparison-cell-icon comparison-cell-icon--caution" size={13} />
          Slow down
        </span>
      </div>
      {teamRows.map((row) => (
        <div class="comparison-table__row" role="row">
          <strong role="cell">{row.signal}</strong>
          <span role="cell">
            <CheckIcon class="comparison-cell-icon comparison-cell-icon--fit" size={12} />
            {row.fit}
          </span>
          <span role="cell">
            <CautionIcon class="comparison-cell-icon comparison-cell-icon--caution" size={12} />
            {row.caution}
          </span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro reveal">
      <h2>Choose by decision, not by default.</h2>
      <p>
        All four toolkits are built on <code>net/http</code>. The differences are philosophy and scope — not performance.
        Use the table below as a decision aid: each row answers "when should I choose this" and "when should I not."
      </p>
    </div>
    <div class="comparison-table reveal" role="table" aria-label="Plumego compared to Gin, Echo, and Chi">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">Toolkit</span>
        <span role="columnheader">
          <CheckIcon class="comparison-cell-icon comparison-cell-icon--fit" size={13} />
          Choose when
        </span>
        <span role="columnheader">
          <CautionIcon class="comparison-cell-icon comparison-cell-icon--caution" size={13} />
          Pause when
        </span>
      </div>
      {frameworkDecision.map((row) => (
        <div class={`comparison-table__row${row.isPlumego ? ' comparison-table__row--highlight' : ''}`} role="row">
          <strong role="cell">
            {row.name}
            {row.isPlumego && (
              <svg class="comparison-cell-icon comparison-cell-icon--fit" width="12" height="12" viewBox="0 0 16 16" fill="none" aria-label="Plumego" style="margin-left:0.3em">
                <path d="M8 2l1.5 4.5H14l-3.7 2.7 1.4 4.3L8 11l-3.7 2.5 1.4-4.3L2 6.5h4.5z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="color-mix(in srgb, currentColor 20%, transparent)"/>
              </svg>
            )}
          </strong>
          <span role="cell" set:html={row.whenToChoose} />
          <span role="cell" set:html={row.whenNotToChoose} />
        </div>
      ))}
    </div>
    <div class="signal-list" style="margin-top: 2rem;">
      <article class="signal-list__item">
        <p class="signal-list__kicker">router overhead</p>
        <h3>Measured: 1.4×–4.3× vs stdlib ServeMux — knowable and bounded</h3>
        <p>
          Plumego's trie router adds per-request context injection, param map construction, and
          middleware chain wiring on top of dispatch. Overhead vs Go 1.22+ <code>http.ServeMux</code>
          ranges from <strong>1.4×</strong> for deep param routes to <strong>4.3×</strong> for
          single-param routes — 110–1,036 ns absolute. For typical handlers spending 1 ms–100 ms
          on I/O, router cost is 0.001%–0.1% of request time.
          <a class="text-link" href="/releases">Full benchmark table on Releases →</a>
        </p>
      </article>
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro reveal">
      <h2>When to pause before adopting.</h2>
      <p>
        Plumego is not meant to win every comparison. If the signals below match your team's goals more closely, the explicit model may add more friction than value right now.
      </p>
    </div>
    <div class="control-grid reveal-stagger">
      {cautionProfiles.map((item) => (
        <article class="page-panel page-panel--dense page-panel--caution">
          <p class="signal-list__kicker">
            <CautionIcon class="comparison-cell-icon comparison-cell-icon--caution" size={13} />
            {item.kicker}
          </p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro reveal">
      <h2>What adoption looks like over time.</h2>
      <p>
        Plumego is intentionally narrow at entry and explicit about where it expands. Here is what the first three stages of adoption typically involve.
      </p>
    </div>
    <div class="timeline-grid reveal-stagger">
      <article class="timeline-card">
        <p class="timeline-card__kicker">Day 1</p>
        <h3>Run the canonical reference service in under 5 minutes</h3>
        <div class="code-block" style="margin: 0.75rem 0;">
          <div class="code-block__bar">
            <div class="code-block__dots"><span></span><span></span><span></span></div>
            <span class="code-block__filename">terminal</span>
          </div>
          <pre class="code-block__pre"><code>go run ./reference/standard-service
# → server started at :8080
# → GET /ping → &#123;"data":&#123;"message":"pong"&#125;&#125;</code></pre>
        </div>
        <p>
          Clone the repo, run the reference service, read <code>internal/app/routes.go</code>. The full request path is visible
          without reading any framework source. Start here before evaluating further.
        </p>
      </article>
      <article class="timeline-card">
        <p class="timeline-card__kicker">Day 30</p>
        <h3>Add a capability from x/* without touching stable roots</h3>
        <p>
          Once the stable-root baseline is working in your service, the next inflection point is whether you need a capability from
          the x/* layer — WebSocket, multi-tenancy, AI streaming, or edge proxying. Each x/* family attaches at the transport layer
          without modifying stable roots. You verify the boundary holds with <code>go run ./internal/checks/dependency-rules</code>.
        </p>
        <p>
          The <code>specs/task-routing.yaml</code> table tells you which x/* family owns any new capability before you start.
          The extension layer evolves at its own pace — stable roots stay unchanged.
        </p>
      </article>
      <article class="timeline-card">
        <p class="timeline-card__kicker">Day 90 and release evidence</p>
        <h3>After v1 is tagged, the upgrade path is deterministic</h3>
        <p>
          The 9 stable roots carry the v1 compatibility promise. After the v1 tag, the upgrade path for
