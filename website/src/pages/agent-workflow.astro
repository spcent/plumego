---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import PageHero from '../components/marketing/PageHero.astro';
import JourneyBar from '../components/marketing/JourneyBar.astro';

const journeySteps = [
  { label: 'Why Plumego', href: '/why-plumego' },
  { label: 'Ecosystem', href: '/ecosystem' },
  { label: 'Agent Workflow', href: '/agent-workflow' },
];

const controlPlaneFiles = [
  {
    file: 'specs/task-routing.yaml',
    role: 'Work classifier',
    desc: 'Maps task descriptions to owning modules. An agent reads this before opening any Go file — so ownership errors appear in the plan, not the diff.',
    example: `routing_rules:
  stable_root_work:
    intent: Change kernel, lifecycle, route structure,
            transport middleware, or storage primitives.
    destination: stable
    packages: [middleware, core, router, ...]
  extension_work:
    intent: Change product capability or protocol adaptation.
    destination: extension
    primary_families: [x/ai, x/tenant, x/gateway, ...]`,
  },
  {
    file: 'specs/dependency-rules.yaml',
    role: 'Import boundary enforcer',
    desc: 'Declares which layers can import which. Stable roots may not import x/*. Violations are caught by CI — not reviewer memory.',
    example: `rules:
  - from: stable_roots
    to: extensions
    allowed: false
    reason: Stable roots must not import x/* families.
  - from: extensions
    to: stable_roots
    allowed: true`,
  },
  {
    file: 'specs/change-recipes/',
    role: 'Predefined change sequences',
    desc: 'YAML files defining the correct step sequence for known change types. An agent following a recipe reads the steps, executes each, then runs the specified checkers.',
    example: `# specs/change-recipes/fix-bug.yaml
steps:
  - read: <module>/module.yaml
  - read: specs/dependency-rules.yaml
  - edit: target files
  - run: go test -race ./<module>/...
  - run: go run ./internal/checks/dependency-rules
  - run: make gates`,
  },
  {
    file: '<module>/module.yaml',
    role: 'Per-module manifest',
    desc: 'Each module declares its responsibilities, allowed imports, forbidden patterns, and required validation commands. Agents read this before editing.',
    example: `module: middleware
status: stable
responsibilities:
  - Transport-layer cross-cutting behavior only
  - next called exactly once per handler invocation
forbidden:
  - Business logic or DTO assembly
  - Importing x/* packages
validation:
  - go test -race ./middleware/...
  - go vet ./middleware/...`,
  },
  {
    file: 'internal/checks/*',
    role: 'CI-enforced gates',
    desc: 'Mechanical checkers for boundary compliance, manifest consistency, workflow adherence, and reference layout. Run locally before pushing — same as CI.',
    example: `# Run before every commit:
go run ./internal/checks/dependency-rules
go run ./internal/checks/agent-workflow
go run ./internal/checks/module-manifests
go run ./internal/checks/reference-layout

# Or run everything at once:
make gates`,
  },
];

const workflowSteps = [
  {
    n: '01',
    title: 'Classify ownership before touching code',
    body: 'Read specs/task-routing.yaml. Match the task description to a routing rule. Identify the owning module. This step runs before any file is opened.',
    signal: 'task-routing.yaml → owning module',
  },
  {
    n: '02',
    title: 'Read the module manifest',
    body: 'Open <module>/module.yaml. Read the responsibilities, forbidden patterns, and required validation commands. Know the scope before writing.',
    signal: 'module.yaml → local constraints',
  },
  {
    n: '03',
    title: 'Check for a predefined recipe',
    body: 'If specs/change-recipes/ has a recipe for this change type, follow its defined step sequence. Known change types should not require agent improvisation.',
    signal: 'change-recipes/ → execution sequence',
  },
  {
    n: '04',
    title: 'Verify import boundaries before committing',
    body: 'Run go run ./internal/checks/dependency-rules. If the check passes, the change does not introduce hidden coupling. If it fails, fix the specific boundary violation.',
    signal: 'dependency-rules check → no boundary violations',
  },
  {
    n: '05',
    title: 'Run the full gate suite',
    body: 'Run make gates before pushing. This mirrors CI: gofmt, go vet, race tests, boundary checks, manifest checks, and reference layout validation.',
    signal: 'make gates → green',
  },
];

const comparisonRows = [
  {
    aspect: 'Ownership classification',
    conventional: 'Lives in team memory and PR review conventions',
    agentReady: 'Machine-readable in specs/task-routing.yaml — agents read it before writing',
  },
  {
    aspect: 'Import boundary rules',
    conventional: 'Enforced by reviewer knowledge and linter config',
    agentReady: 'Declared in specs/dependency-rules.yaml, enforced by internal/checks/ at CI time',
  },
  {
    aspect: 'Change sequences',
    conventional: 'Implied by team practice, varies per person',
    agentReady: 'Explicit in specs/change-recipes/ — known change types have defined steps',
  },
  {
    aspect: 'Module scope',
    conventional: 'Inferred from package names and existing code',
    agentReady: 'Declared in module.yaml per module — responsibilities, limits, and validation commands',
  },
  {
    aspect: 'Validation before commit',
    conventional: 'Team-specific checklist, often skipped',
    agentReady: 'make gates mirrors CI — one command, consistent, required',
  },
];
---

<MarketingLayout
  locale="en"
  title="Agent-Ready Workflow"
  description="How Plumego's machine-readable control plane lets AI coding agents classify work, enforce boundaries, and follow defined change paths — without relying on team memory."
  currentPath="/agent-workflow"
  keywords={['agent-ready go', 'ai coding agent go', 'plumego agent workflow', 'machine-readable go architecture']}
>
  <PageHero
    eyebrow="agent-ready by structure"
    title="Code your agents can read. Services your team can review."
    description="Plumego externalizes architectural conventions into machine-readable files. AI coding agents can classify ownership, check import boundaries, and follow predefined change sequences — without relying on team memory or framework documentation."
    visual="architecture"
    links={[
      { label: 'Read the full docs', href: '/docs/concepts/agent-first-workflow' },
      { label: 'Get started', href: '/docs/getting-started' },
    ]}
  />

  <JourneyBar steps={journeySteps} current="/agent-workflow" />

  <!-- The problem -->
  <section class="section">
    <div class="section-inner section-inner--narrow">
      <p class="section-eyebrow">the problem</p>
      <h2 class="section-title">Most codebases are opaque to AI agents</h2>
      <p class="section-lead">
        AI coding assistants write code that compiles and passes tests — but frequently violates architectural conventions, introduces hidden coupling, or edits the wrong module. Not because the model is wrong, but because the conventions live in team memory and PR comments, not in a form the model can read before writing.
      </p>
      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>Aspect</th>
              <th>Conventional codebase</th>
              <th>Plumego agent-ready codebase</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row) => (
              <tr>
                <td class="comparison-table__aspect">{row.aspect}</td>
                <td class="comparison-table__before">{row.conventional}</td>
                <td class="comparison-table__after">{row.agentReady}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Control plane files -->
  <section class="section section--alt">
    <div class="section-inner">
      <p class="section-eyebrow">the control plane</p>
      <h2 class="section-title">Five files that make a codebase agent-ready</h2>
      <p class="section-lead">
        Plumego's <code>specs/</code> and <code>module.yaml</code> files are a first-class part of the repository. They are not documentation — they are machine-readable operating rules that agents read before editing any Go file.
      </p>
      <div class="cp-grid">
        {controlPlaneFiles.map((f) => (
          <div class="cp-card">
            <div class="cp-card__head">
              <code class="cp-card__file">{f.file}</code>
              <span class="cp-card__role">{f.role}</span>
            </div>
            <p class="cp-card__desc">{f.desc}</p>
            <pre class="cp-card__code"><code>{f.example}</code></pre>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Agent workflow steps -->
  <section class="section">
    <div class="section-inner section-inner--narrow">
      <p class="section-eyebrow">the workflow</p>
      <h2 class="section-title">What an agent does before editing Go code</h2>
      <p class="section-lead">
        The classification step is intentionally front-loaded. Boundary violations and ownership errors should appear in the plan — not in the diff or in CI.
      </p>
      <div class="workflow-steps">
        {workflowSteps.map((step) => (
          <div class="workflow-step">
            <span class="workflow-step__n">{step.n}</span>
            <div class="workflow-step__body">
              <p class="workflow-step__title">{step.title}</p>
              <p class="workflow-step__desc">{step.body}</p>
              <code class="workflow-step__signal">{step.signal}</code>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Worked example -->
  <section class="section section--alt">
    <div class="section-inner section-inner--narrow">
      <p class="section-eyebrow">worked example</p>
      <h2 class="section-title">"Add rate limiting to the inbound greet endpoint"</h2>
      <p class="section-lead">A complete task routing decision from description to owning module.</p>

      <div class="example-steps">
        <div class="example-step">
          <p class="example-step__label">Step 1 — Read task-routing.yaml</p>
          <p class="example-step__body">Signals in the task: "inbound" (transport concern), "rate limiting" (middleware class), "greet endpoint" (route registration).</p>
        </div>
        <div class="example-step">
          <p class="example-step__label">Step 2 — Classify</p>
          <div class="example-table-wrap">
            <table class="example-table">
              <thead><tr><th>Signal in the task</th><th>Routing match</th><th>Owner</th></tr></thead>
              <tbody>
                <tr><td>"inbound"</td><td>Transport concern, not product logic</td><td><code>stable_root_work</code></td></tr>
                <tr><td>"rate limiting" on inbound</td><td>Transport middleware, not circuit breaker</td><td><code>middleware</code></td></tr>
                <tr><td>"greet endpoint"</td><td>Route registration, app-local</td><td><code>app_wiring</code></td></tr>
              </tbody>
            </table>
          </div>
        </div>
        <div class="example-step">
          <p class="example-step__label">Step 3 — Result</p>
          <p class="example-step__body">
            The change belongs in <code>middleware/</code>, starting from <code>middleware/module.yaml</code>.
            <br/>
            <code>x/resilience</code> is for outbound circuit protection — a different classification.
            Opening <code>x/resilience</code> first would be an ownership error the routing table prevents.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stop condition handlers — new section -->
  <section class="section">
    <div class="section-inner section-inner--narrow">
      <p class="section-eyebrow">stop conditions</p>
      <h2 class="section-title">What happens when the agent hits a blocker</h2>
      <p class="section-lead">
        Not every task has a clear path. When an agent reaches a stop condition — unclear ownership, conflicting specs, missing acceptance criteria — the resolution path is also machine-readable.
      </p>
      <div class="stop-grid">
        <div class="stop-card">
          <p class="stop-card__trigger">Owning module is unclear</p>
          <p class="stop-card__action">Read <code>specs/task-routing.yaml</code> → escalate with the specific routing conflict to a human reviewer</p>
        </div>
        <div class="stop-card">
          <p class="stop-card__trigger">Change would force a stable root to import x/*</p>
          <p class="stop-card__action">Stop immediately → record the blocker in the task card → do not widen scope without explicit approval</p>
        </div>
        <div class="stop-card">
          <p class="stop-card__trigger">Task lacks acceptance criteria</p>
          <p class="stop-card__action">Switch to analysis mode only → produce a preflight checklist → ask for acceptance criteria before editing</p>
        </div>
        <div class="stop-card">
          <p class="stop-card__trigger">Spec, manifest, and local pattern conflict</p>
          <p class="stop-card__action">Read <code>specs/stop-condition-handlers.yaml</code> → follow the deterministic resolution path for that condition</p>
        </div>
      </div>
      <p class="stop-note">Every stop condition in <code>specs/stop-condition-handlers.yaml</code> maps to concrete next steps, an escalation action, and unblock criteria — not an open-ended decision tree.</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--alt">
    <div class="section-inner section-inner--narrow">
      <div class="final-cta-panel">
        <p class="final-cta-panel__eyebrow">go deeper</p>
        <h2 class="final-cta-panel__title">Full technical reference in the docs</h2>
        <p class="final-cta-panel__body">
          The docs page covers work routing in detail, boundary enforcement, change recipes, and what to do when an agent change crosses a module boundary.
        </p>
        <div class="final-cta-panel__actions">
          <a href="/docs/concepts/agent-first-workflow" class="btn btn--primary">
            Agent-first Workflow Docs
          </a>
          <a href="/docs/concepts/repo-control-plane" class="btn btn--ghost">
            Repository Control Plane
          </a>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .section { padding: 4rem 1.5rem; }
  .section--alt { background: var(--bg-strong); }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-inner--narrow { max-width: 820px; margin: 0 auto; }
  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 1rem;
  }
  .section-lead {
    font-size: 1.05rem;
    color: var(--fg-soft);
    line-height: 1.65;
    margin-bottom: 2rem;
  }

  /* Comparison table */
  .comparison-table-wrap { overflow-x: auto; }
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .comparison-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    background: var(--bg-strong);
    color: var(--fg-soft);
    font-weight: 600;
    border-bottom: 1px solid var(--line);
  }
  .comparison-table td {
    padding: 0.75rem 1rem;
    vertical-align: top;
    border-bottom: 1px solid var(--line);
    line-height: 1.5;
  }
  .comparison-table__aspect { font-weight: 600; color: var(--fg); width: 20%; }
  .comparison-table__before { color: var(--fg-soft); width: 40%; }
  .comparison-table__after { color: var(--fg); width: 40%; }

  /* Control plane grid */
  .cp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
    gap: 1.25rem;
  }
  .cp-card {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 1.5rem;
  }
  .cp-card__head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .cp-card__file {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }
  .cp-card__role {
    font-size: 0.8rem;
    color: var(--fg-soft);
    font-weight: 500;
  }
  .cp-card__desc {
    font-size: 0.9rem;
    color: var(--fg-soft);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .cp-card__code {
    background: var(--code-bg);
    border-radius: 7px;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.78rem;
    line-height: 1.55;
    color: var(--code-text);
    font-family: var(--font-mono);
    white-space: pre;
    margin: 0;
  }

  /* Workflow steps */
  .workflow-steps { display: flex; flex-direction: column; gap: 0; }
  .workflow-step {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--line);
    align-items: flex-start;
  }
  .workflow-step:last-child { border-bottom: none; }
  .workflow-step__n {
    font-family: var(--font-mono);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--accent);
    opacity: 0.45;
    flex-shrink: 0;
    width: 2.5rem;
    padding-top: 0.15rem;
  }
  .workflow-step__title {
    font-weight: 600;
    font-size: 1rem;
    color: var(--fg);
    margin-bottom: 0.4rem;
  }
  .workflow-step__desc {
    font-size: 0.9rem;
    color: var(--fg-soft);
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }
  .workflow-step__signal {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    display: inline-block;
  }

  /* Worked example */
  .example-steps { display: flex; flex-direction: column; gap: 1.25rem; }
  .example-step {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
  }
  .example-step__label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.6rem;
  }
  .example-step__body {
    font-size: 0.9rem;
    color: var(--fg-soft);
    line-height: 1.6;
  }
  .example-table-wrap { overflow-x: auto; }
  .example-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }
  .example-table th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    background: var(--bg-strong);
    color: var(--fg-soft);
    font-weight: 600;
    font-size: 0.8rem;
    border-bottom: 1px solid var(--line);
  }
  .example-table td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--line);
    color: var(--fg-soft);
    line-height: 1.5;
    vertical-align: top;
  }
  .example-table tr:last-child td { border-bottom: none; }

  /* Final CTA */
  .final-cta-panel {
    background: var(--bg-strong);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 2.5rem;
    text-align: center;
  }
  .final-cta-panel__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .final-cta-panel__title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 0.75rem;
  }
  .final-cta-panel__body {
    font-size: 1rem;
    color: var(--fg-soft);
    line-height: 1.65;
    max-width: 560px;
    margin: 0 auto 1.75rem;
  }
  .final-cta-panel__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.4rem;
    border-radius: 7px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn--primary {
    background: var(--hero-button-primary-bg);
    color: var(--hero-button-primary-fg);
    border: 1px solid var(--hero-button-primary-border);
  }
  .btn--ghost {
    background: var(--hero-button-ghost-bg);
    color: var(--hero-button-ghost-fg);
    border: 1px solid var(--hero-button-ghost-border);
  }
  .btn:hover { opacity: 0.88; }

  /* Stop conditions grid */
  .stop-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.85rem;
    margin-bottom: 1.25rem;
  }

  @media (min-width: 640px) {
    .stop-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .stop-card {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-left: 3px solid color-mix(in srgb, #b45309 50%, var(--line));
    border-radius: 0.6rem;
    padding: 1rem 1.2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  :root[data-theme="dark"] .stop-card {
    border-left-color: color-mix(in srgb, #fbbf4a 35%, var(--line));
  }

  .stop-card__trigger {
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--fg);
    margin: 0;
  }

  .stop-card__action {
    font-size: 0.82rem;
    color: var(--fg-soft);
    line-height: 1.55;
    margin: 0;
  }

  .stop-card__action code {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.08rem 0.35rem;
    border-radius: 0.2rem;
  }

  .stop-note {
    font-size: 0.83rem;
    color: var(--fg-soft);
    font-style: italic;
    line-height: 1.55;
    border-left: 2px solid var(--line);
    padding-left: 0.75rem;
    margin: 0;
  }

  .stop-note code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.08rem 0.35rem;
    border-radius: 0.2rem;
  }
</style>
