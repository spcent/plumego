---
import AgentFirstShowcase from '../components/home/AgentFirstShowcase.astro';
import CoreDifferentiators from '../components/home/CoreDifferentiators.astro';
import FinalCta from '../components/home/FinalCta.astro';
import Hero from '../components/home/Hero.astro';
import MinimalExample from '../components/home/MinimalExample.astro';
import StabilityBand from '../components/home/StabilityBand.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { HOME_COPY } from '../data/site';

const copy = HOME_COPY.en;
---

<MarketingLayout
  locale="en"
  title="Go HTTP Toolkit for Teams and AI Agents — Explicit, Zero-Dependency, Machine-Readable"
  description="Plumego is a Go 1.26+ stdlib-first HTTP toolkit. Routing, middleware, and service wiring stay visible in code — readable by human reviewers and AI coding agents sharing the same route map."
  currentPath="/"
>
  <Hero copy={copy} />

  <CoreDifferentiators locale="en" />

  <AgentFirstShowcase locale="en" />

  <MinimalExample locale="en" />

  <StabilityBand
    title={copy.stabilityBandTitle}
    items={copy.stabilityBandItems}
    cta={copy.stabilityBandCta}
  />

  <section class="section decision-paths-section">
    <div class="section__intro section__intro--center">
      <p class="decision-paths__eyebrow">where to start</p>
      <h2>{copy.adoptionTitle}</h2>
      <p>{copy.adoptionBody}</p>
    </div>
    <div class="decision-paths-grid reveal-stagger">
      {copy.adoptionCards.map((card: { kicker: string; title: string; body: string; href: string; label: string }) => (
        <article class="decision-card">
          <p class="decision-card__kicker">{card.kicker}</p>
          <h3>{card.title}</h3>
          <p>{card.body}</p>
          <a class="decision-card__cta" href={card.href}>{card.label} →</a>
        </article>
      ))}
    </div>
  </section>

  <FinalCta copy={copy} />
</MarketingLayout>

<style>
  .decision-paths-section {
    padding-block: 4rem;
  }

  .decision-paths__eyebrow {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    text-align: center;
    margin: 0 0 0.5rem;
  }

  .decision-paths-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    max-width: 64rem;
    margin-inline: auto;
  }

  @media (min-width: 640px) {
    .decision-paths-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .decision-paths-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .decision-card {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 0.75rem;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-shadow: var(--shadow);
    transition: border-color 0.18s, box-shadow 0.18s;
  }

  .decision-card:hover {
    border-color: color-mix(in srgb, var(--accent) 30%, var(--line));
    box-shadow: var(--shadow), 0 0 0 3px var(--accent-soft);
  }

  .decision-card__kicker {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
  }

  .decision-card h3 {
    font-size: 1rem;
    font-weight: 600;
    margin: 0;
    color: var(--fg);
    line-height: 1.3;
  }

  .decision-card p {
    font-size: 0.875rem;
    color: var(--fg-soft);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .decision-card__cta {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
    text-decoration: none;
    margin-top: 0.25rem;
    transition: color 0.15s;
  }

  .decision-card__cta:hover {
    color: var(--accent-strong);
    text-decoration: underline;
  }
</style>
