---
import AdoptionNav from '../components/home/AdoptionNav.astro';
import CanonicalPath from '../components/home/CanonicalPath.astro';
import FinalCta from '../components/home/FinalCta.astro';
import Hero from '../components/home/Hero.astro';
import MinimalExample from '../components/home/MinimalExample.astro';
import ValueProps from '../components/home/ValueProps.astro';
import WiringContrast from '../components/home/WiringContrast.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { HOME_COPY } from '../data/site';

const copy = HOME_COPY.en;
---

<MarketingLayout
  locale="en"
  title="stdlib-first Go HTTP Toolkit"
  description="A stdlib-first Go web toolkit for explicit HTTP services — visible route ownership, narrow stable roots, and a canonical reference path."
  currentPath="/"
>
  <Hero copy={copy} />
  <MinimalExample locale="en" />
  <WiringContrast copy={copy} />
  <CanonicalPath copy={copy} />

  <section class="section stability-signal-strip">
    <div class="stability-signal-strip__inner">
      <span class="stability-signal-strip__item stability-signal-strip__item--stable">
        <strong>Stable roots</strong> — long-term API target: core, router, contract, middleware, security, store, health, log, metrics
      </span>
      <span class="stability-signal-strip__divider" aria-hidden="true">·</span>
      <span class="stability-signal-strip__item stability-signal-strip__item--experimental">
        <strong>x/* families</strong> — experimental unless labeled otherwise
      </span>
      <a class="text-link stability-signal-strip__cta" href="/releases">Check module maturity →</a>
    </div>
  </section>

  <ValueProps copy={copy} />
  <AdoptionNav copy={copy} />
  <FinalCta copy={copy} />
</MarketingLayout>
