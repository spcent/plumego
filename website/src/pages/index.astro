---
import CanonicalPath from '../components/home/CanonicalPath.astro';
import FinalCta from '../components/home/FinalCta.astro';
import Hero from '../components/home/Hero.astro';
import ModuleMap from '../components/home/ModuleMap.astro';
import ValueProps from '../components/home/ValueProps.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { HOME_COPY } from '../data/site';

const copy = HOME_COPY.en;
---

<MarketingLayout
  locale="en"
  title="Standard Library First"
  description="A stdlib-first Go web toolkit with clear module boundaries."
  currentPath="/"
>
  <Hero copy={copy} />
  <ValueProps copy={copy} />
  <ModuleMap copy={copy} />
  <CanonicalPath copy={copy} />
  <FinalCta copy={copy} />
</MarketingLayout>
