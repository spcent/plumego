---
import FinalCta from '../components/home/FinalCta.astro';
import Hero from '../components/home/Hero.astro';
import ValueProps from '../components/home/ValueProps.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { HOME_COPY } from '../data/site';

const copy = HOME_COPY.en;
---

<MarketingLayout
  locale="en"
  title="Explicit Go HTTP Services"
  description="A stdlib-first Go web toolkit for explicit HTTP services, narrow stable roots, and a visible reference path."
  currentPath="/"
>
  <Hero copy={copy} />
  <ValueProps copy={copy} />
  <FinalCta copy={copy} />
</MarketingLayout>
