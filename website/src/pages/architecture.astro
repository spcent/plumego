---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import PageHero from '../components/marketing/PageHero.astro';
import JourneyBar from '../components/marketing/JourneyBar.astro';
import LayerDiagram from '../components/marketing/LayerDiagram.astro';
import RequestFlowViz from '../components/marketing/RequestFlowViz.astro';
import { ARCHITECTURE_COPY } from '../data/site';
import { MODULE_FACTS } from '../generated/modules';

const copy = ARCHITECTURE_COPY.en;

const journeySteps = [
  { label: 'Why Plumego', href: '/why-plumego' },
  { label: 'Architecture', href: '/architecture' },
  { label: 'Examples', href: '/examples' },
  { label: 'Releases', href: '/releases' },
];

const requestFlowNodes = [
  {
    step: '01',
    title: 'Edge request enters through net/http',
    code: 'net/http',
    note: 'Keep the entry boring so ownership starts in visible code.',
    accent: false,
  },
  {
    step: '02',
    title: 'App-local wiring assembles dependencies',
    code: 'internal/app/app.go',
    note: 'Bootstrap discipline protects readability.',
    accent: true,
  },
  {
    step: '03',
    title: 'Routes classify the public request path',
    code: 'internal/app/routes.go',
    note: 'Route registration is the first architectural map.',
    accent: true,
  },
  {
    step: '04',
    title: 'Capability work branches only after the path is clear',
    code: 'handler / x/*',
    note: 'Expansion follows classification, not convenience.',
    accent: false,
  },
] as const;

const comparisonRows = [
  {
    aspect: 'Ownership test',
    stable: 'Does this belong to almost every service and need a stronger compatibility promise?',
    extension: 'Is this optional, protocol-specific, or product-shaped work that should not redefine the default path?',
  },
  {
    aspect: 'Change velocity',
    stable: 'Slower, narrower, and easier to defend in review because the compatibility burden is higher.',
    extension: 'Allowed to evolve faster as long as the boundary with the canonical path stays legible.',
  },
  {
    aspect: 'Reader expectation',
    stable: 'A newcomer should be able to understand why the module exists from the docs and the reference app alone.',
    extension: 'A newcomer should first understand why they need it before opening the package family.',
  },
] as const;

const repositorySignals = [
  {
    label: 'docs',
    title: 'Learning path and boundary explanation',
    body: 'Docs teach the canonical path, request flow, and public mental model before readers start inferring structure from package names alone.',
    href: '/docs',
    cta: 'Open docs',
  },
  {
    label: 'reference',
    title: 'Runnable service shape',
    body: 'reference/standard-service keeps the default bootstrap and route ownership visible so newcomers have one repository baseline to compare against.',
    href: '/docs/reference-app',
    cta: 'Read the reference app',
  },
  {
    label: 'generated facts',
    title: 'Published inventory and maturity signals',
    body: 'Synced facts turn stable roots, extension families, and maturity signals into machine-readable signals instead of duplicated marketing claims.',
    href: '/releases',
    cta: 'Inspect module maturity',
  },
  {
    label: 'app-local code',
    title: 'The place where ownership stays visible',
    body: 'internal/app is where service-specific wiring stays obvious. It should remain the first stop before deeper capability packages enter the conversation.',
    href: '/examples',
    cta: 'See example paths',
  },
] as const;
---

<MarketingLayout
  locale="en"
  title={copy.title}
  description={copy.description}
  currentPath="/architecture"
  keywords={['plumego architecture', 'go service architecture', 'stdlib-first go', 'explicit http services']}
>
  <PageHero
    eyebrow={copy.eyebrow}
    title={copy.title}
    description={copy.description}
    links={[
      { label: 'Examples', href: '/examples' },
      { label: 'Docs', href: '/docs' },
    ]}
  />

  <JourneyBar steps={journeySteps} current="/architecture" />

  <section class="section">
    <div class="section__intro">
      <h2>{copy.introTitle}</h2>
      <p>{copy.introBody}</p>
    </div>
    <div class="signal-list">
      {copy.guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- Three-zone architecture diagram -->
  <section class="section section--tinted">
    <div class="section__intro">
      <h2>Three cooperating zones — visible on one screen.</h2>
      <p>
        Plumego becomes easier to trust when the kernel, the canonical reading path, and the outward expansion families are all visible with actual repository facts behind them.
      </p>
    </div>
    <LayerDiagram />
  </section>

  <!-- Layers explanation (from copy) -->
  <section class="section">
    <div class="section__intro">
      <h2>{copy.sectionTitle}</h2>
      <p>{copy.sectionBody}</p>
    </div>
    <div class="page-grid">
      {copy.layers.map((item) => (
        <article class="page-panel">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
          <ul>
            {item.items.map((entry) => (
              <li>{entry}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <!-- Request flow: visual diagram + step details -->
  <section class="section section--tinted">
    <div class="section__intro">
      <h2>{copy.flowTitle}</h2>
      <p>{copy.flowBody}</p>
    </div>
    <RequestFlowViz nodes={requestFlowNodes} />
  </section>

  <!-- Routes.go code example -->
  <section class="section">
    <div class="section__intro">
      <h2>What the canonical path looks like in code.</h2>
      <p>
        Route registration is the first architectural map of a service. In Plumego, it lives in one explicit file — readable in any code review without opening framework source.
      </p>
    </div>
    <div class="contrast-grid">
      <div class="code-block">
        <div class="code-block__bar">
          <div class="code-block__dots"><span></span><span></span><span></span></div>
          <span class="code-block__filename">internal/app/routes.go</span>
        </div>
        <pre class="code-block__pre"><code><span class="hc-kw">func</span> (a *App) <span class="hc-fn">Routes</span>() http.Handler &#123;
    r := router.<span class="hc-fn">New</span>()

    r.<span class="hc-fn">Use</span>(middleware.<span class="hc-fn">RequestID</span>())
    r.<span class="hc-fn">Use</span>(middleware.<span class="hc-fn">Logger</span>(a.log))
    r.<span class="hc-fn">Use</span>(middleware.<span class="hc-fn">Recovery</span>(a.log))

    r.<span class="hc-fn">Get</span>(<span class="hc-str">"/api/items"</span>,  a.items.<span class="hc-fn">List</span>)
    r.<span class="hc-fn">Post</span>(<span class="hc-str">"/api/items"</span>, a.items.<span class="hc-fn">Create</span>)
    r.<span class="hc-fn">Get</span>(<span class="hc-str">"/api/orders"</span>, a.orders.<span class="hc-fn">List</span>)

    r.<span class="hc-fn">Get</span>(<span class="hc-str">"/health"</span>, health.<span class="hc-fn">Handler</span>(a.checker))

    <span class="hc-cm">// full route map visible here — no hidden registration</span>
    <span class="hc-kw">return</span> r
&#125;</code></pre>
      </div>
      <div class="code-block">
        <div class="code-block__bar">
          <div class="code-block__dots"><span></span><span></span><span></span></div>
          <span class="code-block__filename">internal/app/app.go</span>
        </div>
        <pre class="code-block__pre"><code><span class="hc-kw">type</span> App <span class="hc-kw">struct</span> &#123;
    log     log.Logger
    db      *sql.DB
    items   *items.Handler
    orders  *orders.Handler
    checker health.Checker
&#125;

<span class="hc-kw">func</span> <span class="hc-fn">New</span>(cfg *config.Config, deps AppDeps) (*App, error) &#123;
    <span class="hc-cm">// explicit — every dependency named here</span>
    <span class="hc-kw">return</span> &App&#123;
        log:     deps.Logger,
        db:      deps.DB,
        items:   items.<span class="hc-fn">NewHandler</span>(deps.DB),
        orders:  orders.<span class="hc-fn">NewHandler</span>(deps.DB),
        checker: health.<span class="hc-fn">NewChecker</span>(),
    &#125;, <span class="hc-kw">nil</span>
&#125;</code></pre>
      </div>
    </div>
  </section>

  <!-- Stable root vs discouraged roots vs extension -->
  <section class="section section--tinted">
    <div class="section__intro">
      <h2>Stable-root signals should stay explicit.</h2>
      <p>
        The architecture page should not just name the kernel. It should also explain what kind of work belongs there and which root names are a
        warning sign that capability concerns are drifting inward.
      </p>
    </div>
    <div class="page-grid">
      <article class="page-panel page-panel--dense page-panel--fit">
        <p class="signal-list__kicker">stable-root work intent</p>
        <h3>Use the kernel for long-lived transport and lifecycle concerns</h3>
        <p>{MODULE_FACTS.stableRootWorkIntent}</p>
        <ul>
          {MODULE_FACTS.stableRoots.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
      <article class="page-panel page-panel--dense page-panel--caution">
        <p class="signal-list__kicker">discouraged roots</p>
        <h3>Capability-shaped names are usually a signal to branch outward</h3>
        <p>
          These names are useful as product or protocol concerns, but they are poor default roots because they blur the ownership boundary of the
          kernel.
        </p>
        <ul>
          {MODULE_FACTS.discouragedRoots.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
      <article class="page-panel page-panel--dense">
        <p class="signal-list__kicker">extension work intent</p>
        <h3>Let outward families move faster without redefining the default path</h3>
        <p>{MODULE_FACTS.extensionWorkIntent}</p>
        <ul>
          {MODULE_FACTS.allExtensionPaths.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  <!-- Comparison table: stable vs extension -->
  <section class="section">
    <div class="section__intro">
      <h2>Stable roots vs extension modules: an ownership distinction, not a capability distinction.</h2>
      <p>
        Both layers matter. The difference is that one protects the default path for almost every service, while the other protects optional
        capability work from leaking inward.
      </p>
    </div>
    <div class="comparison-table" role="table" aria-label="Stable roots compared with extension modules">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">Aspect</span>
        <span role="columnheader">Stable roots</span>
        <span role="columnheader">Extension modules</span>
      </div>
      {comparisonRows.map((row) => (
        <div class="comparison-table__row" role="row">
          <strong role="cell">{row.aspect}</strong>
          <span role="cell">{row.stable}</span>
          <span role="cell">{row.extension}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Repository shape -->
  <section class="section section--tinted">
    <div class="section__intro">
      <h2>Repository shape should reinforce the same mental model.</h2>
      <p>
        The architecture is not only a package story. It is also a repository story: docs teach the path, the reference app proves it, synced
        facts publish the boundaries, and app-local code keeps service ownership readable.
      </p>
    </div>
    <div class="control-grid control-grid--tight">
      {repositorySignals.map((item) => (
        <article class="control-grid__item">
          <p class="signal-list__kicker">{item.label}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
          <a class="text-link" href={item.href}>{item.cta}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>Continue with the reference path.</h2>
      <p>Use the architecture page to classify work, then return to docs and runnable examples for actual adoption.</p>
    </div>
    <div class="page-links">
      <a class="text-link" href="/docs/getting-started">Open getting started</a>
      <a class="text-link" href="/docs/reference-app">Read the reference app</a>
      <a class="text-link" href="/examples">Open examples</a>
      <a class="text-link" href="/releases">Inspect releases</a>
    </div>
  </section>
</MarketingLayout>
