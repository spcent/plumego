---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import PageHero from '../components/marketing/PageHero.astro';
import { ARCHITECTURE_COPY } from '../data/site';

const copy = ARCHITECTURE_COPY.en;

const requestFlow = [
  {
    label: '01',
    title: 'Edge request enters through net/http',
    body: 'The request starts in the standard library surface. Transport stays obvious before Plumego-specific wiring begins.',
    note: 'Keep the entry boring so ownership starts in visible code.',
  },
  {
    label: '02',
    title: 'App-local wiring assembles dependencies',
    body: 'internal/app/app.go should explain what the service owns locally, what gets injected, and which collaborators are optional.',
    note: 'This is where bootstrap discipline protects readability.',
  },
  {
    label: '03',
    title: 'Routes classify the public request path',
    body: 'internal/app/routes.go shows which handlers are public, which middleware participates, and where transport control should stop.',
    note: 'Route registration is the first architectural map, not a detail to skip.',
  },
  {
    label: '04',
    title: 'Capability work branches only after the path is clear',
    body: 'Once the canonical path is visible, deeper work can move into stable roots or x/* families without collapsing everything into the kernel.',
    note: 'Expansion follows classification, not convenience.',
  },
] as const;

const topologyColumns = [
  {
    label: 'stable roots',
    title: 'Compatibility-first kernel',
    body: 'These modules carry the long-lived burden. They should stay smaller, slower-moving, and explainable without repository archaeology.',
    items: ['contract', 'core', 'router', 'middleware', 'security'],
  },
  {
    label: 'canonical path',
    title: 'The one reading path every newcomer should learn first',
    body: 'The site, docs, and reference app all reinforce the same journey from bootstrap to route registration to request handling.',
    items: ['docs/getting-started', 'docs/reference-app', 'internal/app/app.go', 'internal/app/routes.go'],
  },
  {
    label: 'x/* families',
    title: 'Capability families that expand outward',
    body: 'Optional product or protocol work belongs here. Useful surfaces are allowed to move faster without pretending the kernel must absorb them.',
    items: ['x/ai', 'x/data', 'x/gateway', 'x/messaging', 'x/rest', 'x/websocket'],
  },
] as const;

const comparisonRows = [
  {
    aspect: 'Ownership test',
    stable: 'Does this belong to almost every service and need a stronger compatibility promise?',
    extension: 'Is this optional, protocol-specific, or product-shaped work that should not redefine the default path?',
  },
  {
    aspect: 'Change velocity',
    stable: 'Slower, narrower, and easier to defend in review because the compatibility burden is higher.',
    extension: 'Allowed to evolve faster as long as the boundary with the canonical path stays legible.',
  },
  {
    aspect: 'Reader expectation',
    stable: 'A newcomer should be able to understand why the module exists from the docs and the reference app alone.',
    extension: 'A newcomer should first understand why they need it before opening the package family.',
  },
] as const;
---

<MarketingLayout
  locale="en"
  title={copy.title}
  description={copy.description}
  currentPath="/architecture"
  keywords={['plumego architecture', 'go service architecture', 'stdlib-first go', 'explicit http services']}
>
  <PageHero
    eyebrow={copy.eyebrow}
    title={copy.title}
    description={copy.description}
    links={[
      { label: 'Examples', href: '/examples' },
      { label: 'Docs', href: '/docs' },
    ]}
  />

  <section class="section">
    <div class="section__intro">
      <h2>{copy.introTitle}</h2>
      <p>{copy.introBody}</p>
    </div>
    <div class="signal-list">
      {copy.guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>See the architecture as three cooperating zones</h2>
      <p>
        Plumego becomes easier to trust when the kernel, the canonical reading path, and the outward expansion families are all visible on
        one screen.
      </p>
    </div>
    <div class="topology-board">
      {topologyColumns.map((column) => (
        <article class="topology-node">
          <p class="signal-list__kicker">{column.label}</p>
          <h3>{column.title}</h3>
          <p>{column.body}</p>
          <ul>
            {column.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--split section--architecture-flow">
    <div class="section__intro">
      <h2>{copy.flowTitle}</h2>
      <p>{copy.flowBody}</p>
    </div>
    <div class="request-flow-rail">
      {requestFlow.map((step) => (
        <article class="request-flow-step">
          <div>
            <p class="signal-list__kicker">{step.label}</p>
            <h3>{step.title}</h3>
          </div>
          <p>{step.body}</p>
          <p class="request-flow-step__note">{step.note}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.sectionTitle}</h2>
      <p>{copy.sectionBody}</p>
    </div>
    <div class="page-grid">
      {copy.layers.map((item) => (
        <article class="page-panel">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
          <ul>
            {item.items.map((entry) => (
              <li>{entry}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>Stable roots vs x/* is an ownership distinction, not a branding distinction</h2>
      <p>
        Both layers matter. The difference is that one protects the default path for almost every service, while the other protects optional
        capability work from leaking inward.
      </p>
    </div>
    <div class="comparison-table" role="table" aria-label="Stable roots compared with x families">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">Signal</span>
        <span role="columnheader">Stable roots</span>
        <span role="columnheader">x/* families</span>
      </div>
      {comparisonRows.map((row) => (
        <div class="comparison-table__row" role="row">
          <strong role="cell">{row.aspect}</strong>
          <span role="cell">{row.stable}</span>
          <span role="cell">{row.extension}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>Continue with the reference path</h2>
      <p>Use the architecture page to classify work, then return to docs and runnable examples for actual adoption.</p>
    </div>
    <div class="page-links">
      <a class="text-link" href="/docs/getting-started">Open getting started</a>
      <a class="text-link" href="/docs/reference-app">Read the reference app</a>
      <a class="text-link" href="/examples">Open examples</a>
    </div>
  </section>
</MarketingLayout>
