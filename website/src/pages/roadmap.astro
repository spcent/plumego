---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { ROADMAP_COPY } from '../data/site';
import { ROADMAP_FACTS } from '../generated/roadmap';

const copy = ROADMAP_COPY.en;
---

<MarketingLayout locale="en" title={copy.title} description={copy.description} currentPath="/roadmap">
  <section class="page-hero">
    <p class="hero__eyebrow">Repository Direction</p>
    <h1>{copy.title}</h1>
    <p>{copy.description}</p>
  </section>
  <section class="page-grid">
    {[
      { title: 'Current baseline', items: ROADMAP_FACTS.currentBaseline },
      { title: 'In progress', items: ROADMAP_FACTS.inProgress },
      { title: 'Planned', items: ROADMAP_FACTS.planned },
      { title: 'Suggested execution order', items: ROADMAP_FACTS.suggestedExecutionOrder },
    ].map((section) => (
      <article class="page-panel">
        <h2>{section.title}</h2>
        <ul>
          {section.items.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    ))}
  </section>
</MarketingLayout>
