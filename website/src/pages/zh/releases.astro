---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import PageHero from '../../components/marketing/PageHero.astro';
import JourneyBar from '../../components/marketing/JourneyBar.astro';
import { RELEASE_COPY, SITE } from '../../data/site';
import { RELEASE_FACTS } from '../../generated/releases';
import { MODULE_FACTS } from '../../generated/modules';

const copy = RELEASE_COPY.zh;
const stableGroups = RELEASE_FACTS.supportMatrix.filter((entry) => /GA|Stable-root/i.test(entry.status)).length;
const experimentalGroups = RELEASE_FACTS.supportMatrix.filter((entry) =>
  entry.status.toLowerCase().includes('experimental'),
).length;

const journeySteps = [
  { label: '为什么选择', href: '/zh/why-plumego' },
  { label: '架构', href: '/zh/architecture' },
  { label: '示例', href: '/zh/examples' },
  { label: '发布', href: '/zh/releases' },
];

const adoptionGuidance = [
  {
    kicker: 'adopt now',
    title: '先从稳定根与 canonical 参考路径开始',
    body: '如果你准备把 Plumego 用到真实服务里，先从稳定根、reference app 和已文档化的请求路径开始，再决定是否进入可选表面。',
  },
  {
    kicker: 'evaluate deliberately',
    title: '把扩展家族视为有价值但尚未冻结的能力',
    body: '面向应用的扩展家族今天已经有实际价值，但只有在你清楚兼容性承诺到哪里结束、产品能力仍会如何演进时，才适合纳入采用范围。',
  },
  {
    kicker: 'wait for more evidence',
    title: '如果决策依赖实验性的下级原语，就先放慢',
    body: '当你的服务直接依赖下级扩展原语，而不是从所属家族入口进入时，最好等 discovery 路径与兼容性边界更清楚之后再推进采用。',
  },
] as const;

const releaseChannels = [
  {
    kicker: 'stable-root candidate',
    title: '稳定根',
    body: '这些是正在向 v1 收紧的兼容性承担表面，也是 Plumego 期望多数服务长期依赖的默认能力。',
    details: ['公共包表面以长期稳定 API 为目标', '最适合先进入生产评估', '文档与示例都会先围绕这条路径组织'],
  },
  {
    kicker: 'supported reference',
    title: 'canonical 参考应用与 CLI',
    body: '这些表面属于官方采用路径，但应该被看成 bootstrap 与操作流的教学工具，而不是一个可以任意平移复用的扩展目录。',
    details: ['reference app 教会默认服务形态', 'CLI 作为工具被支持，而不是 Go 导入表面', '二者都与 canonical docs 保持对齐'],
  },
  {
    kicker: 'experimental',
    title: '扩展家族与下级原语',
    body: '这些区域仍处于发布范围和质量门禁之内，但 API 与配置兼容性尚未冻结。采用它们应该有明确理由，而不是默认跟进。',
    details: ['先从所属家族入口判断，再看下级路径', '演进速度通常快于稳定根', '产品能力应继续留在内核之外'],
  },
] as const;

const upgradePath = [
  {
    label: '01',
    title: '先确认默认路径仍然匹配当前服务',
    body: '升级前先重新检查你的服务是否仍沿着 canonical bootstrap、routing 与 app-local wiring 路径组织。',
  },
  {
    label: '02',
    title: '把支持矩阵当成边界检查',
    body: '列出服务真正直接依赖的表面，再把它们映射到 stable、supported-reference 或 experimental 状态。',
  },
  {
    label: '03',
    title: '先升级稳定根，再看可选家族',
    body: '如果服务同时依赖稳定表面与实验性家族，应优先确认稳定根与 canonical path 的变化，再评估扩展区域。',
  },
  {
    label: '04',
    title: '升级后回到 docs 与 examples 校验',
    body: '用 reference app、request-flow 文档和 architecture 页面，重新确认本地仓库形态是否仍与预期路径保持一致。',
  },
] as const;

function rowClass(status: string): string {
  if (/GA|Stable-root/i.test(status)) return 'row--ga';
  if (status.toLowerCase().includes('experimental')) return 'row--experimental';
  return 'row--supported';
}

function badgeClass(status: string): string {
  if (/GA|Stable-root/i.test(status)) return 'status-badge status-badge--ga';
  if (status.toLowerCase().includes('experimental')) return 'status-badge status-badge--experimental';
  return 'status-badge status-badge--supported';
}

function zhArea(area: string): string {
  const labels: Record<string, string> = {
    'Stable library roots': '稳定库根',
    'Canonical reference app': 'canonical 参考应用',
    CLI: 'CLI',
    'App-facing extension families': '面向应用的扩展家族',
    'Subordinate extension primitives': '下级扩展原语',
  };
  return labels[area] ?? area;
}

function zhStatus(status: string): string {
  const labels: Record<string, string> = {
    'Stable-root candidate': '稳定根候选',
    'Supported reference': '受支持参考路径',
    'v1 hardening scope': 'v1 收紧范围',
    Experimental: '实验性',
  };
  return labels[status] ?? status;
}

function zhPromise(promise: string): string {
  const labels: Record<string, string> = {
    'Public package surface is intended to remain the long-term stable API after v1 hardening':
      '公共包表面会在 v1 收紧后承担长期稳定 API 目标',
    'Kept aligned with the canonical bootstrap and stable-root usage, but not treated as a reusable extension catalog':
      '与 canonical bootstrap 和稳定根用法保持对齐，但不被当作可复用扩展目录',
    'Supported as a command-line tool, not as a Go import surface; command behavior and generated output must stay aligned with canonical docs':
      '作为命令行工具被支持，不作为 Go 导入表面；命令行为与生成输出必须对齐 canonical docs',
    'Included in repo quality gates and release scope, but API/config compatibility is not frozen':
      '纳入仓库质量门禁和发布范围，但 API/配置兼容性尚未冻结',
    'Maintained and tested, but discovery should start from the owning family entrypoint and compatibility is not frozen':
      '有维护和测试，但 discovery 应从所属家族入口开始，兼容性尚未冻结',
  };
  return labels[promise] ?? promise;
}
---

<MarketingLayout locale="zh" title={copy.title} description={copy.description} currentPath="/zh/releases">
  <PageHero
    eyebrow={copy.eyebrow}
    title={copy.title}
    description={copy.description}
    locale="zh"
    visual="releases"
    links={[
      { label: '架构', href: '/zh/architecture' },
      { label: '文档', href: '/zh/docs' },
    ]}
  />

  <JourneyBar steps={journeySteps} current="/zh/releases" />

  <section class="release-banner">
    <p>当前版本</p>
    <strong>{SITE.currentVersion}</strong>
    <a class="text-link" href={SITE.githubUrl + '/releases'} target="_blank" rel="noreferrer">GitHub Releases</a>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.introTitle}</h2>
      <p>{copy.introBody}</p>
    </div>
    <div class="signal-list">
      {copy.guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro">
      <h2>先用同步事实建立全局判断</h2>
      <p>
        这些数字直接来自仓库同步事实，不是网站手抄清单。先用它们建立尺度，再进入完整支持矩阵。
      </p>
    </div>
    <div class="stat-hero">
      <div class="stat-hero__cell">
        <span class="stat-hero__num stat-hero__num--accent">{MODULE_FACTS.stableRoots.length}</span>
        <span class="stat-hero__label">稳定根</span>
      </div>
      <div class="stat-hero__cell">
        <span class="stat-hero__num">{stableGroups}</span>
        <span class="stat-hero__label">稳定候选分组</span>
      </div>
      <div class="stat-hero__cell">
        <span class="stat-hero__num stat-hero__num--warn">{experimentalGroups}</span>
        <span class="stat-hero__label">实验性分组</span>
      </div>
      <div class="stat-hero__cell">
        <span class="stat-hero__num">{MODULE_FACTS.allExtensionPaths.length}</span>
        <span class="stat-hero__label">扩展路径</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>三种成熟度姿态必须分开读</h2>
      <p>
        稳定根、受支持参考路径与实验性扩展家族可以在同一个仓库里，但不能被当成同一种采用风险。
      </p>
    </div>
    <div class="stability-spectrum">
      <div class="stability-spectrum__cell stability-spectrum__cell--stable">
        <p class="signal-list__kicker">Stable-root candidate</p>
        <p>正在向长期 v1 API 收紧，也是生产服务最适合先评估的范围。</p>
        <ul class="stability-spectrum__items">
          {MODULE_FACTS.stableRoots.map((mod) => (
            <li class="stability-spectrum__item">{mod}</li>
          ))}
        </ul>
      </div>
      <div class="stability-spectrum__cell stability-spectrum__cell--supported">
        <p class="signal-list__kicker">Supported reference</p>
        <p>与 canonical path 保持对齐。它们是教学和操作表面，不是可任意复用的扩展目录。</p>
        <ul class="stability-spectrum__items">
          <li class="stability-spectrum__item">reference/standard-service</li>
          <li class="stability-spectrum__item">cmd/plumego</li>
        </ul>
      </div>
      <div class="stability-spectrum__cell stability-spectrum__cell--experimental">
        <p class="signal-list__kicker">Experimental — extension families</p>
        <p>纳入发布范围和质量门禁，但 API 兼容性尚未冻结。采用前需要明确理由。</p>
        <ul class="stability-spectrum__items">
          {MODULE_FACTS.primaryExtensionFamilies.map((mod) => (
            <li class="stability-spectrum__item">{mod}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro">
      <h2>先用采用指导建立默认判断，再逐行阅读矩阵</h2>
      <p>
        多数读者并不需要一上来就把支持矩阵逐行看完。他们首先需要的是一套默认决策姿态：现在先采用 canonical path，把 supported reference 看成教学表面，
        把 experimental capability work 留在明确评估之后再进入。
      </p>
    </div>
    <div class="control-grid control-grid--tight">
      {adoptionGuidance.map((item) => (
        <article class="control-grid__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>用直白语言解释发布频道</h2>
      <p>
        仓库里同时存在多种发布姿态。这个页面的目标，不是把它们抹平成一条乐观叙事，而是帮你分清：哪些表面应该先进入采用决策，哪些能力应该稍后谨慎跟进。
      </p>
    </div>
    <div class="page-grid">
      {releaseChannels.map((item) => (
        <article class={`page-panel ${item.kicker.includes('stable') ? 'page-panel--fit' : item.kicker === 'experimental' ? 'page-panel--caution' : ''}`}>
          <p class="signal-list__kicker">{item.kicker}</p>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
          <ul>
            {item.details.map((detail) => (
              <li>{detail}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro">
      <h2>{copy.principlesTitle}</h2>
      <p>{copy.principlesBody}</p>
    </div>
    <div class="control-grid">
      {copy.principles.map((item) => (
        <article class="control-grid__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>建议的升级路径</h2>
      <p>
        当兼容性比“包好奇心”更重要时，升级最容易的方式，是让发布讨论始终贴着仓库结构走。下面这组步骤可以作为实际升级时的默认顺序。
      </p>
    </div>
    <div class="request-flow-rail">
      {upgradePath.map((item) => (
        <article class="request-flow-step">
          <div>
            <p class="signal-list__kicker">{item.label}</p>
            <h3>{item.title}</h3>
          </div>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro">
      <h2>{copy.matrixTitle}</h2>
      <p>{copy.matrixBody}</p>
    </div>
    <div class="support-table-wrap">
      <table class="support-table">
        <thead>
          <tr>
            <th>范围</th>
            <th>状态</th>
            <th>兼容性承诺</th>
            <th>模块</th>
          </tr>
        </thead>
        <tbody>
          {RELEASE_FACTS.supportMatrix.map((entry) => (
            <tr class={rowClass(entry.status)}>
              <td><strong>{zhArea(entry.area)}</strong></td>
              <td><span class={badgeClass(entry.status)}>{zhStatus(entry.status)}</span></td>
              <td>{zhPromise(entry.promise)}</td>
              <td class="support-table__modules">{entry.modules}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>回到 canonical path 继续</h2>
      <p>把模块成熟度当成边界地图来用，然后回到默认应用路径推进真正的采用工作。</p>
    </div>
    <div class="page-links">
      <a class="text-link" href="/zh/architecture">查看架构</a>
      <a class="text-link" href="/zh/docs/reference-app">阅读参考应用</a>
      <a class="text-link" href="/zh/roadmap">查看路线图</a>
      <a class="text-link" href="/zh/examples">查看示例</a>
    </div>
  </section>
</MarketingLayout>
