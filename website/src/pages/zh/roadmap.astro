---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import PageHero from '../../components/marketing/PageHero.astro';
import { ROADMAP_COPY } from '../../data/site';
import { ROADMAP_FACTS } from '../../generated/roadmap';

const copy = ROADMAP_COPY.zh;
---

<MarketingLayout locale="zh" title={copy.title} description={copy.description} currentPath="/zh/roadmap">
  <PageHero
    eyebrow={copy.eyebrow}
    title={copy.title}
    description={copy.description}
    links={[
      { label: '文档', href: '/zh/docs' },
      { label: '发布', href: '/zh/releases' },
    ]}
  />

  <section class="section">
    <div class="section__intro">
      <h2>{copy.introTitle}</h2>
      <p>{copy.introBody}</p>
    </div>
    <div class="signal-list">
      {copy.guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.timelineTitle}</h2>
      <p>{copy.timelineBody}</p>
    </div>
    <div class="page-grid">
      {[
        { title: copy.sections[0].title, items: ROADMAP_FACTS.currentBaseline },
        { title: copy.sections[1].title, items: ROADMAP_FACTS.inProgress },
        { title: copy.sections[2].title, items: ROADMAP_FACTS.planned },
        { title: copy.sections[3].title, items: copy.sections[3].items },
      ].map((section) => (
        <article class="page-panel">
          <h2>{section.title}</h2>
          <ul>
            {section.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.orderTitle}</h2>
      <p>{copy.orderBody}</p>
    </div>
    <div class="fact-stack">
      <article class="page-panel">
        <ul>
          {ROADMAP_FACTS.suggestedExecutionOrder.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>把路线图和发布姿态一起看</h2>
      <p>路线图说明方向，发布姿态才说明今天哪些部分可以被采用。</p>
    </div>
    <div class="page-links">
      <a class="text-link" href="/zh/releases">查看发布页</a>
      <a class="text-link" href="/zh/docs/release-posture">阅读发布姿态</a>
      <a class="text-link" href="/zh/docs/reference-app">打开参考应用</a>
    </div>
  </section>
</MarketingLayout>
