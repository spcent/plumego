---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import PageHero from '../../components/marketing/PageHero.astro';
import JourneyBar from '../../components/marketing/JourneyBar.astro';
import CheckIcon from '../../components/shared/CheckIcon.astro';
import CautionIcon from '../../components/shared/CautionIcon.astro';

interface Framework {
  id: string;
  name: string;
  url: string;
  tagline: string;
  handlerSig: string;
  stdlibHandler: boolean;
  zeroDeps: boolean;
  responseContract: boolean;
  canonicalShape: boolean;
  middlewareStdlib: boolean;
  agentReady: boolean;
  stabilityModel: boolean;
  stars: string;
  verdict: string;
  whenToChoose: string[];
  whenNotToChoose: string[];
  migrationCost: 'low' | 'medium' | 'high' | 'n/a';
  migrationNote: string;
  color: string;
  isPlumego?: boolean;
  warning?: string;
}

const frameworks: Framework[] = [
  {
    id: 'gin',
    name: 'Gin',
    url: 'https://github.com/gin-gonic/gin',
    tagline: 'Martini 风格路由器，基数树路由',
    handlerSig: 'func(c *gin.Context)',
    stdlibHandler: false,
    zeroDeps: false,
    responseContract: false,
    canonicalShape: false,
    middlewareStdlib: false,
    agentReady: false,
    stabilityModel: false,
    stars: '~80k',
    verdict: '对于接受自定义 context 类型的团队，是最快上手的选择。生态丰富。很多 Go 团队的默认选项。',
    whenToChoose: [
      '需要最快速度跑起一个 API',
      '需要认证、限流等大量插件生态',
      '团队已经熟悉 gin.Context 及其权衡',
      '已有大量 Gin 代码，切换成本太高',
    ],
    whenNotToChoose: [
      '需要 handler 保持 func(w, r) 形式，让已有 stdlib 中间件无需适配器就能工作',
      '希望在代码评审里直接看到路由归属和中间件顺序，而不需要翻框架源码',
      '需要跨所有 handler 一致的结构化错误与响应封装',
    ],
    migrationCost: 'medium',
    migrationNote: '所有 handler 需要从 gin.Context 改写为 func(w, r)，中间件需要适配或替换。路由语法基本一致（/foo/:id 不变）。视 handler 数量，每个服务预计需要 1–3 天。',
    color: '#00b4d8',
  },
  {
    id: 'echo',
    name: 'Echo',
    url: 'https://github.com/labstack/echo',
    tagline: '高性能极简 Web 框架',
    handlerSig: 'func(c echo.Context) error',
    stdlibHandler: false,
    zeroDeps: false,
    responseContract: false,
    canonicalShape: false,
    middlewareStdlib: false,
    agentReady: false,
    stabilityModel: false,
    stars: '~30k',
    verdict: 'API 整洁，中间件生态不错，handler 里 return error 的设计符合 Go 习惯。自定义 context 的权衡可以接受时，是个扎实的选择。',
    whenToChoose: [
      '更喜欢从 handler 返回 error 而不是直接写 w',
      '需要文档清晰、中间件支持好的框架',
      '团队欣赏路由分组和内置 binder/validator',
    ],
    whenNotToChoose: [
      '需要纯 net/http 兼容——echo.Context 破坏了中间件复用',
      '需要统一的 JSON 响应封装——Echo 把响应格式留给你自己决定',
      '需要跨多个团队共用一套规范服务骨架',
    ],
    migrationCost: 'medium',
    migrationNote: '需要把 handler 从 echo.Context + error return 改写为 func(w, r)。路由分组概念映射较直接。中间件需适配器。与 Gin 迁移工作量相当，约 1–3 天每个服务。',
    color: '#6c63ff',
  },
  {
    id: 'fiber',
    name: 'Fiber',
    url: 'https://github.com/gofiber/fiber',
    tagline: 'Express 风格，基于 Fasthttp',
    handlerSig: 'func(c *fiber.Ctx) error',
    stdlibHandler: false,
    zeroDeps: false,
    responseContract: false,
    canonicalShape: false,
    middlewareStdlib: false,
    agentReady: false,
    stabilityModel: false,
    stars: '~34k',
    verdict: '基准测试吞吐量最高。代价是与 net/http 完全不兼容——没有 stdlib 中间件、没有 net/http handler、没有标准库生态。',
    whenToChoose: [
      '原始 HTTP 吞吐量是主要瓶颈，且你有基准数据证明',
      '从零新建服务，没有任何需要集成的 net/http 中间件',
      '团队有 Fasthttp 经验，清楚这个不兼容性的权衡',
    ],
    whenNotToChoose: [
      '有任何 net/http 中间件、handler 或工具——一个都用不了',
      '使用基于 net/http 的可观测性、链路追踪或认证库',
      '团队以 Go 标准库为中心，期望标准库兼容性',
    ],
    migrationCost: 'high',
    migrationNote: '需要完全重写。Fasthttp 与 net/http 从根本上不兼容——handler 无法复用、中间件无法复用、测试基础设施无法复用。可观测性、认证和链路追踪库全部需要替换。预计以周计，而非天。',
    color: '#00d4aa',
    warning: 'Fiber 使用 Fasthttp，不是 net/http。与 Go 标准库 HTTP 生态完全不兼容。',
  },
  {
    id: 'chi',
    name: 'Chi',
    url: 'https://github.com/go-chi/chi',
    tagline: '轻量惯用的 Go HTTP 服务路由器',
    handlerSig: 'func(w http.ResponseWriter, r *http.Request)',
    stdlibHandler: true,
    zeroDeps: true,
    responseContract: false,
    canonicalShape: false,
    middlewareStdlib: true,
    agentReady: false,
    stabilityModel: false,
    stars: '~18k',
    verdict: '极简主义者的选择。纯 stdlib，对响应格式、服务结构或模块稳定性零主张。如果你想自己搭建所有东西，Chi 是合适的起点。',
    whenToChoose: [
      '只需要路由——愿意自己实现响应封装、中间件和安全层',
      '需要纯 stdlib 兼容，不想要任何框架结构主张',
      '团队偏好最大灵活性，愿意自己构建维护周边层',
    ],
    whenNotToChoose: [
      '需要跨 handler 一致的响应封装，但不想自己实现',
      '需要快速上手的规范服务结构',
      '需要每个模块单独的成熟度信号',
    ],
    migrationCost: 'low',
    migrationNote: 'Handler 签名完全相同（stdlib func(w, r)）。路由语法略有差异：Chi 用 /foo/{id}，Plumego 用 /foo/:id。中间件完全兼容。大多数服务的迁移以小时计，而非天。',
    color: '#f59e0b',
  },
  {
    id: 'plumego',
    name: 'Plumego',
    url: 'https://github.com/spcent/plumego',
    tagline: '显式 HTTP 工具包 — stdlib only，Agent 就绪，v1.0.0',
    handlerSig: 'func(w http.ResponseWriter, r *http.Request)',
    stdlibHandler: true,
    zeroDeps: true,
    responseContract: true,
    canonicalShape: true,
    middlewareStdlib: true,
    agentReady: true,
    stabilityModel: true,
    stars: 'v1.0.0',
    verdict: '适合那些更看重路由 ownership、评审清晰度和共享服务骨架的团队，而不是框架便利性。如果团队在使用 AI 编码工具，这是唯一有机器可读 ownership 信号的选择。',
    whenToChoose: [
      '路由注册、中间件顺序和依赖 wiring 必须在代码评审里清晰可见',
      '多个服务需要从同一个规范骨架起步，而不是各自发明 bootstrap',
      '使用 AI 编码助手，需要明确的机器可读规则来定位变更归属',
      '需要区分稳定模块和实验性能力工作',
    ],
    whenNotToChoose: [
      '希望框架隐藏结构决策——Plumego 刻意保持显式',
      '已有大量 Gin/Echo 代码，迁移成本超过收益',
      '需要经过多年验证的 v1+ 长期使用记录',
      '服务是小脚本或短生命周期工具，结构开销不划算',
    ],
    migrationCost: 'n/a',
    migrationNote: '这是目标框架，不是迁移来源。',
    isPlumego: true,
    color: 'var(--accent)',
  },
];

const matrixRows = [
  {
    feature: 'stdlib handler 签名',
    note: 'func(w http.ResponseWriter, r *http.Request)',
    values: { gin: false, echo: false, fiber: false, chi: true, plumego: true },
  },
  {
    feature: 'net/http 中间件复用',
    note: '已有 stdlib 中间件无需适配器',
    values: { gin: false, echo: false, fiber: false, chi: true, plumego: true },
  },
  {
    feature: '零外部依赖',
    note: '稳定内核仅用 Go 标准库',
    values: { gin: false, echo: false, fiber: false, chi: true, plumego: true },
  },
  {
    feature: '内置响应 contract',
    note: '成功与错误响应的类型化 JSON 封装',
    values: { gin: false, echo: false, fiber: false, chi: false, plumego: true },
  },
  {
    feature: '规范服务骨架',
    note: 'bootstrap、路由和 handler 布局的参考应用',
    values: { gin: false, echo: false, fiber: false, chi: false, plumego: true },
  },
  {
    feature: '显式模块稳定性层级',
    note: 'stable / beta / experimental 标签与采用指南',
    values: { gin: false, echo: false, fiber: false, chi: false, plumego: true },
  },
  {
    feature: 'AI / Agent 就绪控制面',
    note: '机器可读规范、任务路由、边界检查',
    values: { gin: false, echo: false, fiber: false, chi: false, plumego: true },
  },
] as const;

type FwId = 'gin' | 'echo' | 'fiber' | 'chi' | 'plumego';
const fwIds: FwId[] = ['gin', 'echo', 'fiber', 'chi', 'plumego'];

// ── 性能基准数据 ─────────────────────────────────────────────────────────────
// go test -bench -benchmem -count=3 · GET /users/:id · linux/amd64 · Intel Xeon @ 2.10 GHz
const routerRows = [
  { name: 'Plumego', nsOp: 4291, allocsOp: 16, bytesOp: 5715, relative: '1.0×', isPlumego: true },
  { name: 'Chi',     nsOp: 4547, allocsOp: 17, bytesOp: 6036, relative: '1.06×' },
  { name: 'Gin',     nsOp: 3773, allocsOp: 13, bytesOp: 5331, relative: '0.88×', isFaster: true },
  { name: 'Echo',    nsOp: 3743, allocsOp: 13, bytesOp: 5331, relative: '0.87×', isFaster: true },
];
const parallelRows = [
  { name: 'Plumego', nsOp: 663,  allocsOp: 7, bytesOp: 592, relative: '1.0×',  isPlumego: true },
  { name: 'Chi',     nsOp: 1013, allocsOp: 8, bytesOp: 912, relative: '1.53×' },
  { name: 'Gin',     nsOp: 285,  allocsOp: 4, bytesOp: 208, relative: '0.43×', isFaster: true },
  { name: 'Echo',    nsOp: 231,  allocsOp: 4, bytesOp: 208, relative: '0.35×', isFaster: true },
];

const journeySteps = [
  { label: '为什么选择', href: '/zh/why-plumego' },
  { label: '示例', href: '/zh/examples' },
  { label: '状态', href: '/zh/status' },
];
---

<MarketingLayout
  locale="zh"
  title="Go HTTP 框架横向对比：Gin、Echo、Fiber、Chi、Plumego"
  description="五款最常用 Go HTTP 工具包的诚实技术对比。Handler 签名、响应 contract、stdlib 兼容性，以及各自不该选择的场景。"
  currentPath="/zh/compare"
  keywords={['go web 框架对比', 'gin vs echo', 'fiber vs chi', 'plumego 对比', 'go http 工具包']}
>
  <PageHero
    eyebrow="框架对比"
    title="Go HTTP 工具包"
    description="Gin、Echo、Fiber、Chi 和 Plumego——每个框架放弃了什么，换来了什么。这页是决策辅助工具，不是基准测试排行榜。"
    visual="decision"
    links={[
      { label: '为什么选择 Plumego', href: '/zh/why-plumego' },
      { label: '状态', href: '/zh/status' },
      { label: '开始使用', href: '/zh/docs/getting-started' },
    ]}
  />

  <JourneyBar steps={journeySteps} current="/zh/compare" />

  <!-- 30 秒快速结论 -->
  <section class="section">
    <div class="section__intro">
      <h2>30 秒快速结论。</h2>
      <p>
        五个工具包都针对 Go HTTP 服务。差异在于设计哲学和使用范围，而不是在典型请求量下的原始性能。
        先看结论一行，再跟着符合你团队实际约束的深度分析走。
      </p>
    </div>

    <div class="verdict-grid">
      {frameworks.map((fw) => (
        <article class={`verdict-card ${fw.isPlumego ? 'verdict-card--highlight' : ''}`}>
          {fw.warning && (
            <div class="verdict-warning">
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M8 2L14.5 13H1.5L8 2Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
                <path d="M8 6v4M8 11.5v.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              </svg>
              {fw.warning}
            </div>
          )}
          <div class="verdict-card__header">
            <h3 class="verdict-card__name">{fw.name}</h3>
            <span class="verdict-card__stars">{fw.stars} ★</span>
          </div>
          <p class="verdict-card__tagline">{fw.tagline}</p>
          <p class="verdict-card__verdict">{fw.verdict}</p>
          <code class="verdict-card__sig">{fw.handlerSig}</code>
        </article>
      ))}
    </div>
  </section>

  <!-- 特性矩阵 -->
  <section class="section section--tinted">
    <div class="section__intro">
      <h2>特性矩阵。</h2>
      <p>
        横向阅读一行，对比所有五个工具包的同一属性。矩阵不涵盖生态大小、社区活跃度或原始性能——这些取决于你的基准。它捕捉的是不随负载变化的结构性权衡。
      </p>
    </div>

    <div class="matrix-wrap">
      <table class="matrix-table" role="table">
        <thead>
          <tr>
            <th class="matrix-table__feature-col">属性</th>
            {frameworks.map((fw) => (
              <th class={fw.isPlumego ? 'matrix-table__fw-col matrix-table__fw-col--highlight' : 'matrix-table__fw-col'}>
                {fw.name}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {matrixRows.map((row) => (
            <tr>
              <td class="matrix-table__feature">
                <strong>{row.feature}</strong>
                <span class="matrix-table__note">{row.note}</span>
              </td>
              {fwIds.map((id) => {
                const val = row.values[id];
                const isPlumego = id === 'plumego';
                return (
                  <td class={`matrix-table__cell ${isPlumego ? 'matrix-table__cell--highlight' : ''}`}>
                    {val ? (
                      <svg class="matrix-icon matrix-icon--yes" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-label="是">
                        <circle cx="8" cy="8" r="7" fill="color-mix(in srgb, currentColor 12%, transparent)" stroke="currentColor" stroke-width="1.4"/>
                        <path d="M4.5 8l2.5 2.5L11.5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    ) : (
                      <svg class="matrix-icon matrix-icon--no" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-label="否">
                        <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.4" stroke-dasharray="3 2"/>
                        <path d="M10.5 5.5l-5 5M5.5 5.5l5 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
                      </svg>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <p class="matrix-note">
      Fiber 与 net/http 的不兼容性不是缺失的功能——这是换取更高吞吐量的刻意架构取舍。参见 Fiber 深度分析，了解这个权衡什么时候值得做。
    </p>
  </section>

  <!-- Handler 签名对比 -->
  <section class="section">
    <div class="section__intro">
      <h2>Handler 签名是最关键的选择。</h2>
      <p>
        自定义 context 类型（Gin、Echo、Fiber）破坏了与已有 net/http 中间件生态的兼容性。
        采用这些框架后，每个 stdlib 中间件都需要适配器。用 Chi 和 Plumego，整个 net/http 世界都能直接使用。
      </p>
    </div>

    <div class="code-compare-grid">
      <div class="code-compare-item">
        <div class="code-compare-item__header">
          <span class="code-compare-item__fw">Gin</span>
          <span class="compat-badge compat-badge--no">自定义 context</span>
        </div>
        <div class="hero-code">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">handler.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// gin.Context — net/http 中间件需要适配器</span>
r.<span class="hc-fn">GET</span>(<span class="hc-str">"/users/:id"</span>, <span class="hc-kw">func</span>(c *gin.Context) &#123;
    id := c.<span class="hc-fn">Param</span>(<span class="hc-str">"id"</span>)
    c.<span class="hc-fn">JSON</span>(http.StatusOK, gin.H&#123;<span class="hc-str">"id"</span>: id&#125;)
&#125;)
<span class="hc-cm">// 复用 net/http 中间件需要：</span>
r.<span class="hc-fn">Use</span>(gin.<span class="hc-fn">WrapH</span>(myStdlibMiddleware))</code></pre>
        </div>
      </div>

      <div class="code-compare-item">
        <div class="code-compare-item__header">
          <span class="code-compare-item__fw">Echo</span>
          <span class="compat-badge compat-badge--no">自定义 context</span>
        </div>
        <div class="hero-code">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">handler.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// echo.Context + error 返回值</span>
e.<span class="hc-fn">GET</span>(<span class="hc-str">"/users/:id"</span>, <span class="hc-kw">func</span>(c echo.Context) error &#123;
    id := c.<span class="hc-fn">Param</span>(<span class="hc-str">"id"</span>)
    <span class="hc-kw">return</span> c.<span class="hc-fn">JSON</span>(http.StatusOK,
        map[string]any&#123;<span class="hc-str">"id"</span>: id&#125;)
&#125;)</code></pre>
        </div>
      </div>

      <div class="code-compare-item">
        <div class="code-compare-item__header">
          <span class="code-compare-item__fw">Fiber</span>
          <span class="compat-badge compat-badge--warn">fasthttp — 非 net/http</span>
        </div>
        <div class="hero-code">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">handler.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// fasthttp — 与 net/http 完全不兼容</span>
<span class="hc-cm">// 零个 net/http 中间件可以复用</span>
app.<span class="hc-fn">Get</span>(<span class="hc-str">"/users/:id"</span>, <span class="hc-kw">func</span>(c *fiber.Ctx) error &#123;
    id := c.<span class="hc-fn">Params</span>(<span class="hc-str">"id"</span>)
    <span class="hc-kw">return</span> c.<span class="hc-fn">JSON</span>(fiber.Map&#123;<span class="hc-str">"id"</span>: id&#125;)
&#125;)</code></pre>
        </div>
      </div>

      <div class="code-compare-item">
        <div class="code-compare-item__header">
          <span class="code-compare-item__fw">Chi</span>
          <span class="compat-badge compat-badge--yes">stdlib handler</span>
        </div>
        <div class="hero-code">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">handler.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// 纯 stdlib — 但没有响应 contract</span>
r.<span class="hc-fn">Get</span>(<span class="hc-str">"/users/&#123;id&#125;"</span>, <span class="hc-kw">func</span>(w http.ResponseWriter, r *http.Request) &#123;
    id := chi.<span class="hc-fn">URLParam</span>(r, <span class="hc-str">"id"</span>)
    <span class="hc-cm">// 每次都要自己构建 JSON 响应格式</span>
    json.<span class="hc-fn">NewEncoder</span>(w).<span class="hc-fn">Encode</span>(map[string]any&#123;<span class="hc-str">"id"</span>: id&#125;)
&#125;)</code></pre>
        </div>
      </div>

      <div class="code-compare-item code-compare-item--highlight">
        <div class="code-compare-item__header">
          <span class="code-compare-item__fw">Plumego</span>
          <span class="compat-badge compat-badge--yes">stdlib handler + contract</span>
        </div>
        <div class="hero-code hero-code--canonical">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">internal/handler/users.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// stdlib 签名 + 类型化响应 contract</span>
r.<span class="hc-fn">Get</span>(<span class="hc-str">"/users/:id"</span>, <span class="hc-kw">func</span>(w http.ResponseWriter, r *http.Request) &#123;
    id := router.<span class="hc-fn">Param</span>(r, <span class="hc-str">"id"</span>)
    contract.<span class="hc-fn">WriteResponse</span>(w, r, http.StatusOK, user, <span class="hc-kw">nil</span>)
    <span class="hc-cm">// → &#123;"data": &#123;...&#125;, "meta": null&#125;</span>
&#125;)

<span class="hc-cm">// 所有 net/http 中间件直接可用</span>
r.<span class="hc-fn">Use</span>(middleware.RequestID)
r.<span class="hc-fn">Use</span>(myOtelMiddleware)</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- 响应 contract 对比 -->
  <section class="section section--tinted">
    <div class="section__intro">
      <h2>响应 contract：统一封装 vs. 自己构建。</h2>
      <p>
        Gin、Echo、Fiber 和 Chi 都把 JSON 响应格式留给你决定。这意味着每个团队、每个 handler 或每个项目的响应格式可能都微妙不同。
        Plumego 的 <code>contract</code> 模块对成功和错误响应强制执行同一个封装。
      </p>
    </div>

    <div class="contract-compare">
      <div class="contract-panel contract-panel--before">
        <p class="contract-panel__label">Gin / Echo / Fiber / Chi — 各自决定格式</p>
        <div class="hero-code">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">handler.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// 成功响应 — 每个团队格式不同</span>
c.<span class="hc-fn">JSON</span>(200, gin.H&#123;
    <span class="hc-str">"data"</span>:    user,
    <span class="hc-str">"success"</span>: <span class="hc-kw">true</span>,   <span class="hc-cm">// 有些团队加</span>
    <span class="hc-str">"code"</span>:    0,          <span class="hc-cm">// 有些团队加</span>
&#125;)

<span class="hc-cm">// 错误响应 — 更加不一致</span>
c.<span class="hc-fn">JSON</span>(400, gin.H&#123;
    <span class="hc-str">"error"</span>:   <span class="hc-str">"name required"</span>,
    <span class="hc-str">"message"</span>: <span class="hc-str">"..."</span>,  <span class="hc-cm">// 重复？缺失？</span>
    <span class="hc-str">"code"</span>:    1001,
&#125;)</code></pre>
        </div>
      </div>

      <div class="contract-panel contract-panel--after">
        <p class="contract-panel__label">Plumego — 所有 handler 共用一套 contract</p>
        <div class="hero-code hero-code--canonical">
          <div class="hero-code__bar">
            <span class="hero-code__dots"><span></span><span></span><span></span></span>
            <span class="hero-code__filename">internal/handler/users.go</span>
          </div>
          <pre class="hero-code__pre"><code><span class="hc-cm">// 成功 — 始终是 &#123;"data": ..., "meta": ...&#125;</span>
contract.<span class="hc-fn">WriteResponse</span>(w, r, 200, user, <span class="hc-kw">nil</span>)

<span class="hc-cm">// 错误 — 始终是 &#123;"error": &#123;"type": ..., "message": ...&#125;&#125;</span>
contract.<span class="hc-fn">WriteError</span>(w, r,
    contract.<span class="hc-fn">NewErrorBuilder</span>().
        <span class="hc-fn">Type</span>(contract.TypeRequired).
        <span class="hc-fn">Field</span>(<span class="hc-str">"name"</span>).
        <span class="hc-fn">Message</span>(<span class="hc-str">"name 是必填项"</span>).
        <span class="hc-fn">Build</span>())

<span class="hc-cm">// 每个 handler、每个服务的封装都一致</span></code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- 决策表 -->
  <section class="section">
    <div class="section__intro">
      <h2>各框架的选择指南。</h2>
      <p>
        下表不是为了评出胜者。每行回答两个问题：这个框架擅长什么，以及什么情况下应该暂停考虑。
        「什么时候不该选 Plumego」的诚实回答在最后。
      </p>
    </div>

    <div class="comparison-table" role="table" aria-label="框架决策指南">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">框架</span>
        <span role="columnheader">
          <CheckIcon size={12} class="comparison-cell-icon comparison-cell-icon--fit" />
          选择场景
        </span>
        <span role="columnheader">
          <CautionIcon size={12} class="comparison-cell-icon comparison-cell-icon--caution" />
          暂停场景
        </span>
      </div>
      {frameworks.map((fw) => (
        <div class={`comparison-table__row ${fw.isPlumego ? 'comparison-table__row--highlight' : ''}`} role="row">
          <strong role="cell">
            {fw.name}
            {fw.isPlumego && <span class="plumego-star" aria-label="本页框架">★</span>}
            {fw.warning && <span class="fw-warning-chip" title={fw.warning}>⚠ fasthttp</span>}
          </strong>
          <ul class="fw-points" role="cell">
            {fw.whenToChoose.map((point) => (
              <li>
                <CheckIcon size={11} class="comparison-cell-icon comparison-cell-icon--fit" />
                {point}
              </li>
            ))}
          </ul>
          <ul class="fw-points" role="cell">
            {fw.whenNotToChoose.map((point) => (
              <li>
                <CautionIcon size={11} class="comparison-cell-icon comparison-cell-icon--caution" />
                {point}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- 不该选 Plumego 的场景 -->
  <section class="section section--tinted">
    <div class="section__intro">
      <h2>什么时候不该选 Plumego。</h2>
      <p>
        这一节是 Plumego 自己的内容规则要求的。诚实的对比必须包含框架不合适的场景——不只是它赢的地方。
      </p>
    </div>
    <div class="control-grid">
      <article class="control-grid__item">
        <p class="signal-list__kicker">
          <CautionIcon size={13} class="comparison-cell-icon comparison-cell-icon--caution" />
          约定优先的团队
        </p>
        <h3>你希望框架替你管理结构</h3>
        <p>
          Plumego 把路由注册、中间件顺序和依赖 wiring 都明确地留在你的代码里。
          如果团队更希望框架隐式管理结构，显式模型只会增加摩擦而没有额外价值。选 Gin 或 Echo 会更高效。
        </p>
      </article>
      <article class="control-grid__item">
        <p class="signal-list__kicker">
          <CautionIcon size={13} class="comparison-cell-icon comparison-cell-icon--caution" />
          已有大型代码库
        </p>
        <h3>团队已经有大量 Gin/Echo 服务</h3>
        <p>
          把成熟的 Gin 或 Echo 服务迁移到 Plumego，需要把所有 handler 从自定义 context 改成 net/http 签名。
          如果服务运行正常、团队工作顺畅，这个迁移成本几乎不值得。留在你已有的框架上。
        </p>
      </article>
      <article class="control-grid__item">
        <p class="signal-list__kicker">
          <CautionIcon size={13} class="comparison-cell-icon comparison-cell-icon--caution" />
          最大吞吐量
        </p>
        <h3>原始 HTTP 吞吐量是你的主要瓶颈</h3>
        <p>
          Plumego 使用 net/http 兼容的 trie 路由器，开销极小但不为零，比 Fiber 的 Fasthttp 基线多一点。
          如果你有<em>测量数据</em>证明 HTTP 路由是瓶颈（不是数据库、不是业务逻辑），那 Fiber 才是对的话题。
        </p>
      </article>
      <article class="control-grid__item">
        <p class="signal-list__kicker">
          <CautionIcon size={13} class="comparison-cell-icon comparison-cell-icon--caution" />
          现在就需要长期生产记录
        </p>
        <h3>你需要经过验证的 v1+ 版本记录</h3>
        <p>
          Plumego 已有 v1.0.0 标签，9 个稳定根有兼容性承诺，但项目尚未积累 Gin 或 Echo 那样的长期生产记录。
          如果"5年以上大规模验证"是硬性要求，Gin 或 Echo 在组织层面更安全。
        </p>
      </article>
    </div>
  </section>

  <!-- 性能基准说明 -->
  <section class="section">
    <div class="section__intro">
      <h2>关于性能基准的说明。</h2>
      <p>这几个框架的基准对比在网上广泛流传。阅读时请保持审慎。</p>
    </div>
    <div class="signal-list">
      <article class="signal-list__item">
        <p class="signal-list__kicker">Fiber 注意事项</p>
        <h3>Fiber 的性能优势来自 Fasthttp，而不是更好的路由</h3>
        <p>
          Fasthttp 通过复用 buffer 来避免标准库分配，在合成基准中产生可测量的吞吐量提升。
          但如果你需要 net/http 中间件、使用标准库 HTTP 客户端对接同一服务，或者工作负载的瓶颈是数据库 I/O 而不是 HTTP 解析，这个提升就会消失。
        </p>
      </article>
      <article class="signal-list__item">
        <p class="signal-list__kicker">Plumego 基准</p>
        <h3>Plumego 路由器与 net/http 性能相当——尚未正式发布基准数据</h3>
        <p>
          Trie 路由器无反射、无全局状态，设计目标是与 net/http 性能相当。与 Gin、Echo、Chi 的可重现基准尚未发布，请关注
          <a class="text-link" href="https://github.com/spcent/plumego/issues">issue tracker</a> 中的基准路线图。
        </p>
      </article>
      <article class="signal-list__item">
        <p class="signal-list__kicker">通用建议</p>
        <h3>以性能为由选框架之前，先对你的实际工作负载做性能分析</h3>
        <p>
          大多数 Go HTTP 服务的瓶颈在数据库往返、外部 API 调用或序列化——而不是路由器。
          没有针对你的具体工作负载和目标规模的测量数据，纯粹基于性能选择框架很难站住脚。
        </p>
      </article>
    </div>
  </section>

  <!-- 迁移成本 -->
  <section class="section">
    <div class="section__intro">
      <h2>迁移到 Plumego 的成本。</h2>
      <p>
        切换框架的决策不只是 API 人机工程学问题——还涉及 handler 改写、中间件替换和测试基础设施的调整。
        下表对从各框架迁移到 Plumego 所需工作量给出诚实估算。
      </p>
    </div>
    <div class="comparison-table" role="table" aria-label="从各框架迁移到 Plumego 的成本">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">来源框架</span>
        <span role="columnheader">成本</span>
        <span role="columnheader">变化内容</span>
      </div>
      {frameworks.filter((fw) => !fw.isPlumego).map((fw) => (
        <div class="comparison-table__row" role="row">
          <strong role="cell">{fw.name}</strong>
          <span role="cell">
            <span class={`migration-badge migration-badge--${fw.migrationCost}`}>{fw.migrationCost}</span>
          </span>
          <span role="cell" class="migration-note">{fw.migrationNote}</span>
        </div>
      ))}
    </div>
    <p class="matrix-note">
      迁移成本以现有 handler 和中间件的服务为基准。
      从 <code>reference/standard-service</code> 全新搭建的服务没有迁移成本。
    </p>
  </section>

  <!-- 性能基准 -->
  <section class="section" id="benchmarks">
    <div class="section__intro">
      <h2>路由性能基准数据。</h2>
      <p>
        使用 <code>go test -bench -benchmem -count=3</code> 实测的顺序与并发调度数据。
        路由：<code>GET /users/:id</code>，无中间件。linux/amd64，Intel Xeon @ 2.10 GHz。
        包含完整 <code>httptest</code> 请求/响应周期。相对列以 Plumego 为基准（1.0×）。
      </p>
      <p class="bench-note">
        路由开销很少是真正的瓶颈——数据库调用耗时 500 µs–5 ms，路由仅 1–5 µs。
        选择框架时，以团队真正关注的因素为准。
      </p>
    </div>

    <div class="bench-tables">
      <div class="bench-table-block">
        <h3 class="bench-table-title">顺序调度（ns/op）</h3>
        <div class="bench-table-wrap">
          <table class="bench-table">
            <thead>
              <tr>
                <th>框架</th>
                <th>ns/op</th>
                <th>allocs/op</th>
                <th>B/op</th>
                <th>vs Plumego</th>
              </tr>
            </thead>
            <tbody>
              {routerRows.map((row) => (
                <tr class:list={[row.isPlumego && 'bench-row--plumego']}>
                  <td class="bench-td--name">
                    {row.name}
                    {row.isPlumego && <span class="bench-badge">本项</span>}
                    {row.isFaster && <span class="bench-badge bench-badge--faster">更快</span>}
                  </td>
                  <td class="bench-td--num">{row.nsOp}</td>
                  <td class="bench-td--num">{row.allocsOp}</td>
                  <td class="bench-td--num">{row.bytesOp}</td>
                  <td class="bench-td--relative">{row.relative}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="bench-table-block">
        <h3 class="bench-table-title">并发吞吐 — b.RunParallel at GOMAXPROCS</h3>
        <div class="bench-table-wrap">
          <table class="bench-table">
            <thead>
              <tr>
                <th>框架</th>
                <th>ns/op</th>
                <th>allocs/op</th>
                <th>B/op</th>
                <th>vs Plumego</th>
              </tr>
            </thead>
            <tbody>
              {parallelRows.map((row) => (
                <tr class:list={[row.isPlumego && 'bench-row--plumego']}>
                  <td class="bench-td--name">
                    {row.name}
                    {row.isPlumego && <span class="bench-badge">本项</span>}
                    {row.isFaster && <span class="bench-badge bench-badge--faster">更快</span>}
                  </td>
                  <td class="bench-td--num">{row.nsOp}</td>
                  <td class="bench-td--num">{row.allocsOp}</td>
                  <td class="bench-td--num">{row.bytesOp}</td>
                  <td class="bench-td--relative">{row.relative}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="bench-footnote">
          Gin 和 Echo 在并发负载下快 ~2.5–3×，因为 <code>sync.Pool</code> context
          消除了每次请求的内存分配——代价是使用与标准库中间件不兼容的自定义 context 类型。
        </p>
      </div>
    </div>

    <p class="bench-reproduce">
      复现方法：<code>cd reference/benchmark &amp;&amp; go test -bench=. -benchmem -count=3 ./...</code>
    </p>
  </section>

  <!-- CTA -->
  <section class="section section--cta">
    <div class="section__intro section__intro--cta">
      <h2>做出决策了吗？</h2>
      <p>
        如果 Plumego 符合你团队的工作模式，从 reference app 开始。如果另一个框架更合适，那就是正确的选择——这页存在是为了帮你决策，不是为了推销。
      </p>
      <div class="cta-actions">
