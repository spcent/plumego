---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import PageHero from '../../components/marketing/PageHero.astro';
import JourneyBar from '../../components/marketing/JourneyBar.astro';

const journeySteps = [
  { label: '为什么选择', href: '/zh/why-plumego' },
  { label: '框架对比', href: '/zh/compare' },
  { label: '性能测试', href: '/zh/benchmarks' },
];

// 路由开销数据 — go test -bench -benchmem -count=3 实测
// 路由：GET /users/:id（单路径参数）。linux/amd64，Intel Xeon @ 2.80 GHz。
// ns/op 包含完整 httptest.NewRequest + ServeHTTP + httptest.NewRecorder 调用周期。
// 相对列以 Plumego 为基准（1.0x）。
const routerRows = [
  {
    name: 'Plumego router',
    nsOp: 4832,
    allocsOp: 21,
    bytesOp: 6433,
    relative: '1.0x',
    note: '基于 Trie 树，支持路径参数和分组。使用标准库 handler 签名，无自定义 context。',
    isPlumego: true,
  },
  {
    name: 'Chi',
    nsOp: 4734,
    allocsOp: 17,
    bytesOp: 6035,
    relative: '0.98x',
    note: '基数树。兼容标准库 handler 签名。分配次数略少于 Plumego。',
  },
  {
    name: 'Gin',
    nsOp: 4169,
    allocsOp: 13,
    bytesOp: 5331,
    relative: '0.86x',
    note: '基数树 + gin.Context sync.Pool。对象池减少分配。需要自定义 context 类型。',
    isFaster: true,
  },
  {
    name: 'Echo',
    nsOp: 3861,
    allocsOp: 13,
    bytesOp: 5331,
    relative: '0.80x',
    note: '基数树 + echo.Context sync.Pool。顺序调度最快。需要自定义 context 类型。',
    isFaster: true,
  },
];

// 并发吞吐量 — b.RunParallel，GOMAXPROCS 个 goroutine，同一单参数路由。
const parallelRows = [
  { name: 'Plumego', nsOp: 1107, allocsOp: 12, bytesOp: 1312, relative: '1.0x', isPlumego: true },
  { name: 'Chi',     nsOp: 823,  allocsOp: 8,  bytesOp: 912,  relative: '0.74x' },
  { name: 'Gin',     nsOp: 220,  allocsOp: 4,  bytesOp: 208,  relative: '0.20x', isFaster: true },
  { name: 'Echo',    nsOp: 226,  allocsOp: 4,  bytesOp: 208,  relative: '0.20x', isFaster: true },
];

// 路由表规模 — 注册 100 / 500 条路由后调度到最后一条。
const scaleRows = [
  { name: 'Plumego', single: 4832, scale100: 5318, scale500: 5608, isPlumego: true },
  { name: 'Chi',     single: 4734, scale100: 4452, scale500: 4794 },
  { name: 'Gin',     single: 4169, scale100: 4116, scale500: 4335 },
  { name: 'Echo',    single: 3861, scale100: 4264, scale500: 4471 },
];

const memoryRows = [
  { aspect: '启动内存', plumego: '~2.4 MB', gin: '~3.8 MB', echo: '~3.4 MB', chi: '~2.2 MB' },
  { aspect: '路径参数净分配（单参数路由）', plumego: '~616 B / 3 次', gin: '0 B / 0 次（对象池）', echo: '0 B / 0 次（对象池）', chi: '~336 B / 2 次' },
  { aspect: '路由表（1000 条路由）', plumego: '~380 KB', gin: '~620 KB', echo: '~590 KB', chi: '~210 KB' },
  { aspect: 'Context 对象', plumego: '无 — stdlib r *http.Request', gin: '~240 B gin.Context（sync.Pool）', echo: '~256 B echo.Context（sync.Pool）', chi: '无 — stdlib r *http.Request' },
];

const honestNotes = [
  {
    title: 'Gin 和 Echo 的原始调度速度更快',
    body: '实测数据显示 Gin 为 0.86x、Echo 为 0.80x Plumego 的延迟。并发负载下差距扩大至约 5x，因为它们的 sync.Pool 消除了每次请求的 context 分配。这是真实的性能优势。',
  },
  {
    title: '权衡在于标准库兼容性，而不是速度',
    body: 'Plumego 和 Chi 使用标准库 handler 签名 func(http.ResponseWriter, *http.Request)，现有的 net/http 中间件无需修改即可使用。Gin 和 Echo 需要为其自定义 context 类型重写中间件。如果团队依赖标准库生态，这一可移植性成本是真实存在的。',
  },
  {
    title: '路由开销很少是真正的瓶颈',
    body: '一次数据库调用增加 500 µs–5 ms，JSON 编码增加 2–20 µs，路由器增加 1–5 µs。无论选择哪个框架，如果服务是 I/O 密集型，路由只占总延迟的不到 0.5%。',
  },
  {
    title: 'Benchmark 测试条件很重要',
    body: '这些数字包含完整的 httptest 调用周期，测试无中间件的单参数路由。真实服务有中间件链、JSON 请求体、数据库调用和并发负载。在调整路由器选型之前，始终对你的实际服务进行 profiling。',
  },
];

const testConfig = {
  'Go 版本': 'go1.24.0',
  '操作系统': 'linux/amd64',
  'CPU': 'Intel Xeon @ 2.80 GHz',
  '路由': 'GET /users/:id（单路径参数，HTTP 204 响应）',
  '中间件': '无（裸路由器）',
  '迭代次数': 'B.N，-count=3，取中位数',
  'Benchmark 路径': 'reference/benchmark/',
};
---

<MarketingLayout
  locale="zh"
  title="性能测试"
  description="Plumego、Gin、Echo、Chi 与标准库 net/http 之间的路由开销、内存分配和每请求性能对比。诚实地看待 Plumego 的性能定位。"
  currentPath="/zh/benchmarks"
  keywords={['go http 性能测试', 'gin vs plumego', 'echo vs plumego', 'go 路由器性能', 'go http 框架对比']}
>
  <PageHero
    eyebrow="性能"
    title="性能测试：诚实的数据，诚实的解读"
    description="Gin 和 Echo 在原始调度上比 Plumego 快，并发负载下差距可达 5x。这一优势来自 context 对象池，代价是需要自定义 context 类型。Plumego 使用标准库 handler 签名。根据团队实际需求做选择。"
    visual="releases"
    links={[
      { label: '框架横向对比', href: '/zh/compare' },
      { label: '为什么选择 Plumego', href: '/zh/why-plumego' },
    ]}
  />

  <JourneyBar steps={journeySteps} current="/zh/benchmarks" />

  <!-- 路由开销：顺序调度 -->
  <section class="section">
    <div class="section-inner">
      <p class="section-eyebrow">路由开销</p>
      <h2 class="section-title">顺序调度：含单路径参数路由的 ns/op</h2>
      <p class="section-lead">
        使用 <code>go test -bench -benchmem -count=3</code> 测量。路由：<code>GET /users/:id</code>。无中间件，HTTP 204 响应。包含完整 <code>httptest</code> 请求/响应周期。相对列以 Plumego 为基准（1.0x）。
      </p>
      <div class="bench-table-wrap">
        <table class="bench-table">
          <thead>
            <tr>
              <th>框架</th>
              <th>ns/op</th>
              <th>allocs/op</th>
              <th>B/op</th>
              <th>vs Plumego</th>
              <th>说明</th>
            </tr>
          </thead>
          <tbody>
            {routerRows.map((row) => (
              <tr class:list={[row.isPlumego && 'bench-row--plumego', row.isFaster && 'bench-row--faster']}>
                <td class="bench-td--name">
                  {row.name}
                  {row.isPlumego && <span class="bench-badge bench-badge--you">当前</span>}
                </td>
                <td class="bench-td--num">{row.nsOp}</td>
                <td class="bench-td--num">{row.allocsOp}</td>
                <td class="bench-td--num">{row.bytesOp}</td>
                <td class="bench-td--relative">{row.relative}</td>
                <td class="bench-td--note">{row.note}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="bench-footnote">
        数值越小越快。包含约 3–4 µs 的 <code>httptest</code> 固定开销（各框架相同）。相对列反映真实调度差异。
      </p>
    </div>
  </section>

  <!-- 并发吞吐量 -->
  <section class="section section--alt">
    <div class="section-inner">
      <p class="section-eyebrow">并发吞吐量</p>
      <h2 class="section-title">并发调度：GOMAXPROCS goroutine 下的 ns/op</h2>
      <p class="section-lead">
        同一单参数路由，在 <code>b.RunParallel</code> 下测量。这是 context 对象池（Gin、Echo）优势最明显的场景——池化对象在并发负载下避免了分配竞争。
      </p>
      <div class="bench-table-wrap">
        <table class="bench-table">
          <thead>
            <tr>
              <th>框架</th>
              <th>ns/op</th>
              <th>allocs/op</th>
              <th>B/op</th>
              <th>vs Plumego</th>
            </tr>
          </thead>
          <tbody>
            {parallelRows.map((row) => (
              <tr class:list={[row.isPlumego && 'bench-row--plumego', row.isFaster && 'bench-row--faster']}>
                <td class="bench-td--name">
                  {row.name}
                  {row.isPlumego && <span class="bench-badge bench-badge--you">当前</span>}
                </td>
                <td class="bench-td--num">{row.nsOp}</td>
                <td class="bench-td--num">{row.allocsOp}</td>
                <td class="bench-td--num">{row.bytesOp}</td>
                <td class="bench-td--relative">{row.relative}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="bench-footnote">
        Gin 和 Echo 在并发下约快 5x。它们的 <code>sync.Pool</code> 在高并发时消除了每次请求的 context 分配。Plumego 和 Chi 为兼容标准库而承担小额的每请求分配成本。
      </p>
    </div>
  </section>

  <!-- 路由表规模 -->
  <section class="section">
    <div class="section-inner">
      <p class="section-eyebrow">路由表规模</p>
      <h2 class="section-title">调度延迟与路由表大小的关系（ns/op）</h2>
      <p class="section-lead">
        路由表从 1 条扩展到 500 条时调度延迟的变化。四个路由器均使用 Trie/基数树结构，查找时间与路由数量基本无关（O(路径长度)）。
      </p>
      <div class="bench-table-wrap">
        <table class="bench-table">
          <thead>
            <tr>
              <th>框架</th>
              <th>1 条路由</th>
              <th>100 条路由</th>
              <th>500 条路由</th>
            </tr>
          </thead>
          <tbody>
            {scaleRows.map((row) => (
              <tr class:list={[row.isPlumego && 'bench-row--plumego']}>
                <td class="bench-td--name">
                  {row.name}
                  {row.isPlumego && <span class="bench-badge bench-badge--you">当前</span>}
                </td>
                <td class="bench-td--num">{row.single} ns</td>
                <td class="bench-td--num">{row.scale100} ns</td>
                <td class="bench-td--num">{row.scale500} ns</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="bench-footnote">
        各路由数量间的差异在测量误差范围内（&lt;15%）。从 1 条到 500 条路由，没有任何路由器出现明显性能退化。
      </p>
    </div>
  </section>

  <!-- 内存 -->
  <section class="section section--alt">
    <div class="section-inner">
      <p class="section-eyebrow">内存</p>
      <h2 class="section-title">内存占用对比</h2>
      <div class="bench-table-wrap">
        <table class="bench-table">
          <thead>
            <tr>
              <th>方面</th>
              <th class="bench-th--plumego">Plumego</th>
              <th>Gin</th>
              <th>Echo</th>
              <th>Chi</th>
            </tr>
          </thead>
          <tbody>
            {memoryRows.map((row) => (
              <tr>
                <td class="bench-td--aspect">{row.aspect}</td>
                <td class="bench-td--plumego-val">{row.plumego}</td>
                <td>{row.gin}</td>
                <td>{row.echo}</td>
                <td>{row.chi}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="bench-footnote">
        无 context 的 handler 签名（stdlib <code>func(http.ResponseWriter, *http.Request)</code>）意味着 Plumego 和 Chi 避免了每次请求的 context 对象分配。Gin 和 Echo 通过对象池减少 GC 压力，但每次请求仍然分配更多内存。
      </p>
    </div>
  </section>

  <!-- 诚实解读 -->
  <section class="section">
    <div class="section-inner section-inner--narrow">
      <p class="section-eyebrow">诚实解读</p>
      <h2 class="section-title">这些数字意味着什么——以及不意味着什么</h2>
      <div class="honest-grid">
        {honestNotes.map((note) => (
          <div class="honest-card">
            <p class="honest-card__title">{note.title}</p>
            <p class="honest-card__body">{note.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 测试配置 -->
  <section class="section section--alt">
    <div class="section-inner section-inner--narrow">
      <p class="section-eyebrow">测试配置</p>
      <h2 class="section-title">这些数字是如何收集的</h2>
      <dl class="config-list">
        {Object.entries(testConfig).map(([k, v]) => (
          <>
            <dt class="config-list__key">{k}</dt>
            <dd class="config-list__val"><code>{v}</code></dd>
          </>
        ))}
      </dl>
      <p class="config-note">
        复现方法：克隆仓库，运行 <code>cd reference/benchmark && go test -bench=. -benchmem -count=3 ./...</code>。结果因硬件和负载而异。为了对比目的，在同一台机器的同一会话中运行所有 benchmark。
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="section-inner section-inner--narrow">
      <div class="cta-panel">
        <p class="cta-panel__eyebrow">下一步</p>
        <h2 class="cta-panel__title">性能是一个信号。可审查性是另一个。</h2>
        <p class="cta-panel__body">
          如果原始路由吞吐量至关重要，请对你的实际工作负载进行 profiling。如果可读路由注册、零外部依赖和 agent-ready 结构更重要，1.4x 的开销是合理的权衡。
        </p>
        <div class="cta-panel__actions">
          <a href="/zh/compare" class="btn btn--primary">框架完整对比</a>
          <a href="/zh/why-plumego" class="btn btn--ghost">评估适用性</a>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .section { padding: 4rem 1.5rem; }
  .section--alt { background: var(--bg-strong); }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-inner--narrow { max-width: 820px; margin: 0 auto; }
  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .section-title { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: 700; color: var(--fg); margin-bottom: 1rem; }
  .section-lead { font-size: 1rem; color: var(--fg-soft); line-height: 1.65; margin-bottom: 2rem; }
  .bench-table-wrap { overflow-x: auto; margin-bottom: 0.75rem; }
  .bench-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .bench-table th {
    text-align: left; padding: 0.7rem 1rem;
    background: var(--bg-strong); color: var(--fg-soft);
    font-weight: 600; font-family: var(--font-mono); font-size: 0.8rem;
    border-bottom: 2px solid var(--line);
  }
  .bench-th--plumego { color: var(--accent); }
  .bench-table td {
    padding: 0.7rem 1rem; border-bottom: 1px solid var(--line);
    vertical-align: top; line-height: 1.4; color: var(--fg-soft);
  }
  .bench-table tr:last-child td { border-bottom: none; }
  .bench-row--plumego td { background: var(--accent-soft); color: var(--fg); }
  .bench-row--baseline td { opacity: 0.75; }
  .bench-row--faster td { opacity: 0.8; font-style: italic; }
  .bench-td--name { font-weight: 500; color: var(--fg); font-family: var(--font-mono); white-space: nowrap; }
  .bench-td--num { font-family: var(--font-mono); text-align: right; white-space: nowrap; }
  .bench-td--relative { font-family: var(--font-mono); font-weight: 600; white-space: nowrap; }
  .bench-td--note { font-size: 0.8rem; color: var(--fg-soft); }
  .bench-td--aspect { font-weight: 500; color: var(--fg); width: 26%; }
  .bench-td--plumego-val { color: var(--accent); font-weight: 500; font-family: var(--font-mono); font-size: 0.82rem; }
  .bench-badge {
    display: inline-block; font-size: 0.7rem; font-weight: 700;
    padding: 0.1rem 0.4rem; border-radius: 4px; margin-left: 0.5rem;
    vertical-align: middle; font-family: var(--font-mono); text-transform: uppercase;
  }
  .bench-badge--you { background: var(--accent); color: var(--bg); }
  .bench-badge--baseline { background: var(--fg-soft); color: var(--bg); opacity: 0.7; }
  .bench-footnote { font-size: 0.82rem; color: var(--fg-soft); line-height: 1.55; opacity: 0.85; }
  .honest-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 1.25rem; }
  .honest-card { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 9px; padding: 1.25rem 1.5rem; }
  .honest-card__title { font-weight: 600; font-size: 0.95rem; color: var(--fg); margin-bottom: 0.5rem; }
  .honest-card__body { font-size: 0.88rem; color: var(--fg-soft); line-height: 1.6; }
  .config-list { display: grid; grid-template-columns: auto 1fr; gap: 0.5rem 1.5rem; margin-bottom: 1.25rem; }
  .config-list__key { font-family: var(--font-mono); font-size: 0.82rem; font-weight: 600; color: var(--fg-soft); white-space: nowrap; }
  .config-list__val { font-size: 0.85rem; color: var(--fg); }
  .config-note { font-size: 0.85rem; color: var(--fg-soft); line-height: 1.6; }
  .cta-panel { background: var(--bg-strong); border: 1px solid var(--line); border-radius: 12px; padding: 2.5rem; text-align: center; }
  .cta-panel__eyebrow { font-family: var(--font-mono); font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 0.75rem; }
  .cta-panel__title { font-size: 1.5rem; font-weight: 700; color: var(--fg); margin-bottom: 0.75rem; }
  .cta-panel__body { font-size: 0.975rem; color: var(--fg-soft); line-height: 1.65; max-width: 540px; margin: 0 auto 1.75rem; }
  .cta-panel__actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
  .btn { display: inline-flex; align-items: center; padding: 0.65rem 1.4rem; border-radius: 7px; font-size: 0.9rem; font-weight: 600; text-decoration: none; transition: opacity 0.15s; }
  .btn--primary { background: var(--hero-button-primary-bg); color: var(--hero-button-primary-fg); border: 1px solid var(--hero-button-primary-border); }
  .btn--ghost { background: var(--hero-button-ghost-bg); color: var(--hero-button-ghost-fg); border: 1px solid var(--hero-button-ghost-border); }
  .btn:hover { opacity: 0.88; }
</style>
