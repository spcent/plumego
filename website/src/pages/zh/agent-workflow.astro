---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import PageHero from '../../components/marketing/PageHero.astro';
import JourneyBar from '../../components/marketing/JourneyBar.astro';

const journeySteps = [
  { label: '为什么选择', href: '/zh/why-plumego' },
  { label: 'Agent 工作流', href: '/zh/agent-workflow' },
  { label: '文档', href: '/zh/docs' },
];

const controlPlaneFiles = [
  {
    file: 'specs/task-routing.yaml',
    role: '工作分类器',
    desc: '把任务描述映射到所属模块。Agent 在打开任何 Go 文件之前先读这个——归属错误出现在计划阶段，而不是 diff 里。',
    example: `routing_rules:
  stable_root_work:
    intent: 修改内核、生命周期、路由结构、
            传输层中间件或存储 primitive。
    destination: stable
    packages: [middleware, core, router, ...]
  extension_work:
    intent: 修改产品能力或协议适配。
    destination: extension
    primary_families: [x/ai, x/tenant, x/gateway, ...]`,
  },
  {
    file: 'specs/dependency-rules.yaml',
    role: '导入边界执行器',
    desc: '声明哪些层可以导入哪些层。稳定根不得导入 x/*。CI 机械强制执行——不依赖评审者记忆。',
    example: `rules:
  - from: stable_roots
    to: extensions
    allowed: false
    reason: 稳定根不得导入 x/* 家族。
  - from: extensions
    to: stable_roots
    allowed: true`,
  },
  {
    file: 'specs/change-recipes/',
    role: '预定义变更序列',
    desc: '定义已知变更类型正确步骤序列的 YAML 文件。按 recipe 工作的 agent 读取步骤，依次执行，然后运行指定的检查器。',
    example: `# specs/change-recipes/fix-bug.yaml
steps:
  - read: <module>/module.yaml
  - read: specs/dependency-rules.yaml
  - edit: 目标文件
  - run: go test -race ./<module>/...
  - run: go run ./internal/checks/dependency-rules
  - run: make gates`,
  },
  {
    file: '<module>/module.yaml',
    role: '模块级清单',
    desc: '每个模块声明其职责、允许的导入、禁止的模式和必要的验证命令。Agent 在编辑前读取。',
    example: `module: middleware
status: stable
responsibilities:
  - 仅限传输层横切关注点
  - 每次 handler 调用 next 恰好一次
forbidden:
  - 业务逻辑或 DTO 组装
  - 导入 x/* 包
validation:
  - go test -race ./middleware/...
  - go vet ./middleware/...`,
  },
  {
    file: 'internal/checks/*',
    role: 'CI 强制 gate',
    desc: '用于边界合规、manifest 一致性、工作流合规和参考布局的机械检查器。推送前本地运行——与 CI 相同。',
    example: `# 每次提交前运行：
go run ./internal/checks/dependency-rules
go run ./internal/checks/agent-workflow
go run ./internal/checks/module-manifests
go run ./internal/checks/reference-layout

# 或者一次性运行所有：
make gates`,
  },
];

const workflowSteps = [
  {
    n: '01',
    title: '在碰代码之前先分类归属',
    body: '读取 specs/task-routing.yaml。将任务描述匹配到路由规则。确认所属模块。这一步在打开任何文件之前运行。',
    signal: 'task-routing.yaml → 所属模块',
  },
  {
    n: '02',
    title: '读取模块清单',
    body: '打开 <module>/module.yaml。读取职责、禁止模式和必要的验证命令。在写代码之前先了解作用域。',
    signal: 'module.yaml → 本地约束',
  },
  {
    n: '03',
    title: '检查是否有预定义 recipe',
    body: '如果 specs/change-recipes/ 有对应这类变更的 recipe，按其定义的步骤序列执行。已知变更类型不应该需要 agent 即兴发挥。',
    signal: 'change-recipes/ → 执行序列',
  },
  {
    n: '04',
    title: '提交前验证导入边界',
    body: '运行 go run ./internal/checks/dependency-rules。通过即说明变更没有引入隐式耦合。失败则修复具体的边界违规。',
    signal: 'dependency-rules 检查 → 无边界违规',
  },
  {
    n: '05',
    title: '运行完整 gate 套件',
    body: '推送前运行 make gates。这与 CI 等效：gofmt、go vet、race 测试、边界检查、manifest 检查和参考布局验证。',
    signal: 'make gates → 绿色',
  },
];

const comparisonRows = [
  {
    aspect: '归属分类',
    conventional: '存在于团队记忆和 PR review 惯例中',
    agentReady: '机器可读，在 specs/task-routing.yaml 中——agent 在写代码前就能读取',
  },
  {
    aspect: '导入边界规则',
    conventional: '由评审者知识和 linter 配置执行',
    agentReady: '在 specs/dependency-rules.yaml 中声明，由 internal/checks/ 在 CI 时强制执行',
  },
  {
    aspect: '变更序列',
    conventional: '由团队实践暗示，因人而异',
    agentReady: '在 specs/change-recipes/ 中明确——已知变更类型有定义好的步骤',
  },
  {
    aspect: '模块作用域',
    conventional: '从包名和现有代码中推断',
    agentReady: '在每个模块的 module.yaml 中声明——职责、限制和验证命令',
  },
  {
    aspect: '提交前验证',
    conventional: '团队特定的清单，经常被跳过',
    agentReady: 'make gates 与 CI 等效——一条命令，一致，必须执行',
  },
];
---

<MarketingLayout
  locale="zh"
  title="Agent 就绪工作流"
  description="Plumego 的机器可读控制面如何让 AI 编程 agent 分类工作归属、执行边界检查、遵循预定义变更路径——无需依赖团队记忆。"
  currentPath="/zh/agent-workflow"
  keywords={['agent-ready go', 'ai coding agent go', 'plumego agent 工作流', '机器可读 go 架构']}
>
  <PageHero
    eyebrow="结构化 agent-ready"
    title="Agent 能读懂的代码。团队能 review 的服务。"
    description="Plumego 把架构约定外化为机器可读的文件。AI 编程 agent 可以分类归属、检查导入边界、遵循预定义的变更序列——无需依赖团队记忆或框架文档。"
    visual="architecture"
    links={[
      { label: '阅读完整文档', href: '/zh/docs/concepts/agent-first-workflow' },
      { label: '开始使用', href: '/zh/docs/getting-started' },
    ]}
  />

  <JourneyBar steps={journeySteps} current="/zh/agent-workflow" />

  <!-- 问题 -->
  <section class="section">
    <div class="section-inner section-inner--narrow">
      <p class="section-eyebrow">问题所在</p>
      <h2 class="section-title">大多数代码库对 AI agent 是不透明的</h2>
      <p class="section-lead">
        AI 编程 assistant 能写出可以编译、能过测试的代码——但经常违反架构约定、引入隐式耦合，或修改了错误的模块。不是因为模型本身有问题，而是因为这些约定存在于团队记忆和 PR 评论里，不是以模型在写代码之前就能读懂的形式存在的。
      </p>
      <div class="comparison-table-wrap">
        <table class="comparison-table">
          <thead>
            <tr>
              <th>方面</th>
              <th>传统代码库</th>
              <th>Plumego agent-ready 代码库</th>
            </tr>
          </thead>
          <tbody>
            {comparisonRows.map((row) => (
              <tr>
                <td class="comparison-table__aspect">{row.aspect}</td>
                <td class="comparison-table__before">{row.conventional}</td>
                <td class="comparison-table__after">{row.agentReady}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- 控制面文件 -->
  <section class="section section--alt">
    <div class="section-inner">
      <p class="section-eyebrow">控制面</p>
      <h2 class="section-title">让代码库具备 agent-ready 的五个文件</h2>
      <p class="section-lead">
        Plumego 的 <code>specs/</code> 和 <code>module.yaml</code> 文件是仓库的一等公民。它们不是文档——它们是机器可读的操作规则，agent 在编辑任何 Go 文件之前先读取这些规则。
      </p>
      <div class="cp-grid">
        {controlPlaneFiles.map((f) => (
          <div class="cp-card">
            <div class="cp-card__head">
              <code class="cp-card__file">{f.file}</code>
              <span class="cp-card__role">{f.role}</span>
            </div>
            <p class="cp-card__desc">{f.desc}</p>
            <pre class="cp-card__code"><code>{f.example}</code></pre>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Agent 工作流步骤 -->
  <section class="section">
    <div class="section-inner section-inner--narrow">
      <p class="section-eyebrow">工作流</p>
      <h2 class="section-title">Agent 在编辑 Go 代码之前做什么</h2>
      <p class="section-lead">
        分类步骤被刻意前置。边界违规和归属错误应该出现在计划阶段——而不是在 diff 里或 CI 中。
      </p>
      <div class="workflow-steps">
        {workflowSteps.map((step) => (
          <div class="workflow-step">
            <span class="workflow-step__n">{step.n}</span>
            <div class="workflow-step__body">
              <p class="workflow-step__title">{step.title}</p>
              <p class="workflow-step__desc">{step.body}</p>
              <code class="workflow-step__signal">{step.signal}</code>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 实战示例 -->
  <section class="section section--alt">
    <div class="section-inner section-inner--narrow">
      <p class="section-eyebrow">实战示例</p>
      <h2 class="section-title">"给入站 greet 端点添加限流"</h2>
      <p class="section-lead">从任务描述到确定所属模块的完整路由决策过程。</p>

      <div class="example-steps">
        <div class="example-step">
          <p class="example-step__label">第一步 — 读取 task-routing.yaml</p>
          <p class="example-step__body">任务中的信号："入站"（传输关注点）、"限流"（中间件类别）、"greet 端点"（路由注册）。</p>
        </div>
        <div class="example-step">
          <p class="example-step__label">第二步 — 分类</p>
          <div class="example-table-wrap">
            <table class="example-table">
              <thead><tr><th>任务中的信号</th><th>路由匹配</th><th>归属</th></tr></thead>
              <tbody>
                <tr><td>"入站"</td><td>传输关注点，不是产品逻辑</td><td><code>stable_root_work</code></td></tr>
                <tr><td>入站路径上的"限流"</td><td>传输层中间件，不是熔断器</td><td><code>middleware</code></td></tr>
                <tr><td>"greet 端点"</td><td>路由注册，应用本地</td><td><code>app_wiring</code></td></tr>
              </tbody>
            </table>
          </div>
        </div>
        <div class="example-step">
          <p class="example-step__label">第三步 — 结果</p>
          <p class="example-step__body">
            改动属于 <code>middleware/</code>，从 <code>middleware/module.yaml</code> 开始。
            <br/>
            <code>x/resilience</code> 是出站熔断保护——不同的分类。
            先开 <code>x/resilience</code> 是路由表可以预防的归属错误。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="section-inner section-inner--narrow">
      <div class="final-cta-panel">
        <p class="final-cta-panel__eyebrow">深入了解</p>
        <h2 class="final-cta-panel__title">文档中的完整技术参考</h2>
        <p class="final-cta-panel__body">
          文档页面详细介绍工作路由、边界强制执行、变更 recipe，以及当 agent 改动跨越模块边界时该怎么做。
        </p>
        <div class="final-cta-panel__actions">
          <a href="/zh/docs/concepts/agent-first-workflow" class="btn btn--primary">
            Agent 工作流文档
          </a>
          <a href="/zh/docs/concepts/repo-control-plane" class="btn btn--ghost">
            仓库控制面
          </a>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>

<style>
  .section { padding: 4rem 1.5rem; }
  .section--alt { background: var(--bg-strong); }
  .section-inner { max-width: 1100px; margin: 0 auto; }
  .section-inner--narrow { max-width: 820px; margin: 0 auto; }
  .section-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .section-title {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 700;
    color: var(--fg);
    margin-bottom: 1rem;
  }
  .section-lead {
    font-size: 1.05rem;
    color: var(--fg-soft);
    line-height: 1.65;
    margin-bottom: 2rem;
  }
  .comparison-table-wrap { overflow-x: auto; }
  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .comparison-table th {
    text-align: left;
    padding: 0.75rem 1rem;
    background: var(--bg-strong);
    color: var(--fg-soft);
    font-weight: 600;
    border-bottom: 1px solid var(--line);
  }
  .comparison-table td {
    padding: 0.75rem 1rem;
    vertical-align: top;
    border-bottom: 1px solid var(--line);
    line-height: 1.5;
  }
  .comparison-table__aspect { font-weight: 600; color: var(--fg); width: 20%; }
  .comparison-table__before { color: var(--fg-soft); width: 40%; }
  .comparison-table__after { color: var(--fg); width: 40%; }
  .cp-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(420px, 1fr));
    gap: 1.25rem;
  }
  .cp-card {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 1.5rem;
  }
  .cp-card__head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }
  .cp-card__file {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }
  .cp-card__role {
    font-size: 0.8rem;
    color: var(--fg-soft);
    font-weight: 500;
  }
  .cp-card__desc {
    font-size: 0.9rem;
    color: var(--fg-soft);
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  .cp-card__code {
    background: var(--code-bg);
    border-radius: 7px;
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.78rem;
    line-height: 1.55;
    color: var(--code-text);
    font-family: var(--font-mono);
    white-space: pre;
    margin: 0;
  }
  .workflow-steps { display: flex; flex-direction: column; gap: 0; }
  .workflow-step {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--line);
    align-items: flex-start;
  }
  .workflow-step:last-child { border-bottom: none; }
  .workflow-step__n {
    font-family: var(--font-mono);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--accent);
    opacity: 0.45;
    flex-shrink: 0;
    width: 2.5rem;
    padding-top: 0.15rem;
  }
  .workflow-step__title { font-weight: 600; font-size: 1rem; color: var(--fg); margin-bottom: 0.4rem; }
  .workflow-step__desc { font-size: 0.9rem; color: var(--fg-soft); line-height: 1.6; margin-bottom: 0.5rem; }
  .workflow-step__signal {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--accent);
    background: var(--accent-soft);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    display: inline-block;
  }
  .example-steps { display: flex; flex-direction: column; gap: 1.25rem; }
  .example-step {
    background: var(--bg-elevated);
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
  }
  .example-step__label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.6rem;
  }
  .example-step__body { font-size: 0.9rem; color: var(--fg-soft); line-height: 1.6; }
  .example-table-wrap { overflow-x: auto; }
  .example-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.85rem;
    margin-top: 0.5rem;
  }
  .example-table th {
    text-align: left;
    padding: 0.5rem 0.75rem;
    background: var(--bg-strong);
    color: var(--fg-soft);
    font-weight: 600;
    font-size: 0.8rem;
    border-bottom: 1px solid var(--line);
  }
  .example-table td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--line);
    color: var(--fg-soft);
    line-height: 1.5;
    vertical-align: top;
  }
  .example-table tr:last-child td { border-bottom: none; }
  .final-cta-panel {
    background: var(--bg-strong);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 2.5rem;
    text-align: center;
  }
  .final-cta-panel__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .final-cta-panel__title { font-size: 1.6rem; font-weight: 700; color: var(--fg); margin-bottom: 0.75rem; }
  .final-cta-panel__body {
    font-size: 1rem;
    color: var(--fg-soft);
    line-height: 1.65;
    max-width: 560px;
    margin: 0 auto 1.75rem;
  }
  .final-cta-panel__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 1.4rem;
    border-radius: 7px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .btn--primary {
    background: var(--hero-button-primary-bg);
    color: var(--hero-button-primary-fg);
    border: 1px solid var(--hero-button-primary-border);
  }
  .btn--ghost {
    background: var(--hero-button-ghost-bg);
    color: var(--hero-button-ghost-fg);
    border: 1px solid var(--hero-button-ghost-border);
  }
  .btn:hover { opacity: 0.88; }
</style>
