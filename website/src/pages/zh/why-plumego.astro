---
import PageHero from '../../components/marketing/PageHero.astro';
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const guideCards = [
  {
    kicker: 'explicit wiring',
    title: 'Plumego 适合那些希望服务结构在代码库增长后依然可读的团队',
    body: '真正的价值在团队变大之后才会显现：路由注册、中间件顺序与依赖注入都写在代码里——评审一次改动就是阅读代码本身，而不是追踪框架约定。',
  },
  {
    kicker: 'shared baseline',
    title: '当多个服务需要共用一套默认结构时，它会更有价值',
    body: '如果新服务应该从同一份可读的参考结构起步，而不是让每个团队各写一套启动逻辑，Plumego 提供的基线就能方便地交接和扩展，而不会逐渐偏离成各自的模式。',
  },
  {
    kicker: '清晰的成熟度信号',
    title: '当你需要在采用前区分稳定与实验时，它最有说服力',
    body: '稳定模块与实验性能力被刻意分开，采用决策可以基于今天真正生产就绪的内容——而不仅仅是某个包已经存在于仓库。',
  },
] as const;

const fitProfiles = [
  {
    kicker: 'best fit',
    title: '需要在代码里追踪请求链路的内部 API',
    body: '当一次 PR 应该让你看清哪些路由被注册、哪些中间件按序执行、依赖由谁持有——而不需要阅读框架源码——Plumego 更合适。',
    points: [
      '路由注册必须在代码评审中保持可见',
      'handler 归属与中间件顺序必须显式',
      '团队已经习惯在 net/http 心智下工作',
    ],
  },
  {
    kicker: 'best fit',
    title: '多个团队共用一套服务骨架的平台服务',
    body: '当多个团队需要从同一份参考结构起步建立新服务，并且你希望服务间的结构漂移保持在低位时，这套框架会最有效。',
    points: [
      '新服务应该沿用和现有服务一致的结构',
      '评审者希望整个代码库遵循一套收敛的模式',
      '共用骨架能降低团队轮换时的上手成本',
    ],
  },
  {
    kicker: 'best fit',
    title: '需要清晰模块成熟度信号的仓库',
    body: '当采用决策需要基于明确的成熟度证据——稳定、受支持或实验阶段——而不是从包是否存在来推断，Plumego 更有说服力。',
    points: [
      '稳定表面与实验表面必须容易区分',
      '团队需要知道哪些可以依赖、哪些还可能变动',
      '采用范围应该跟着已发布的证据走，而不仅仅是可用性',
    ],
  },
] as const;

const cautionProfiles = [
  {
    kicker: 'slow down',
    title: '你希望框架约定自动处理服务结构',
    body: '如果团队主要想把路由和依赖配置交给框架隐式处理，Plumego 可能会显得比预期更刻意。',
  },
  {
    kicker: 'slow down',
    title: '每个服务都刻意采用独立的自定义结构',
    body: '每个服务需要自己定义启动流程、路由逻辑和依赖模式的比例越高，共用参考基线能提供的价值就越少。',
  },
  {
    kicker: 'slow down',
    title: '你希望直接使用包而不遵循结构化的采用模型',
    body: 'Plumego 更适合那些愿意区分稳定、受支持与实验模块的团队；如果这种区分对你的团队不重要，围绕它建立的纪律就会显得多余。',
  },
] as const;

const teamRows = [
  {
    signal: '团队姿态',
    fit: '你希望在代码库变得太宽、超过单人认知之前，先建立一套共用的服务结构。',
    caution: '你更希望每个团队自行优化各自的服务形态，不需要共同的参考模型。',
  },
  {
    signal: '代码评审预期',
    fit: '评审者应该能直接在代码里检查路由、中间件和依赖注入。',
    caution: '评审主要关注业务逻辑，并愿意把结构性决策交给框架来负责。',
  },
  {
    signal: '仓库结构',
    fit: '你希望文档、示例、发布和路线图共同强化同一套可见的采用模型。',
    caution: '你可以接受”包存在”就暗示成熟度，不需要公开的模块边界地图。',
  },
] as const;

const decisionPaths = [
  {
    kicker: 'ready now',
    title: '适配已经明确，下一个问题是实现',
    body: '如果评估已经完成，下一步是如何构建服务，就先进入文档首页，再按顺序进入 Getting Started 和参考应用。',
    href: '/zh/docs',
    cta: '打开文档首页',
  },
  {
    kicker: '查看模块布局',
    title: '你认同这套模型，但需要先了解模块布局',
    body: '如果下一个决策取决于哪些模块稳定、哪些是扩展模块、改动应该落在哪里，就先去看架构页。',
    href: '/zh/architecture',
    cta: '阅读架构页',
  },
  {
    kicker: '需要可运行的证明',
    title: '一个真实的服务示例能更快回答适配问题',
    body: '如果把框架和真实服务形态做对照，比再读一页概念性内容更能回答你的问题，就去看示例页。',
    href: '/zh/examples',
    cta: '打开示例页',
  },
  {
    kicker: '确认成熟度',
    title: '你需要在决定之前确认哪些模块已经准备好',
    body: '如果真正的问题不是某个模块是否存在，而是它今天是否稳定到可以放进正在评估的服务里，就先看发布页。',
    href: '/zh/releases',
    cta: '查看发布页',
  },
] as const;
---

<MarketingLayout
  locale="zh"
  title="为什么选择 Plumego"
  description="当你需要判断 Plumego 是否匹配眼前这个服务、团队姿态与仓库形态时，请先读这一页。"
  currentPath="/zh/why-plumego"
  imagePath="/brand/og-zh.svg"
  keywords={['为什么选择 plumego', 'plumego 采用判断', 'go 服务工具包', '显式 http 服务']}
>
  <PageHero
    eyebrow="Adoption Decision"
    title="为什么选择 Plumego"
    description="当问题变成 Plumego 是否适合你的团队与评审预期——而不再是技术细节如何使用时，先读这一页。"
    links={[
      { label: '架构', href: '/zh/architecture' },
      { label: '发布', href: '/zh/releases' },
      { label: '示例', href: '/zh/examples' },
    ]}
  />

  <section class="section">
    <div class="section__intro">
      <h2>在深入技术细节之前先读这一页。</h2>
      <p>
        架构页解释模块如何组织，发布页说明哪些稳定、哪些还在实验阶段。这一页位于更早的一步：在你花时间了解技术布局之前，先帮你判断 Plumego 是否是你的团队真正需要的模型。
      </p>
    </div>
    <div class="signal-list">
      {guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro">
      <h2>Plumego 最强的场景在哪里。</h2>
      <p>
        当评审清晰度、显式归属感与一套默认服务形态，比框架托管的便利更重要时，Plumego 会更有说服力。
      </p>
    </div>
    <div class="page-grid">
      {fitProfiles.map((item) => (
        <article class="page-panel page-panel--fit">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
          <ul>
            {item.points.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>适合信号与谨慎信号。</h2>
      <p>
        这张对照表的目的，是帮助你做决定，而不是只欣赏架构。当你真正想知道 Plumego 的显式模型会不会改善眼前这个服务时，就看这里。
      </p>
    </div>
    <div class="comparison-table" role="table" aria-label="Plumego 采用判断的适配信号与谨慎信号对照">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">信号</span>
        <span role="columnheader">适合</span>
        <span role="columnheader">先放慢</span>
      </div>
      {teamRows.map((row) => (
        <div class="comparison-table__row" role="row">
          <strong role="cell">{row.signal}</strong>
          <span role="cell">{row.fit}</span>
          <span role="cell">{row.caution}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro">
      <h2>哪些情况下应该先暂停采用。</h2>
      <p>
        Plumego 并不是为了赢下每次比较。如果下面这些信号更接近你的团队目标，显式模型现在可能带来的摩擦大于价值。
      </p>
    </div>
    <div class="control-grid">
      {cautionProfiles.map((item) => (
        <article class="page-panel page-panel--dense page-panel--caution">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>按你的确定度选择下一页。</h2>
      <p>
        一旦你确认了适配关系，就打开那个真正回答你下一个具体问题的页面。
      </p>
    </div>
    <div class="control-grid control-grid--tight">
      {decisionPaths.map((item) => (
        <article class="control-grid__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
          <a class="text-link" href={item.href}>{item.cta}</a>
        </article>
      ))}
    </div>
  </section>
</MarketingLayout>
