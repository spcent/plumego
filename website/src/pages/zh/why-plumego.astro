---
import PageHero from '../../components/marketing/PageHero.astro';
import JourneyBar from '../../components/marketing/JourneyBar.astro';
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import CheckIcon from '../../components/shared/CheckIcon.astro';
import CautionIcon from '../../components/shared/CautionIcon.astro';

const journeySteps = [
  { label: '为什么选择', href: '/zh/why-plumego' },
  { label: '示例', href: '/zh/examples' },
  { label: '发布', href: '/zh/releases' },
];

const fitChecks = [
  {
    label: '01',
    title: 'reviewable wiring',
    evidence: 'route 注册、中间件顺序和依赖入口都能直接在代码评审里看到',
  },
  {
    label: '02',
    title: 'shared baseline',
    evidence: '新服务先从同一套参考形态起步，而不是各自发明 bootstrap',
  },
  {
    label: '03',
    title: 'maturity signal',
    evidence: '采用之前先区分稳定根、受支持参考路径和实验性扩展家族',
  },
  {
    label: '04',
    title: 'agent-ready',
    evidence: '机器可读规范、每模块 manifest 和标准化检查命令，为代码 Agent 提供清晰的操作模型',
  },
  {
    label: '05',
    title: 'stdlib-first',
    evidence: 'handler 签名是 func(w http.ResponseWriter, r *http.Request)——无自定义 context，所有 net/http 中间件零改造复用',
  },
  {
    label: '06',
    title: 'zero deps',
    evidence: '稳定核心只导入 Go 标准库——内核层无任何传递性外部依赖风险',
  },
] as const;

const fitProfiles = [
  {
    kicker: 'best fit',
    title: '需要在代码里追踪请求链路的内部 API',
    body: '当一次 PR 应该让你看清哪些路由被注册、哪些中间件按序执行、依赖由谁持有——而不需要阅读框架源码——Plumego 更合适。',
    points: [
      '路由注册必须在代码评审中保持可见',
      'handler 归属与中间件顺序必须显式',
      '团队已经习惯在 net/http 心智下工作',
    ],
  },
  {
    kicker: 'best fit',
    title: '多个团队共用一套服务骨架的平台服务',
    body: '当多个团队需要从同一份参考结构起步建立新服务，并且你希望服务间的结构漂移保持在低位时，这套框架会最有效。',
    points: [
      '新服务应该沿用和现有服务一致的结构',
      '评审者希望整个代码库遵循一套收敛的模式',
      '共用骨架能降低团队轮换时的上手成本',
    ],
  },
  {
    kicker: 'best fit',
    title: '需要清晰模块成熟度信号的仓库',
    body: '当采用决策需要基于明确的成熟度证据——稳定、受支持或实验阶段——而不是从包是否存在来推断，Plumego 更有说服力。',
    points: [
      '稳定表面与实验表面必须容易区分',
      '团队需要知道哪些可以依赖、哪些还可能变动',
      '采用范围应该跟着已发布的证据走，而不仅仅是可用性',
    ],
  },
  {
    kicker: 'best fit',
    title: '人类工程师与 AI 代码 Agent 共同维护的仓库',
    body: 'Plumego 专为 AI Agent 参与执行和评审的代码库设计。四个机器可读控制面——<code>docs/</code>、<code>specs/</code>、<code>tasks/</code> 和 <code>reference/</code>——给 Agent 提供确定性操作模型：任务如何分类、先读哪些文件、正确改动应该是什么样子、贡献落地前哪些检查必须通过。让人类评审更容易的结构，同样让 Agent 的贡献可被验证。',
    points: [
      'specs/task-routing.yaml 在打开任何代码文件之前先将任务意图映射到归属模块',
      'specs/change-recipes/ 为 15 种常见修改类型定义了有序步骤和止步条件',
      '每个 module/module.yaml 声明该包的改动范围、风险等级、测试命令和评审清单',
      'internal/checks/ 以程序化方式执行边界规则——本地运行与 CI 运行的检查完全相同',
      'make gates 在每次推送前提供 Agent 可执行的、等同于 CI 的验证循环',
    ],
  },
] as const;

const cautionProfiles = [
  {
    kicker: 'not a fit',
    title: '团队深度依赖 Gin 或 Echo 的插件生态',
    body: 'Gin 和 Echo 有大量围绕其自定义 context 类型（gin.Context / echo.Context）构建的中间件目录、认证插件和社区工具。如果团队依赖这套生态，切换 handler 签名的迁移代价是真实存在的，且收益不明显。',
  },
  {
    kicker: 'not a fit',
    title: '你需要框架内置 ORM、依赖注入容器或自动注册机制',
    body: 'Plumego 不携带数据库访问、依赖注入或自动注册逻辑。如果团队期待框架提供或装配这些关注点，显式 DI 模式会像不必要的负担。请选择一个完整的应用框架。',
  },
  {
    kicker: 'not a fit',
    title: 'x/* 家族的成熟度风险是你组织的硬性阻断',
    body: '9 个稳定根承载 v1 兼容性承诺。x/* 扩展家族属于 experimental 或 beta——在各自证据闭环前 API 仍可能变化。如果组织政策要求所有能力都具备稳定版本化 API，请只采用稳定根和已晋级 beta 的表面。',
  },
  {
    kicker: 'slow down',
    title: '你希望框架约定自动处理服务结构',
    body: '如果团队主要想把路由和依赖配置交给框架隐式处理，Plumego 可能会显得比预期更刻意。',
  },
  {
    kicker: 'slow down',
    title: '每个服务都刻意采用独立的自定义结构',
    body: '每个服务需要自己定义启动流程、路由逻辑和依赖模式的比例越高，共用参考基线能提供的价值就越少。',
  },
] as const;

const teamRows = [
  {
    signal: '团队姿态',
    fit: '你希望在代码库变得太宽、超过单人认知之前，先建立一套共用的服务结构。',
    caution: '你更希望每个团队自行优化各自的服务形态，不需要共同的参考模型。',
  },
  {
    signal: '代码评审预期',
    fit: '评审者应该能直接在代码里检查路由、中间件和依赖注入。',
    caution: '评审主要关注业务逻辑，并愿意把结构性决策交给框架来负责。',
  },
  {
    signal: '仓库结构',
    fit: '你希望文档、示例、发布和路线图共同强化同一套可见的采用模型。',
    caution: '你可以接受”包存在”就暗示成熟度，不需要公开的模块边界地图。',
  },
] as const;


const frameworkRows = [
  {
    name: 'Gin / Echo',
    fit: '上手快，生态大，约定优先的路由风格。',
    tradeoff: '自定义 context 类型（<code>gin.Context</code>、<code>echo.Context</code>）替换了标准库 handler 签名——已有的 <code>net/http</code> 中间件需要适配器。',
    isPlumego: false,
  },
  {
    name: 'Chi',
    fit: '纯标准库路由，极简，高度可组合。',
    tradeoff: '只提供路由——没有响应体封装、没有中间件目录、没有安全辅助工具，这些都需要自己组装。',
    isPlumego: false,
  },
  {
    name: 'Plumego',
    fit: '显式服务结构，标准库 handler 签名（<code>func(w http.ResponseWriter, r *http.Request)</code>），结构化 <code>contract</code> 层，中间件目录，安全辅助工具。',
    tradeoff: '比 chi 有更多结构意见，比 gin/echo 少一些自动约定。最适合那些更看重路由 ownership 可见性和评审清晰度，而不是框架便利性的团队。',
    isPlumego: true,
  },
] as const;
---

<MarketingLayout
  locale="zh"
  title="采用决策"
  description="当你需要判断 Plumego 是否匹配眼前这个服务、团队姿态与仓库形态时，请先读这一页。"
  currentPath="/zh/why-plumego"
  imagePath="/brand/og-zh.svg"
  keywords={['为什么选择 plumego', 'plumego 采用判断', 'go 服务工具包', '显式 http 服务']}
>
  <PageHero
    eyebrow="Adoption Decision"
    title="为什么选择 Plumego"
    description="当问题变成 Plumego 是否适合你的团队与评审预期——而不再是技术细节如何使用时，先读这一页。"
    locale="zh"
    visual="decision"
    links={[
      { label: '架构', href: '/zh/architecture' },
      { label: '发布', href: '/zh/releases' },
      { label: '示例', href: '/zh/examples' },
    ]}
  />

  <JourneyBar steps={journeySteps} current="/zh/why-plumego" />

  <!-- Agent-first callout — 独特差异化能力，在页面顶部突出展示 -->
  <section class="section agent-first-callout">
    <div class="agent-first-callout__inner">
      <div class="agent-first-callout__badge">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
          <rect x="9" y="2" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
          <rect x="2" y="9" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
          <rect x="9" y="9" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.5"/>
        </svg>
        Agent 就绪
      </div>
      <h2 class="agent-first-callout__title">专为使用 AI 编码工具的团队设计。</h2>
      <p class="agent-first-callout__body">
        <em>这里讨论的是 AI 编码助手（Claude、Copilot、Cursor）——帮助写代码或评审代码的工具。这不是关于构建 AI agent 服务的内容；那是 <code>x/ai</code> 模块的范围。</em>
      </p>
      <p class="agent-first-callout__body">
        Plumego 是第一个让这些编码助手在动手写代码之前就能精确定位变更归属的 Go HTTP 工具包。
        机器可读规范、每模块 manifest 和显式边界规则，让 Agent 拥有和资深 reviewer 相同的任务路由信号。
      </p>
      <div class="agent-first-callout__points">
        <div class="agent-first-callout__point">
          <code>specs/task-routing.yaml</code>
          <span>将任务类型映射到所属模块</span>
        </div>
        <div class="agent-first-callout__point">
          <code>specs/dependency-rules.yaml</code>
          <span>阻止 Agent 越过稳定根边界</span>
        </div>
        <div class="agent-first-callout__point">
          <code>AGENTS.md</code>
          <span>定义人类与 AI 协作的共享协议</span>
        </div>
      </div>
      <a class="text-link" href="/zh/docs/concepts/agent-first-workflow">查看交互式任务路由演示 →</a>
    </div>
  </section>

  <!-- 术语定义：Plumego 专有术语（CONTENT_RULES Rule 4） -->
  <section class="section section--tinted">
    <div class="section__intro">
      <h2>Plumego 使用的四个专有术语。</h2>
      <p>这些词在本仓库有精确含义，不是通用的 Go 术语。</p>
    </div>
    <div class="comparison-table" role="table" aria-label="Plumego 专有术语">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">术语</span>
        <span role="columnheader">一行定义</span>
      </div>
      <div class="comparison-table__row" role="row">
        <strong role="cell">stable root（稳定根）</strong>
        <span role="cell">具有长期 API 兼容承诺的模块，属于 v1 稳定根表面：<code>core</code>、<code>router</code>、<code>contract</code>、<code>middleware</code>、<code>security</code>、<code>store</code>、<code>health</code>、<code>log</code>、<code>metrics</code>。</span>
      </div>
      <div class="comparison-table__row" role="row">
        <strong role="cell">x/* family（x/* 家族）</strong>
        <span role="cell"><code>x/</code> 目录下的可选能力模块，除非另有标注否则为 Experimental。应从所属家族入口进入，而不是直接使用下级 primitive。</span>
      </div>
      <div class="comparison-table__row" role="row">
        <strong role="cell">control plane（控制面）</strong>
        <span role="cell"><code>docs/</code>、<code>specs/</code>、<code>tasks/</code> 目录，存放人类可读规则和机器可读约束，供人类和 AI 编码助手使用。</span>
      </div>
      <div class="comparison-table__row" role="row">
        <strong role="cell">canonical path（规范路径）</strong>
        <span role="cell">由 <code>reference/standard-service</code> 定义的默认服务布局——每个新服务都应以此为基准进行对比。</span>
      </div>
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro">
      <h2>先用三个工程信号判断是否适配。</h2>
      <p>
        Plumego 的适配问题应该用可见证据回答，而不是用框架宣传回答。
      </p>
    </div>
    <div class="fit-check-board">
      <div class="fit-check-board__track">
        {fitChecks.map((item) => (
          <article class="fit-check-board__item">
            <span>{item.label}</span>
            <h3>{item.title}</h3>
            <p>{item.evidence}</p>
          </article>
        ))}
      </div>
      <div class="code-block">
        <div class="code-block__bar">
          <div class="code-block__dots"><span></span><span></span><span></span></div>
          <span class="code-block__filename">adoption-review.md</span>
        </div>
        <pre class="code-block__pre"><code>- route registration stays visible
- middleware order is reviewable
- reference app is the canonical service shape
- release posture limits adoption assumptions
- stdlib handler signature — no adapters needed
- zero external deps in the stable core</code></pre>
      </div>
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro">
      <h2>Plumego 最强的场景在哪里。</h2>
      <p>
        当评审清晰度、显式归属感与一套默认服务形态，比框架托管的便利更重要时，Plumego 会更有说服力。
      </p>
    </div>
    <div class="page-grid">
      {fitProfiles.map((item) => (
        <article class="page-panel page-panel--fit">
          <p class="signal-list__kicker">
            <CheckIcon class="comparison-cell-icon comparison-cell-icon--fit" size={13} />
            {item.kicker}
          </p>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
          <ul>
            {item.points.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>AI coding assistant 也能可靠地在这套仓库里工作。</h2>
      <p>
        <em>这一节讨论的是 AI <strong>编码助手</strong>（Copilot、Claude、Cursor）——帮助写代码或评审代码的工具。这不是关于构建 AI agent 服务的话题；那是 <code>x/ai</code> 模块的范围。</em>
      </p>
      <p>
        现在大多数团队的 review 流程里都有 AI 助手参与。关键区别在于：这些助手是在猜架构规则，还是在读机器可读的规则？
        Plumego 的控制面——<code>specs/</code>、<code>tasks/</code>、<code>docs/</code>——被设计来给 agent 提供与人工评审相同的归属信号。
      </p>
    </div>
    <div class="signal-list">
      <article class="signal-list__item">
        <p class="signal-list__kicker">work routing</p>
        <h3>Agent 在改代码之前就能知道改动该落在哪个模块</h3>
        <p>
          <code>specs/task-routing.yaml</code> 把工作类型映射到所属模块。agent 在评估一次改动时读路由表，而不是靠猜测目录结构来推断归属。
        </p>
      </article>
      <article class="signal-list__item">
        <p class="signal-list__kicker">boundary enforcement</p>
        <h3>Import 违规靠机器捕获，不靠评审者记忆</h3>
        <p>
          <code>specs/dependency-rules.yaml</code> 与 <code>internal/checks/dependency-rules</code> 配合，违反稳定根边界的 PR 会直接卡在 gate——无论改动来自人还是 agent。
        </p>
      </article>
      <article class="signal-list__item">
        <p class="signal-list__kicker">change recipes</p>
        <h3>常见修改类型有定义好的路径，而不是一个开放的 prompt</h3>
        <p>
          <code>specs/change-recipes/</code> 给 agent 提供已知改动类型的显式执行顺序：新建稳定模块、修复 bug、晋升扩展、废弃处理。
          recipe 缩小了 hallucination 空间，让 agent 的输出能用与人工评审相同的规则来检验。
        </p>
      </article>
    </div>
    <div class="routing-teaser">
      <p class="routing-teaser__label">任务路由实际效果</p>
      <div class="comparison-table routing-teaser__table" role="table" aria-label="任务路由示例">
        <div class="comparison-table__head" role="row">
          <strong role="columnheader">任务描述</strong>
          <strong role="columnheader">路由规则</strong>
          <strong role="columnheader">归属模块</strong>
        </div>
        <div class="comparison-table__row" role="row">
          <span role="cell">给入站 HTTP 端点加限流</span>
          <span role="cell"><code>middleware</code></span>
          <span role="cell"><code>middleware/</code></span>
        </div>
        <div class="comparison-table__row" role="row">
          <span role="cell">加入租户级 JWT 校验</span>
          <span role="cell"><code>tenant_policy_change</code></span>
          <span role="cell"><code>x/tenant/</code></span>
        </div>
        <div class="comparison-table__row" role="row">
          <span role="cell">构建 AI 流式 SSE 端点</span>
          <span role="cell"><code>extension_work → x/ai</code></span>
          <span role="cell"><code>x/ai/</code></span>
        </div>
        <div class="comparison-table__row" role="row">
          <span role="cell">更新 specs 中的 import 方向规则</span>
          <span role="cell"><code>repo_rules</code></span>
          <span role="cell"><code>specs/</code></span>
        </div>
      </div>
      <p class="routing-teaser__note">完整路由表覆盖 10 种任务类型。文档页面提供交互式 demo，可以逐步查看每种分类过程。</p>
    </div>
    <div class="page-links" style="margin-top: 1.5rem;">
      <a class="text-link" href="/zh/docs/concepts/agent-first-workflow">体验交互式路由 demo →</a>
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>适合信号与谨慎信号。</h2>
      <p>
        这张对照表的目的，是帮助你做决定，而不是只欣赏架构。当你真正想知道 Plumego 的显式模型会不会改善眼前这个服务时，就看这里。
      </p>
    </div>
    <div class="comparison-table" role="table" aria-label="Plumego 采用判断的适配信号与谨慎信号对照">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">信号</span>
        <span role="columnheader">
          <CheckIcon class="comparison-cell-icon comparison-cell-icon--fit" size={13} />
          适合
        </span>
        <span role="columnheader">
          <CautionIcon class="comparison-cell-icon comparison-cell-icon--caution" size={13} />
          先放慢
        </span>
      </div>
      {teamRows.map((row) => (
        <div class="comparison-table__row" role="row">
          <strong role="cell">{row.signal}</strong>
          <span role="cell">
            <CheckIcon class="comparison-cell-icon comparison-cell-icon--fit" size={12} />
            {row.fit}
          </span>
          <span role="cell">
            <CautionIcon class="comparison-cell-icon comparison-cell-icon--caution" size={12} />
            {row.caution}
          </span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>与 Gin、Echo、Chi 的横向对比。</h2>
      <p>
        四者都基于 <code>net/http</code>，差异在哲学和范围上，而不是性能。
        选型依据应该是你希望在代码评审里看到什么，而不仅仅是 benchmark 数字。
      </p>
    </div>
    <div class="comparison-table" role="table" aria-label="Plumego 与 Gin、Echo、Chi 的对比">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">工具包</span>
        <span role="columnheader">优势</span>
        <span role="columnheader">权衡</span>
      </div>
      {frameworkRows.map((row) => (
        <div class={`comparison-table__row${row.isPlumego ? ' comparison-table__row--highlight' : ''}`} role="row">
          <strong role="cell">{row.name}{row.isPlumego ? ' ✦' : ''}</strong>
          <span role="cell" set:html={row.fit} />
          <span role="cell" set:html={row.tradeoff} />
        </div>
      ))}
    </div>
    <div class="signal-list" style="margin-top: 2rem;">
      <article class="signal-list__item">
        <p class="signal-list__kicker">router 开销</p>
        <h3>实测：相比 stdlib ServeMux 为 1.4×–4.3×——可知且有界</h3>
        <p>
          Plumego 的 trie 路由器在分发之上增加了 per-request context 注入、参数映射构建和中间件链接线。
          相比 Go 1.22+ <code>http.ServeMux</code> 的开销区间从深路径参数的 <strong>1.4×</strong>
          到单参数路由的 <strong>4.3×</strong>——绝对值为 110–1,036 ns。
          对于典型的 I/O 耗时 1 ms–100 ms 的 handler，router 开销占请求总时间的 0.001%–0.1%。
          <a class="text-link" href="/zh/releases">在发布页查看完整 benchmark 表格 →</a>
        </p>
      </article>
    </div>
  </section>

