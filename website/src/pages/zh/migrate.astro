---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import PageHero from '../../components/marketing/PageHero.astro';
import JourneyBar from '../../components/marketing/JourneyBar.astro';

const journeySteps = [
  { label: '为什么选择', href: '/zh/why-plumego' },
  { label: '扩展', href: '/zh/extensions' },
  { label: '示例', href: '/zh/examples' },
  { label: '发布', href: '/zh/releases' },
];

const migrations = [
  {
    from: 'Gin',
    tagline: 'func(c *gin.Context) → func(w, r)',
    cost: 'medium',
    costNote: '每个服务 1–3 天',
    handlerDiff: '所有 handler 需从 gin.Context 改写。路由语法保持不变。',
    middlewareDiff: '中间件需从 gin.HandlerFunc 适配为 func(http.Handler) http.Handler。',
    routingDiff: '/foo/:id 可以直接映射。Group 结构保持不变。',
    wins: ['无自定义 context 类型', 'stdlib 中间件无需适配器即可使用', '内核零传递依赖'],
    guide: '/zh/docs/guides/migrate-from-gin-echo',
    compareHref: '/zh/compare#gin',
  },
  {
    from: 'Echo',
    tagline: 'func(c echo.Context) error → func(w, r)',
    cost: 'medium',
    costNote: '每个服务 1–3 天',
    handlerDiff: '所有 handler 需从 echo.Context 改写。error return 惯用法替换为 contract.WriteError。',
    middlewareDiff: 'Echo 中间件需要适配。Logger、CORS 和 recover 都有 Plumego 对应实现。',
    routingDiff: '路由语法相似。Echo group API 可直接映射到 router.Group。',
    wins: ['无自定义 context 类型', '显式错误模型', '内核零传递依赖'],
    guide: '/zh/docs/guides/migrate-from-gin-echo',
    compareHref: '/zh/compare#echo',
  },
  {
    from: 'Chi',
    tagline: '相同的 handler 签名——改动极少',
    cost: 'low',
    costNote: '数小时到一天',
    handlerDiff: 'Chi 使用 func(w, r)——与 Plumego 相同。Handler 代码无需修改。',
    middlewareDiff: 'Chi 中间件为 func(http.Handler) http.Handler——兼容。现有中间件通常可直接使用。',
    routingDiff: '路由语法相似。chi.URLParam(r, "id") 替换为 router.PathParam(r, "id")。',
    wins: ['handler 代码不变', '现有 stdlib 中间件可复用', '学习曲线更低'],
    guide: '/zh/docs/guides/migrate-from-chi',
    compareHref: '/zh/compare#chi',
  },
];

const costColors: Record<string, string> = {
  low: '#22c55e',
  medium: '#f59e0b',
  high: '#ef4444',
};
---

<MarketingLayout
  locale="zh"
  title="迁移到 Plumego — 从 Gin、Echo 或 Chi"
  description="从 Gin、Echo 或 Chi 迁移到 Plumego 的指南和成本估算。Handler 映射、中间件适配、路由翻译及分步指南。"
  currentPath="/zh/migrate"
>
  <PageHero
    eyebrow="迁移"
    title="迁移到 Plumego。从 Gin、Echo 或 Chi 出发。"
    description="每条迁移路径的成本和模式各不相同。Chi 是摩擦最低的路径；Gin 和 Echo 需要改写 handler。选择你的源框架，看看哪些需要改变，哪些保持不变。"
  />

  <JourneyBar steps={journeySteps} current="/zh/migrate" />

  <section class="section migrate-section">
    <div class="migrate-cards">
      {migrations.map((m) => (
        <div class="migrate-card">
          <div class="migrate-card__header">
            <div class="migrate-card__from">
              <span class="migrate-from-label">来自</span>
              <span class="migrate-from-name">{m.from}</span>
            </div>
            <div class="migrate-card__cost" style={`--cost-color: ${costColors[m.cost]}`}>
              <span class="migrate-cost-dot"></span>
              <span class="migrate-cost-label">{m.cost === 'low' ? '低' : m.cost === 'medium' ? '中' : '高'}迁移成本</span>
              <span class="migrate-cost-note">{m.costNote}</span>
            </div>
          </div>

          <p class="migrate-card__tagline">{m.tagline}</p>

          <div class="migrate-diffs">
            <div class="migrate-diff">
              <span class="migrate-diff__label">Handler</span>
              <p>{m.handlerDiff}</p>
            </div>
            <div class="migrate-diff">
              <span class="migrate-diff__label">中间件</span>
              <p>{m.middlewareDiff}</p>
            </div>
            <div class="migrate-diff">
              <span class="migrate-diff__label">路由</span>
              <p>{m.routingDiff}</p>
            </div>
          </div>

          <div class="migrate-wins">
            <span class="migrate-wins__label">你能得到什么</span>
            <ul>
              {m.wins.map(w => <li>{w}</li>)}
            </ul>
          </div>

          <div class="migrate-card__actions">
            <a class="button button--primary" href={m.guide}>迁移指南 →</a>
            <a class="button button--ghost" href={m.compareHref}>并排对比 →</a>
          </div>
        </div>
      ))}
    </div>

    <div class="migrate-adoption-note">
      <h3>还没准备好一次性迁移所有内容？</h3>
      <p>阅读<a href="/zh/docs/guides/adoption-path">渐进式采用指南</a>，了解分阶段方案——先迁移稳定根，仅在需要时引入扩展，无需大爆炸式重写。</p>
    </div>
  </section>
</MarketingLayout>

<style>
  .migrate-section { padding-block: 3rem 5rem; max-width: 64rem; margin-inline: auto; }
  .migrate-cards { display: flex; flex-direction: column; gap: 1.5rem; }
  .migrate-card { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 0.875rem; padding: 2rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .migrate-card__header { display: flex; align-items: flex-start; gap: 1.5rem; flex-wrap: wrap; justify-content: space-between; }
  .migrate-card__from { display: flex; align-items: baseline; gap: 0.5rem; }
  .migrate-from-label { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-soft); }
  .migrate-from-name { font-size: 1.4rem; font-weight: 800; color: var(--fg); letter-spacing: -0.02em; }
  .migrate-card__cost { display: flex; align-items: center; gap: 0.45rem; flex-wrap: wrap; }
  .migrate-cost-dot { width: 0.55rem; height: 0.55rem; border-radius: 50%; background: var(--cost-color); flex-shrink: 0; }
  .migrate-cost-label { font-size: 0.78rem; font-weight: 600; color: var(--cost-color); }
  .migrate-cost-note { font-size: 0.72rem; color: var(--fg-soft); border-left: 1px solid var(--line); padding-left: 0.5rem; margin-left: 0.1rem; }
  .migrate-card__tagline { font-family: var(--font-mono); font-size: 0.85rem; color: var(--accent); background: var(--accent-soft); padding: 0.4rem 0.8rem; border-radius: 0.4rem; margin: 0; display: inline-block; }
  .migrate-diffs { display: grid; grid-template-columns: 1fr; gap: 0.75rem; }
  @media (min-width: 640px) { .migrate-diffs { grid-template-columns: repeat(3, 1fr); } }
  .migrate-diff { background: var(--bg-strong); border: 1px solid var(--line); border-radius: 0.5rem; padding: 0.85rem 1rem; display: flex; flex-direction: column; gap: 0.35rem; }
  .migrate-diff__label { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.09em; text-transform: uppercase; color: var(--fg-soft); }
  .migrate-diff p { font-size: 0.83rem; color: var(--fg-soft); line-height: 1.55; margin: 0; }
  .migrate-wins { display: flex; flex-direction: column; gap: 0.4rem; }
  .migrate-wins__label { font-size: 0.65rem; font-weight: 700; letter-spacing: 0.09em; text-transform: uppercase; color: var(--accent); }
  .migrate-wins ul { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .migrate-wins li { font-size: 0.8rem; color: var(--fg-soft); background: var(--bg-strong); border: 1px solid var(--line); border-radius: 0.3rem; padding: 0.18rem 0.55rem; }
  .migrate-card__actions { display: flex; gap: 0.75rem; flex-wrap: wrap; padding-top: 0.5rem; border-top: 1px solid var(--line); }
  .migrate-adoption-note { margin-top: 3rem; padding: 1.5rem 2rem; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: 0.75rem; border-left: 3px solid var(--accent); }
  .migrate-adoption-note h3 { font-size: 1rem; font-weight: 600; color: var(--fg); margin: 0 0 0.5rem; }
  .migrate-adoption-note p { font-size: 0.88rem; color: var(--fg-soft); line-height: 1.65; margin: 0; }
  .migrate-adoption-note a { color: var(--accent); text-decoration: underline; }
</style>
