---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import PageHero from '../../components/marketing/PageHero.astro';
import JourneyBar from '../../components/marketing/JourneyBar.astro';
import LayerDiagram from '../../components/marketing/LayerDiagram.astro';
import RequestFlowViz from '../../components/marketing/RequestFlowViz.astro';
import { ARCHITECTURE_COPY } from '../../data/site';
import { MODULE_FACTS } from '../../generated/modules';

function moduleHref(name: string): string {
  if (name.startsWith('x/')) return `/zh/docs/modules/${name.replace('/', '-')}`;
  return `/zh/docs/modules/${name}`;
}

const MODULE_PRIMER: Record<string, string> = {
  core: '/zh/docs/modules/core',
  router: '/zh/docs/modules/router',
  contract: '/zh/docs/modules/contract',
  middleware: '/zh/docs/modules/middleware',
  security: '/zh/docs/modules/security',
  store: '/zh/docs/modules/store',
  health: '/zh/docs/modules/health',
  log: '/zh/docs/modules/log',
  metrics: '/zh/docs/modules/metrics',
  'x/ai': '/zh/docs/modules/x-ai',
  'x/cache': '/zh/docs/modules/x-cache',
  'x/data': '/zh/docs/modules/x-data',
  'x/devtools': '/zh/docs/modules/x-devtools',
  'x/discovery': '/zh/docs/modules/x-discovery',
  'x/fileapi': '/zh/docs/modules/x-fileapi',
  'x/frontend': '/zh/docs/modules/x-frontend',
  'x/gateway': '/zh/docs/modules/x-gateway',
  'x/messaging': '/zh/docs/modules/x-messaging',
  'x/mq': '/zh/docs/modules/x-messaging-subordinates',
  'x/pubsub': '/zh/docs/modules/x-messaging-subordinates',
  'x/observability': '/zh/docs/modules/x-observability',
  'x/ops': '/zh/docs/modules/x-ops',
  'x/resilience': '/zh/docs/modules/x-resilience',
  'x/rest': '/zh/docs/modules/x-rest',
  'x/scheduler': '/zh/docs/modules/x-scheduler',
  'x/tenant': '/zh/docs/modules/x-tenant',
  'x/webhook': '/zh/docs/modules/x-webhook',
  'x/websocket': '/zh/docs/modules/x-websocket',
  // x/ipc 暂无独立 primer，渲染为纯文本
};

const xScenarios = [
  {
    kicker: 'multi-tenant saas',
    title: '带 per-tenant 路由、配额与 JWT 策略的多租户服务',
    body: 'x/tenant 在 HTTP 内核之外提供强制租户身份、per-tenant 配额和策略评估。稳定根承担传输基线，x/tenant 承担租户层，两者互不污染。',
    href: '/zh/docs/modules/x-tenant',
    label: '打开 x/tenant 模块手册',
  },
  {
    kicker: 'ai service',
    title: '带 streaming 和工具路由的多 Provider AI 服务',
    body: 'x/ai 在稳定 net/http 内核旁边提供 provider 抽象、session 生命周期和 streaming 响应处理。AI 能力工作留在默认请求路径之外。',
    href: '/zh/docs/modules/x-ai',
    label: '打开 x/ai 模块手册',
  },
  {
    kicker: 'api gateway',
    title: '边缘代理、负载均衡与路由组合',
    body: 'x/gateway 在边缘提供反向代理、上游健康检查和负载均衡，而不改变上游服务的稳定路由模型。',
    href: '/zh/docs/modules/x-gateway',
    label: '打开 x/gateway 模块手册',
  },
  {
    kicker: 'real-time',
    title: '在同一 HTTP 服务器上的 WebSocket 连接',
    body: 'x/websocket 提供全双工 WebSocket 处理，与标准 HTTP 路由共存，复用同一套稳定中间件链和 handler 形态。',
    href: '/zh/docs/modules/x-websocket',
    label: '打开 x/websocket 模块手册',
  },
] as const;

const copy = ARCHITECTURE_COPY.zh;

const journeySteps = [
  { label: '为什么选择', href: '/zh/why-plumego' },
  { label: '示例', href: '/zh/examples' },
  { label: '发布', href: '/zh/releases' },
];

const requestFlowNodes = [
  {
    step: '01',
    title: '边界请求先进入 net/http',
    code: 'net/http',
    note: '先把入口保持克制，ownership 才会从显式代码开始。',
    accent: false,
  },
  {
    step: '02',
    title: '应用本地 wiring 负责组装依赖',
    code: 'internal/app/app.go',
    note: 'bootstrap 是否自律，直接决定后续代码是否还容易读。',
    accent: true,
  },
  {
    step: '03',
    title: 'routes 负责划定公开请求路径',
    code: 'internal/app/routes.go',
    note: 'route 注册是第一张架构地图，而不是可以跳过的细节。',
    accent: true,
  },
  {
    step: '04',
    title: '路径读清以后，能力再向外分层',
    code: 'handler / x/*',
    note: '扩展应当建立在分类之后，而不是为了省事。',
    accent: false,
  },
] as const;

const comparisonRows = [
  {
    aspect: '归属判断',
    stable: '它是否属于几乎所有服务都会依赖、并且需要更强兼容性承诺的职责？',
    extension: '它是否属于可选、协议相关或产品形态很强的能力，不应该重写默认路径？',
  },
  {
    aspect: '演进速度',
    stable: '更慢、更收敛、更容易在评审中为兼容性负责。',
    extension: '可以更快演进，只要和 canonical path 的边界仍然足够清楚。',
  },
  {
    aspect: '读者预期',
    stable: '新读者应该只看文档和 reference app 就能理解为什么它存在。',
    extension: '新读者应该先理解自己为什么需要它，再决定是否打开具体家族。',
  },
] as const;

const repositorySignals = [
  {
    label: 'docs',
    title: '承担学习路径与边界解释',
    body: 'Docs 负责先教会 canonical path、request flow 与公开心智模型，而不是让读者单靠包名猜结构。',
    href: '/zh/docs',
    cta: '打开文档',
  },
  {
    label: 'reference',
    title: '提供可运行的服务形态',
    body: 'reference/standard-service 让默认 bootstrap 与 route ownership 保持可见，让新读者先拥有一条可以对照的仓库基线。',
    href: '/zh/docs/reference-app',
    cta: '阅读参考应用',
  },
  {
    label: 'generated facts',
    title: '公开发布库存与成熟度信号',
    body: '同步生成的事实把稳定根、扩展家族与成熟度信号变成机器可读信号，而不是重复书写的营销表述。',
    href: '/zh/releases',
    cta: '查看模块成熟度',
  },
  {
    label: 'app-local code',
    title: '让 ownership 保持可见的代码位置',
    body: 'internal/app 是服务自有 wiring 最该保持直观的地方。在更深的能力包进入讨论之前，它应该始终是第一站。',
    href: '/zh/examples',
    cta: '查看示例路径',
  },
  {
    label: 'control plane',
    title: '供人和 agent 读取的机器可读规则',
    body: 'specs/ 以机器可读格式存放 dependency rules、task routing 和 change recipes。AI coding assistant 在改代码之前先读这些规则来分类工作——和人工评审使用的是同一套信号。',
    href: '/zh/docs/concepts/agent-first-workflow',
    cta: '阅读 Agent 工作流',
  },
] as const;
---

<MarketingLayout
  locale="zh"
  title={copy.title}
  description={copy.description}
  currentPath="/zh/architecture"
  keywords={['plumego 架构', 'go 服务架构', 'stdlib-first go', '显式 http 服务']}
>
  <PageHero
    eyebrow={copy.eyebrow}
    title={copy.title}
    description={copy.description}
    locale="zh"
    visual="architecture"
    links={[
      { label: '示例', href: '/zh/examples' },
      { label: '文档', href: '/zh/docs' },
    ]}
  />

  <JourneyBar steps={journeySteps} current="/zh/architecture" />

  <section class="section">
    <div class="section__intro">
      <h2>{copy.introTitle}</h2>
      <p>{copy.introBody}</p>
    </div>
    <div class="signal-list">
      {copy.guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro">
      <h2>先把架构看成三块互相配合的区域</h2>
      <p>
        只有当内核、canonical 阅读路径与向外分叉的能力家族，能够带着真实仓库事实同时出现在一个视图里时，Plumego 才更容易被判断与信任。
      </p>
    </div>
    <LayerDiagram locale="zh" />
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.sectionTitle}</h2>
      <p>{copy.sectionBody}</p>
    </div>
    <div class="page-grid">
      {copy.layers.map((item) => (
        <article class="page-panel">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
          <ul>
            {item.items.map((entry) => {
              const href = MODULE_PRIMER[entry];
              return href
                ? <li><a class="text-link" href={href}>{entry}</a></li>
                : <li>{entry}</li>;
            })}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro">
      <h2>{copy.flowTitle}</h2>
      <p>{copy.flowBody}</p>
    </div>
    <RequestFlowViz nodes={requestFlowNodes} />
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>canonical path 在代码里应该长什么样。</h2>
      <p>
        route 注册是服务的第一张架构地图。它应该能直接在评审里被读懂，而不是藏在框架源码或隐式注册里。
      </p>
    </div>
    <div class="contrast-grid">
      <div class="code-block">
        <div class="code-block__bar">
          <div class="code-block__dots"><span></span><span></span><span></span></div>
          <span class="code-block__filename">internal/app/routes.go</span>
        </div>
        <pre class="code-block__pre"><code><span class="hc-kw">func</span> (a *App) <span class="hc-fn">Routes</span>() http.Handler &#123;
    r := router.<span class="hc-fn">New</span>()

    r.<span class="hc-fn">Use</span>(middleware.<span class="hc-fn">RequestID</span>())
    r.<span class="hc-fn">Use</span>(middleware.<span class="hc-fn">Logger</span>(a.log))
    r.<span class="hc-fn">Use</span>(middleware.<span class="hc-fn">Recovery</span>(a.log))

    r.<span class="hc-fn">Get</span>(<span class="hc-str">"/api/items"</span>,  a.items.<span class="hc-fn">List</span>)
    r.<span class="hc-fn">Post</span>(<span class="hc-str">"/api/items"</span>, a.items.<span class="hc-fn">Create</span>)
    r.<span class="hc-fn">Get</span>(<span class="hc-str">"/health"</span>, health.<span class="hc-fn">Handler</span>(a.checker))

    <span class="hc-cm">// route map 保持可见，没有隐藏注册</span>
    <span class="hc-kw">return</span> r
&#125;</code></pre>
      </div>
      <div class="code-block">
        <div class="code-block__bar">
          <div class="code-block__dots"><span></span><span></span><span></span></div>
          <span class="code-block__filename">internal/app/app.go</span>
        </div>
        <pre class="code-block__pre"><code><span class="hc-kw">type</span> App <span class="hc-kw">struct</span> &#123;
    log     log.Logger
    db      *sql.DB
    items   *items.Handler
    checker health.Checker
&#125;

<span class="hc-kw">func</span> <span class="hc-fn">New</span>(cfg *config.Config, deps AppDeps) (*App, error) &#123;
    <span class="hc-cm">// 每个依赖都在构造函数里显式出现</span>
    <span class="hc-kw">return</span> &App&#123;
        log:     deps.Logger,
        db:      deps.DB,
        items:   items.<span class="hc-fn">NewHandler</span>(deps.DB),
        checker: health.<span class="hc-fn">NewChecker</span>(),
    &#125;, <span class="hc-kw">nil</span>
&#125;</code></pre>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>稳定根的信号必须保持显式</h2>
      <p>
        架构页不应该只把内核列出来，还应该说明哪些工作真的属于那里，以及哪些 root 名称本身就在提醒你：能力关注点正在继续向内漂移。
      </p>
    </div>
    <div class="page-grid">
      <article class="page-panel page-panel--dense page-panel--fit">
        <p class="signal-list__kicker">stable-root work intent</p>
        <h3>让内核承担长期的 transport 与 lifecycle 职责</h3>
        <p>{MODULE_FACTS.stableRootWorkIntent}</p>
        <ul>
          {MODULE_FACTS.stableRoots.map((item) => (
            MODULE_PRIMER[item] ? <li><a class="text-link" href={MODULE_PRIMER[item]}>{item}</a></li> : <li>{item}</li>
          ))}
        </ul>
      </article>
      <article class="page-panel page-panel--dense page-panel--caution">
        <p class="signal-list__kicker">discouraged roots</p>
        <h3>能力导向的名字，通常意味着应该继续向外分层</h3>
        <p>这些名字在产品能力或协议语境里很常见，但它们不适合作为默认根，因为会模糊内核的 ownership 边界。</p>
        <ul>
          {MODULE_FACTS.discouragedRoots.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </article>
      <article class="page-panel page-panel--dense">
        <p class="signal-list__kicker">extension work intent</p>
        <h3>让向外家族更快演进，同时不重写默认路径</h3>
        <p>{MODULE_FACTS.extensionWorkIntent}</p>
        <ul>
          {MODULE_FACTS.allExtensionPaths.map((item) => (
            MODULE_PRIMER[item] ? <li><a class="text-link" href={MODULE_PRIMER[item]}>{item}</a></li> : <li>{item}</li>
          ))}
        </ul>
      </article>
    </div>
  </section>

  <!-- x/* 场景区块 -->
  <section class="section">
    <div class="section__intro">
      <h2>用 x/* 扩展家族可以构建什么。</h2>
      <p>
        扩展家族不只是模块名——每个家族拥有一个具体的能力域。用下面四个场景判断哪个 x/* 家族最相关，再决定是否打开对应的模块手册。
      </p>
    </div>
    <div class="page-grid">
      {xScenarios.map((item) => (
        <article class="page-panel page-panel--dense">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
          <a class="text-link" href={item.href}>{item.label}</a>
        </article>
      ))}
    </div>
    <div class="page-links" style="margin-top: 1.5rem;">
      <a class="text-link" href="/zh/use-cases">查看全部使用场景</a>
      <a class="text-link" href="/zh/docs/x-family">浏览全部 x/* 家族</a>
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro">
      <h2>仓库形态也应该强化同一套心智模型</h2>
      <p>
        架构并不只是包结构故事，它同样是仓库结构故事：docs 负责教路径，reference app 负责证明路径，生成事实负责公开边界，app-local code 负责保持服务 ownership 的可读性，control plane 负责把规则变成机器可读的信号。
      </p>
    </div>
    <div class="control-grid control-grid--tight">
      {repositorySignals.map((item) => (
        <article class="control-grid__item">
          <p class="signal-list__kicker">{item.label}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
          <a class="text-link" href={item.href}>{item.cta}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>stable roots 与扩展模块的区别，本质上是归属区别</h2>
      <p>这两层都重要。差别在于，一层负责保护几乎所有服务都会依赖的默认路径，另一层负责防止可选能力继续向内渗透。</p>
    </div>
    <div class="comparison-table" role="table" aria-label="稳定根与扩展模块对比">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">信号</span>
        <span role="columnheader">稳定根</span>
        <span role="columnheader">扩展模块</span>
      </div>
      {comparisonRows.map((row) => (
        <div class="comparison-table__row" role="row">
          <strong role="cell">{row.aspect}</strong>
          <span role="cell">{row.stable}</span>
          <span role="cell">{row.extension}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>回到 reference path 继续</h2>
      <p>架构页解答改动应该落在哪一层。下一个问题是如何运行它——先从「开始使用」入手，再用「示例」看它实际跑起来的样子。</p>
    </div>
    <div class="page-links">
      <a class="text-link" href="/zh/docs/getting-started">打开开始使用 →</a>
      <a class="text-link" href="/zh/examples">查看可运行示例 →</a>
    </div>
  </section>
</MarketingLayout>
