---
import PageHero from '../../components/marketing/PageHero.astro';
import MarketingLayout from '../../layouts/MarketingLayout.astro';

const quickChecks = [
  {
    kicker: 'request flow',
    title: '你希望请求路径在代码里保持可评审',
    body: '当 route 注册、中间件顺序与 app-local wiring 应该继续保持可见，而不是被框架默认值吞没时，Plumego 会更有价值。',
  },
  {
    kicker: 'service shape',
    title: '你希望新服务有一条统一起步路径',
    body: '如果新服务应该从同一条可读的参考布局起步，而不是继续长出仓库私有的 bootstrap 变体，这套模型会更有吸引力。',
  },
  {
    kicker: 'maturity posture',
    title: '你需要显式的支持与 ownership 信号',
    body: 'stable roots、x/* families、release posture 与 roadmap direction 被拆开，是为了公开说明哪些区域是 baseline，哪些仍然需要谨慎采用。',
  },
] as const;

const nextQuestions = [
  {
    kicker: 'go deeper',
    title: '为什么选择 Plumego',
    body: '如果你需要更长的判断答案——团队画像、反适配信号，以及按确定度选择下一步路径——就进入完整的 adoption 落地页。',
    href: '/zh/why-plumego',
    cta: '打开 Why Plumego',
  },
  {
    kicker: 'topology first',
    title: '架构',
    body: '如果你的下一个决策取决于 stable roots、extension families 与改动真正该落在哪一层，就先去看 Architecture。',
    href: '/zh/architecture',
    cta: '阅读架构页',
  },
  {
    kicker: 'runnable proof',
    title: '示例',
    body: '如果 canonical runnable path 与 guided recipes 比继续看概念页更快回答适配问题，就直接进入 Examples。',
    href: '/zh/examples',
    cta: '打开示例页',
  },
  {
    kicker: 'support posture',
    title: '发布',
    body: '如果真正的问题不是某个模块存不存在，而是它现在是否足够成熟到可以采用，就去看 Releases。',
    href: '/zh/releases',
    cta: '查看发布页',
  },
] as const;

const cautionSignals = [
  {
    kicker: 'slow down',
    title: '你更重视框架魔法，而不是显式评审路径',
    body: '如果目标是让结构尽量隐藏在框架约定后面，Plumego 可能会显得过于克制。',
  },
  {
    kicker: 'slow down',
    title: '每个服务都应该继续发明自己的形态',
    body: '这套模型更适合仓库想收敛出一条 canonical path，而不是允许多个本地 bootstrap 风格同时扩散。',
  },
] as const;
---

<MarketingLayout
  locale="zh"
  title="采用判断"
  description="把这一页当作快速判断入口：先快速筛选，再决定是否继续进入 Why Plumego、Architecture、Examples 或 Releases。"
  currentPath="/zh/use-cases"
  imagePath="/brand/og-zh.svg"
  keywords={['plumego 采用判断', '为什么选择 plumego', 'go 服务工具包', '显式 http 服务']}
>
  <PageHero
    eyebrow="Quick Fit Check"
    title="采用判断"
    description="把这一页当作 adoption 问题的短版本。如果信号基本对齐，再继续进入 Why Plumego 查看更完整的判断路径。"
    links={[
      { label: '为什么选择 Plumego', href: '/zh/why-plumego' },
      { label: '架构', href: '/zh/architecture' },
      { label: '示例', href: '/zh/examples' },
    ]}
  />

  <section class="section">
    <div class="section__intro">
      <h2>当你只需要一个快速答案时，从这里开始。</h2>
      <p>
        这一页现在是更短的 adoption gateway。它的作用，是先帮助你判断 Plumego 是否值得继续深入，再把你送往真正回答下一个问题的页面。
      </p>
    </div>
    <div class="control-grid">
      {quickChecks.map((item) => (
        <article class="page-panel page-panel--dense">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>两个通常意味着“先放慢”的信号。</h2>
      <p>
        Plumego 并不是为了覆盖所有场景。如果下面这些谨慎信号更接近你的团队，就先保留架构模型的理解，不必过早强行采用。
      </p>
    </div>
    <div class="control-grid control-grid--tight">
      {cautionSignals.map((item) => (
        <article class="control-grid__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>有意识地选择下一页。</h2>
      <p>
        一旦快速判断已经更清楚，就去打开真正匹配你当前确定度的页面：继续深入 adoption、先看仓库边界、先做 runnable 对照，或者先核对成熟度姿态。
      </p>
    </div>
    <div class="control-grid control-grid--tight">
      {nextQuestions.map((item) => (
        <article class="control-grid__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
          <a class="text-link" href={item.href}>{item.cta}</a>
        </article>
      ))}
    </div>
  </section>
</MarketingLayout>
