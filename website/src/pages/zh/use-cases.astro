---
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import PageHero from '../../components/marketing/PageHero.astro';
import { USE_CASES_COPY } from '../../data/site';

const copy = USE_CASES_COPY.zh;
---

<MarketingLayout
  locale="zh"
  title={copy.title}
  description={copy.description}
  currentPath="/zh/use-cases"
  imagePath="/brand/og-zh.svg"
  keywords={['plumego 适用场景', 'go 服务工具包', 'stdlib-first', '显式 http 服务']}
>
  <PageHero
    eyebrow={copy.eyebrow}
    title={copy.title}
    description={copy.description}
    links={[
      { label: '示例', href: '/zh/examples' },
      { label: '文档', href: '/zh/docs' },
    ]}
  />

  <section class="section">
    <div class="section__intro">
      <h2>{copy.introTitle}</h2>
      <p>{copy.introBody}</p>
    </div>
    <div class="signal-list">
      {copy.guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.decisionTitle}</h2>
      <p>{copy.decisionBody}</p>
    </div>
  </section>

  <section class="page-grid">
    {copy.cases.map((item) => (
      <article class="page-panel">
        <p class="signal-list__kicker">{item.kicker}</p>
        <h2>{item.title}</h2>
        <p>{item.body}</p>
        <ul>
          {item.fitPoints.map((point) => (
            <li>{point}</li>
          ))}
        </ul>
        <a class="text-link" href={item.startHref}>{item.startLabel}</a>
      </article>
    ))}
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>顺着默认路径继续</h2>
      <p>当适用性判断清楚之后，下一步应该回到 canonical 示例和 docs 主入口。</p>
    </div>
    <div class="page-links">
      <a class="text-link" href="/zh/examples">查看示例</a>
      <a class="text-link" href="/zh/docs/getting-started">打开开始使用</a>
      <a class="text-link" href="/zh/docs/reference-app">阅读参考应用</a>
    </div>
  </section>
</MarketingLayout>
