---
import PageHero from '../../components/marketing/PageHero.astro';
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import { USE_CASES_COPY } from '../../data/site';

const copy = USE_CASES_COPY.zh;
const fitChecks = [
  {
    kicker: 'review path',
    title: '你是否希望 request flow 在代码评审里保持可见？',
    body: '当 reviewer 需要直接看清 route 注册、中间件顺序和 app-local wiring 时，Plumego 的价值会更明显。',
  },
  {
    kicker: 'service shape',
    title: '你是否希望新服务从同一 canonical 形态起步？',
    body: '如果新服务应当共享同一 reference app，而不是各自长出不同 bootstrap 模式，Plumego 会更顺手。',
  },
  {
    kicker: 'boundary map',
    title: '你是否需要显式成熟度与 ownership 信号？',
    body: 'Plumego 倾向于公开边界：稳定根保持收敛，能力家族向外分叉，release posture 也会明确说明，而不是靠存在感暗示。',
  },
];

const cautionCards = [
  {
    kicker: '不太适合',
    title: '更希望框架约定彻底隐身',
    body: '如果团队更期待 batteries-included 式抽象完全藏进框架魔法里，Plumego 可能会显得更慢、更克制。',
  },
  {
    kicker: '不太适合',
    title: '每个服务都故意保持雪花结构',
    body: '这里的价值来自收敛 accepted path。如果每个服务都必须拥有不同 bootstrap 或 routing 形态，canonical path 的价值就会下降。',
  },
  {
    kicker: '不太适合',
    title: '只想看架构，不需要判断是否采用',
    body: '想了解边界模型时请直接看 Architecture；只有当你要判断当前服务是否适合采用 Plumego 时，再使用这一页。',
  },
];
---

<MarketingLayout
  locale="zh"
  title={copy.title}
  description={copy.description}
  currentPath="/zh/use-cases"
  imagePath="/brand/og-zh.svg"
  keywords={['plumego 采用判断', 'go 服务工具包', 'stdlib-first', '显式 http 服务']}
>
  <PageHero
    eyebrow={copy.eyebrow}
    title={copy.title}
    description={copy.description}
    links={[
      { label: '架构', href: '/zh/architecture' },
      { label: '示例', href: '/zh/examples' },
    ]}
  />

  <section class="section">
    <div class="section__intro">
      <h2>{copy.introTitle}</h2>
      <p>{copy.introBody}</p>
    </div>
    <div class="signal-list">
      {copy.guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.decisionTitle}</h2>
      <p>{copy.decisionBody}</p>
    </div>
    <div class="control-grid">
      {fitChecks.map((item) => (
        <article class="page-panel page-panel--dense">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="page-grid">
    {copy.cases.map((item) => (
      <article class="page-panel">
        <p class="signal-list__kicker">{item.kicker}</p>
        <h2>{item.title}</h2>
        <p>{item.body}</p>
        <ul>
          {item.fitPoints.map((point) => (
            <li>{point}</li>
          ))}
        </ul>
        <a class="text-link" href={item.startHref}>{item.startLabel}</a>
      </article>
    ))}
  </section>

  <section class="section section--split">
    <div class="section__intro">
      <h2>哪些情况下应该先放慢采用节奏</h2>
      <p>
        这页应该帮你做出采用判断，而不是逼你立刻采用。如果下面这些姿态更像你当前团队，就先把 Architecture 当成边界地图，等仓库目标更清楚之后再决定是否采用。
      </p>
    </div>
    <div class="control-grid">
      {cautionCards.map((item) => (
        <article class="page-panel page-panel--dense">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>有了判断之后，再选下一页</h2>
      <p>一旦适配度更清楚，就根据下一个问题选择页面：边界模型、可运行路径，或者直接回到文档入口。</p>
    </div>
    <div class="page-links">
      <a class="text-link" href="/zh/architecture">先看架构</a>
      <a class="text-link" href="/zh/examples">查看示例</a>
      <a class="text-link" href="/zh/docs/getting-started">打开开始使用</a>
    </div>
  </section>
</MarketingLayout>
