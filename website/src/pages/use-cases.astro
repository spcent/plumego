---
import PageHero from '../components/marketing/PageHero.astro';
import JourneyBar from '../components/marketing/JourneyBar.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';

const journeySteps = [
  { label: 'Why Plumego', href: '/why-plumego' },
  { label: 'Examples', href: '/examples' },
  { label: 'Status', href: '/status' },
];

const scenarios = [
  {
    kicker: 'internal api',
    title: 'Internal HTTP services where route ownership is visible in review',
    body: 'Use Plumego when a pull request should let reviewers see which routes are registered, which middleware runs in order, and who owns each dependency — without opening framework source code.',
    fitPoints: [
      'service boundaries matter to reviewers',
      'bootstrap and handler ownership stay obvious in code',
      'team already thinks in net/http terms',
    ],
    modules: 'core, router, contract, middleware',
    moduleNote: 'stable roots only',
    startHref: '/docs/getting-started',
    startLabel: 'Start with Getting Started',
    secondaryHref: '/docs/reference-app',
    secondaryLabel: 'Read the Reference App',
  },
  {
    kicker: 'platform service',
    title: 'Shared platform services where multiple teams start from one canonical shape',
    body: 'Plumego is strongest when new services should begin from one readable reference layout rather than each team writing its own bootstrap and routing setup. Structural drift stays low when everyone reads the same canonical starting point.',
    fitPoints: [
      'new services inherit the same directory and wiring shape',
      'reviewers accept one small set of patterns across services',
      'onboarding cost stays low as teams rotate',
    ],
    modules: 'reference/standard-service',
    moduleNote: 'canonical reference',
    startHref: '/docs/reference-app',
    startLabel: 'Read the Reference App',
    secondaryHref: '/architecture',
    secondaryLabel: 'Inspect architecture',
  },
  {
    kicker: 'multi-tenant saas',
    title: 'Multi-tenant services with enforced per-tenant routing, quota, and policy',
    body: 'When your service needs JWT-backed tenant identity, per-tenant quota enforcement, and policy evaluation that sits outside the HTTP kernel, reach for x/tenant. Stable roots carry the HTTP baseline; x/tenant carries the tenant layer without mixing the two concerns.',
    fitPoints: [
      'tenant identity comes from JWT or header, evaluated at the transport layer',
      'per-tenant quota and policy stay separate from route wiring',
      'stable roots stay compatible when tenant logic evolves',
    ],
    modules: 'x/tenant',
    moduleNote: 'beta — API stable between minor releases',
    startHref: '/docs/modules/x-tenant',
    startLabel: 'Open x/tenant Primer',
    secondaryHref: '/releases',
    secondaryLabel: 'Check maturity posture',
  },
  {
    kicker: 'ai service',
    title: 'AI-capable services with streaming, provider management, and tool routing',
    body: 'Use x/ai when you need multi-provider abstraction, session lifecycle, streaming response handling, and tool-call routing alongside a stable HTTP kernel. Stable roots keep the transport layer compatible; x/ai absorbs the fast-moving AI capability work.',
    fitPoints: [
      'AI provider abstraction stays separate from HTTP transport',
      'streaming responses work through standard net/http handlers',
      'stable roots remain compatible as AI API shapes evolve',
    ],
    modules: 'x/ai/provider, x/ai/session, x/ai/streaming, x/ai/tool',
    moduleNote: 'beta surfaces — stable subpackages within experimental family',
    startHref: '/docs/modules/x-ai',
    startLabel: 'Open x/ai Primer',
    secondaryHref: '/releases',
    secondaryLabel: 'Check maturity posture',
  },
  {
    kicker: 'api gateway',
    title: 'Reverse proxy and API gateway services with load balancing and edge routing',
    body: 'Use x/gateway when your service needs to proxy requests to upstream backends, apply rewrite rules, or balance load across multiple targets. The stable HTTP kernel handles all transport; x/gateway owns the proxy and edge behavior layer.',
    fitPoints: [
      'upstream proxy and rewrite rules stay outside the HTTP kernel',
      'load balancing and backend discovery are explicit in config',
      'stable middleware handles auth and rate limiting before forwarding',
    ],
    modules: 'x/gateway',
    moduleNote: 'beta — API stable between minor releases',
    startHref: '/docs/modules/x-gateway',
    startLabel: 'Open x/gateway Primer',
    secondaryHref: '/docs/reference-app',
    secondaryLabel: 'Read the Reference App',
  },
  {
    kicker: 'real-time service',
    title: 'Real-time services with WebSocket hubs, rooms, and broadcast',
    body: 'Use x/websocket when your service needs persistent connections, room management, and broadcast alongside standard HTTP routes. WebSocket handling is registered explicitly on routes; the stable kernel does not learn WebSocket semantics.',
    fitPoints: [
      'WebSocket routes register alongside standard HTTP routes',
      'hub lifecycle and room management stay separate from HTTP handler logic',
      'stable transport middleware applies before WebSocket upgrade',
    ],
    modules: 'x/websocket',
    moduleNote: 'beta — API stable between minor releases',
    startHref: '/docs/modules/x-websocket',
    startLabel: 'Open x/websocket Primer',
    secondaryHref: '/releases',
    secondaryLabel: 'Check maturity posture',
  },
  {
    kicker: 'messaging service',
    title: 'Services with queues, webhooks, and scheduled tasks integrated into HTTP handlers',
    body: 'Use x/messaging when your service dispatches or consumes jobs, outbound webhooks, pubsub events, or scheduled tasks alongside HTTP routes. The app-facing service layer is beta; subordinate primitives (mq, pubsub, scheduler) remain experimental.',
    fitPoints: [
      'message dispatch and consumption stay separate from HTTP handler logic',
      'scheduled tasks and outbound webhooks are declared as service dependencies',
      'stable transport layer handles request routing independently of messaging',
    ],
    modules: 'x/messaging',
    moduleNote: 'beta — app-facing service layer; primitives are experimental',
    startHref: '/docs/modules/x-messaging',
    startLabel: 'Open x/messaging Primer',
    secondaryHref: '/releases',
    secondaryLabel: 'Check maturity posture',
  },
] as const;

const fitGuide = [
  {
    kicker: 'good fit',
    title: 'Your team wants visible structure, not framework conventions',
    body: 'Plumego rewards teams that want route ownership, middleware order, and dependency wiring visible in code — not managed behind framework-owned registration.',
  },
  {
    kicker: 'good fit',
    title: 'You need a stable kernel that stays compatible as capabilities evolve',
    body: 'Stable roots carry long-term compatibility promises. Capability work starts in x/* families so the kernel does not absorb every fast-moving concern.',
  },
  {
    kicker: 'slow down',
    title: 'You want framework conventions to handle structure automatically',
    body: 'If the team mainly wants routing and dependency setup handled invisibly, Plumego may feel more deliberate than productive.',
  },
] as const;
---

<MarketingLayout
  locale="en"
  title="Use Cases"
  description="Seven concrete service scenarios where Plumego is a strong fit: internal APIs, platform services, multi-tenant SaaS, AI services, API gateway, real-time WebSocket, and messaging."
  currentPath="/use-cases"
  keywords={['plumego use cases', 'go http service scenarios', 'multi-tenant go', 'ai go service', 'platform service go']}
>
  <PageHero
    eyebrow="Use Cases"
    title="Where Plumego fits best"
    description="Seven concrete service scenarios where the explicit wiring model becomes a clear advantage. Each scenario shows the best-fit modules, the fit signals to check, and where to start."
    visual="fit"
    links={[
      { label: 'Why Plumego', href: '/why-plumego' },
      { label: 'Architecture', href: '/architecture' },
      { label: 'Examples', href: '/examples' },
    ]}
  />

  <JourneyBar steps={journeySteps} current="/use-cases" />

  <section class="section">
    <div class="section__intro">
      <h2>Seven scenarios where explicit wiring pays off.</h2>
      <p>
        Plumego becomes a stronger fit when the service shape needs to stay readable as the codebase grows, when multiple teams must start from one baseline, or when capability work should stay outside the HTTP kernel.
      </p>
    </div>
    <div class="signal-list">
      {fitGuide.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section section--tinted">
    <div class="section__intro">
      <h2>Scenario walkthroughs.</h2>
      <p>
        Each card names the capability modules involved, the fit signals to verify, and the best starting page for that scenario.
      </p>
    </div>
    <div class="page-grid">
      {scenarios.map((item) => (
        <article class="page-panel">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h2>{item.title}</h2>
          <p>{item.body}</p>
          <ul>
            {item.fitPoints.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
          <p class="use-case-modules">
            <span class="use-case-modules__label">Modules: </span>
            <code>{item.modules}</code>
            <span class="use-case-modules__note">{item.moduleNote}</span>
          </p>
          <div class="page-links page-links--inline">
            <a class="text-link" href={item.startHref}>{item.startLabel}</a>
            <a class="text-link" href={item.secondaryHref}>{item.secondaryLabel}</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>Not sure which scenario fits?</h2>
      <p>
        Read Why Plumego for the longer team-level adoption decision, or inspect Architecture to understand which modules are stable versus experimental before committing.
      </p>
    </div>
    <div class="page-links">
      <a class="text-link" href="/why-plumego">Read Why Plumego</a>
      <a class="text-link" href="/architecture">Open architecture</a>
    </div>
  </section>
</MarketingLayout>
