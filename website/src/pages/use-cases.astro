---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { USE_CASES_COPY } from '../data/site';

const copy = USE_CASES_COPY.en;
---

<MarketingLayout
  locale="en"
  title={copy.title}
  description={copy.description}
  currentPath="/use-cases"
  keywords={['plumego use cases', 'go service toolkit', 'stdlib-first go', 'explicit http services']}
>
  <section class="page-hero">
    <p class="hero__eyebrow">{copy.eyebrow}</p>
    <h1>{copy.title}</h1>
    <p>{copy.description}</p>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.introTitle}</h2>
      <p>{copy.introBody}</p>
    </div>
    <div class="signal-list">
      {copy.guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.decisionTitle}</h2>
      <p>{copy.decisionBody}</p>
    </div>
  </section>

  <section class="page-grid">
    {copy.cases.map((item) => (
      <article class="page-panel">
        <p class="signal-list__kicker">{item.kicker}</p>
        <h2>{item.title}</h2>
        <p>{item.body}</p>
        <ul>
          {item.fitPoints.map((point) => (
            <li>{point}</li>
          ))}
        </ul>
        <a class="text-link" href={item.startHref}>{item.startLabel}</a>
      </article>
    ))}
  </section>
</MarketingLayout>
