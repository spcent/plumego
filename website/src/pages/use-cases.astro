---
import PageHero from '../components/marketing/PageHero.astro';
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { USE_CASES_COPY } from '../data/site';

const copy = USE_CASES_COPY.en;

const fitChecks = [
  {
    kicker: 'review path',
    title: 'Do you want request flow to stay visible in code review?',
    body: 'Plumego is strongest when reviewers should be able to inspect route registration, middleware order, and app-local wiring directly in code.',
  },
  {
    kicker: 'service shape',
    title: 'Do you want one canonical service shape?',
    body: 'The framework works best when new services can begin from one reference app instead of growing repository-specific bootstrap patterns.',
  },
  {
    kicker: 'boundary map',
    title: 'Do you need explicit maturity and ownership signals?',
    body: 'Plumego favors published boundaries: stable roots stay narrow, capability families move outward, and release posture is explained instead of implied.',
  },
] as const;

const cautionCards = [
  {
    kicker: 'not ideal',
    title: 'Framework conventions should stay invisible',
    body: 'If the team wants batteries-included abstractions to disappear behind framework-owned magic, Plumego can feel slower and more deliberate than expected.',
  },
  {
    kicker: 'not ideal',
    title: 'Every service is intentionally snowflake-shaped',
    body: 'The value here comes from narrowing the accepted path. If each service needs a different bootstrap or routing style, the canonical path becomes less useful.',
  },
  {
    kicker: 'not ideal',
    title: 'You want architecture answers without adoption decisions',
    body: 'Use Architecture to learn the boundary model. Use this page only when you need to decide whether Plumego fits the service in front of you.',
  },
] as const;

const decisionRows = [
  {
    signal: 'Primary concern',
    fit: 'Readable request flow, explicit wiring, one shared bootstrap model, and visible maturity boundaries.',
    caution: 'Convention-heavy ergonomics, interchangeable service skeletons, or convenience wrappers that hide structural choices.',
  },
  {
    signal: 'Team posture',
    fit: 'Reviewers want to reason about ownership directly from code and documents before the repository grows larger.',
    caution: 'The team values framework-owned defaults more than repository clarity and is comfortable with magic registration.',
  },
  {
    signal: 'Repository expectation',
    fit: 'You want docs, generated facts, examples, and release posture to reinforce one shared mental model.',
    caution: 'You prefer each project to invent its own shape and do not want a canonical service path to guide new work.',
  },
] as const;

const decisionPaths = [
  {
    kicker: 'good fit',
    title: 'You already want a canonical path',
    body: 'Start in docs and the reference app, then use examples and architecture to keep that path explicit as your service grows.',
    href: '/docs/getting-started',
    cta: 'Start with getting started',
  },
  {
    kicker: 'still evaluating',
    title: 'You need to inspect boundaries before deciding',
    body: 'Use architecture and release posture when the question is less about syntax and more about compatibility, ownership, and repository shape.',
    href: '/architecture',
    cta: 'Read architecture first',
  },
  {
    kicker: 'cautious fit',
    title: 'You like the model but need a runnable proof',
    body: 'Go directly to the reference app and example paths when the fastest way to decide is to compare your own service against the canonical layout.',
    href: '/examples',
    cta: 'Open examples',
  },
] as const;
---

<MarketingLayout
  locale="en"
  title={copy.title}
  description={copy.description}
  currentPath="/use-cases"
  keywords={['plumego adoption fit', 'go service toolkit', 'stdlib-first go', 'explicit http services']}
>
  <PageHero
    eyebrow={copy.eyebrow}
    title={copy.title}
    description={copy.description}
    links={[
      { label: 'Architecture', href: '/architecture' },
      { label: 'Examples', href: '/examples' },
    ]}
  />

  <section class="section">
    <div class="section__intro">
      <h2>{copy.introTitle}</h2>
      <p>{copy.introBody}</p>
    </div>
    <div class="signal-list">
      {copy.guideCards.map((item) => (
        <article class="signal-list__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>{copy.decisionTitle}</h2>
      <p>{copy.decisionBody}</p>
    </div>
    <div class="control-grid">
      {fitChecks.map((item) => (
        <article class="page-panel page-panel--dense">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>Good fit versus caution signals</h2>
      <p>
        This page should help you make a decision, not just admire the architecture. Read the comparison below when you need to know whether the
        service in front of you actually benefits from Plumego’s explicit model.
      </p>
    </div>
    <div class="comparison-table" role="table" aria-label="Good fit versus caution signals">
      <div class="comparison-table__head" role="row">
        <span role="columnheader">Signal</span>
        <span role="columnheader">Good fit</span>
        <span role="columnheader">Slow down</span>
      </div>
      {decisionRows.map((row) => (
        <div class="comparison-table__row" role="row">
          <strong role="cell">{row.signal}</strong>
          <span role="cell">{row.fit}</span>
          <span role="cell">{row.caution}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="page-grid">
    {copy.cases.map((item) => (
      <article class="page-panel">
        <p class="signal-list__kicker">{item.kicker}</p>
        <h2>{item.title}</h2>
        <p>{item.body}</p>
        <ul>
          {item.fitPoints.map((point) => (
            <li>{point}</li>
          ))}
        </ul>
        <a class="text-link" href={item.startHref}>{item.startLabel}</a>
      </article>
    ))}
  </section>

  <section class="section section--split">
    <div class="section__intro">
      <h2>When to slow down before adopting</h2>
      <p>
        This page should help you make a fit decision, not force one. If the service posture below sounds more like your team, keep Architecture
        as a mental model and hold adoption until the repository goals are clearer.
      </p>
    </div>
    <div class="control-grid">
      {cautionCards.map((item) => (
        <article class="page-panel page-panel--dense">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>Choose the next page by confidence level</h2>
      <p>
        Once the fit is clearer, move to the page that answers the next question: start immediately, inspect boundaries first, or compare your
        own service against the canonical runnable path.
      </p>
    </div>
    <div class="control-grid control-grid--tight">
      {decisionPaths.map((item) => (
        <article class="control-grid__item">
          <p class="signal-list__kicker">{item.kicker}</p>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
          <a class="text-link" href={item.href}>{item.cta}</a>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="section__intro">
      <h2>Pick the next page deliberately</h2>
      <p>
        Once the fit is clearer, move to the page that answers the next question: boundary model, runnable path, or direct docs entry.
      </p>
    </div>
    <div class="page-links">
      <a class="text-link" href="/architecture">Read architecture first</a>
      <a class="text-link" href="/examples">Open examples</a>
      <a class="text-link" href="/docs/getting-started">Open getting started</a>
      <a class="text-link" href="/releases">Inspect releases</a>
    </div>
  </section>
</MarketingLayout>
